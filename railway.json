{
  "$schema": "https://railway.app/schema.json",
  "build": {
    "dockerfilePath": "Dockerfile",
    "buildCommand": "cd life && cargo build --release --manifest-path life/Cargo.toml"
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  },
  "port": 8080,
  "persist": true
}
