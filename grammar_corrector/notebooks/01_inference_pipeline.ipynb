   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# 01 — Intention CNN Inference Pipeline\n",
    "\n",
    "**Purpose:** Load the trained intention_cnn model and wire it into Starfire's grammar correction pipeline.\n",
    "\n",
    "**Inputs:**\n",
    "- `artifacts/intention_cnn.onnx` — ONNX model (for inference)\n",
    "- `artifacts/intention_cnn_config.json` — vocab, label map, config\n",
    "- `artifacts/intention_cnn.pt.zip` — PyTorch weights (backup)\n",
    "\n",
    "**What this notebook does:**\n",
    "1. Load and verify the ONNX model\n",
    "2. Run qualitative tests on \"im X\" utterances\n",
    "3. Generate test vectors for Rust integration\n",
    "4. Show how to wire into Starfire's grammar_corrector module"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["## 1. Setup"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import os\n",
    "import json\n",
    "import numpy as np\n",
    "import torch\n",
    "import onnx\n",
    "import onnxruntime as ort\n",
    "\n",
    "ARTIFACTS_DIR = os.path.join(os.path.dirname(os.path.dirname(os.path.abspath(''))), 'grammar_corrector', 'artifacts')\n",
    "print('Artifacts dir:', ARTIFACTS_DIR)\n",
    "print('Exists:', os.path.exists(ARTIFACTS_DIR))\n",
    "\n",
    "# Load config\n",
    "CONFIG_PATH = os.path.join(ARTIFACTS_DIR, 'intention_cnn_config.json')\n",
    "with open(CONFIG_PATH) as f:\n",
    "    config = json.load(f)\n",
    "print('Config loaded:', config)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["## 2. Character Encoder (matches training)"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Build the exact same character vocabulary as the training notebook\n",
    "CHARS = \" abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ'\\\""-.,!?;:\\n\\t0123456789\"\n",
    "PAD_CHAR = 0\n",
    "UNK_CHAR = 1\n",
    "\n",
    "char2idx = {c: i + 2 for i, c in enumerate(CHARS)}\n",
    "idx2char = {i + 2: c for i, c in enumerate(CHARS)}\n",
    "idx2char[PAD_CHAR] = '<PAD>'\n",
    "idx2char[UNK_CHAR] = '<UNK>'\n",
    "VOCAB_SIZE = len(char2idx) + 2\n",
    "\n",
    "MAX_LEN = config['max_len']  # 48\n",
    "\n",
    "def encode(text, max_len=MAX_LEN):\n",
    "    \"\"\"Encode string to character integer sequence, padded to max_len.\"\"\"\n",
    "    encoded = []\n",
    "    for ch in text[:max_len]:\n",
    "        encoded.append(char2idx.get(ch, UNK_CHAR))\n",
    "    while len(encoded) < max_len:\n",
    "        encoded.append(PAD_CHAR)\n",
    "    return encoded\n",
    "\n",
    "def decode(encoded):\n",
    "    return ''.join(idx2char.get(i, '<') for i in encoded)\n",
    "\n",
    "LABEL2ID = config['label2id']\n",
    "ID2LABEL = {v: k for k, v in LABEL2ID.items()}\n",
    "NUM_CLASSES = config['num_classes']\n",
    "\n",
    "print(f'Vocab size: {VOCAB_SIZE}')\n",
    "print(f'Max length: {MAX_LEN}')\n",
    "print(f'Labels: {LABEL2ID}')\n",
    "\n",
    "# Verify config matches\n",
    "assert VOCAB_SIZE == config['vocab_size'], f\"Vocab mismatch: {VOCAB_SIZE} vs {config['vocab_size']}\"\n",
    "assert MAX_LEN == config['max_len'], f\"Max len mismatch: {MAX_LEN} vs {config['max_len']}\"\n",
    "print('Config verified OK')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["## 3. Load ONNX Model"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "ONNX_PATH = os.path.join(ARTIFACTS_DIR, 'intention_cnn.onnx')\n",
    "print(f'ONNX path: {ONNX_PATH}')\n",
    "print(f'File size: {os.path.getsize(ONNX_PATH) / 1024:.1f} KB')\n",
    "\n",
    "# Load and verify ONNX model\n",
    "onnx_model = onnx.load(ONNX_PATH)\n",
    "onnx.checker.check_model(onnx_model)\n",
    "print('ONNX model verified OK')\n",
    "\n",
    "# Create ONNX Runtime session\n",
    "sess_options = ort.SessionOptions()\n",
    "sess_options.graph_optimization_level = ort.GraphOptimizationLevel.ORT_ENABLE_ALL\n",
    "session = ort.InferenceSession(ONNX_PATH, sess_options)\n",
    "\n",
    "# Show input/output names\n",
    "print('\\nInput names:', [i.name for i in session.get_inputs()])\n",
    "print('Output names:', [o.name for o in session.get_outputs()])"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["## 4. Inference Function"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def predict(text):\n",
    "    \"\"\"Classify an 'im X' utterance.\"\"\"\n",
    "    encoded = np.array([encode(text)], dtype=np.int64)\n",
    "    logits = session.run(None, {'input': encoded})[0]\n",
    "    probs = torch.softmax(torch.tensor(logits), dim=1).numpy()[0]\n",
    "    pred_id = int(logits.argmax(1)[0])\n",
    "    pred_label = ID2LABEL[pred_id]\n",
    "    confidence = float(probs[pred_id])\n",
    "    return pred_label, confidence, dict(zip(ID2LABEL.values(), probs.tolist()))\n",
    "\n",
    "\n",
    "# Test it\n",
    "test_texts = [\n",
    "    \"I'm Sarah\",\n",
    "    \"im bored\",\n",
    "    \"im sorry\",\n",
    "    \"im going to NYC\",\n",
    "    \"im just vibing\",\n",
    "]\n",
    "for t in test_texts:\n",
    "    label, conf, _ = predict(t)\n",
    "    print(f'{t:<25} → {label:<10} ({conf:.4f})')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["## 5. Full Test Suite — Qualitative + Edge Cases"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "test_cases = [\n",
    "    # Name\n",
    "    (\"I'm Sarah\", 'name'),\n",
    "    (\"im zara\", 'name'),\n",
    "    (\"im bob\", 'name'),\n",
    "    (\"I'M ALEX\", 'name'),\n",
    "    (\"im daniella\", 'name'),\n",
    "    # State\n",
    "    (\"I'm bored\", 'state'),\n",
    "    (\"im tired\", 'state'),\n",
    "    (\"im so hungry rn\", 'state'),\n",
    "    (\"I'm frustrated\", 'state'),\n",
    "    (\"im alone\", 'state'),\n",
    "    # Apology\n",
    "    (\"im sorry\", 'apology'),\n",
    "    (\"im so sorry about that\", 'apology'),\n",
    "    (\"Im my bad\", 'apology'),\n",
    "    (\"im sry\", 'apology'),\n",
    "    # Intent\n",
    "    (\"im going to NYC\", 'intent'),\n",
    "    (\"im about to sleep\", 'intent'),\n",
    "    (\"imma head out\", 'intent'),\n",
    "    (\"im finna eat\", 'intent'),\n",
    "    # Chitchat\n",
    "    (\"im just vibing\", 'chitchat'),\n",
    "    (\"im just saying\", 'chitchat'),\n",
    "    (\"im just rambling\", 'chitchat'),\n",
    "    (\"im just checking in\", 'chitchat'),\n",
    "    # Other\n",
    "    (\"imgonnawork\", 'other'),\n",
    "    (\"imo it's fine\", 'other'),\n",
    "    (\"actually im good\", 'other'),\n",
    "    (\"nah im good\", 'other'),\n",
    "    (\"lol im dead\", 'other'),\n",
    "    (\"wait im not sure\", 'other'),\n",
    "    # Edge cases\n",
    "    (\"I'm\\xa0tired\", 'state'),  # non-breaking space\n",
    "    (\"i meant im gonna\", 'other'),\n",
    "    (\"I'm impossible to reach\", 'other'),\n",
    "]\n",
    "\n",
    "correct = 0\n",
    "total = len(test_cases)\n",
    "\n",
    "print(f'{\"Input\":<35} {\"Predicted\":<12} {\"Expected\":<12} {\"Confidence\":<10} {\"OK?\"}')\n",
    "print('-' * 80)\n",
    "\n",
    "for text, expected in test_cases:\n",
    "    label, conf, all_probs = predict(text)\n",
    "    ok = '✓' if label == expected else '✗'\n",
    "    if label == expected:\n",
    "        correct += 1\n",
    "    print(f'{text:<35} {label:<12} {expected:<12} {conf:.4f}      {ok}')\n",
    "\n",
    "print(f'\\nAccuracy: {correct}/{total} = {100*correct/total:.1f}%')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["## 6. Per-Class Confidence Analysis"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Show full probability distribution for ambiguous cases\n",
    "ambiguous = [\n",
    "    \"im just tired\",       # state vs chitchat\n",
    "    \"im just sorry\",       # apology vs chitchat\n",
    "    \"im gonna go\",         # intent vs chitchat\n",
    "    \"im sarah\",            # name (lowercase = state or name?)\n",
    "    \"Im TIRED\",            # ALL CAPS state\n",
    "]\n",
    "\n",
    "for text in ambiguous:\n",
    "    label, conf, all_probs = predict(text)\n",
    "    print(f'\\nInput: \"{text}\"')\n",
    "    print(f'  Prediction: {label} ({conf:.4f})')\n",
    "    for cls, prob in sorted(all_probs.items(), key=lambda x: -x[1]):\n",
    "        bar = '█' * int(prob * 20)\n",
    "        print(f'    {cls:<10}: {prob:.4f} {bar}')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["## 7. Rust Integration — Generate Test Vectors"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Generate test vectors for Rust unit tests\n",
    "# These are fixed inputs + expected outputs that the Rust code should reproduce\n",
    "\n",
    "RUST_TEST_VECTORS = []\n",
    "for text, expected_label in test_cases:\n",
    "    encoded = encode(text)\n",
    "    label, conf, all_probs = predict(text)\n",
    "    RUST_TEST_VECTORS.append({\n",
    "        'input_text': text,\n",
    "        'encoded': encoded,\n",
    "        'expected_label': expected_label,\n",
    "        'predicted_label': label,\n",
    "        'confidence': conf,\n",
    "        'all_probs': all_probs,\n",
    "    })\n",
    "\n",
    "# Save as JSON for Rust to load\n",
    "TEST_VECTORS_PATH = os.path.join(ARTIFACTS_DIR, 'test_vectors.json')\n",
    "with open(TEST_VECTORS_PATH, 'w') as f:\n",
    "    json.dump(RUST_TEST_VECTORS, f, indent=2)\n",
    "\n",
    "print(f'Saved {len(RUST_TEST_VECTORS)} test vectors to {TEST_VECTORS_PATH}')\n",
    "\n",
    "# Show a sample\n",
    "print('\\nSample test vector:')\n",
    "import json as json_lib\n",
    "sample = json_lib.dumps(RUST_TEST_VECTORS[0], indent=2)\n",
    "print(sample[:500])"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["## 8. ONNX Export for Rust (alternative to candle)"],
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# The ONNX model can be loaded in Rust using:\n",
    "# 1. ortools/ortensor (basic ONNX support)\n",
    "# 2. candle's ONNX loader (if available)\n",
    "# 3. A small ONNX runtime binding\n",
    "\n",
    "# Let's verify the ONNX model input/output shapes match expectations\n",
    "print('Model input shape:', session.get_inputs()[0].shape)\n",
    "print('Model output shape:', session.get_outputs()[0].shape)\n",
    "\n",
    "# Run a batch to verify\n",
    "batch = np.array([encode(t) for t in test_texts[:3]], dtype=np.int64)\n",
    "batch_logits = session.run(None, {'input': batch})[0]\n",
    "print('Batch logits shape:', batch_logits.shape)\n",
    "\n",
    "# Show the ONNX model architecture\n",
    "print('\\nONNX model IR version:', onnx_model.ir_version)\n",
    "print('Producer:', onnx_model.producer_name, onnx_model.producer_version)\n",
    "print('Opset version:', onnx_model.opset_import[0].version)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 9. Wire into Starfire's Grammar Corrector\n",
    "\n",
    "The intention_cnn classifies `im X` utterances before the main grammar correction pipeline. It routes:\n",
    "\n",
    "| Prediction | Action |\n",
    "|-----------|--------|\n",
    "| `name` | Store as user identity — don't grammar-correct |\n",
    "| `state` | Record emotional state, pass to empathy module |\n",
    "| `apology` | Trigger empathy response, don't grammar-correct |\n",
    "| `intent` | Parse as intent, update goal tracker |\n",
    "| `chitchat` | Pass through to normal KG pipeline |\n",
    "| `other` | Full grammar correction + KG reasoning |\n",
    "\n",
    "In Rust, the integration looks like:\n",
    "```rust\n",
    "// grammar_corrector/mod.rs\n",
    "pub struct ImIntentionClassifier {\n",
    "    session: ort::Session,  // ONNX Runtime session\n",
    "    vocab: HashMap<char, i64>,\n",
    "    max_len: usize,\n",
    "}\n",
    "\n",
    "#[derive(Debug, Clone, Copy, PartialEq, Eq)]\n",
    "pub enum ImIntention {\n",
    "    Name,     // \"I'm Sarah\" — user identifying themselves\n",
    "    State,    // \"I'm bored\" — emotional state report\n",
    "    Apology,  // \"im sorry\" — apology\n",
    "    Intent,   // \"im going to NYC\" — stated intention\n",
    "    Chitchat, // \"im just vibing\" — casual filler\n",
    "    Other,    // anything else\n",
    "}\n",
    "\n",
    "impl ImIntentionClassifier {\n",
    "    /// Returns (intention, confidence)\n",
    "    pub fn classify(&self, text: &str) -> (ImIntention, f32) {\n",
    "        let encoded = self.encode(text);\n",
    "        let logits = self.session.run(vec![encoded]).unwrap();\n",
    "        let probs = softmax(&logits);\n",
    "        let pred = probs.argmax();\n",
    "        let conf = probs[pred];\n",
    "        (ImIntention::from_id(pred), conf)\n",
    "    }\n",
    "\n",
    "    /// Check if input starts with \"im\" or \"i'm\" pattern\n",
    "    pub fn is_im_utterance(&self, text: &str) -> bool {\n",
    "        let t = text.trim().to_lowercase();\n",
    "        t.starts_with(\"im \") || t.starts_with(\"i'm \") || t.starts_with(\"i m \")\n",
    "    }\n",
    "}\n",
    "\n",
    "/// In runtime/grammar_corrector.rs — called BEFORE normal grammar correction:\n",
    "pub fn pre_process(input: &str) -> (Option<ImIntention>, String) {\n",
    "    let classifier = get_im_classifier();\n",
    "    if !classifier.is_im_utterance(input) {\n",
    "        return (None, input.to_string());\n",
    "    }\n",
    "    let (intention, confidence) = classifier.classify(input);\n",
    "    match intention {\n",
    "        ImIntention::Name => {\n",
    "            // Extract name, store as user identity\n",
    "            let name = extract_name_from_im(input);\n",
    "            world_model.update_user_name(&name);\n",
    "            return (Some(intention), input.to_string()); // pass through\n",
    "        }\n",
    "        ImIntention::State => {\n",
    "            // Record emotional state\n",
    "            let state = extract_emotional_state(input);\n",
    "            world_model.update_emotional_state(state);\n",
    "        }\n",
    "        ImIntention::Apology => {\n",
    "            // Emit brief empathy, skip KG reasoning\n",
    "            return (Some(intention), \"I appreciate that. Is everything okay?\".to_string());\n",
    "        }\n",
    "        ImIntention::Intent => {\n",
    "            // Parse and update goal stack\n",
    "            let goal = parse_intent(input);\n",
    "            goals.push(goal);\n",
    "        }\n",
    "        ImIntention::Chitchat | ImIntention::Other => {\n",
    "            // Normal pipeline continues\n",
    "        }\n",
    "    }\n",
    "    (Some(intention), input.to_string())\n",
    "}\n",
    "```"
   ]
  },
