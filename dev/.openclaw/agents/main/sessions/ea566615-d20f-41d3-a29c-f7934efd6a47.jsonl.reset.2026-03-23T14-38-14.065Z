{"type":"message","id":"495b47dd","parentId":"ab935116","timestamp":"2026-03-23T14:19:23.440Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"The file is truncated at \"Pre\" which was probably the start of `Pre-pull model`. The file has the code up to 885 lines. The exec() call got cut off. I need to rewrite the full file properly. Let me write the complete file cleanly. The modal_app structure needs:\n\n1. Volume setup\n2. SparkAPI class with:\n   - start(): Start ollama serve\n   - FastAPI app with routes\n   - Serve web UI\n   - generate endpoint\n\nLet me write the complete file as a single write call.","thinkingSignature":"a43aa4e8cecab964d97756f93b8871c762be77cb857c25d1582e13134a445354"},{"type":"toolCall","id":"call_function_i9we4co85f39_1","name":"write","arguments":{"path":"C:/Users/Zwmar/Claw/projects/spark/deploy/spark_app.py","content":"\"\"\"\nSPARK — Full Modal Deployment\nRun: modal deploy spark.deploy.spark_app\n\nServes:\n  /v1/spark/generate  — creative text generation\n  /                   — SPARK web UI (static)\n  /health             — health check\n\"\"\"\n\nimport modal\nimport subprocess\nimport os\nimport sys\nimport time\n\napp = modal.App(\"spark\")\n\n# ─────────────────────────────────────────────────────────────────────────────\n# IMAGE\n# ─────────────────────────────────────────────────────────────────────────────\n\nspark_image = (\n    modal.Image.debian_slim(python_version=\"3.11\")\n    .pip_install(\n        \"fastapi[standard]==0.115.0\",\n        \"uvicorn[standard]==0.30.0\",\n        \"requests==2.32.3\",\n        \"httpx==0.27.0\",\n        \"pydantic==2.9.0\",\n        \"numpy==1.26.4\",\n        \"networkx==3.4.2\",\n    )\n    .run_commands(\n        \"apt-get update && apt-get install -y curl zstd unzip && curl -fsSL https://ollama.com/install.sh | sh\",\n        _quiet=False,\n    )\n    .env({\"OLLAMA_MODELS\": \"/root/.ollama\", \"OLLAMA_HOST\": \"0.0.0.0\"})\n)\n\n# Persistent volume for Ollama models\nvolume = modal.Volume.from_name(\"spark-ollama-models\", create=True)\n\n\n# ─────────────────────────────────────────────────────────────────────────────\n# DRIFT CHAMBER (embedded)\n# ─────────────────────────────────────────────────────────────────────────────\n\nDRIFT_CODE = '''\nimport random, math\n\nWITHIN_CLUSTER_WEIGHT = 0.3\nCROSS_CLUSTER_WEIGHT = 0.15\n\nCONCEPT_CLUSTERS = {\n    \"emotions\": [\"longing\",\"grief\",\"joy\",\"hope\",\"despair\",\"love\",\"hate\",\"fear\",\"shame\",\"awe\",\"nostalgia\",\"regret\",\"elation\",\"dread\",\"tenderness\"],\n    \"relationships\": [\"betrayal\",\"trust\",\"loyalty\",\"secrets\",\"confession\",\"reunion\",\"loss\",\"devotion\",\"estrangement\",\"reconciliation\",\"commitment\",\"betrayer\",\"beloved\"],\n    \"sensory\": [\"rain\",\"fire\",\"blood\",\"snow\",\"shadow\",\"light\",\"flesh\",\"iron\",\"salt\",\"glass\",\"mirror\",\"door\",\"threshold\",\"darkness\",\"heat\",\"cold\",\"smoke\",\"water\"],\n    \"cosmos\": [\"universe\",\"star\",\"void\",\"black_hole\",\"gravity\",\"silence\",\"infinity\",\"light_year\",\"extinction\",\"origins\",\"entropy\",\"cosmic\",\"orbit\",\"collapse\",\"singularity\"],\n    \"mortality\": [\"death\",\"dying\",\"ghost\",\"corpse\",\"grave\",\"afterlife\",\"memory\",\"forgetting\",\"bone\",\"decay\",\"resurrection\",\"sacrifice\",\"survival\",\"last_breath\",\"funeral\"],\n    \"narrative\": [\"pursuit\",\"escape\",\"revelation\",\"betrayal\",\"climax\",\"resolution\",\"setup\",\"misdirect\",\"backstory\",\"frame\",\"twist\",\"denouement\"],\n    \"creative\": [\"art\",\"story\",\"image\",\"word\",\"form\",\"fragment\",\"revision\",\"constraint\",\"voice\",\"style\",\"truth\",\"lie\",\"catharsis\",\"expression\",\"imitation\",\"originality\"],\n    \"literary\": [\"sentence\",\"paragraph\",\"page\",\"chapter\",\"narrator\",\"perspective\",\"tension\",\"rhythm\",\"pace\",\"ending\",\"opening\",\"image\",\"symbol\",\"motif\",\"leitmotif\"],\n    \"archetypes\": [\"mother\",\"father\",\"child\",\"stranger\",\"mentor\",\"shadow_self\",\"trickster\",\"hero\",\"villain\",\"victim\",\"rebel\",\"outcast\",\"prophet\",\"fool\"],\n    \"nature\": [\"forest\",\"ocean\",\"desert\",\"mountain\",\"river\",\"storm\",\"sunset\",\"sunrise\",\"season\",\"winter\",\"summer\",\"autumn\",\"spring\",\"flood\",\"drought\",\"earth\",\"sky\"],\n}\n\nDOMAINS = {\n    \"all\":      {\"clusters\":[\"emotions\",\"relationships\",\"sensory\",\"cosmos\",\"mortality\",\"narrative\",\"creative\",\"literary\",\"archetypes\",\"nature\"], \"goal\":[\"creative\",\"emotions\"]},\n    \"romance\":  {\"clusters\":[\"emotions\",\"relationships\",\"sensory\"],                   \"goal\":[\"emotions\",\"relationships\"]},\n    \"scifi\":    {\"clusters\":[\"cosmos\",\"creative\",\"mortality\"],                        \"goal\":[\"cosmos\",\"creative\"]},\n    \"thriller\": {\"clusters\":[\"narrative\",\"cosmos\",\"relationships\"],                  \"goal\":[\"narrative\",\"cosmos\"]},\n    \"literary\": {\"clusters\":[\"literary\",\"creative\",\"emotions\"],                      \"goal\":[\"literary\",\"creative\"]},\n    \"horror\":   {\"clusters\":[\"mortality\",\"sensory\",\"emotions\"],                      \"goal\":[\"mortality\",\"sensory\"]},\n    \"poetry\":   {\"clusters\":[\"sensory\",\"literary\",\"creative\",\"emotions\"],            \"goal\":[\"sensory\",\"creative\"]},\n}\n\nTENSION_PAIRS = {\n    (\"light\",\"darkness\"),(\"creation\",\"destruction\"),(\"love\",\"hate\"),\n    (\"order\",\"chaos\"),(\"birth\",\"death\"),(\"hope\",\"despair\"),\n    (\"truth\",\"lie\"),(\"memory\",\"forgetting\"),(\"ghost\",\"flesh\"),\n}\n\n\nclass DriftChamber:\n    def __init__(self, domain=\"all\", seed=42):\n        self.domain = domain\n        self.seed = seed\n        self.graph = {}\n        self.concept_to_cluster = {}\n        self.goal_concepts = set()\n        self.all_concepts = []\n        self.history = []\n        self._build()\n\n    def _build(self):\n        cfg = DOMAINS.get(self.domain, DOMAINS[\"all\"])\n        selected = []\n        for cn in cfg[\"clusters\"]:\n            if cn in CONCEPT_CLUSTERS:\n                for c in CONCEPT_CLUSTERS[cn]:\n                    if c not in selected:\n                        selected.append(c)\n\n        self.concept_to_cluster = {}\n        for cn, concepts in CONCEPT_CLUSTERS.items():\n            for c in concepts:\n                if c not in self.concept_to_cluster:\n                    self.concept_to_cluster[c] = cn\n\n        adj = {}\n        for c1 in selected:\n            ca = self.concept_to_cluster.get(c1, \"\")\n            within = [(c2, 2.0 if (c1,c2) in TENSION_PAIRS or (c2,c1) in TENSION_PAIRS else 1.0)\n                      for c2 in selected if c1!=c2 and self.concept_to_cluster.get(c2,\"\")==ca]\n            within.sort(key=lambda x: -x[1])\n            for c2, _ in within[:6]:\n                adj[(c1,c2)] = WITHIN_CLUSTER_WEIGHT\n\n            cross = [(c2, CROSS_CLUSTER_WEIGHT) for c2 in selected\n                     if c1!=c2 and self.concept_to_cluster.get(c2,\"\")!=ca]\n            cross.sort(key=lambda x: -x[1])\n            for c2, w in cross[:4]:\n                adj[(c1,c2)] = w\n\n        self.graph = {c: {\"activation\": 0.05, \"neighbors\": {}} for c in selected}\n        for (a, b), w in adj.items():\n            self.graph[a][\"neighbors\"][b] = w\n            self.graph[b][\"neighbors\"][a] = w\n\n        self.all_concepts = selected\n        self.goal_concepts = set()\n        for cn in cfg[\"goal\"]:\n            if cn in CONCEPT_CLUSTERS:\n                for c in CONCEPT_CLUSTERS[cn]:\n                    if c in selected:\n                        self.goal_concepts.add(c)\n\n    def run(self, steering=0.3, steps=30, diffusion=0.1, decay=0.02):\n        rng = random.Random(self.seed)\n        goal_clusters = {self.concept_to_cluster.get(c,\"\") for c in self.goal_concepts}\n\n        for c in self.graph:\n            if c in self.goal_concepts:\n                self.graph[c][\"activation\"] = 0.95\n            elif self.concept_to_cluster.get(c,\"\") in goal_clusters:\n                self.graph[c][\"activation\"] = 0.5\n            else:\n                self.graph[c][\"activation\"] = 0.05\n\n        self.history = []\n        for step in range(steps):\n            if step > 0 and step % 4 == 0 and steering > 0:\n                for c in self.graph:\n                    if self.concept_to_cluster.get(c,\"\") in goal_clusters:\n                        self.graph[c][\"activation\"] = max(self.graph[c][\"activation\"], 0.6)\n                    if c in self.goal_concepts:\n                        self.graph[c][\"activation\"] = max(self.graph[c][\"activation\"], 0.8)\n\n            new_act = {}\n            for c in self.graph:\n                nb = self.graph[c][\"neighbors\"]\n                if not nb:\n                    new_act[c] = self.graph[c][\"activation\"]\n                    continue\n                total_w = sum(nb.values())\n                if total_w == 0:\n                    new_act[c] = self.graph[c][\"activation\"]\n                    continue\n                neighbor_act = sum(self.graph[n][\"activation\"] * w for n, w in nb.items()) / total_w\n                new_act[c] = (1 - diffusion) * self.graph[c][\"activation\"] + diffusion * neighbor_act\n\n            for c in self.graph:\n                self.graph[c][\"activation\"] = new_act[c]\n\n            if steering > 0:\n                for c in self.goal_concepts:\n                    self.graph[c][\"activation\"] = min(1.0, self.graph[c][\"activation\"] + steering * 0.15)\n\n            for c in self.graph:\n                self.graph[c][\"activation\"] *= (1 - decay)\n\n            acts = list(self.graph[c][\"activation\"] for c in self.graph)\n            self.history.append({\n                \"step\": step,\n                \"mean\": sum(acts)/len(acts),\n                \"strong\": sum(1 for a in acts if a > 0.3),\n            })\n        return self\n\n    def top_concepts(self, n=20, threshold=0.05):\n        sorted_c = sorted(self.graph.keys(), key=lambda c: self.graph[c][\"activation\"], reverse=True)\n        return [(c, self.graph[c][\"activation\"]) for c in sorted_c[:n] if self.graph[c][\"activation\"] > threshold]\n\n    def entropy(self):\n        acts = [self.graph[c][\"activation\"] for c in self.graph]\n        total = sum(acts)\n        if total == 0:\n            return 0.0\n        return -sum((a/total)*math.log2(a/total) for a in acts if a > 0)\n'''\n\n\n# ─────────────────────────────────────────────────────────────────────────────\n# LLM MAPPER (inline)\n# ─────────────────────────────────────────────────────────────────────────────\n\nMAPPER_CODE = '''\nimport random\n\nSPARK_VOICE = \"\"\"You are SPARK. Not a writing workshop. Not a Hallmark card.\nReal prose. The kind where something is at stake.\nPrecision of image. Emotion earned through concrete detail, not declared.\nSentences that do real work. Endings that open rather than close.\"\"\"\n\nSPARK_CREATIVE = \"\"\"SPARK creative voice:\n- Ground every abstraction in a concrete sensory moment\n- Let the emotional logic be complex, not simple\n- A character can want two contradictory things\n- What\\\\'s unsaid matters more than what\\\\'s said\n- End on an image that contains the whole feeling\"\"\"\n\nSPARK_DIVERGENT = \"\"\"SPARK divergent voice:\n- Break expected form. Break expected rhythm.\n- Let the sentence become the thought\n- Association over narration\n- Surprising juxtapositions earn their place\"\"\"\n\nSPARK_EXPLORATORY = \"\"\"SPARK exploratory voice:\n- Patient attention to the overlooked\n- Small things seen clearly\n- Restraint is a form of precision\n- Let silence do work\"\"\"\n\nCREATIVE_TENSIONS = [\n    (\"light\",\"darkness\",0.95),(\"creation\",\"destruction\",0.95),(\"love\",\"hate\",0.90),\n    (\"birth\",\"death\",0.90),(\"hope\",\"despair\",0.85),(\"memory\",\"forgetting\",0.80),\n    (\"loyalty\",\"betrayal\",0.85),(\"voice\",\"silence\",0.75),\n]\n\n\ndef find_tensions(concepts):\n    cs = set(concepts)\n    return [(a,b) for a,b,_ in CREATIVE_TENSIONS if a in cs and b in cs]\n\n\ndef sample_path(activations, n=5):\n    sorted_c = sorted(activations.items(), key=lambda x: x[1], reverse=True)\n    top = [c for c,a in sorted_c[:10] if a > 0.5]\n    mid = [c for c,a in sorted_c[10:25] if a > 0.3]\n    path = []\n    k = n // 2\n    if top:\n        path.extend(random.sample(top, min(len(top), k)))\n    if mid:\n        path.extend(random.sample(mid, min(len(mid), n - len(path))))\n    random.shuffle(path)\n    return path[:n]\n\n\ndef build_prompt(theme, concepts, mode, seed, constraints):\n    primary = \", \".join([c for c,_ in concepts[:8]])\n    drift = \" -> \".join(sample_path(dict(concepts)))\n    tensions = find_tensions([c for c,_ in concepts])\n    tension_str = \" Track: \" + \"; \".join(f\"{a} vs {b}\" for a,b in tensions[:3]) + \".\" if tensions else \"\"\n    constraints_str = \"\\\\nUser wants: \" + \", \".join(constraints) + \".\" if constraints else \"\"\n    seed_str = f'\\\\nSeed moment: \"{seed}\"' if seed else \"\"\n\n    if mode == \"divergent\":\n        return f\"\"\"{SPARK_VOICE}\n\n{SPARK_DIVERGENT}\n\nA brief, strange piece (100-200 words) about: {theme}\n\nConcepts: {primary}\nDrift: {drift}\n{tension_str}{constraints_str}{seed_str}\n\nBreak form. An image containing a world beats a sentence that explains one.\"\"\"\n\n    elif mode == \"exploratory\":\n        return f\"\"\"{SPARK_VOICE}\n\n{SPARK_EXPLORATORY}\n\nA contemplative piece (200-300 words) about: {theme}\n\n{primary}\nDrift: {drift}\n{tension_str}{constraints_str}{seed_str}\n\nSmall things, seen clearly. Restraint is precision. Let silence do the work.\"\"\"\n\n    else:\n        return f\"\"\"{SPARK_VOICE}\n\n{SPARK_CREATIVE}\n\nA short literary fiction piece (200-300 words) about: {theme}\n\nPrimary: {primary}\nDrift: {drift}\n{tension_str}{constraints_str}{seed_str}\n\nDo NOT:\n- Start with \"The [time] [character] felt [emotion]\"\n- End with a moral or lesson\n- Use \"in that moment\" or \"journey\"\n\nDo:\n- Ground abstractions in sensory detail\n- Let the ending open\n- Earn emotion through what you show\"\"\"\n\n\ndef generate_via_ollama(prompt, model, url, temperature, max_tokens):\n    import requests\n    resp = requests.post(\n        f\"{url}/api/generate\",\n        json={\"model\": model, \"prompt\": prompt, \"stream\": False,\n              \"options\": {\"temperature\": temperature, \"num_predict\": max_tokens}},\n        timeout=120,\n    )\n    resp.raise_for_status()\n    return resp.json().get(\"response\", \"\").strip()\n\n\ndef generate_text(concepts, theme, mode, seed, constraints, ollama_url, model_name):\n    prompt = build_prompt(theme, concepts, mode, seed, constraints or [])\n    temp = {\"creative\": 0.8, \"divergent\": 1.1, \"exploratory\": 0.7}[mode]\n    max_tok = {\"creative\": 600, \"divergent\": 400, \"exploratory\": 600}[mode]\n    return generate_via_ollama(prompt, model_name or \"qwen2.5:7b\", ollama_url, temp, max_tok)\n'''\n\n\n# ─────────────────────────────────────────────────────────────────────────────\n# WEB UI\n# ─────────────────────────────────────────────────────────────────────────────\n\nWEB_UI = r'''<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\"/>\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\"/>\n<title>SPARK — Creative Intelligence</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Crimson+Pro:ital,wght@0,300;0,400;0,600;1,300;1,400&family=JetBrains+Mono:wght@400;500&display=swap');\n  :root {\n    --bg: #0d0d0f; --surface: #141418; --border: #222228;\n    --text: #e8e4df; --muted: #7a7772; --accent: #c8a96e;\n    --accent2: #6e8fc8; --dim: #3a3835;\n  }\n  * { box-sizing: border-box; margin: 0; padding: 0; }\n  body { background: var(--bg); color: var(--text); font-family: 'Crimson Pro', Georgia, serif; font-size: 18px; line-height: 1.6; min-height: 100vh; }\n  header { border-bottom: 1px solid var(--border); padding: 1.5rem 2rem; display: flex; align-items: baseline; gap: 1.5rem; }\n  header h1 { font-size: 1.6rem; font-weight: 300; letter-spacing: 0.3em; text-transform: uppercase; color: var(--accent); }\n  header p { font-size: 0.9rem; color: var(--muted); font-style: italic; }\n  main { display: grid; grid-template-columns: 320px 1fr; min-height: calc(100vh - 80px); }\n  aside { border-right: 1px solid var(--border); padding: 1.5rem; display: flex; flex-direction: column; gap: 1.2rem; }\n  .control-group { display: flex; flex-direction: column; gap: 0.4rem; }\n  .control-group label { font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.12em; color: var(--muted); font-family: 'JetBrains Mono', monospace; }\n  select, input[type=\"text\"], textarea { background: var(--surface); border: 1px solid var(--border); color: var(--text); font-family: inherit; font-size: 0.95rem; padding: 0.5rem 0.75rem; border-radius: 4px; outline: none; transition: border-color 0.2s; width: 100%; }\n  select:focus, input[type=\"text\"]:focus, textarea:focus { border-color: var(--accent); }\n  textarea { resize: vertical; min-height: 60px; line-height: 1.5; }\n  .steering-wrap { display: flex; flex-direction: column; gap: 0.4rem; }\n  .steering-header { display: flex; justify-content: space-between; align-items: center; }\n  .steering-value { font-family: 'JetBrains Mono', monospace; font-size: 0.85rem; color: var(--accent2); }\n  input[type=\"range\"] { width: 100%; accent-color: var(--accent); cursor: pointer; }\n  .range-labels { display: flex; justify-content: space-between; font-size: 0.6rem; color: var(--dim); font-family: 'JetBrains Mono', monospace; margin-top: 2px; }\n  #generate-btn { background: var(--accent); color: #0d0d0f; border: none; padding: 0.75rem 1.5rem; font-family: 'JetBrains Mono', monospace; font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.15em; cursor: pointer; border-radius: 4px; transition: opacity 0.2s, transform 0.1s; margin-top: 0.5rem; }\n  #generate-btn:hover { opacity: 0.85; }\n  #generate-btn:active { transform: scale(0.98); }\n  #generate-btn:disabled { opacity: 0.4; cursor: not-allowed; }\n  #output-pane { padding: 2rem; overflow-y: auto; }\n  .output-card { background: var(--surface); border: 1px solid var(--border); border-radius: 6px; padding: 1.5rem 2rem; margin-bottom: 1.5rem; animation: fadein 0.4s ease; }\n  @keyframes fadein { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }\n  .output-meta { display: flex; gap: 0.6rem; margin-bottom: 1rem; flex-wrap: wrap; }\n  .output-meta span { font-family: 'JetBrains Mono', monospace; font-size: 0.68rem; text-transform: uppercase; letter-spacing: 0.1em; padding: 0.2rem 0.5rem; border-radius: 3px; background: var(--border); color: var(--muted); }\n  .output-meta span.regime { background: rgba(200,169,110,0.15); color: var(--accent); }\n  .output-text { font-size: 1.05rem; line-height: 1.8; color: var(--text); white-space: pre-wrap; }\n  .concept-viz { margin-top: 1.2rem; padding-top: 1rem; border-top: 1px solid var(--border); }\n  .concept-viz-title { font-family: 'JetBrains Mono', monospace; font-size: 0.62rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--muted); margin-bottom: 0.7rem; }\n  .concept-row { display: flex; align-items: center; gap: 0.6rem; margin-bottom: 0.3rem; }\n  .concept-name { font-size: 0.78rem; color: var(--muted); width: 110px; flex-shrink: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }\n  .concept-bar-wrap { flex: 1; height: 3px; background: var(--dim); border-radius: 2px; overflow: hidden; }\n  .concept-bar { height: 100%; background: linear-gradient(90deg, var(--accent), var(--accent2)); border-radius: 2px; transition: width 0.6s ease; }\n  .loading { display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 1rem; height: 200px; color: var(--muted); font-style: italic; }\n  .spinner { width: 28px; height: 28px; border: 2px solid var(--border); border-top-color: var(--accent); border-radius: 50%; animation: spin 0.8s linear infinite; }\n  @keyframes spin { to { transform: rotate(360deg); } }\n  .empty-state { height: 100%; display: flex; flex-direction: column; align-items: center; justify-content: center; color: var(--muted); font-style: italic; gap: 0.5rem; }\n  .empty-state strong { font-size: 1.1rem; font-weight: 300; color: var(--dim); }\n  .error-msg { background: rgba(180,60,60,0.15); border: 1px solid rgba(180,60,60,0.3); border-radius: 4px; padding: 0.75rem 1rem; color: #e07070; font-size: 0.9rem; }\n</style>\n</head>\n<body>\n<header>\n  <h1>SPARK</h1>\n  <p>Semantic Pattern Recognition via Associative Drift + Constrained Steering</p>\n</header>\n<main>\n  <aside>\n    <div class=\"control-group\">\n      <label>Domain</label>\n      <select id=\"domain\">\n        <option value=\"all\">All — Full creative range</option>\n        <option value=\"romance\">Romance — Love, longing, loss</option>\n        <option value=\"scifi\">Sci-Fi — Tech, cosmos, creation</option>\n        <option value=\"thriller\">Thriller — Tension, pursuit</option>\n        <option value=\"literary\">Literary — Craft, meaning, form</option>\n        <option value=\"horror\">Horror — Death, dread, flesh</option>\n        <option value=\"poetry\">Poetry — Image, rhythm, metaphor</option>\n      </select>\n    </div>\n    <div class=\"control-group\">\n      <label>Mode</label>\n      <select id=\"mode\">\n        <option value=\"creative\">Creative — Balanced & alive</option>\n        <option value=\"divergent\">Divergent — Maximum surprise</option>\n        <option value=\"exploratory\">Exploratory — Contemplative</option>\n      </select>\n    </div>\n    <div class=\"control-group\">\n      <label>Theme</label>\n      <input type=\"text\" id=\"theme\" placeholder=\"love in the age of AI\" value=\"love in the age of AI\"/>\n    </div>\n    <div class=\"control-group\">\n      <label>Seed Moment (optional)</label>\n      <textarea id=\"seed\" placeholder=\"A character, moment, or image to anchor the piece...\"></textarea>\n    </div>\n    <div class=\"control-group\">\n      <label>Required Elements (optional)</label>\n      <input type=\"text\" id=\"constraints\" placeholder=\"rain, betrayal, a door\"/>\n    </div>\n    <div class=\"steering-wrap\">\n      <div class=\"steering-header\">\n        <label>Drift Steering</label>\n        <span class=\"steering-value\" id=\"steer-val\">0.30</span>\n      </div>\n      <input type=\"range\" id=\"steering\" min=\"0\" max=\"1\" step=\"0.05\" value=\"0.3\"/>\n      <div class=\"range-labels\"><span>Pure Drift</span><span>Guided</span></div>\n    </div>\n    <div style=\"display:grid;grid-template-columns:1fr 1fr;gap:0.75rem;\">\n      <div class=\"control-group\">\n        <label>Variations</label>\n        <select id=\"n\">\n          <option value=\"1\">1</option><option value=\"2\" selected>2</option><option value=\"3\">3</option>\n        </select>\n      </div>\n      <div class=\"control-group\">\n        <label>Steps</label>\n        <select id=\"steps\">\n          <option value=\"20\">20</option><option value=\"30\" selected>30</option><option value=\"50\">50</option>\n        </select>\n      </div>\n    </div>\n    <button id=\"generate-btn\" onclick=\"generate()\">&#9650; Spark</button>\n    <p style=\"font-size:0.68rem;color:var(--dim);font-family:'JetBrains Mono',monospace;text-align:center;margin-top:auto;\">\n      qwen2.5:7b on Modal A100\n    </p>\n  </aside>\n  <div id=\"output-pane\">\n    <div class=\"empty-state\">\n      <strong>Your turn.</strong>\n      Configure a prompt and hit Spark.\n    </div>\n  </div>\n</main>\n<script>\n  const API = window.location.origin;\n  document.getElementById('steering').addEventListener('input', function() {\n    document.getElementById('steer-val').textContent = parseFloat(this.value).toFixed(2);\n  });\n\n  async function generate() {\n    const btn = document.getElementById('generate-btn');\n    const pane = document.getElementById('output-pane');\n    const req = {\n      theme: document.getElementById('theme').value || \"love in the age of AI\",\n      domain: document.getElementById('domain').value,\n      mode: document.getElementById('mode').value,\n      steering: parseFloat(document.getElementById('steering').value),\n      n: parseInt(document.getElementById('n').value),\n      steps: parseInt(document.getElementById('steps').value),\n      seed_moment: document.getElementById('seed').value || null,\n      constraints: document.getElementById('constraints').value\n        ? document.getElementById('constraints').value.split(\",\").map(s=>s.trim()).filter(Boolean) : null,\n    };\n    btn.disabled = true; btn.textContent = \"Igniting...\";\n    pane.innerHTML = '<div class=\"loading\"><div class=\"spinner\"></div><span>Running drift chamber...</span></div>';\n    try {\n      const res = await fetch(API + \"/v1/spark/generate\", {\n        method: \"POST\", headers: {\"Content-Type\": \"application/json\"}, body: JSON.stringify(req),\n      });\n      if (!res.ok) {\n        const err = await res.json().catch(()=>({}));\n        throw new Error(err.detail || (\"HTTP \" + res.status));\n      }\n      renderResults(await res.json());\n    } catch(e) {\n      pane.innerHTML = `<div class=\"error-msg\">&#9888; ${e.message}</div>`;\n    } finally {\n      btn.disabled = false; btn.textContent = \"&#9650; Spark\";\n    }\n  }\n\n  function renderResults(data) {\n    const pane = document.getElementById('output-pane');\n    if (!data.variations || !data.variations.length) {\n      pane.innerHTML = '<div class=\"empty-state\"><strong>No output.</strong> Try different settings.</div>'; return;\n    }\n    pane.innerHTML = data.variations.map((v, i) => `\n      <div class=\"output-card\">\n        <div class=\"output-meta\">\n          <span>${data.meta.mode}</span>\n          <span>steer&nbsp;${data.meta.steering}</span>\n          <span>${data.meta.n_concepts} concepts</span>\n          <span>${data.meta.entropy}&nbsp;bits</span>\n          <span class=\"regime\">${data.meta.regime}</span>\n        </div>\n        <div class=\"output-text\">${esc(v.text)}</div>\n        <div class=\"concept-viz\">\n          <div class=\"concept-viz-title\">Top Activated Concepts</div>\n          ${(v.concepts || []).slice(0, 12).map((c, idx) => `\n            <div class=\"concept-row\">\n              <span class=\"concept-name\">${esc(c)}</span>\n              <div class=\"concept-bar-wrap\">\n                <div class=\"concept-bar\" style=\"width:${Math.max(8, (12-idx)/12*100)}%\"></div>\n              </div>\n            </div>`).join('')}\n        </div>\n      </div>`).join('');\n  }\n  function esc(s) {\n    return String(s).replace(/&/g,\"&amp;\").replace(/</g,\"&lt;\").replace(/>/g,\"&gt;\");\n  }\n</script>\n</body>\n</html>'''\n\n\n# ─────────────────────────────────────────────────────────────────────────────\n# FASTAPI ROUTES (inline string, mounted as file)\n# ─────────────────────────────────────────────────────────────────────────────\n\nFASTAPI_ROUTES_CODE = '''\nimport fastapi, os\nfrom pydantic import BaseModel\nfrom typing import Optional, List\n\napp = fastapi.FastAPI(title=\"SPARK API\", version=\"0.1.0\")\n\nclass GenerateRequest(BaseModel):\n    theme: str = \"love in the age of AI\"\n    domain: str = \"all\"\n    mode: str = \"creative\"\n    steering: float = 0.3\n    n: int = 2\n    steps: int = 30\n    seed_moment: Optional[str] = None\n    constraints: Optional[List[str]] = None\n    model: Optional[str] = None\n\n\n@app.post(\"/v1/spark/generate\")\nasync def generate(req: GenerateRequest):\n    import requests, random, math\n\n    # Build drift chamber\n    exec(open(\"/tmp/drift_code.py\").read())\n    exec(open(\"/tmp/mapper_code.py\").read())\n\n    chamber = DriftChamber(domain=req.domain, seed=42)\n    chamber.run(steering=req.steering, steps=req.steps)\n    top = chamber.top_concepts(n=20, threshold=0.05)\n    entropy = chamber.entropy()\n    strong = sum(1 for _, a in top if a > 0.3)\n\n    results = []\n    for i in range(req.n):\n        text = generate_text(\n            concepts=top,\n            theme=req.theme,\n            mode=req.mode,\n            seed=req.seed_moment,\n            constraints=req.constraints,\n            ollama_url=\"http://localhost:11434\",\n            model_name=req.model or \"qwen2.5:7b\",\n        )\n        results.append({\n            \"id\": f\"spark_{i+1:03d}\",\n            \"text\": text,\n            \"concepts\": [c for c, _ in top[:10]],\n            \"coherence_score\": strong / max(len(chamber.graph), 1),\n            \"entropy\": entropy,\n            \"regime\": \"IMAGINATIVE\" if strong > 5 else \"EXPLORING\",\n        })\n\n    return {\n        \"variations\": results,\n        \"meta\": {\n            \"domain\": req.domain, \"mode\": req.mode, \"steering\": req.steering,\n            \"steps\": req.steps, \"n_concepts\": len(chamber.graph),\n            \"strong_concepts\": strong, \"entropy\": round(entropy, 3),\n            \"regime\": \"IMAGINATIVE\" if strong > 5 else \"EXPLORING\",\n            \"model\": req.model or \"qwen2.5:7b\",\n        },\n    }\n\n\n@app.get(\"/health\")\nasync def health():\n    return {\"status\": \"ok\", \"service\": \"spark\", \"model\": \"qwen2.5:7b\"}\n\n\n@app.get(\"/v1/spark/domains\")\nasync def list_domains():\n    return {\n        \"domains\": [\n            {\"id\": \"all\", \"description\": \"All creative concepts\"},\n            {\"id\": \"romance\", \"description\": \"Love, longing, connection, loss\"},\n            {\"id\": \"scifi\", \"description\": \"Technology, cosmos, humanity, creation\"},\n            {\"id\": \"thriller\", \"description\": \"Tension, power, pursuit, secrets\"},\n            {\"id\": \"literary\", \"description\": \"Craft, meaning, form, expression\"},\n            {\"id\": \"horror\", \"description\": \"Death, dread, flesh, threshold\"},\n            {\"id\": \"poetry\", \"description\": \"Sensory, image, rhythm, metaphor\"},\n        ],\n        \"modes\": [\"creative\", \"divergent\", \"exploratory\"],\n    }\n'''\n\n\n# ─────────────────────────────────────────────────────────────────────────────\n# MODAL CLASS — serves FastAPI + web UI\n# ─────────────────────────────────────────────────────────────────────────────\n\n@app.cls(\n    image=spark_image,\n    gpu=\"A100\",\n    memory=32768,\n    volumes={\"/root/.ollama\": volume},\n    scaledown_window=600,\n    timeout=3600,\n    container_idle_timeout=300,\n)\nclass SparkAPI:\n\n    @modal.enter()\n    def start(self):\n        import subprocess, os, signal, sys\n\n        print(\"[spark] Starting ollama serve...\", file=sys.stderr)\n        self._proc = subprocess.Popen(\n            [\"ollama\", \"serve\"],\n            stdout=subprocess.DEVNULL,\n            stderr=subprocess.STDOUT,\n            preexec_fn=os.setsid,\n            env={**os.environ, \"OLLAMA_MODELS\": \"/root/.ollama\"},\n        )\n        print(f\"[spark] ollama serve started, pid={self._proc.pid}\", file=sys.stderr)\n\n        # Wait for ollama to be ready\n        import requests\n        for attempt in range(30):\n            try:\n                r = requests.get(\"http://localhost:11434\", timeout=2)\n                if r.status_code == 200:\n                    print(\"[spark] Ollama ready\", file=sys.stderr)\n                    break\n            except Exception:\n                pass\n            time.sleep(2)\n        else:\n            print(\"[spark] WARNING: Ollama may not be ready\", file=sys.stderr)\n\n        # Write code files for the FastAPI app\n        with open(\"/tmp/drift_code.py\", \"w\") as f:\n            f.write(DRIFT_CODE)\n        with open(\"/tmp/mapper_code.py\", \"w\") as f:\n            f.write(MAPPER_CODE)\n\n        # Write a simple uvicorn launcher that serves both FastAPI and"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.7","usage":{"input":25798,"output":8192,"cacheRead":13593,"cacheWrite":0,"totalTokens":47583,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"length","timestamp":1774275438091}}
