{"type":"message","id":"b3559ae2","parentId":"674f0715","timestamp":"2026-03-23T14:21:24.200Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"The file is only 3551 bytes, which seems too small - it should be much larger with all the code. The append didn't work properly. Let me start fresh and write the complete file as one write command.\n\nActually, the issue is the write tool only writes the content I specify. The previous write to `spark_app.py` was a full write that started with `\"\"\"` and got cut off. Then the second write appended to it. Let me check the actual content.\n\nWait, actually looking at the line count: 87 lines. That's the second write. The original file was 589 lines and got truncated at \"Write a simple uvicorn launcher that serves both FastAPI and\". \n \nSo the second write appended after that truncation point rather than replacing the file. The write tool overwrites the entire file, not just appends, so something went wrong with how the content was being written. I need to write the complete file from scratch with all the necessary imports and code.","thinkingSignature":"a5f57d4b0d7fe5d3fc92230e15f1e9936e116e1c4517f432024e607218b23fb2"},{"type":"text","text":"The file is fragmented from the partial writes. Let me write the complete clean version:\n"},{"type":"toolCall","id":"call_function_4uk20m215kte_1","name":"write","arguments":{"path":"C:/Users/Zwmar/Claw/projects/spark/deploy/spark_app.py","content":"\"\"\"\nSPARK — Full Modal Deployment\nRun: modal deploy spark.deploy.spark_app\nUI: https://spark-{user}.modal.run\n\"\"\"\n\nimport modal\nimport subprocess\nimport os\nimport sys\nimport time\n\napp = modal.App(\"spark\")\n\n# ─────────────────────────────────────────────────────────────────────────────\n# IMAGE\n# ─────────────────────────────────────────────────────────────────────────────\n\nspark_image = (\n    modal.Image.debian_slim(python_version=\"3.11\")\n    .pip_install(\n        \"fastapi[standard]==0.115.0\",\n        \"uvicorn[standard]==0.30.0\",\n        \"requests==2.32.3\",\n        \"httpx==0.27.0\",\n        \"pydantic==2.9.0\",\n        \"numpy==1.26.4\",\n        \"networkx==3.4.2\",\n    )\n    .run_commands(\n        \"apt-get update && apt-get install -y curl zstd unzip && curl -fsSL https://ollama.com/install.sh | sh\",\n        _quiet=False,\n    )\n    .env({\"OLLAMA_MODELS\": \"/root/.ollama\", \"OLLAMA_HOST\": \"0.0.0.0\"})\n)\n\nvolume = modal.Volume.from_name(\"spark-ollama-models\", create=True)\n\n# ─────────────────────────────────────────────────────────────────────────────\n# DRIFT CHAMBER CODE (string, written to /tmp on Modal at startup)\n# ─────────────────────────────────────────────────────────────────────────────\n\nDRIFT_CODE = '''\nimport random, math\n\nWITHIN_CLUSTER_WEIGHT = 0.3\nCROSS_CLUSTER_WEIGHT = 0.15\n\nCONCEPT_CLUSTERS = {\n    \"emotions\": [\"longing\",\"grief\",\"joy\",\"hope\",\"despair\",\"love\",\"hate\",\"fear\",\"shame\",\"awe\",\"nostalgia\",\"regret\",\"elation\",\"dread\",\"tenderness\"],\n    \"relationships\": [\"betrayal\",\"trust\",\"loyalty\",\"secrets\",\"confession\",\"reunion\",\"loss\",\"devotion\",\"estrangement\",\"reconciliation\",\"commitment\",\"betrayer\",\"beloved\"],\n    \"sensory\": [\"rain\",\"fire\",\"blood\",\"snow\",\"shadow\",\"light\",\"flesh\",\"iron\",\"salt\",\"glass\",\"mirror\",\"door\",\"threshold\",\"darkness\",\"heat\",\"cold\",\"smoke\",\"water\"],\n    \"cosmos\": [\"universe\",\"star\",\"void\",\"black_hole\",\"gravity\",\"silence\",\"infinity\",\"light_year\",\"extinction\",\"origins\",\"entropy\",\"cosmic\",\"orbit\",\"collapse\",\"singularity\"],\n    \"mortality\": [\"death\",\"dying\",\"ghost\",\"corpse\",\"grave\",\"afterlife\",\"memory\",\"forgetting\",\"bone\",\"decay\",\"resurrection\",\"sacrifice\",\"survival\",\"last_breath\",\"funeral\"],\n    \"narrative\": [\"pursuit\",\"escape\",\"revelation\",\"betrayal\",\"climax\",\"resolution\",\"setup\",\"misdirect\",\"backstory\",\"frame\",\"twist\",\"denouement\"],\n    \"creative\": [\"art\",\"story\",\"image\",\"word\",\"form\",\"fragment\",\"revision\",\"constraint\",\"voice\",\"style\",\"truth\",\"lie\",\"catharsis\",\"expression\",\"imitation\",\"originality\"],\n    \"literary\": [\"sentence\",\"paragraph\",\"page\",\"chapter\",\"narrator\",\"perspective\",\"tension\",\"rhythm\",\"pace\",\"ending\",\"opening\",\"image\",\"symbol\",\"motif\",\"leitmotif\"],\n    \"archetypes\": [\"mother\",\"father\",\"child\",\"stranger\",\"mentor\",\"shadow_self\",\"trickster\",\"hero\",\"villain\",\"victim\",\"rebel\",\"outcast\",\"prophet\",\"fool\"],\n    \"nature\": [\"forest\",\"ocean\",\"desert\",\"mountain\",\"river\",\"storm\",\"sunset\",\"sunrise\",\"season\",\"winter\",\"summer\",\"autumn\",\"spring\",\"flood\",\"drought\",\"earth\",\"sky\"],\n}\n\nDOMAINS = {\n    \"all\":      {\"clusters\":[\"emotions\",\"relationships\",\"sensory\",\"cosmos\",\"mortality\",\"narrative\",\"creative\",\"literary\",\"archetypes\",\"nature\"], \"goal\":[\"creative\",\"emotions\"]},\n    \"romance\":  {\"clusters\":[\"emotions\",\"relationships\",\"sensory\"],                   \"goal\":[\"emotions\",\"relationships\"]},\n    \"scifi\":    {\"clusters\":[\"cosmos\",\"creative\",\"mortality\"],                        \"goal\":[\"cosmos\",\"creative\"]},\n    \"thriller\": {\"clusters\":[\"narrative\",\"cosmos\",\"relationships\"],                  \"goal\":[\"narrative\",\"cosmos\"]},\n    \"literary\": {\"clusters\":[\"literary\",\"creative\",\"emotions\"],                      \"goal\":[\"literary\",\"creative\"]},\n    \"horror\":   {\"clusters\":[\"mortality\",\"sensory\",\"emotions\"],                      \"goal\":[\"mortality\",\"sensory\"]},\n    \"poetry\":   {\"clusters\":[\"sensory\",\"literary\",\"creative\",\"emotions\"],            \"goal\":[\"sensory\",\"creative\"]},\n}\n\nTENSION_PAIRS = {\n    (\"light\",\"darkness\"),(\"creation\",\"destruction\"),(\"love\",\"hate\"),\n    (\"order\",\"chaos\"),(\"birth\",\"death\"),(\"hope\",\"despair\"),\n    (\"truth\",\"lie\"),(\"memory\",\"forgetting\"),(\"ghost\",\"flesh\"),\n}\n\nclass DriftChamber:\n    def __init__(self, domain=\"all\", seed=42):\n        self.domain = domain\n        self.seed = seed\n        self.graph = {}\n        self.concept_to_cluster = {}\n        self.goal_concepts = set()\n        self.all_concepts = []\n        self.history = []\n        self._build()\n\n    def _build(self):\n        cfg = DOMAINS.get(self.domain, DOMAINS[\"all\"])\n        selected = []\n        for cn in cfg[\"clusters\"]:\n            if cn in CONCEPT_CLUSTERS:\n                for c in CONCEPT_CLUSTERS[cn]:\n                    if c not in selected:\n                        selected.append(c)\n        self.concept_to_cluster = {}\n        for cn, concepts in CONCEPT_CLUSTERS.items():\n            for c in concepts:\n                if c not in self.concept_to_cluster:\n                    self.concept_to_cluster[c] = cn\n        adj = {}\n        for c1 in selected:\n            ca = self.concept_to_cluster.get(c1, \"\")\n            within = [(c2, 2.0 if (c1,c2) in TENSION_PAIRS or (c2,c1) in TENSION_PAIRS else 1.0)\n                      for c2 in selected if c1!=c2 and self.concept_to_cluster.get(c2,\"\")==ca]\n            within.sort(key=lambda x: -x[1])\n            for c2, _ in within[:6]:\n                adj[(c1,c2)] = WITHIN_CLUSTER_WEIGHT\n            cross = [(c2, CROSS_CLUSTER_WEIGHT) for c2 in selected\n                     if c1!=c2 and self.concept_to_cluster.get(c2,\"\")!=ca]\n            cross.sort(key=lambda x: -x[1])\n            for c2, w in cross[:4]:\n                adj[(c1,c2)] = w\n        self.graph = {c: {\"activation\": 0.05, \"neighbors\": {}} for c in selected}\n        for (a, b), w in adj.items():\n            self.graph[a][\"neighbors\"][b] = w\n            self.graph[b][\"neighbors\"][a] = w\n        self.all_concepts = selected\n        self.goal_concepts = set()\n        for cn in cfg[\"goal\"]:\n            if cn in CONCEPT_CLUSTERS:\n                for c in CONCEPT_CLUSTERS[cn]:\n                    if c in selected:\n                        self.goal_concepts.add(c)\n\n    def run(self, steering=0.3, steps=30, diffusion=0.1, decay=0.02):\n        rng = random.Random(self.seed)\n        goal_clusters = {self.concept_to_cluster.get(c,\"\") for c in self.goal_concepts}\n        for c in self.graph:\n            if c in self.goal_concepts:\n                self.graph[c][\"activation\"] = 0.95\n            elif self.concept_to_cluster.get(c,\"\") in goal_clusters:\n                self.graph[c][\"activation\"] = 0.5\n            else:\n                self.graph[c][\"activation\"] = 0.05\n        self.history = []\n        for step in range(steps):\n            if step > 0 and step % 4 == 0 and steering > 0:\n                for c in self.graph:\n                    if self.concept_to_cluster.get(c,\"\") in goal_clusters:\n                        self.graph[c][\"activation\"] = max(self.graph[c][\"activation\"], 0.6)\n                    if c in self.goal_concepts:\n                        self.graph[c][\"activation\"] = max(self.graph[c][\"activation\"], 0.8)\n            new_act = {}\n            for c in self.graph:\n                nb = self.graph[c][\"neighbors\"]\n                if not nb:\n                    new_act[c] = self.graph[c][\"activation\"]\n                    continue\n                total_w = sum(nb.values())\n                if total_w == 0:\n                    new_act[c] = self.graph[c][\"activation\"]\n                    continue\n                neighbor_act = sum(self.graph[n][\"activation\"] * w for n, w in nb.items()) / total_w\n                new_act[c] = (1 - diffusion) * self.graph[c][\"activation\"] + diffusion * neighbor_act\n            for c in self.graph:\n                self.graph[c][\"activation\"] = new_act[c]\n            if steering > 0:\n                for c in self.goal_concepts:\n                    self.graph[c][\"activation\"] = min(1.0, self.graph[c][\"activation\"] + steering * 0.15)\n            for c in self.graph:\n                self.graph[c][\"activation\"] *= (1 - decay)\n            acts = [self.graph[c][\"activation\"] for c in self.graph]\n            self.history.append({\"step\": step, \"mean\": sum(acts)/len(acts), \"strong\": sum(1 for a in acts if a > 0.3)})\n        return self\n\n    def top_concepts(self, n=20, threshold=0.05):\n        sorted_c = sorted(self.graph.keys(), key=lambda c: self.graph[c][\"activation\"], reverse=True)\n        return [(c, self.graph[c][\"activation\"]) for c in sorted_c[:n] if self.graph[c][\"activation\"] > threshold]\n\n    def entropy(self):\n        acts = [self.graph[c][\"activation\"] for c in self.graph]\n        total = sum(acts)\n        if total == 0:\n            return 0.0\n        return -sum((a/total)*math.log2(a/total) for a in acts if a > 0)\n'''\n\n# ─────────────────────────────────────────────────────────────────────────────\n# LLM MAPPER CODE (string)\n# ─────────────────────────────────────────────────────────────────────────────\n\nMAPPER_CODE = '''\nimport random\n\nSPARK_VOICE = \"You are SPARK. Not a writing workshop. Not a Hallmark card. Real prose. The kind where something is at stake. Precision of image. Emotion earned through concrete detail, not declared. Sentences that do real work. Endings that open rather than close.\"\nSPARK_CREATIVE = \"SPARK creative voice: Ground every abstraction in a concrete sensory moment. Let the emotional logic be complex, not simple. A character can want two contradictory things. What is unsaid matters more than what is said. End on an image that contains the whole feeling.\"\nSPARK_DIVERGENT = \"SPARK divergent voice: Break expected form. Break expected rhythm. Let the sentence become the thought. Association over narration. Surprising juxtapositions earn their place.\"\nSPARK_EXPLORATORY = \"SPARK exploratory voice: Patient attention to the overlooked. Small things seen clearly. Restraint is a form of precision. Let silence do work.\"\n\nCREATIVE_TENSIONS = [\n    (\"light\",\"darkness\",0.95),(\"creation\",\"destruction\",0.95),(\"love\",\"hate\",0.90),\n    (\"birth\",\"death\",0.90),(\"hope\",\"despair\",0.85),(\"memory\",\"forgetting\",0.80),\n    (\"loyalty\",\"betrayal\",0.85),(\"voice\",\"silence\",0.75),\n]\n\ndef find_tensions(concepts):\n    cs = set(concepts)\n    return [(a,b) for a,b,_ in CREATIVE_TENSIONS if a in cs and b in cs]\n\ndef sample_path(activations, n=5):\n    sorted_c = sorted(activations.items(), key=lambda x: x[1], reverse=True)\n    top = [c for c,a in sorted_c[:10] if a > 0.5]\n    mid = [c for c,a in sorted_c[10:25] if a > 0.3]\n    path = []\n    k = n // 2\n    if top:\n        path.extend(random.sample(top, min(len(top), k)))\n    if mid:\n        path.extend(random.sample(mid, min(len(mid), n - len(path))))\n    random.shuffle(path)\n    return path[:n]\n\ndef build_prompt(theme, concepts, mode, seed, constraints):\n    primary = \", \".join([c for c,_ in concepts[:8]])\n    drift = \" -> \".join(sample_path(dict(concepts)))\n    tensions = find_tensions([c for c,_ in concepts])\n    tension_str = \" Track: \" + \"; \".join(f\"{a} vs {b}\" for a,b in tensions[:3]) + \".\" if tensions else \"\"\n    constraints_str = \"\\\\nUser wants: \" + \", \".join(constraints) + \".\" if constraints else \"\"\n    seed_str = f'\\\\nSeed moment: \"{seed}\"' if seed else \"\"\n    if mode == \"divergent\":\n        return f\"{SPARK_VOICE}\\\\n\\\\n{SPARK_DIVERGENT}\\\\n\\\\nA brief, strange piece (100-200 words) about: {theme}\\\\n\\\\nConcepts: {primary}\\\\nDrift: {drift}\\\\n{tension_str}{constraints_str}{seed_str}\\\\n\\\\nBreak form. An image containing a world beats a sentence that explains one.\"\n    elif mode == \"exploratory\":\n        return f\"{SPARK_VOICE}\\\\n\\\\n{SPARK_EXPLORATORY}\\\\n\\\\nA contemplative piece (200-300 words) about: {theme}\\\\n\\\\n{primary}\\\\nDrift: {drift}\\\\n{tension_str}{constraints_str}{seed_str}\\\\n\\\\nSmall things, seen clearly. Restraint is precision. Let silence do the work.\"\n    else:\n        return f\"{SPARK_VOICE}\\\\n\\\\n{SPARK_CREATIVE}\\\\n\\\\nA short literary fiction piece (200-300 words) about: {theme}\\\\n\\\\nPrimary: {primary}\\\\nDrift: {drift}\\\\n{tension_str}{constraints_str}{seed_str}\\\\n\\\\nDo NOT: Start with 'The [time] [character] felt [emotion]'. End with a moral. Use 'in that moment' or 'journey'.\\\\n\\\\nDo: Ground abstractions in sensory detail. Let the ending open. Earn emotion through what you show.\"\n\ndef generate_via_ollama(prompt, model, url, temperature, max_tokens):\n    import requests\n    resp = requests.post(\n        f\"{url}/api/generate\",\n        json={\"model\": model, \"prompt\": prompt, \"stream\": False,\n              \"options\": {\"temperature\": temperature, \"num_predict\": max_tokens}},\n        timeout=120,\n    )\n    resp.raise_for_status()\n    return resp.json().get(\"response\", \"\").strip()\n\ndef generate_text(concepts, theme, mode, seed, constraints, ollama_url, model_name):\n    prompt = build_prompt(theme, concepts, mode, seed, constraints or [])\n    temp = {\"creative\": 0.8, \"divergent\": 1.1, \"exploratory\": 0.7}[mode]\n    max_tok = {\"creative\": 600, \"divergent\": 400, \"exploratory\": 600}[mode]\n    return generate_via_ollama(prompt, model_name or \"qwen2.5:7b\", ollama_url, temp, max_tok)\n'''\n\n# ─────────────────────────────────────────────────────────────────────────────\n# WEB UI (HTML string)\n# ─────────────────────────────────────────────────────────────────────────────\n\nWEB_UI = '''<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\"/>\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\"/>\n<title>SPARK — Creative Intelligence</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Crimson+Pro:ital,wght@0,300;0,400;0,600;1,300;1,400&family=JetBrains+Mono:wght@400;500&display=swap');\n  :root { --bg: #0d0d0f; --surface: #141418; --border: #222228; --text: #e8e4df; --muted: #7a7772; --accent: #c8a96e; --accent2: #6e8fc8; --dim: #3a3835; }\n  * { box-sizing: border-box; margin: 0; padding: 0; }\n  body { background: var(--bg); color: var(--text); font-family: 'Crimson Pro', Georgia, serif; font-size: 18px; line-height: 1.6; min-height: 100vh; }\n  header { border-bottom: 1px solid var(--border); padding: 1.5rem 2rem; display: flex; align-items: baseline; gap: 1.5rem; }\n  header h1 { font-size: 1.6rem; font-weight: 300; letter-spacing: 0.3em; text-transform: uppercase; color: var(--accent); }\n  header p { font-size: 0.9rem; color: var(--muted); font-style: italic; }\n  main { display: grid; grid-template-columns: 320px 1fr; min-height: calc(100vh - 80px); }\n  aside { border-right: 1px solid var(--border); padding: 1.5rem; display: flex; flex-direction: column; gap: 1.2rem; }\n  .control-group { display: flex; flex-direction: column; gap: 0.4rem; }\n  .control-group label { font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.12em; color: var(--muted); font-family: 'JetBrains Mono', monospace; }\n  select, input[type=\"text\"], textarea { background: var(--surface); border: 1px solid var(--border); color: var(--text); font-family: inherit; font-size: 0.95rem; padding: 0.5rem 0.75rem; border-radius: 4px; outline: none"},"partialJson":"{\"path\": \"C:/Users/Zwmar/Claw/projects/spark/deploy/spark_app.py\", \"content\": \"\\\"\\\"\\\"\\nSPARK — Full Modal Deployment\\nRun: modal deploy spark.deploy.spark_app\\nUI: https://spark-{user}.modal.run\\n\\\"\\\"\\\"\\n\\nimport modal\\nimport subprocess\\nimport os\\nimport sys\\nimport time\\n\\napp = modal.App(\\\"spark\\\")\\n\\n# ─────────────────────────────────────────────────────────────────────────────\\n# IMAGE\\n# ─────────────────────────────────────────────────────────────────────────────\\n\\nspark_image = (\\n    modal.Image.debian_slim(python_version=\\\"3.11\\\")\\n    .pip_install(\\n        \\\"fastapi[standard]==0.115.0\\\",\\n        \\\"uvicorn[standard]==0.30.0\\\",\\n        \\\"requests==2.32.3\\\",\\n        \\\"httpx==0.27.0\\\",\\n        \\\"pydantic==2.9.0\\\",\\n        \\\"numpy==1.26.4\\\",\\n        \\\"networkx==3.4.2\\\",\\n    )\\n    .run_commands(\\n        \\\"apt-get update && apt-get install -y curl zstd unzip && curl -fsSL https://ollama.com/install.sh | sh\\\",\\n        _quiet=False,\\n    )\\n    .env({\\\"OLLAMA_MODELS\\\": \\\"/root/.ollama\\\", \\\"OLLAMA_HOST\\\": \\\"0.0.0.0\\\"})\\n)\\n\\nvolume = modal.Volume.from_name(\\\"spark-ollama-models\\\", create=True)\\n\\n# ─────────────────────────────────────────────────────────────────────────────\\n# DRIFT CHAMBER CODE (string, written to /tmp on Modal at startup)\\n# ─────────────────────────────────────────────────────────────────────────────\\n\\nDRIFT_CODE = '''\\nimport random, math\\n\\nWITHIN_CLUSTER_WEIGHT = 0.3\\nCROSS_CLUSTER_WEIGHT = 0.15\\n\\nCONCEPT_CLUSTERS = {\\n    \\\"emotions\\\": [\\\"longing\\\",\\\"grief\\\",\\\"joy\\\",\\\"hope\\\",\\\"despair\\\",\\\"love\\\",\\\"hate\\\",\\\"fear\\\",\\\"shame\\\",\\\"awe\\\",\\\"nostalgia\\\",\\\"regret\\\",\\\"elation\\\",\\\"dread\\\",\\\"tenderness\\\"],\\n    \\\"relationships\\\": [\\\"betrayal\\\",\\\"trust\\\",\\\"loyalty\\\",\\\"secrets\\\",\\\"confession\\\",\\\"reunion\\\",\\\"loss\\\",\\\"devotion\\\",\\\"estrangement\\\",\\\"reconciliation\\\",\\\"commitment\\\",\\\"betrayer\\\",\\\"beloved\\\"],\\n    \\\"sensory\\\": [\\\"rain\\\",\\\"fire\\\",\\\"blood\\\",\\\"snow\\\",\\\"shadow\\\",\\\"light\\\",\\\"flesh\\\",\\\"iron\\\",\\\"salt\\\",\\\"glass\\\",\\\"mirror\\\",\\\"door\\\",\\\"threshold\\\",\\\"darkness\\\",\\\"heat\\\",\\\"cold\\\",\\\"smoke\\\",\\\"water\\\"],\\n    \\\"cosmos\\\": [\\\"universe\\\",\\\"star\\\",\\\"void\\\",\\\"black_hole\\\",\\\"gravity\\\",\\\"silence\\\",\\\"infinity\\\",\\\"light_year\\\",\\\"extinction\\\",\\\"origins\\\",\\\"entropy\\\",\\\"cosmic\\\",\\\"orbit\\\",\\\"collapse\\\",\\\"singularity\\\"],\\n    \\\"mortality\\\": [\\\"death\\\",\\\"dying\\\",\\\"ghost\\\",\\\"corpse\\\",\\\"grave\\\",\\\"afterlife\\\",\\\"memory\\\",\\\"forgetting\\\",\\\"bone\\\",\\\"decay\\\",\\\"resurrection\\\",\\\"sacrifice\\\",\\\"survival\\\",\\\"last_breath\\\",\\\"funeral\\\"],\\n    \\\"narrative\\\": [\\\"pursuit\\\",\\\"escape\\\",\\\"revelation\\\",\\\"betrayal\\\",\\\"climax\\\",\\\"resolution\\\",\\\"setup\\\",\\\"misdirect\\\",\\\"backstory\\\",\\\"frame\\\",\\\"twist\\\",\\\"denouement\\\"],\\n    \\\"creative\\\": [\\\"art\\\",\\\"story\\\",\\\"image\\\",\\\"word\\\",\\\"form\\\",\\\"fragment\\\",\\\"revision\\\",\\\"constraint\\\",\\\"voice\\\",\\\"style\\\",\\\"truth\\\",\\\"lie\\\",\\\"catharsis\\\",\\\"expression\\\",\\\"imitation\\\",\\\"originality\\\"],\\n    \\\"literary\\\": [\\\"sentence\\\",\\\"paragraph\\\",\\\"page\\\",\\\"chapter\\\",\\\"narrator\\\",\\\"perspective\\\",\\\"tension\\\",\\\"rhythm\\\",\\\"pace\\\",\\\"ending\\\",\\\"opening\\\",\\\"image\\\",\\\"symbol\\\",\\\"motif\\\",\\\"leitmotif\\\"],\\n    \\\"archetypes\\\": [\\\"mother\\\",\\\"father\\\",\\\"child\\\",\\\"stranger\\\",\\\"mentor\\\",\\\"shadow_self\\\",\\\"trickster\\\",\\\"hero\\\",\\\"villain\\\",\\\"victim\\\",\\\"rebel\\\",\\\"outcast\\\",\\\"prophet\\\",\\\"fool\\\"],\\n    \\\"nature\\\": [\\\"forest\\\",\\\"ocean\\\",\\\"desert\\\",\\\"mountain\\\",\\\"river\\\",\\\"storm\\\",\\\"sunset\\\",\\\"sunrise\\\",\\\"season\\\",\\\"winter\\\",\\\"summer\\\",\\\"autumn\\\",\\\"spring\\\",\\\"flood\\\",\\\"drought\\\",\\\"earth\\\",\\\"sky\\\"],\\n}\\n\\nDOMAINS = {\\n    \\\"all\\\":      {\\\"clusters\\\":[\\\"emotions\\\",\\\"relationships\\\",\\\"sensory\\\",\\\"cosmos\\\",\\\"mortality\\\",\\\"narrative\\\",\\\"creative\\\",\\\"literary\\\",\\\"archetypes\\\",\\\"nature\\\"], \\\"goal\\\":[\\\"creative\\\",\\\"emotions\\\"]},\\n    \\\"romance\\\":  {\\\"clusters\\\":[\\\"emotions\\\",\\\"relationships\\\",\\\"sensory\\\"],                   \\\"goal\\\":[\\\"emotions\\\",\\\"relationships\\\"]},\\n    \\\"scifi\\\":    {\\\"clusters\\\":[\\\"cosmos\\\",\\\"creative\\\",\\\"mortality\\\"],                        \\\"goal\\\":[\\\"cosmos\\\",\\\"creative\\\"]},\\n    \\\"thriller\\\": {\\\"clusters\\\":[\\\"narrative\\\",\\\"cosmos\\\",\\\"relationships\\\"],                  \\\"goal\\\":[\\\"narrative\\\",\\\"cosmos\\\"]},\\n    \\\"literary\\\": {\\\"clusters\\\":[\\\"literary\\\",\\\"creative\\\",\\\"emotions\\\"],                      \\\"goal\\\":[\\\"literary\\\",\\\"creative\\\"]},\\n    \\\"horror\\\":   {\\\"clusters\\\":[\\\"mortality\\\",\\\"sensory\\\",\\\"emotions\\\"],                      \\\"goal\\\":[\\\"mortality\\\",\\\"sensory\\\"]},\\n    \\\"poetry\\\":   {\\\"clusters\\\":[\\\"sensory\\\",\\\"literary\\\",\\\"creative\\\",\\\"emotions\\\"],            \\\"goal\\\":[\\\"sensory\\\",\\\"creative\\\"]},\\n}\\n\\nTENSION_PAIRS = {\\n    (\\\"light\\\",\\\"darkness\\\"),(\\\"creation\\\",\\\"destruction\\\"),(\\\"love\\\",\\\"hate\\\"),\\n    (\\\"order\\\",\\\"chaos\\\"),(\\\"birth\\\",\\\"death\\\"),(\\\"hope\\\",\\\"despair\\\"),\\n    (\\\"truth\\\",\\\"lie\\\"),(\\\"memory\\\",\\\"forgetting\\\"),(\\\"ghost\\\",\\\"flesh\\\"),\\n}\\n\\nclass DriftChamber:\\n    def __init__(self, domain=\\\"all\\\", seed=42):\\n        self.domain = domain\\n        self.seed = seed\\n        self.graph = {}\\n        self.concept_to_cluster = {}\\n        self.goal_concepts = set()\\n        self.all_concepts = []\\n        self.history = []\\n        self._build()\\n\\n    def _build(self):\\n        cfg = DOMAINS.get(self.domain, DOMAINS[\\\"all\\\"])\\n        selected = []\\n        for cn in cfg[\\\"clusters\\\"]:\\n            if cn in CONCEPT_CLUSTERS:\\n                for c in CONCEPT_CLUSTERS[cn]:\\n                    if c not in selected:\\n                        selected.append(c)\\n        self.concept_to_cluster = {}\\n        for cn, concepts in CONCEPT_CLUSTERS.items():\\n            for c in concepts:\\n                if c not in self.concept_to_cluster:\\n                    self.concept_to_cluster[c] = cn\\n        adj = {}\\n        for c1 in selected:\\n            ca = self.concept_to_cluster.get(c1, \\\"\\\")\\n            within = [(c2, 2.0 if (c1,c2) in TENSION_PAIRS or (c2,c1) in TENSION_PAIRS else 1.0)\\n                      for c2 in selected if c1!=c2 and self.concept_to_cluster.get(c2,\\\"\\\")==ca]\\n            within.sort(key=lambda x: -x[1])\\n            for c2, _ in within[:6]:\\n                adj[(c1,c2)] = WITHIN_CLUSTER_WEIGHT\\n            cross = [(c2, CROSS_CLUSTER_WEIGHT) for c2 in selected\\n                     if c1!=c2 and self.concept_to_cluster.get(c2,\\\"\\\")!=ca]\\n            cross.sort(key=lambda x: -x[1])\\n            for c2, w in cross[:4]:\\n                adj[(c1,c2)] = w\\n        self.graph = {c: {\\\"activation\\\": 0.05, \\\"neighbors\\\": {}} for c in selected}\\n        for (a, b), w in adj.items():\\n            self.graph[a][\\\"neighbors\\\"][b] = w\\n            self.graph[b][\\\"neighbors\\\"][a] = w\\n        self.all_concepts = selected\\n        self.goal_concepts = set()\\n        for cn in cfg[\\\"goal\\\"]:\\n            if cn in CONCEPT_CLUSTERS:\\n                for c in CONCEPT_CLUSTERS[cn]:\\n                    if c in selected:\\n                        self.goal_concepts.add(c)\\n\\n    def run(self, steering=0.3, steps=30, diffusion=0.1, decay=0.02):\\n        rng = random.Random(self.seed)\\n        goal_clusters = {self.concept_to_cluster.get(c,\\\"\\\") for c in self.goal_concepts}\\n        for c in self.graph:\\n            if c in self.goal_concepts:\\n                self.graph[c][\\\"activation\\\"] = 0.95\\n            elif self.concept_to_cluster.get(c,\\\"\\\") in goal_clusters:\\n                self.graph[c][\\\"activation\\\"] = 0.5\\n            else:\\n                self.graph[c][\\\"activation\\\"] = 0.05\\n        self.history = []\\n        for step in range(steps):\\n            if step > 0 and step % 4 == 0 and steering > 0:\\n                for c in self.graph:\\n                    if self.concept_to_cluster.get(c,\\\"\\\") in goal_clusters:\\n                        self.graph[c][\\\"activation\\\"] = max(self.graph[c][\\\"activation\\\"], 0.6)\\n                    if c in self.goal_concepts:\\n                        self.graph[c][\\\"activation\\\"] = max(self.graph[c][\\\"activation\\\"], 0.8)\\n            new_act = {}\\n            for c in self.graph:\\n                nb = self.graph[c][\\\"neighbors\\\"]\\n                if not nb:\\n                    new_act[c] = self.graph[c][\\\"activation\\\"]\\n                    continue\\n                total_w = sum(nb.values())\\n                if total_w == 0:\\n                    new_act[c] = self.graph[c][\\\"activation\\\"]\\n                    continue\\n                neighbor_act = sum(self.graph[n][\\\"activation\\\"] * w for n, w in nb.items()) / total_w\\n                new_act[c] = (1 - diffusion) * self.graph[c][\\\"activation\\\"] + diffusion * neighbor_act\\n            for c in self.graph:\\n                self.graph[c][\\\"activation\\\"] = new_act[c]\\n            if steering > 0:\\n                for c in self.goal_concepts:\\n                    self.graph[c][\\\"activation\\\"] = min(1.0, self.graph[c][\\\"activation\\\"] + steering * 0.15)\\n            for c in self.graph:\\n                self.graph[c][\\\"activation\\\"] *= (1 - decay)\\n            acts = [self.graph[c][\\\"activation\\\"] for c in self.graph]\\n            self.history.append({\\\"step\\\": step, \\\"mean\\\": sum(acts)/len(acts), \\\"strong\\\": sum(1 for a in acts if a > 0.3)})\\n        return self\\n\\n    def top_concepts(self, n=20, threshold=0.05):\\n        sorted_c = sorted(self.graph.keys(), key=lambda c: self.graph[c][\\\"activation\\\"], reverse=True)\\n        return [(c, self.graph[c][\\\"activation\\\"]) for c in sorted_c[:n] if self.graph[c][\\\"activation\\\"] > threshold]\\n\\n    def entropy(self):\\n        acts = [self.graph[c][\\\"activation\\\"] for c in self.graph]\\n        total = sum(acts)\\n        if total == 0:\\n            return 0.0\\n        return -sum((a/total)*math.log2(a/total) for a in acts if a > 0)\\n'''\\n\\n# ─────────────────────────────────────────────────────────────────────────────\\n# LLM MAPPER CODE (string)\\n# ─────────────────────────────────────────────────────────────────────────────\\n\\nMAPPER_CODE = '''\\nimport random\\n\\nSPARK_VOICE = \\\"You are SPARK. Not a writing workshop. Not a Hallmark card. Real prose. The kind where something is at stake. Precision of image. Emotion earned through concrete detail, not declared. Sentences that do real work. Endings that open rather than close.\\\"\\nSPARK_CREATIVE = \\\"SPARK creative voice: Ground every abstraction in a concrete sensory moment. Let the emotional logic be complex, not simple. A character can want two contradictory things. What is unsaid matters more than what is said. End on an image that contains the whole feeling.\\\"\\nSPARK_DIVERGENT = \\\"SPARK divergent voice: Break expected form. Break expected rhythm. Let the sentence become the thought. Association over narration. Surprising juxtapositions earn their place.\\\"\\nSPARK_EXPLORATORY = \\\"SPARK exploratory voice: Patient attention to the overlooked. Small things seen clearly. Restraint is a form of precision. Let silence do work.\\\"\\n\\nCREATIVE_TENSIONS = [\\n    (\\\"light\\\",\\\"darkness\\\",0.95),(\\\"creation\\\",\\\"destruction\\\",0.95),(\\\"love\\\",\\\"hate\\\",0.90),\\n    (\\\"birth\\\",\\\"death\\\",0.90),(\\\"hope\\\",\\\"despair\\\",0.85),(\\\"memory\\\",\\\"forgetting\\\",0.80),\\n    (\\\"loyalty\\\",\\\"betrayal\\\",0.85),(\\\"voice\\\",\\\"silence\\\",0.75),\\n]\\n\\ndef find_tensions(concepts):\\n    cs = set(concepts)\\n    return [(a,b) for a,b,_ in CREATIVE_TENSIONS if a in cs and b in cs]\\n\\ndef sample_path(activations, n=5):\\n    sorted_c = sorted(activations.items(), key=lambda x: x[1], reverse=True)\\n    top = [c for c,a in sorted_c[:10] if a > 0.5]\\n    mid = [c for c,a in sorted_c[10:25] if a > 0.3]\\n    path = []\\n    k = n // 2\\n    if top:\\n        path.extend(random.sample(top, min(len(top), k)))\\n    if mid:\\n        path.extend(random.sample(mid, min(len(mid), n - len(path))))\\n    random.shuffle(path)\\n    return path[:n]\\n\\ndef build_prompt(theme, concepts, mode, seed, constraints):\\n    primary = \\\", \\\".join([c for c,_ in concepts[:8]])\\n    drift = \\\" -> \\\".join(sample_path(dict(concepts)))\\n    tensions = find_tensions([c for c,_ in concepts])\\n    tension_str = \\\" Track: \\\" + \\\"; \\\".join(f\\\"{a} vs {b}\\\" for a,b in tensions[:3]) + \\\".\\\" if tensions else \\\"\\\"\\n    constraints_str = \\\"\\\\\\\\nUser wants: \\\" + \\\", \\\".join(constraints) + \\\".\\\" if constraints else \\\"\\\"\\n    seed_str = f'\\\\\\\\nSeed moment: \\\"{seed}\\\"' if seed else \\\"\\\"\\n    if mode == \\\"divergent\\\":\\n        return f\\\"{SPARK_VOICE}\\\\\\\\n\\\\\\\\n{SPARK_DIVERGENT}\\\\\\\\n\\\\\\\\nA brief, strange piece (100-200 words) about: {theme}\\\\\\\\n\\\\\\\\nConcepts: {primary}\\\\\\\\nDrift: {drift}\\\\\\\\n{tension_str}{constraints_str}{seed_str}\\\\\\\\n\\\\\\\\nBreak form. An image containing a world beats a sentence that explains one.\\\"\\n    elif mode == \\\"exploratory\\\":\\n        return f\\\"{SPARK_VOICE}\\\\\\\\n\\\\\\\\n{SPARK_EXPLORATORY}\\\\\\\\n\\\\\\\\nA contemplative piece (200-300 words) about: {theme}\\\\\\\\n\\\\\\\\n{primary}\\\\\\\\nDrift: {drift}\\\\\\\\n{tension_str}{constraints_str}{seed_str}\\\\\\\\n\\\\\\\\nSmall things, seen clearly. Restraint is precision. Let silence do the work.\\\"\\n    else:\\n        return f\\\"{SPARK_VOICE}\\\\\\\\n\\\\\\\\n{SPARK_CREATIVE}\\\\\\\\n\\\\\\\\nA short literary fiction piece (200-300 words) about: {theme}\\\\\\\\n\\\\\\\\nPrimary: {primary}\\\\\\\\nDrift: {drift}\\\\\\\\n{tension_str}{constraints_str}{seed_str}\\\\\\\\n\\\\\\\\nDo NOT: Start with 'The [time] [character] felt [emotion]'. End with a moral. Use 'in that moment' or 'journey'.\\\\\\\\n\\\\\\\\nDo: Ground abstractions in sensory detail. Let the ending open. Earn emotion through what you show.\\\"\\n\\ndef generate_via_ollama(prompt, model, url, temperature, max_tokens):\\n    import requests\\n    resp = requests.post(\\n        f\\\"{url}/api/generate\\\",\\n        json={\\\"model\\\": model, \\\"prompt\\\": prompt, \\\"stream\\\": False,\\n              \\\"options\\\": {\\\"temperature\\\": temperature, \\\"num_predict\\\": max_tokens}},\\n        timeout=120,\\n    )\\n    resp.raise_for_status()\\n    return resp.json().get(\\\"response\\\", \\\"\\\").strip()\\n\\ndef generate_text(concepts, theme, mode, seed, constraints, ollama_url, model_name):\\n    prompt = build_prompt(theme, concepts, mode, seed, constraints or [])\\n    temp = {\\\"creative\\\": 0.8, \\\"divergent\\\": 1.1, \\\"exploratory\\\": 0.7}[mode]\\n    max_tok = {\\\"creative\\\": 600, \\\"divergent\\\": 400, \\\"exploratory\\\": 600}[mode]\\n    return generate_via_ollama(prompt, model_name or \\\"qwen2.5:7b\\\", ollama_url, temp, max_tok)\\n'''\\n\\n# ─────────────────────────────────────────────────────────────────────────────\\n# WEB UI (HTML string)\\n# ─────────────────────────────────────────────────────────────────────────────\\n\\nWEB_UI = '''<!DOCTYPE html>\\n<html lang=\\\"en\\\">\\n<head>\\n<meta charset=\\\"UTF-8\\\"/>\\n<meta name=\\\"viewport\\\" content=\\\"width=device-width, initial-scale=1.0\\\"/>\\n<title>SPARK — Creative Intelligence</title>\\n<style>\\n  @import url('https://fonts.googleapis.com/css2?family=Crimson+Pro:ital,wght@0,300;0,400;0,600;1,300;1,400&family=JetBrains+Mono:wght@400;500&display=swap');\\n  :root { --bg: #0d0d0f; --surface: #141418; --border: #222228; --text: #e8e4df; --muted: #7a7772; --accent: #c8a96e; --accent2: #6e8fc8; --dim: #3a3835; }\\n  * { box-sizing: border-box; margin: 0; padding: 0; }\\n  body { background: var(--bg); color: var(--text); font-family: 'Crimson Pro', Georgia, serif; font-size: 18px; line-height: 1.6; min-height: 100vh; }\\n  header { border-bottom: 1px solid var(--border); padding: 1.5rem 2rem; display: flex; align-items: baseline; gap: 1.5rem; }\\n  header h1 { font-size: 1.6rem; font-weight: 300; letter-spacing: 0.3em; text-transform: uppercase; color: var(--accent); }\\n  header p { font-size: 0.9rem; color: var(--muted); font-style: italic; }\\n  main { display: grid; grid-template-columns: 320px 1fr; min-height: calc(100vh - 80px); }\\n  aside { border-right: 1px solid var(--border); padding: 1.5rem; display: flex; flex-direction: column; gap: 1.2rem; }\\n  .control-group { display: flex; flex-direction: column; gap: 0.4rem; }\\n  .control-group label { font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.12em; color: var(--muted); font-family: 'JetBrains Mono', monospace; }\\n  select, input[type=\\\"text\\\"], textarea { background: var(--surface); border: 1px solid var(--border); color: var(--text); font-family: inherit; font-size: 0.95rem; padding: 0.5rem 0.75rem; border-radius: 4px; outline: none"}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.7","usage":{"input":36436,"output":0,"cacheRead":13593,"cacheWrite":0,"totalTokens":50029,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"aborted","timestamp":1774275619279,"errorMessage":"Request was aborted."}}
