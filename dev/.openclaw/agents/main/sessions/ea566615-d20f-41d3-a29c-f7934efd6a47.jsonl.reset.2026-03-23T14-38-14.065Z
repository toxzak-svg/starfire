{"type":"message","id":"a1a92a25","parentId":"bb20d422","timestamp":"2026-03-23T14:14:05.642Z","message":{"role":"toolResult","toolCallId":"call_function_2622nrzbm291_2","toolName":"read","content":[{"type":"text","text":"\"\"\"\nSPARK API Server\nRun: python -m uvicorn spark.api.main:app --reload --port 8765\n\"\"\"\n\nimport sys\nfrom pathlib import Path\n\n# Ensure spark core is importable\nSPARK_DIR = Path(__file__).parent.parent\nsys.path.insert(0, str(SPARK_DIR))\nsys.path.insert(0, str(SPARK_DIR.parent))\n\nfrom fastapi import FastAPI\nfrom fastapi.middleware.cors import CORSMiddleware\n\nfrom spark.api.routes.creative import router as creative_router\n\napp = FastAPI(\n    title=\"SPARK — Creative Intelligence API\",\n    description=\"Semantic Pattern Recognition via Associative Drift + Constrained Steering\",\n    version=\"0.1.0\",\n)\n\n# CORS — allow all for dev\napp.add_middleware(\n    CORSMiddleware,\n    allow_origins=[\"*\"],\n    allow_credentials=True,\n    allow_methods=[\"*\"],\n    allow_headers=[\"*\"],\n)\n\napp.include_router(creative_router)\n\n\n@app.get(\"/health\")\nasync def health():\n    return {\"status\": \"ok\", \"service\": \"spark\"}\n\n\nif __name__ == \"__main__\":\n    import uvicorn\n    uvicorn.run(\"spark.api.main:app\", host=\"0.0.0.0\", port=8765, reload=True)\n"}],"isError":false,"timestamp":1774275245594}}
