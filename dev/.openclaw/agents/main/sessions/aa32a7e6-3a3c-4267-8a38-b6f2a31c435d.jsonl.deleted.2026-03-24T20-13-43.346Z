{"type":"message","id":"bb712444","parentId":"0eaa31c9","timestamp":"2026-03-24T20:06:15.112Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"There's a syntax error. Let me fix the f-string with the escaped characters.","thinkingSignature":"9ff37cd0fcb1233d3366b0656ae0f7a6f8a68816e822347fb9a75884ca570c4a"},{"type":"toolCall","id":"call_function_9onkew6hikn4_1","name":"write","arguments":{"path":"C:\\Users\\Zwmar\\.openclaw\\sandbox\\scripts\\conditional_importance.py","content":"\"\"\"Conditional Importance Analysis: Does removing token T hurt prediction?\"\"\"\nimport re\nfrom collections import defaultdict\nfrom pathlib import Path\n\nLOG_DIR = Path(\"C:/Users/Zwmar/.openclaw/sandbox/logs\")\nMIN_PULSE_LEN = 500\n\ndef extract_tokens(pulse_path):\n    content = pulse_path.read_text(encoding=\"utf-8\")\n    tokens = {\"all_ngrams\": set()}\n    words = content.split()\n    for i in range(len(words) - 1):\n        bigram = words[i].lower() + \" \" + words[i+1].lower()\n        if len(bigram) > 4:\n            tokens[\"all_ngrams\"].add(bigram)\n    for i in range(len(words) - 2):\n        trigram = words[i].lower() + \" \" + words[i+1].lower() + \" \" + words[i+2].lower()\n        if len(trigram) > 6:\n            tokens[\"all_ngrams\"].add(trigram)\n    return tokens\n\npulses = sorted([f for f in LOG_DIR.glob(\"pulse_*.md\") if f.stat().st_size >= MIN_PULSE_LEN], key=lambda x: x.stat().st_mtime)[:200]\npulse_tokens = []\nfor p in pulses:\n    t = extract_tokens(p)\n    pulse_tokens.append(t)\n\n# For each pulse pair\npairs = []\nfor idx in range(len(pulse_tokens) - 1):\n    curr = pulse_tokens[idx][\"all_ngrams\"]\n    next_t = pulse_tokens[idx+1][\"all_ngrams\"]\n    pairs.append((curr, next_t))\n\n# Raw frequency\ntoken_count = defaultdict(int)\nfor curr, _ in pairs:\n    for tok in curr:\n        token_count[tok] += 1\n\n# CFI\ncfi_correct = defaultdict(int)\ncfi_total = defaultdict(int)\nfor curr, next_t in pairs:\n    for tok in curr:\n        cfi_total[tok] += 1\n        if tok in next_t:\n            cfi_correct[tok] += 1\n\ncfi = {tok: cfi_correct[tok] / cfi_total[tok] if cfi_total[tok] > 0 else 0 for tok in cfi_total}\n\n# THE EXPERIMENT: Compare prediction WITH vs WITHOUT each token\ntop_tokens = sorted(token_count.keys(), key=lambda x: -token_count[x])[:40]\n\nresults = []\nfor tok in top_tokens:\n    freq = token_count[tok]\n    c = cfi.get(tok, 0)\n    \n    jaccard_with = 0.0\n    jaccard_without = 0.0\n    count = 0\n    \n    for curr, next_t in pairs:\n        if tok not in curr:\n            continue\n        count += 1\n        \n        # With token\n        state_with = curr\n        ov_with = len(state_with & next_t)\n        union_with = len(state_with | next_t)\n        jaccard_with += ov_with / union_with if union_with > 0 else 0\n        \n        # Without token\n        state_without = curr - {tok}\n        ov_without = len(state_without & next_t)\n        union_without = len(state_without | next_t)\n        jaccard_without += ov_without / union_without if union_without > 0 else 0\n    \n    avg_jw = jaccard_with / count if count > 0 else 0\n    avg_jwo = jaccard_without / count if count > 0 else 0\n    delta = avg_jwo - avg_jw  # Negative = token helps (causal), 0 = scaffolding\n    \n    results.append((tok, freq, c, avg_jw, avg_jwo, delta))\n\n# Sort by delta (most negative = most causal)\nresults.sort(key=lambda x: x[5])\n\nprint(\"=== CONDITIONAL IMPORTANCE ANALYSIS ===\")\nprint(\"Delta < 0 means removing token HURTS prediction (token is causal)\")\nprint(\"Delta ~ 0 means removing token doesn't matter (token is scaffolding)\")\nprint()\nheader = \"Token                          Freq    CFI   Jac+Tok  Jac-Tok    Delta\"\nprint(header)\nprint(\"-\" * 80)\nfor tok, freq, c, jw, jwo, delta in results:\n    safe = tok.encode(\"ascii\", \"replace\").decode(\"ascii\")[:30]\n    print(f\"{safe:<30} {freq:>5} {c:>6.3f} {jw:>8.4f} {jwo:>8.4f} {delta:>+8.4f}\")\n\nprint()\nprint(\"=== CATEGORIZATION ===\")\nprint()\nprint(\"SCAFFOLDING (delta > -0.001, removing doesn't hurt):\")\nfor tok, freq, c, jw, jwo, delta in results:\n    if delta > -0.001:\n        safe = tok.encode(\"ascii\", \"replace\").decode(\"ascii\")[:60]\n        print(f\"  freq={freq:3d} CFI={c:.3f} delta={delta:+.5f} | {safe}\")\n\nprint()\nprint(\"CAUSAL (delta < -0.005, removing HURTS prediction):\")\nfor tok, freq, c, jw, jwo, delta in results:\n    if delta < -0.005:\n        safe = tok.encode(\"ascii\", \"replace\").decode(\"ascii\")[:60]\n        print(f\"  freq={freq:3d} CFI={c:.3f} delta={delta:+.5f} | {safe}\")\n\nprint()\nprint(\"=== KEY INSIGHT ===\")\nscaffolding = [(tok, freq, c, delta) for tok, freq, c, _, _, delta in results if delta > -0.001]\ncausal = [(tok, freq, c, delta) for tok, freq, c, _, _, delta in results if delta < -0.005]\nprint(f\"Scaffolding tokens: {len(scaffolding)}\")\nprint(f\"Causal tokens: {len(causal)}\")\n# Avg CFI for each\navg_cfi_scaff = sum(c for _,_,c,_ in scaffolding) / len(scaffolding) if scaffolding else 0\navg_cfi_causal = sum(c for _,_,c,_ in causal) / len(causal) if causal else 0\nprint(f\"Avg CFI of scaffolding: {avg_cfi_scaff:.3f}\")\nprint(f\"Avg CFI of causal: {avg_cfi_causal:.3f}\")\n"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.7","usage":{"input":25870,"output":1445,"cacheRead":12158,"cacheWrite":0,"totalTokens":39473,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774382751667}}
