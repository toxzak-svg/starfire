{"type":"message","id":"107b1198","parentId":"45b6e271","timestamp":"2026-03-22T23:15:22.786Z","message":{"role":"toolResult","toolCallId":"call_function_ab9yjedom4d8_1","toolName":"read","content":[{"type":"text","text":"\"\"\"\nQuery Engine\n============\nHigh-level causal queries over the dependency graph.\n\nProvides natural-language-style queries that map to graph traversals,\nplus ranking/filtering of results.\n\"\"\"\n\nfrom __future__ import annotations\n\nfrom dataclasses import dataclass\nfrom typing import Optional\nfrom .graph_builder import CausalGraph\n\n\n@dataclass\nclass CausalResult:\n    \"\"\"A single result from a causal query.\"\"\"\n    entity: str\n    kind: str\n    file_path: str\n    lineno: int\n    docstring: Optional[str]\n    score: float            # importance/relevance score\n    path: list[str]        # causal path from query root to this entity\n    reason: str            # human-readable explanation of why this matters\n\n\nclass QueryEngine:\n    \"\"\"\n    Causal query interface for a codebase graph.\n\n    Example:\n        engine = QueryEngine(graph)\n        results = engine.query(\"what happens if I change auth.py validate_token?\")\n        for r in results:\n            print(f\"{r.entity} (score={r.score:.2f}): {r.reason}\")\n    \"\"\"\n\n    def __init__(self, graph: CausalGraph):\n        self.graph = graph\n\n    def query(self, question: str, top_k: int = 10) -> list[CausalResult]:\n        \"\"\"\n        Parse a natural-ish question and execute the corresponding causal query.\n\n        Supported question patterns:\n        - \"what happens if I change X?\" / \"what does X affect?\" / \"impact of X\"\n        - \"what caused X?\" / \"what does X depend on?\" / \"causes of X\"\n        - \"what uses X?\" / \"who calls X?\" / \"dependents of X\"\n        - \"ripple effect of X\" / \"full impact of X\"\n        \"\"\"\n        q = question.lower()\n\n        # Extract entity name from quotes or \"of X\" pattern\n        entity = self._extract_entity(q)\n\n        # \"what calls X\" / \"who uses X\" → dependents (who depends on X)\n        if any(k in q for k in [\"calls\", \"who calls\", \"who use\", \"what calls\", \"dependents\", \"who depend\"]):\n            return self._query_dependents(entity, top_k)\n        # \"what does X affect\" / \"what will break if X changes\" → impact (what X touches)\n        elif any(k in q for k in [\"affect\", \"ripple\", \"break\", \"what will\", \"happens if\"]):\n            return self._query_impact(entity, top_k)\n        # \"what does X depend on\" / \"what caused X\" → causes (what X needs)\n        elif any(k in q for k in [\"caus\", \"depend on\", \"prereq\", \"needed\", \"require\"]):\n            return self._query_causes(entity, top_k)\n        else:\n            # Default to impact query\n            return self._query_impact(entity, top_k)\n\n    def _extract_entity(self, question: str) -> Optional[str]:\n        \"\"\"Extract the entity being asked about from the question text.\"\"\"\n        import re\n\n        # Match quoted strings: \"auth.validate_token\" or 'auth.validate_token'\n        quoted = re.findall(r'[\"\\']([^\"\\']+)[\"\\']', question)\n        if quoted:\n            return quoted[0]\n\n        # Match \"of X\" pattern: \"of auth.validate_token\"\n        of_match = re.search(r'\\bof\\s+([\\w.]+)', question)\n        if of_match:\n            return of_match.group(1)\n\n        # Match \"change X\" / \"modify X\" / \"affect X\"\n        modify_match = re.search(r'(?:change|modify|affect|update|edit)\\s+([\\w.]+)', question)\n        if modify_match:\n            return modify_match.group(1)\n\n        return None\n\n    def _score_result(self, name: str, depth: int, is_interface: bool, edge_kind: str) -> float:\n        \"\"\"\n        Score a query result by importance.\n        Higher score = more important to consider.\n        \"\"\"\n        score = 1.0\n\n        # Depth penalty: shallow impacts matter more\n        score -= depth * 0.15\n\n        # Interface bonus: things with many dependents are critical\n        if is_interface:\n            score += 0.5\n\n        # Entry point bonus\n        node = self.graph.nodes.get(name)\n        if node and node.is_entry_point:\n            score += 0.4\n\n        # Edge kind weighting\n        if edge_kind == \"calls\":\n            score += 0.1\n        elif edge_kind == \"inherits\":\n            score += 0.2\n        elif edge_kind == \"imports\":\n            score -= 0.1\n\n        # External nodes are less interesting\n        if node and node.kind == \"external\":\n            score -= 0.3\n\n        return max(0.0, score)\n\n    def _query_impact(self, entity: Optional[str], top_k: int) -> list[CausalResult]:\n        \"\"\"What changes if I modify this entity?\"\"\"\n        if not entity:\n            return []\n\n        # Try exact match first, then fuzzy\n        target = self._resolve_entity(entity)\n        if not target:\n            return []\n\n        impacts = self.graph.query_impact(target, depth=5)\n        results = []\n\n        for imp in impacts[:top_k * 2]:  # over-fetch for scoring\n            node_data = imp[\"node\"]\n            score = self._score_result(\n                imp[\"name\"],\n                imp[\"depth\"],\n                node_data.get(\"is_interface\", False),\n                imp[\"edge_kind\"]\n            )\n            reason = self._make_impact_reason(entity, imp[\"name\"], imp[\"edge_kind\"], imp[\"depth\"])\n\n            results.append(CausalResult(\n                entity=imp[\"name\"],\n                kind=node_data.get(\"kind\", \"unknown\"),\n                file_path=node_data.get(\"file_path\", \"\"),\n                lineno=node_data.get(\"lineno\", 0),\n                docstring=node_data.get(\"docstring\"),\n                score=score,\n                path=[entity, imp[\"name\"]],\n                reason=reason,\n            ))\n\n        results.sort(key=lambda r: -r.score)\n        return results[:top_k]\n\n    def _query_causes(self, entity: Optional[str], top_k: int) -> list[CausalResult]:\n        \"\"\"What caused this entity to be the way it is?\"\"\"\n        if not entity:\n            return []\n\n        target = self._resolve_entity(entity)\n        if not target:\n            return []\n\n        causes = self.graph.query_causes(target, depth=5)\n        results = []\n\n        for cause in causes[:top_k * 2]:\n            node_data = cause[\"node\"]\n            score = self._score_result(\n                cause[\"name\"],\n                cause[\"depth\"],\n                node_data.get(\"is_interface\", False),\n                cause[\"edge_kind\"]\n            )\n            reason = self._make_causes_reason(entity, cause[\"name\"], cause[\"edge_kind\"], cause[\"depth\"])\n\n            results.append(CausalResult(\n                entity=cause[\"name\"],\n                kind=node_data.get(\"kind\", \"unknown\"),\n                file_path=node_data.get(\"file_path\", \"\"),\n                lineno=node_data.get(\"lineno\", 0),\n                docstring=node_data.get(\"docstring\"),\n                score=score,\n                path=[cause[\"name\"], entity],\n                reason=reason,\n            ))\n\n        results.sort(key=lambda r: -r.score)\n        return results[:top_k]\n\n    def _query_dependents(self, entity: Optional[str], top_k: int) -> list[CausalResult]:\n        \"\"\"Who depends on this entity?\"\"\"\n        if not entity:\n            return []\n\n        target = self._resolve_entity(entity)\n        if not target:\n            return []\n\n        direct = self.graph._outgoing.get(target, [])\n        results = []\n\n        for dep_name in direct:\n            node = self.graph.nodes.get(dep_name)\n            if not node:\n                continue\n            results.append(CausalResult(\n                entity=dep_name,\n                kind=node.kind,\n                file_path=node.file_path,\n                lineno=node.lineno,\n                docstring=node.docstring,\n                score=1.0,\n                path=[target, dep_name],\n                reason=f\"{dep_name} directly calls/imports {entity}\",\n            ))\n\n        results.sort(key=lambda r: -r.score)\n        return results[:top_k]\n\n    def _resolve_entity(self, entity: str) -> Optional[str]:\n        \"\"\"Resolve a partial name to a fully qualified name.\"\"\"\n        # Strip leading dot if present\n        entity = entity.lstrip(\".\")\n\n        # Normalize underscores/hyphens\n        entity_norm = entity.replace(\"-\", \"_\")\n\n        if entity in self.graph.nodes:\n            return entity\n\n        # Try case-insensitive match with normalization\n        lower = entity_norm.lower()\n        for name in self.graph.nodes:\n            if name.replace(\"-\", \"_\").lower() == lower:\n                return name\n\n        # Try suffix match with dot boundary\n        for name in self.graph.nodes:\n            if name.endswith(\".\" + entity) or name == entity:\n                return name\n\n        # Try normalized suffix match\n        for name in self.graph.nodes:\n            name_norm = name.replace(\"-\", \"_\")\n            if name_norm.endswith(\".\" + entity_norm) or name_norm == entity_norm:\n                return name\n\n        # Try last-component match\n        parts = entity.split(\".\")\n        for name in self.graph.nodes:\n            if name.endswith(parts[-1]):\n                return name\n\n        return None\n\n    def _make_impact_reason(self, changed: str, affected: str, edge_kind: str, depth: int) -> str:\n        kind_map = {\n            \"calls\": f\"directly calls\",\n            \"imports\": f\"imports\",\n            \"inherits\": f\"inherits from\",\n            \"attributes\": f\"accesses attribute of\",\n        }\n        action = kind_map.get(edge_kind, f\"relates to\")\n        d_str = f\" (cascade {depth} hops)\" if depth > 1 else \"\"\n        return f\"{affected} {action} {changed}{d_str}\"\n\n    def _make_causes_reason(self, entity: str, cause: str, edge_kind: str, depth: int) -> str:\n        kind_map = {\n            \"calls\": f\"calls\",\n            \"imports\": f\"imports\",\n            \"inherits\": f\"inherits from\",\n            \"attributes\": f\"accesses attribute of\",\n        }\n        action = kind_map.get(edge_kind, f\"relates to\")\n        d_str = f\" ({depth} hops up)\" if depth > 1 else \"\"\n        return f\"{entity} {action} {cause}{d_str}\"\n\n    def explain_entity(self, entity: str) -> dict:\n        \"\"\"Get a full causal explanation of an entity.\"\"\"\n        target = self._resolve_entity(entity)\n        if not target:\n            return {}\n\n        node = self.graph.nodes.get(target, None)\n        if not node:\n            return {}\n\n        impact = self.graph.query_impact(target, depth=2)\n        causes = self.graph.query_causes(target, depth=2)\n        hot_path = self.graph.query_hot_path(target)\n\n        return {\n            \"entity\": target,\n            \"definition\": {\n                \"kind\": node.kind,\n                \"file\": node.file_path,\n                \"lines\": f\"{node.lineno}-{node.end_lineno}\" if node.end_lineno else f\"line {node.lineno}\",\n                \"docstring\": node.docstring,\n                \"is_entry_point\": node.is_entry_point,\n                \"is_interface\": node.is_interface,\n            },\n            \"direct_dependents\": self.graph._outgoing.get(target, []),\n            \"direct_dependencies\": self.graph._incoming.get(target, []),\n            \"top_impact\": [i[\"name\"] for i in impact[:5]],\n            \"top_causes\": [c[\"name\"] for c in causes[:5]],\n            \"hot_path\": hot_path,\n            \"graph_stats\": {\n                \"in_degree\": len(self.graph._incoming[target]),\n                \"out_degree\": len(self.graph._outgoing[target]),\n            }\n        }\n"}],"isError":false,"timestamp":1774221322781}}
{"type":"message","id":"f213ca4f","parentId":"107b1198","timestamp":"2026-03-22T23:15:25.543Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now let me look at the graph_builder to understand the current state, and check the scripts/index_codebase.py to see the demo.","thinkingSignature":"7ff2e7beb5b8f6430446bc433ef6dcb42a49e91b683ff985e35daa449cb53116"},{"type":"toolCall","id":"call_function_dg4khc8xp1k4_1","name":"read","arguments":{"file_path":"C:/dev/code-cause/scripts/index_codebase.py"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.7","usage":{"input":7367,"output":63,"cacheRead":12619,"cacheWrite":0,"totalTokens":20049,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774221322787}}
{"type":"message","id":"671a3b24","parentId":"f213ca4f","timestamp":"2026-03-22T23:15:25.558Z","message":{"role":"toolResult","toolCallId":"call_function_dg4khc8xp1k4_1","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\n\"\"\"\nindex_codebase.py\n=================\nCLI tool to index a codebase and save its causal graph.\n\nUsage:\n    python index_codebase.py /path/to/codebase [--output graph.json]\n\"\"\"\n\nimport argparse\nimport json\nimport sys\nfrom pathlib import Path\n\n# Add src to path for local development\nsys.path.insert(0, str(Path(__file__).parent.parent / \"src\"))\n\nfrom causal_indexer import StaticAnalyzer, CausalGraph, QueryEngine\n\n\ndef main():\n    parser = argparse.ArgumentParser(description=\"Index a codebase and build its causal graph.\")\n    parser.add_argument(\"codebase\", help=\"Path to the codebase to index\")\n    parser.add_argument(\"--output\", \"-o\", default=None, help=\"Output path for graph JSON\")\n    parser.add_argument(\"--stats\", \"-s\", action=\"store_true\", help=\"Print graph stats\")\n    parser.add_argument(\"--query\", \"-q\", default=None, help=\"Run a causal query after indexing\")\n    parser.add_argument(\"--top-k\", \"-k\", type=int, default=10, help=\"Number of results to return\")\n    args = parser.parse_args()\n\n    codebase_path = Path(args.codebase).resolve()\n    if not codebase_path.exists():\n        print(f\"Error: path does not exist: {codebase_path}\")\n        sys.exit(1)\n\n    print(f\"[index] Indexing {codebase_path}...\")\n\n    analyzer = StaticAnalyzer(str(codebase_path))\n    analyzer.analyze()\n\n    print(f\"   Found {len(analyzer.definitions)} definitions, {len(analyzer.references)} references\")\n\n    graph = CausalGraph.from_analysis(analyzer.definitions, analyzer.references)\n    stats = graph.stats()\n\n    print(f\"   Built graph with {stats['total_nodes']} nodes, {stats['total_edges']} edges\")\n    if args.stats:\n        print()\n        print(\"Graph Stats:\")\n        print(f\"   Node kinds: {stats['node_kinds']}\")\n        print(f\"   Entry points: {stats['entry_points']}\")\n        print(f\"   Interfaces: {stats['interfaces']}\")\n        print(f\"   External nodes: {stats['external_nodes']}\")\n\n    # Save graph\n    output_path = args.output or str(codebase_path.parent / f\"{codebase_path.name}_causal_graph.json\")\n    graph.save(output_path)\n    print(f\"   [saved] Graph to {output_path}\")\n\n    # Run query if requested\n    if args.query:\n        print()\n        print(f\"[query] {args.query}\")\n        engine = QueryEngine(graph)\n        results = engine.query(args.query, top_k=args.top_k)\n        if not results:\n            print(\"   No results found.\")\n        for i, r in enumerate(results, 1):\n            print(f\"   {i}. [{r.kind}] {r.entity} (score={r.score:.2f})\")\n            print(f\"      File: {r.file_path}:{r.lineno}\")\n            if r.docstring:\n                preview = r.docstring[:80].strip()\n                print(f\"      Doc: {preview}...\")\n            print(f\"      Why: {r.reason}\")\n            print()\n\n\nif __name__ == \"__main__\":\n    main()\n"}],"isError":false,"timestamp":1774221325554}}
{"type":"message","id":"b3c4c756","parentId":"671a3b24","timestamp":"2026-03-22T23:15:29.252Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Let me check the current state - the project is scaffolded, static analysis and graph building work. What was described as \"not working\" was the query engine entity extraction (needs quotes for dotted paths). Let me test the query engine to see what's actually broken vs what works.\n\nLet me run a test query on the temporal-attention codebase to see the current state.","thinkingSignature":"2db40d2d9c5843cfa8f46b4e186dc9316127458eacbcbdd47bdf245a7940bc5c"},{"type":"toolCall","id":"call_function_hdgg6fy24dns_1","name":"exec","arguments":{"command":"cd C:/dev/code-cause && python scripts/index_codebase.py C:/dev/temporal-attention --stats 2>&1"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.7","usage":{"input":8119,"output":125,"cacheRead":12619,"cacheWrite":0,"totalTokens":20863,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774221325559}}
