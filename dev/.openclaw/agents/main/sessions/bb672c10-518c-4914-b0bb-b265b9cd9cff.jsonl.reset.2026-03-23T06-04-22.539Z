nt access token handy?"}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.7","usage":{"input":23074,"output":377,"cacheRead":13627,"cacheWrite":0,"totalTokens":37078,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"stop","timestamp":1774244944398}}
