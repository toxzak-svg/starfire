ame = \"John Doe\"\r\n> demo-script.ps1:219:    em[7mai[0ml = \"john@example.com\"[0m\r\n[7m[0m  demo-script.ps1:220:    message = \"Testing Schemock!\"[0m\r\n[7m[0m  demo-script.ps1:221:} | ConvertTo-Json[0m\r\n[7m[0m  demo-script.ps1:222:[0m\r\n[7m[0m  demo-script.ps1:223:Write-Host \"Request Body:\" -ForegroundColor Cyan[0m\r\n[7m[0m  demo-script.ps1:224:Write-Host $body -ForegroundColor White[0m","cwd":"C:\\Users\\Zwmar\\.openclaw\\workspace"},"isError":false,"timestamp":1774188187092}}
