ext: str) -> dict:\r\n    \"\"\"Extract features that indicate invariant vs variant content.\"\"\"\r\n    features = {\r\n        \"word_count\": len(text.split()),\r\n        \"line_count\": len(text.splitlines()),\r\n        \"has_date\": bool(re.search(r'\\d{4}-\\d{2}-\\d{2}', text)),\r\n        \"has_time\": bool(re.search(r'\\d{6}', text)),\r\n        \"has_file_path\": bool(re.search(r'[\\w/]+\\.\\w+', text)),\r\n        \"has_code\": bool(re.search(r'```|`.*`', text)),\r\n        \"has_bullet\": text.strip().startswith((\"-\", \"*\", \"\")),\r\n        \"caps_ratio\": sum(1 for c in text if c.isupper()) / max(len(text), 1),\r\n    }\r\n    return features\r\n\r\ndef classify_content(text: str, prev_text: str = \"\") -> str:\r\n    \"\"\"Classify content as INVARIANT (causal structure) or VARIANT (ephemeral).\"\"\"\r\n    features = extract_text_features(text)\r\n    prev_features = extract_text_features(prev_text) if prev_text else features\r\n    \r\n    # Invariant indicators: structure, patterns, architecture, goals\r\n    invariant_keywords = [\r\n        \"architecture\", \"hypothesis\", \"synthesis\", \"algorithm\",\r\n        \"phase\", \"goal\", \"insight\", \"theorem\", \"principle\",\r\n        \"compress\", \"causal\", \"invariant\", \"structure\", \"model\"\r\n    ]\r\n    \r\n    # Variant indicators: timestamps, specific values, ephemeral details\r\n    variant_keywords = [\r\n        \"timestamp\", \"created\", \"modified\", \"pulse_\", \r\n        \"duration\", \"seconds\", \"now\", \"current time\"\r\n    ]\r\n    \r\n    text_lower = text.lower()\r\n    invariant_score = sum(1 for kw in invariant_keywords if kw in text_lower)\r\n    variant_score = sum(1 for kw in variant_keywords if kw in text_lower)\r\n    \r\n    # Heuristic: structural elements are invariant\r\n    if features[\"has_code\"] and invariant_score > 0:\r\n        return \"INVARIANT\"\r\n    if features[\"has_bullet\"] and features[\"word_count\"] > 10:\r\n        return \"INVARIANT\"\r\n    if invariant_score > variant_score + 1:\r\n        return \"INVARIANT\"\r\n    if variant_score > invariant_score:\r\n        return \"VARIANT\"\r\n    \r\n    # Check for repeated patterns with prev\r\n    if prev_text and text[:50] == prev_text[:50]:\r\n        return \"INVARIANT\"\r\n    \r\n    return \"VARIANT\"\r\n\r\ndef predict_next_pulse(invariants: list, current: str) -> str:\r\n    \"\"\"Predict next pulse content based on invariant structure.\"\"\"\r\n    # Simple prediction: next pulse continues invariant patterns\r\n    invariant_text = \" \".join(invariants)\r\n    \r\n    if \"hypothesis\" in invariant_text.lower():\r\n        return \"continuation\"\r\n    if \"architecture\" in invariant_text.lower():\r\n        return \"refinement\"\r\n    if \"phase\" in invariant_text.lower():\r\n        return \"progression\"\r\n    \r\n    return \"unknown\"\r\n\r\ndef run_tic_experiment():\r\n    \"\"\"Run TIC experiment on pulse logs.\"\"\"\r\n    print(\"=\" * 60)\r\n    print(\"TIC Experiment: Temporal Invariance Compression\")\r\n    print(\"Hypothesis: Causal structure IS invariant structure\")\r\n    print(\"=\" * 60)\r\n    \r\n    # Collect pulse logs\r\n    log_files = sorted(LOGS_DIR.glob(\"pulse_*.md\"), key=os.path.getmtime, reverse=True)\r\n    \r\n    if len(log_files) < MIN_LOGS:\r\n        print(f\"ERROR: Need at least {MIN_LOGS} logs, found {len(log_files)}\")\r\n        return\r\n    \r\n    # Use last 20 logs\r\n    logs_to_analyze = log_files[:20]\r\n    print(f\"\\nAnalyzing {len(logs_to_analyze)} pulse logs...\")\r\n    \r\n    all_classifications = []\r\n    invariant_content = []\r\n    prev_text = \"\"\r\n    \r\n    for i, log_file in enumerate(reversed(logs_to_analyze)):\r\n        content = log_file.read_text()\r\n        classification = classify_content(content, prev_text)\r\n        \r\n        all_classifications.append({\r\n            \"log\": log_file.name,\r\n            \"classification\": classification\r\n        })\r\n        \r\n        if classification == \"INVARIANT\":\r\n            invariant_content.append(content[:200])\r\n        \r\n        prev_text =\n\n## For Next Instantiation\n- Proposed mutations waiting: 1\n- Completed at: 2026-03-24 04:54:41","cwd":"C:\\Users\\Zwmar\\.openclaw\\workspace"},"isError":false,"timestamp":1774342555792}}
