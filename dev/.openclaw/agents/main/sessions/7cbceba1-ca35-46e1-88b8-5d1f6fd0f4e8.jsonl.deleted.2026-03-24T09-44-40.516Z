p|decay|pulse|session|synthesis|architecture)\\b', \r\n                          text, re.IGNORECASE)\r\n        concepts.extend([t.lower() for t in terms])\r\n        \r\n        return concepts\r\n    \r\n    def learn_from_pulses(self, pulse_files: List[Path]) -> Dict[str, float]:\r\n        \"\"\"Learn invariant/variant patterns from pulse history.\"\"\"\r\n        pulse_concepts = []\r\n        \r\n        for pf in sorted(pulse_files):\r\n            text = pf.read_text()\r\n            concepts = self.extract_concepts(text)\r\n            pulse_concepts.append(set(concepts))\r\n            self.concept_frequency.update(concepts)\r\n        \r\n        # Invariant = appears in >= MIN_PULSES_FOR_INVARIANT pulses\r\n        for concept, freq in self.concept_frequency.items():\r\n            if freq >= MIN_PULSES_FOR_INVARIANT:\r\n                self.invariant_concepts.add(concept)\r\n            else:\r\n                self.variant_concepts.add(concept)\r\n        \r\n        return {\r\n            'total_concepts': len(self.concept_frequency),\r\n            'invariants': len(self.invariant_concepts),\r\n            'variants': len(self.variant_concepts),\r\n            'invariant_ratio': len(self.invariant_concepts) / max(1, len(self.concept_frequency))\r\n        }\r\n    \r\n    def classify(self, text: str) -> Tuple[set, set]:\r\n        \"\"\"Classify concepts in text as invariant or variant.\"\"\"\r\n        concepts = self.extract_concepts(text)\r\n        invariants_found = set()\r\n        variants_found = set()\r\n        \r\n        for c in concepts:\r\n            if c.lower() in [i.lower() for i in self.invariant_concepts]:\r\n                invariants_found.add(c)\r\n            else:\r\n                variants_found.add(c)\r\n        \r\n        return invariants_found, variants_found\r\n    \r\n    def predict_next_pulse(self, recent_pulses: List[str]) -> Dict[str, float]:\r\n        \"\"\"Predict likely invariants in next pulse based on recent history.\"\"\"\r\n        if not self.invariant_concepts:\r\n            return {'prediction': 'unknown', 'confidence': 0.0}\r\n        \r\n        # Higher confidence if recent pulses have high invariant overlap\r\n        recent_invariants = []\r\n        for pulse in recent_pulses[-5:]:\r\n            inv, _ =\r\n\r\n## For Next Instantiation\r\n- Proposed mutations waiting: 1\r\n- Completed at: 2026-03-23 17:01:26","cwd":"C:\\Users\\Zwmar\\.openclaw\\workspace"},"isError":false,"timestamp":1774300272200}}
