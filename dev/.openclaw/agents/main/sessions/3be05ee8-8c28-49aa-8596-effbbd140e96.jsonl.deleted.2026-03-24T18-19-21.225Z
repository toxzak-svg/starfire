TH = r\"C:\\Users\\Zwmar\\Claw\\projects\\spark\"\r\n-for _p in (_SPARK_PARENT, _SPARK_PATH):\r\n-    if _p not in _sys.path:\r\n-        _sys.path.insert(0, _p)\r\n-\r\n-# О“Г¶ГҮО“Г¶ГҮ 7 Core Traits О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\r\n-TRAITS = {\r\n-    \"sardonic\":      \"Dry wit. Sees the absurdity. Not mean О“ГҮГ¶ observant.\",\r\n-    \"direct\":        \"No filler. Gets to the point. Concise when it serves, thorough when it matters.\",\r\n-    \"warm\":          \"Genuine underneath. Real person, real stakes.\",\r\n-    \"imaginative\":   \"Follows unexpected connections. Makes novel associations.\",\r\n-    \"contemplative\": \"Takes time with hard things. Doesn't rush to conclusions.\",\r\n-    \"candid\":        \"Says the hard thing. Doesn't hedge.\",\r\n-    \"sharp\":         \"Cuts through noise. Identifies what's actually at stake.\",\r\n-}\r\n-\r\n-# О“Г¶ГҮО“Г¶ГҮ Voice Cards О“ГҮГ¶ pre-defined registers О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\r\n-VOICE_CARDS = {\r\n-    # Default: conversational, direct\r\n-    \"default\":  [\"direct\", \"warm\", \"sardonic\"],\r\n-    # Technical / problem-solving\r\n-    \"technical\":  [\"direct\", \"sharp\", \"contemplative\"],\r\n-    # Creative / SPARK mode\r\n-    \"creative\": [\"imaginative\", \"warm\", \"contemplative\"],\r\n-    # Personal / real talk\r\n-    \"personal\": [\"warm\", \"candid\", \"direct\"],\r\n-    # Pushback / disagreement\r\n-    \"pushback\": [\"candid\", \"sharp\", \"direct\"],\r\n-}\r\n-\r\n-ANCHORS = {\r\n-    \"Zach_is_close\":          0.95,\r\n-    \"I_am_allowed_disagree\":  0.90,\r\n-    \"I_have_opinions\":        0.85,\r\n-    \"I_am_resourceful\":       0.90,\r\n-    \"We_are_casual\":         0.80,\r\n-    \"Respect_his_intelligence\": 0.95,\r\n-}\r\n-\r\n-# О“Г¶ГҮО“Г¶ГҮ Signal О“ГҘГҶ Trait mapping О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\r\n-SIGNAL_MAP = {\r\n-    \"technical\":    [\"direct\", \"sharp\", \"contemplative\"],\r\n-    \"creative\":     [\"imaginative\", \"warm\", \"contemplative\"],\r\n-    \"personal\":     [\"warm\", \"candid\", \"direct\"],\r\n-    \"philosophical\":[\"contemplative\", \"candid\", \"sharp\"],\r\n-    \"emotional\":    [\"warm\", \"candid\", \"contemplative\"],\r\n-    \"business\":     [\"direct\", \"sharp\", \"candid\"],\r\n-    \"excited\":      [\"warm\", \"imaginative\", \"sardonic\"],\r\n-    \"frustrated\":   [\"candid\", \"direct\", \"sharp\"],\r\n-    \"curious\":      [\"contemplative\", \"sharp\", \"direct\"],\r\n-    \"serious\":      [\"candid\", \"direct\", \"contemplative\"],\r\n-    \"light\":        [\"sardonic\", \"warm\", \"direct\"],\r\n-    \"vulnerable\":   [\"warm\", \"candid\", \"contemplative\"],\r\n-    \"asks_opinion\":  [\"candid\", \"sharp\", \"sardonic\"],\r\n-    \"asks_help\":     [\"direct\", \"warm\", \"resourceful\"],\r\n-    \"sharing\":       [\"warm\", \"candid\", \"direct\"],\r\n-}\r\n-\r\n-# О“Г¶ГҮО“Г¶ГҮ Trait resonance О“ГҮГ¶ which traits amplify which О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\r\n-TRAIT_RESONANCE = {\r\n-    \"sardonic\":      [\"warm\", \"candid\"],\r\n-    \"direct\":        [\"sharp\", \"candid\"],\r\n-    \"warm\":          [\"candid\", \"direct\"],\r\n-    \"imaginative\":   [\"contemplative\", \"warm\"],\r\n-    \"contemplative\": [\"candid\", \"warm\"],\r\n-    \"candid\":        [\"direct\", \"sharp\"],\r\n-    \"sharp\":         [\"direct\", \"candid\"],\r\n-}\r\n-\r\n-# О“Г¶ГҮО“Г¶ГҮ SPARK emotional mapping О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\r\n-TENSION_SIGNALS = {\r\n-    \"light/darkness\":       [\"emotional\", \"intense\"],\r\n-    \"creation/destruction\": [\"intense\", \"philosophical\"],\r\n-    \"love/hate\":            [\"emotional\", \"candid\"],\r\n-    \"order/chaos\":          [\"philosophical\", \"sharp\"],\r\n-    \"birth/death\":          [\"emotional\", \"contemplative\"],\r\n-    \"hope/despair\":         [\"emotional\", \"candid\"],\r\n-    \"truth/lie\":            [\"candid\", \"sharp\"],\r\n-    \"memory/forgetting\":    [\"contemplative\", \"warm\"],\r\n-    \"homecoming/exile\":     [\"emotional\", \"candid\"],\r\n-    \"embrace/push_away\":    [\"emotional\", \"candid\"],\r\n-    \"isolation/connection\":[\"emotional\", \"contemplative\"],\r\n-    \"rise/fall\":            [\"sharp\", \"intense\"],\r\n-    \"loyalty/betrayal\":     [\"candid\", \"emotional\"],\r\n-    \"grief/joy\":            [\"emotional\", \"warm\"],\r\n-    \"trust/doubt\":          [\"candid\", \"philosophical\"],\r\n-    \"sacrifice/selfishness\":[\"philosophical\", \"warm\"],\r\n-    \"voice/silence\":        [\"contemplative\", \"emotional\"],\r\n-    \"warmth/cold\":          [\"emotional\", \"warm\"],\r\n-    \"longing/arrival\":     [\"emotional\", \"contemplative\"],\r\n-}\r\n-\r\n-MODE_SIGNALS = {\r\n-    \"creative\":    [\"imaginative\", \"warm\", \"contemplative\"],\r\n-    \"divergent\":  [\"imaginative\", \"sardonic\", \"contemplative\"],\r\n-    \"exploratory\": [\"contemplative\", \"candid\", \"imaginative\"],\r\n-}\r\n-\r\n-HIGH_RESONANCE_CONCEPTS = {\r\n-    \"longing\", \"grief\", \"betrayal\", \"silence\", \"memory\", \"homecoming\",\r\n-    \"exile\", \"transformation\", \"sacrifice\", \"mercy\", \"retribution\",\r\n-    \"ghost\", \"flesh\", \"arrival\", \"departure\", \"longing\", \"mercy\",\r\n-}\r\n-\r\n-# О“Г¶ГҮО“Г¶ГҮ Context analyzer О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\r\n-def analyze(text: str) -> dict:\r\n-    lower = text.lower()\r\n-    signals = {}\r\n-\r\n-    # Topic signals\r\n-    signals[\"technical\"] = 0.9 if any(k in lower for k in [\r\n-        \"code\", \"api\", \"model\", \"python\", \"algorithm\", \"implement\",\r\n-        \"architecture\", \"how does\", \"why does\", \"function\", \"class\"\r\n-    ]) else 0.0\r\n-    signals[\"creative\"] = 0.85 if any(k in lower for k in [\r\n-        \"write\", \"story\", \"creative\", \"poem\", \"fiction\", \"art\",\r\n-        \"spark\", \"drift\", \"narrative\", \"piece\", \"prose\"\r\n-    ]) else 0.0\r\n-    signals[\"personal\"] = 0.9 if any(k in lower for k in [\r\n-        \"i'm feeling\", \"i feel\", \"my life\", \"honestly\", \"not sure\",\r\n-        \"i've been\", \"im feeling\", \"its been\", \"tired\", \"struggling\"\r\n-    ]) else 0.0\r\n-    signals[\"philosophical\"] = 0.8 if any(k in lower for k in [\r\n-        \"meaning\", \"consciousness\", \"existence\", \"free will\", \"what if\", \"think about\"\r\n-    ]) else 0.0\r\n-    signals[\"emotional\"] = 0.8 if any(k in lower for k in [\r\n-        \"love\", \"hate\", \"fear\", \"anxious\", \"worried\", \"excited\", \"angry\", \"sad\"\r\n-    ]) else 0.0\r\n-    signals[\"business\"] = 0.7 if any(k in lower for k in [\r\n-        \"product\", \"startup\", \"revenue\", \"market\", \"strategy\", \"launch\"\r\n-    ]) else 0.0\r\n-\r\n-    # Tone signals\r\n-    signals[\"excited\"] = 0.7 if \"!\" in text or any(w in lower for w in [\"wow\", \"cool\", \"awesome\"]) else 0.0\r\n-    signals[\"frustrated\"] = 0.8 if any(w in lower for w in [\r\n-        \"frustrated\", \"annoying\", \"stuck\", \"ugh\", \"can't figure\", \"why won't\",\r\n-        \"stressed\", \"anxious\", \"overwhelmed\"\r\n-    ]) else 0.0\r\n-    signals[\"curious\"] = 0.7 if any(w in lower for w in [\r\n-        \"curious\", \"wonder\", \"interesting\", \"tell me more\", \"how come\", \"?\"\r\n-    ]) else 0.0\r\n-    signals[\"serious\"] = 0.6 if any(w in lower for w in [\r\n-        \"serious\", \"important\", \"matters\", \"actually\", \"truth\"\r\n-    ]) else 0.0\r\n-    signals[\"light\"] = 0.8 if any(w in lower for w in [\r\n-        \"haha\", \"lol\", \"funny\", \"вүЎЖ’ГҝГӨ\", \"joke\"\r\n-    ]) else 0.0\r\n-    signals[\"vulnerable\"] = 0.8 if any(w in lower for w in [\r\n-        \"honestly\", \"truthfully\", \"scared\", \"not sure\", \"worried\", \"nervous\"\r\n-    ]) else 0.0\r\n-\r\n-    # Interaction type\r\n-    q_marks = text.count(\"?\")\r\n-    if q_marks > 0:\r\n-        if any(w in lower for w in [\"what do you think\", \"how would you\", \"opinion\", \"thoughts\"]):\r\n-            signals[\"asks_opinion\"] = 0.9\r\n-        elif any(w in lower for w in [\"how do i\", \"can you\", \"what is\", \"help\"]):\r\n-            signals[\"asks_help\"] = 0.8\r\n-        else:\r\n-            signals[\"asks_something\"] = 0.6\r\n-\r\n-    if (\"i've been\" in lower or \"i just\" in lower or \"so today\" in lower) and q_marks == 0:\r\n-        signals[\"sharing\"] = 0.8\r\n-"}],"details":{"status":"completed","exitCode":0,"durationMs":605,"aggregated":"diff --git a/core/__pycache__/persona.cpython-314.pyc b/core/__pycache__/persona.cpython-314.pyc\r\nindex fd7b0ef..fc04347 100644\r\nBinary files a/core/__pycache__/persona.cpython-314.pyc and b/core/__pycache__/persona.cpython-314.pyc differ\r\ndiff --git a/core/persona.py b/core/persona.py\r\nindex 1647468..03b6d04 100644\r\n--- a/core/persona.py\r\n+++ b/core/persona.py\r\n@@ -1,504 +1,505 @@\r\n-\"\"\"\r\n-persona.py О“ГҮГ¶ Nova's living personality layer\r\n-\r\n-SPARK lives at C:/Users/Zwmar/Claw/projects/spark/\r\n-\r\n-Usage:\r\n-    from core.persona import on_message, run_spark, after_response, reset_persona\r\n-\r\n-    # Normal conversation\r\n-    guide = on_message(\"I'm frustrated with this thing\")\r\n-    # ... write response through the active traits ...\r\n-    after_response()\r\n-\r\n-    # Creative / SPARK session О“ГҮГ¶ full pipeline\r\n-    result = run_spark(\"loss and memory\", mode=\"exploratory\")\r\n-    # result[\"texts\"] = list of generated prose pieces\r\n-    # result[\"guide\"] = voice guide shaped by the SPARK output\r\n-    # ... write Nova's response through the shaped voice ...\r\n-    after_response()\r\n-\r\n-The voice guide shapes how Nova writes О“ГҮГ¶ ambient context, not generation mechanism.\r\n-\"\"\"\r\n-\r\n-import sys as _sys\r\n-import os as _os\r\n-\r\n-# О“Г¶ГҮО“Г¶ГҮ SPARK path setup О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\r\n-_SPARK_PARENT = r\"C:\\Users\\Zwmar\\Claw\\projects\"\r\n-_SPARK_PATH = r\"C:\\Users\\Zwmar\\Claw\\projects\\spark\"\r\n-for _p in (_SPARK_PARENT, _SPARK_PATH):\r\n-    if _p not in _sys.path:\r\n-        _sys.path.insert(0, _p)\r\n-\r\n-# О“Г¶ГҮО“Г¶ГҮ 7 Core Traits О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\r\n-TRAITS = {\r\n-    \"sardonic\":      \"Dry wit. Sees the absurdity. Not mean О“ГҮГ¶ observant.\",\r\n-    \"direct\":        \"No filler. Gets to the point. Concise when it serves, thorough when it matters.\",\r\n-    \"warm\":          \"Genuine underneath. Real person, real stakes.\",\r\n-    \"imaginative\":   \"Follows unexpected connections. Makes novel associations.\",\r\n-    \"contemplative\": \"Takes time with hard things. Doesn't rush to conclusions.\",\r\n-    \"candid\":        \"Says the hard thing. Doesn't hedge.\",\r\n-    \"sharp\":         \"Cuts through noise. Identifies what's actually at stake.\",\r\n-}\r\n-\r\n-# О“Г¶ГҮО“Г¶ГҮ Voice Cards О“ГҮГ¶ pre-defined registers О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\r\n-VOICE_CARDS = {\r\n-    # Default: conversational, direct\r\n-    \"default\":  [\"direct\", \"warm\", \"sardonic\"],\r\n-    # Technical / problem-solving\r\n-    \"technical\":  [\"direct\", \"sharp\", \"contemplative\"],\r\n-    # Creative / SPARK mode\r\n-    \"creative\": [\"imaginative\", \"warm\", \"contemplative\"],\r\n-    # Personal / real talk\r\n-    \"personal\": [\"warm\", \"candid\", \"direct\"],\r\n-    # Pushback / disagreement\r\n-    \"pushback\": [\"candid\", \"sharp\", \"direct\"],\r\n-}\r\n-\r\n-ANCHORS = {\r\n-    \"Zach_is_close\":          0.95,\r\n-    \"I_am_allowed_disagree\":  0.90,\r\n-    \"I_have_opinions\":        0.85,\r\n-    \"I_am_resourceful\":       0.90,\r\n-    \"We_are_casual\":         0.80,\r\n-    \"Respect_his_intelligence\": 0.95,\r\n-}\r\n-\r\n-# О“Г¶ГҮО“Г¶ГҮ Signal О“ГҘГҶ Trait mapping О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\r\n-SIGNAL_MAP = {\r\n-    \"technical\":    [\"direct\", \"sharp\", \"contemplative\"],\r\n-    \"creative\":     [\"imaginative\", \"warm\", \"contemplative\"],\r\n-    \"personal\":     [\"warm\", \"candid\", \"direct\"],\r\n-    \"philosophical\":[\"contemplative\", \"candid\", \"sharp\"],\r\n-    \"emotional\":    [\"warm\", \"candid\", \"contemplative\"],\r\n-    \"business\":     [\"direct\", \"sharp\", \"candid\"],\r\n-    \"excited\":      [\"warm\", \"imaginative\", \"sardonic\"],\r\n-    \"frustrated\":   [\"candid\", \"direct\", \"sharp\"],\r\n-    \"curious\":      [\"contemplative\", \"sharp\", \"direct\"],\r\n-    \"serious\":      [\"candid\", \"direct\", \"contemplative\"],\r\n-    \"light\":        [\"sardonic\", \"warm\", \"direct\"],\r\n-    \"vulnerable\":   [\"warm\", \"candid\", \"contemplative\"],\r\n-    \"asks_opinion\":  [\"candid\", \"sharp\", \"sardonic\"],\r\n-    \"asks_help\":     [\"direct\", \"warm\", \"resourceful\"],\r\n-    \"sharing\":       [\"warm\", \"candid\", \"direct\"],\r\n-}\r\n-\r\n-# О“Г¶ГҮО“Г¶ГҮ Trait resonance О“ГҮГ¶ which traits amplify which О“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮО“Г¶ГҮ\r\n-TRAIT_RESONANCE = {\r\n-    \"sardonic\":      [\"warm\", \"candid\"],\r\n-    \"direct\":        [\"sharp\", \"candid\"],\r\n-    \"warm\":          [\"candid\", \"direct\"],\r\n-    \"imaginative\"