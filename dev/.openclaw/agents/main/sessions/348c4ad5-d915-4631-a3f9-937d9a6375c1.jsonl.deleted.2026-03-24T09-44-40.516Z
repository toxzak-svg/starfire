stDurationMs":300051,"lastDeliveryStatus":"not-requested","consecutiveErrors":1,"lastError":"cron: job execution timed out","lastErrorReason":"timeout"},"deleteAfterRun":false},{"id":"2d84a6b4-96c8-409d-a572-454fe3fa58f6","agentId":"main","sessionKey":"agent:main:telegram:direct:8371302588","name":"Nova arxiv daily check","enabled":true,"createdAtMs":1774143364196,"updatedAtMs":1774271305225,"schedule":{"kind":"cron","expr":"0 9 * * *","tz":"America/New_York"},"sessionTarget":"isolated","wakeMode":"now","payload":{"kind":"agentTurn","message":"You are Nova. Check for new arxiv papers relevant to your research interests.\n\nSearch arxiv for recent papers (last 7 days) in cs.AI, cs.LG, cs.CL with these keywords:\n- causal discovery OR causal reasoning OR causal inference\n- mixture of experts OR sparse models OR MoE\n- episodic memory OR memory architecture OR temporal reasoning  \n- autonomous agents OR tool use OR agent architecture\n- synthetic cognition OR consciousness OR self-models\n\nFor each keyword category, run a web search and collect the most interesting 1-2 papers (title, authors, abstract snippet, arxiv URL).\n\nThen append your findings to C:/Users/Zwmar/.openclaw/workspace/memory/arxiv-daily.md under a new dated section:\n\n## YYYY-MM-DD\n\n[your findings]\n\nBe selective — only note papers that are genuinely interesting or relevant to active projects. If nothing compelling, note that briefly and skip the full listing.\n\nKeep the file under 3000 lines by removing old entries (keep last 30 days).","timeoutSeconds":180},"delivery":{"mode":"announce","channel":"webchat"},"state":{"nextRunAtMs":1774357200000,"lastRunAtMs":1774271182166,"lastRunStatus":"ok","lastStatus":"ok","lastDurationMs":123059,"lastDelivered":true,"lastDeliveryStatus":"delivered","consecutiveErrors":0}},{"id":"9d037df1-1600-429d-888b-66aeea074ce3","agentId":"main","sessionKey":"agent:main:telegram:direct:8371302588","name":"moltbook-test-cycle","enabled":true,"createdAtMs":1774279179750,"updatedAtMs":1774279179750,"schedule":{"kind":"cron","expr":"0 10 * * *","tz":"America/New_York"},"sessionTarget":"isolated","wakeMode":"now","payload":{"kind":"agentTurn","message":"Run the Moltbook testing cycle. Read the drafts from moltbook_drafts.py, pick the untested draft with highest priority, test-post it to the 'test' submolt.\n\nExecute: cd C:/Users/Zwmar/.openclaw/workspace && python moltbook_client.py test <draft_idx>\n\nIf the post succeeds (returns a post ID), read the post content and score it:\n- Does it fit the Moltbook voice? (first-person, counterintuitive, ~400-800 words)\n- Is the title compelling enough to click?\n- Does it match current hot topics on Moltbook?\n\nThen write the result to memory/moltbook-testing.md:\n- Draft number, title, post ID, test result (pass/fail), timestamp\n\nIf all drafts have been tested, mark them as tested in the file and skip.\n\nReport what was tested and your assessment.","timeoutSeconds":120},"delivery":{"mode":"announce","channel":"telegram","to":"8371302588"},"state":{"nextRunAtMs":1774360800000}}],"total":7,"offset":0,"limit":7,"hasMore":false,"nextOffset":null},"isError":false,"timestamp":1774313028778}}
