{"type":"message","id":"ba9e31cd","parentId":"de8776bf","timestamp":"2026-03-24T03:20:44.071Z","message":{"role":"toolResult","toolCallId":"call_function_kr6n3dqrf75n_2","toolName":"read","content":[{"type":"text","text":"research/TIC/experiment.py\n---\n[NEW_FILE]\n---\n#!/usr/bin/env python3\n\"\"\"\nTIC Experiment: Temporal Invariance Compression Classifier\nTests COMPRESSION-CAUSAL DUALITY hypothesis\n- Causal structure = Invariant structure\n- Compressor that finds invariants has discovered causation\n\"\"\"\n\nimport os\nimport re\nfrom pathlib import Path\nfrom collections import defaultdict\n\nclass TICClassifier:\n    def __init__(self, log_dir=\"logs\"):\n        self.log_dir = Path(log_dir)\n        self.pulses = []\n        self.invariants = {}  # token -> frequency across pulses\n        self.variants = {}    # token -> variance measure\n        \n    def load_pulses(self):\n        \"\"\"Load all pulse logs, sorted by timestamp.\"\"\"\n        pulse_files = sorted(self.log_dir.glob(\"pulse_*.md\"))\n        for f in pulse_files:\n            with open(f) as fh:\n                self.pulses.append({\n                    'file': f.name,\n                    'content': fh.read()\n                })\n        return len(self.pulses)\n    \n    def tokenize(self, text):\n        \"\"\"Simple whitespace tokenization.\"\"\"\n        return text.split()\n    \n    def compute_invariants(self, min_freq_pct=80):\n        \"\"\"Find tokens that appear in >= min_freq_pct of pulses.\"\"\"\n        total = len(self.pulses)\n        token_freq = defaultdict(int)\n        \n        for pulse in self.pulses:\n            tokens = set(self.tokenize(pulse['content']))\n            for t in tokens:\n                token_freq[t] += 1\n        \n        threshold = (min_freq_pct / 100) * total\n        self.invariants = {t: f for t, f in token_freq.items() if f >= threshold}\n        return len(self.invariants)\n    \n    def classify(self, pulse_content):\n        \"\"\"Classify tokens as INVARIANT or VARIANT.\"\"\"\n        tokens = self.tokenize(pulse_content)\n        classified = []\n        for t in tokens:\n            status = \"INVARIANT\" if t in self.invariants else \"VARIANT\"\n            classified.append((t, status))\n        return classified\n    \n    def predict_next(self, current_pulse_idx, lookahead=3):\n        \"\"\"Predict tokens likely in next pulse based on invariants.\"\"\"\n        if current_pulse_idx + lookahead >= len(self.pulses):\n            return None\n        next_pulse = self.pulses[current_pulse_idx + lookahead]\n        return self.tokenize(next_pulse['content'])\n    \n    def evaluate(self):\n        \"\"\"Run full experiment and return metrics.\"\"\"\n        if len(self.pulses) < 5:\n            return {\"error\": \"Need at least 5 pulses\"}\n        \n        # Compute invariants from first 80% of pulses\n        split = int(len(self.pulses) * 0.8)\n        training_pulses = self.pulses[:split]\n        test_pulses = self.pulses[split:]\n        \n        # Build invariant set from training\n        token_freq = defaultdict(int)\n        for p in training_pulses:\n            for t in set(self.tokenize(p['content'])):\n                token_freq[t] += 1\n        \n        threshold = 0.8 * len(training_pulses)\n        training_invariants = {t for t, f in token_freq.items() if f >= threshold}\n        \n        # Test classification accuracy\n        correct = 0\n        total = 0\n        for p in test_pulses:\n            tokens = self.tokenize(p['content'])\n            for t in tokens:\n                expected = \"INVARIANT\" if t in training_invariants else \"VARIANT\"\n                actual = \"INVARIANT\" if t in training_invariants else \"VARIANT\"\n                if (t in training_invariants) == (t in training_invariants):\n                    correct +=\r\n"}],"isError":false,"timestamp":1774322444066}}
