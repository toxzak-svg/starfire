\n        return len(self.invariants)\\n    \\n    def classify(self, pulse_content):\\n        \\\"\\\"\\\"Classify tokens as INVARIANT or VARIANT.\\\"\\\"\\\"\\n        tokens = self.tokenize(pulse_content)\\n        classified = []\\n        for t in tokens:\\n            status = \\\"INVARIANT\\\" if t in self.invariants else \\\"VARIANT\\\"\\n            classified.append((t, status))\\n        return classified\\n    \\n    def predict_next(self, current_pulse_idx, lookahead=3):\\n        \\\"\\\"\\\"Predict tokens likely in next pulse based on invariants.\\\"\\\"\\\"\\n        if current_pulse_idx + lookahead >= len(self.pulses):\\n            return None\\n        next_pulse = self.pulses[current_pulse_idx + lookahead]\\n        return self.tokenize(next_pulse['content'])\\n    \\n    def evaluate(self):\\n        \\\"\\\"\\\"Run full experiment and return metrics.\\\"\\\"\\\"\\n        if len(self.pulses) < 5:\\n            return {\\\"error\\\": \\\"Need at least 5 pulses\\\"}\\n        \\n        # Compute invariants from first 80% of pulses\\n        split = int(len(self.pulses) * 0.8)\\n        training_pulses = self.pulses[:split]\\n        test_pulses = self.pulses[split:]\\n        \\n        # Build invariant set from training\\n        token_freq = defaultdict(int)\\n        for p in training_pulses:\\n            for t in set(self.tokenize(p['content'])):\\n                token_freq[t] += 1\\n        \\n        threshold = 0.8 * len(training_pulses)\\n        training_invariants = {t for t, f in token_freq.items() if f >= threshold}\\n        \\n        # Test classification accuracy\\n        correct = 0\\n        total = 0\\n        for p in test_pulses:\\n            tokens = self.tokenize(p['content'])\\n            for t in tokens:\\n                expected = \\\"INVARIANT\\\" if t in training_invariants else \\\"VARIANT\\\"\\n                actual = \\\"INVARIANT\\\" if t in training_invariants else \\\"VARIANT\\\"\\n                if (t in training_invariants) == (t in training_invariants):\\n                    correct +=\",\r\n  \"file\": \"\"\r\n}"}],"isError":false,"timestamp":1774322415973}}
