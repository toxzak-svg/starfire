s/variants to extract, then build the classifier.\r\n\r\n### ACTION\r\nCreate the TIC classifier implementation that analyzes pulse logs for invariant/variant patterns and tests prediction accuracy against the success criteria (>70% classification, >60% prediction).\r\n\r\n### MUTATION\r\n```\r\nold_text: (new file)\r\nnew_text: #!/usr/bin/env python3\r\n\"\"\"\r\nTemporal Invariance Compression (TIC) Classifier\r\nPhase 1-2 Unified Experiment\r\n\r\nHypothesis: Causal structure IS invariant structure.\r\nCompressor that finds invariants has discovered causation.\r\n\r\nSuccess Criteria:\r\n- >70% invariant/variant classification accuracy\r\n- >60% next-pulse content prediction accuracy\r\n\"\"\"\r\n\r\nimport os\r\nimport re\r\nfrom pathlib import Path\r\nfrom collections import Counter\r\nfrom typing import List, Dict, Tuple, Set\r\n\r\n# Configuration\r\nLOG_DIR = Path(\"logs\")\r\nMIN_PULSES = 5  # Minimum pulses needed for prediction\r\nINVARIANT_THRESHOLD = 0.7  # Element appears in 70%+ of pulses = invariant\r\n\r\n# Track element types\r\nELEMENT_PATTERNS = {\r\n    'goal': r'## (Active|Completed|Pending)',\r\n    'action': r'### (OBSERVATION|ACTION|MUTATION)',\r\n    'file_ref': r'`([^`]+\\.(md|ps1|txt))`',\r\n    'heading': r'^#{1,3}\\s+\\w+',\r\n    'timestamp': r'\\d{4}-\\d{2}-\\d{2}',\r\n    'checkbox': r'\\[ \\]|\\[x\\]',\r\n}\r\n\r\ndef extract_elements(pulse_content: str) -> Dict[str, Set[str]]:\r\n    \"\"\"Extract different element types from pulse content.\"\"\"\r\n    elements = {}\r\n    \r\n    # Goals section - invariant tracking\r\n    goal_match = re.search(r'## Active\\s*\\n(.*?)(?=##|$)', pulse_content, re.DOTALL)\r\n    if goal_match:\r\n        goals = set(re.findall(r'- \\[.*?\\]\\s+(.+)', goal_match.group(1)))\r\n        elements['goals'] = goals\r\n    \r\n    # File references - what files are being touched\r\n    elements['files'] = set(re.findall(ELEMENT_PATTERNS['file_ref'], pulse_content))\r\n    \r\n    # Actions/mutations - behavioral patterns\r\n    action_matches = re.findall(r'### (OBSERVATION|ACTION|MUTATION)', pulse_content)\r\n    elements['action_types'] = set(action_matches)\r\n    \r\n    # Headings structure - document organization\r\n    headings = re.findall(r'^#{1,3}\\s+[^\\n]+', pulse_content, re.MULTILINE)\r\n    elements['structure'] = set(headings)\r\n    \r\n    # Key phrases - common language patterns\r\n    phrases = re.findall(r'\\b(Phase \\d|\\\\['completed|pending|active|insight]\\\\)\\b', pulse_content)\r\n    elements['phrases'] = set(phrases)\r\n    \r\n    return elements\r\n\r\ndef identify_invariants(pulse_elements: List[Dict]) -> Dict[str, Set]:\r\n    \"\"\"Identify elements that remain constant across pulses.\"\"\"\r\n    if not pulse_elements:\r\n        return {}\r\n    \r\n    invariants = {}\r\n    element_types = pulse_elements[0].keys()\r\n    \r\n    for element_type in element_types:\r\n        # Count occurrences of each element across all pulses\r\n        all_elements = []\r\n        for pulse in pulse_elements:\r\n            all_elements.extend(pulse.get(element_type, []))\r\n        \r\n        if all_elements:\r\n            element_counts = Counter(all_elements)\r\n            total_pulses = len(pulse_elements)\r\n            \r\n            # Invariant = appears in 70%+ of pulses\r\n            invariant_threshold = int(total_pulses * INVARIANT_THRESHOLD)\r\n            invariants[element_type] = {\r\n                elem for elem, count in element_counts.items() \r\n                if count >= invariant_threshold\r\n            }\r\n    \r\n    return invariants\r\n\r\ndef identify_variants(pulse_elements: List[Dict], invariants: Dict[str, Set]) -> Dict[str, Set]:\r\n    \"\"\"Identify elements that change across pulses.\"\"\"\r\n    variants = {}\r\n    element_types = pulse_elements[0].keys()\r\n    \r\n    for element_type in element_types:\r\n        all_in_pulse = set()\r\n        for pulse in pulse_elements:\r\n            all_in_pul