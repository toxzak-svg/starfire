     random.shuffle(pulse)\n        pulses.append(pulse)\n    \n    return pulses\n\n# ============================================================================\n# COMPRESSION METHODS\n# ============================================================================\n\ndef compute_frequencies(pulses):\n    \"\"\"Standard frequency-based compression (like current Breakaway).\"\"\"\n    all_tokens = [t for pulse in pulses for t in pulse]\n    freq = Counter(all_tokens)\n    return freq\n\ndef compute_cfi(pulses, window=5):\n    \"\"\"\n    Compute Causal Fidelity Index for each token.\n    \n    CFI = probability token appears in context of its own causal cluster\n    vs random appearance in corpus.\n    \"\"\"\n    all_tokens = [t for pulse in pulses for t in pulse]\n    total_count = len(all_tokens)\n    corpus_freq = Counter(all_tokens)\n    \n    cfi_scores = {}\n    for token in corpus_freq:\n        # Count appearances in causal-adjacent context\n        causal_count = 0\n        for i, pulse in enumerate(pulses):\n            if token in pulse:\n                # Check if previous pulse had related causal tokens\n                for j in range(max(0,\r\n"}],"isError":false,"timestamp":1774361337645}}
