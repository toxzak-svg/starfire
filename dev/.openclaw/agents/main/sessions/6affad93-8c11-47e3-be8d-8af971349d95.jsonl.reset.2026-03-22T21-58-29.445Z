{"type":"message","id":"f8ebfa7b","parentId":"22f77644","timestamp":"2026-03-22T20:38:22.042Z","message":{"role":"toolResult","toolCallId":"call_function_7heilvioea04_1","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\n\"\"\"\nindex_codebase.py\n=================\nCLI tool to index a codebase and save its causal graph.\n\nUsage:\n    python index_codebase.py /path/to/codebase [--output graph.json]\n\"\"\"\n\nimport argparse\nimport json\nimport sys\nfrom pathlib import Path\n\n# Add src to path for local development\nsys.path.insert(0, str(Path(__file__).parent.parent / \"src\"))\n\nfrom causal_indexer import StaticAnalyzer, CausalGraph, QueryEngine\n\n\ndef main():\n    parser = argparse.ArgumentParser(description=\"Index a codebase and build its causal graph.\")\n    parser.add_argument(\"codebase\", help=\"Path to the codebase to index\")\n    parser.add_argument(\"--output\", \"-o\", default=None, help=\"Output path for graph JSON\")\n    parser.add_argument(\"--stats\", \"-s\", action=\"store_true\", help=\"Print graph stats\")\n    parser.add_argument(\"--query\", \"-q\", default=None, help=\"Run a causal query after indexing\")\n    parser.add_argument(\"--top-k\", \"-k\", type=int, default=10, help=\"Number of results to return\")\n    args = parser.parse_args()\n\n    codebase_path = Path(args.codebase).resolve()\n    if not codebase_path.exists():\n        print(f\"Error: path does not exist: {codebase_path}\")\n        sys.exit(1)\n\n    print(f\"[index] Indexing {codebase_path}...\")\n\n    analyzer = StaticAnalyzer(str(codebase_path))\n    analyzer.analyze()\n\n    print(f\"   Found {len(analyzer.definitions)} definitions, {len(analyzer.references)} references\")\n\n    graph = CausalGraph.from_analysis(analyzer.definitions, analyzer.references)\n    stats = graph.stats()\n\n    print(f\"   Built graph with {stats['total_nodes']} nodes, {stats['total_edges']} edges\")\n    if args.stats:\n        print()\n        print(\"📊 Graph Stats:\")\n        print(f\"   Node kinds: {stats['node_kinds']}\")\n        print(f\"   Entry points: {stats['entry_points']}\")\n        print(f\"   Interfaces: {stats['interfaces']}\")\n        print(f\"   External nodes: {stats['external_nodes']}\")\n\n    # Save graph\n    output_path = args.output or str(codebase_path.parent / f\"{codebase_path.name}_causal_graph.json\")\n    graph.save(output_path)\n    print(f\"   💾 Saved graph to {output_path}\")\n\n    # Run query if requested\n    if args.query:\n        print()\n        print(f\"🔎 Query: {args.query}\")\n        engine = QueryEngine(graph)\n        results = engine.query(args.query, top_k=args.top_k)\n        if not results:\n            print(\"   No results found.\")\n        for i, r in enumerate(results, 1):\n            print(f\"   {i}. [{r.kind}] {r.entity} (score={r.score:.2f})\")\n            print(f\"      File: {r.file_path}:{r.lineno}\")\n            if r.docstring:\n                preview = r.docstring[:80].strip()\n                print(f\"      Doc: {preview}...\")\n            print(f\"      Why: {r.reason}\")\n            print()\n\n\nif __name__ == \"__main__\":\n    main()\n"}],"isError":false,"timestamp":1774211902031}}
{"type":"message","id":"1ab28b95","parentId":"f8ebfa7b","timestamp":"2026-03-22T20:38:33.444Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Let me just rewrite the file without emoji to avoid encoding issues on Windows.","thinkingSignature":"cb6a3ee4bbdcb75606ec4ce7a112c90d476f395128a32c5b6b012b2144c561ed"},{"type":"toolCall","id":"call_function_66p17me3zlw8_1","name":"write","arguments":{"path":"C:/dev/code-cause/scripts/index_codebase.py","content":"#!/usr/bin/env python3\n\"\"\"\nindex_codebase.py\n=================\nCLI tool to index a codebase and save its causal graph.\n\nUsage:\n    python index_codebase.py /path/to/codebase [--output graph.json]\n\"\"\"\n\nimport argparse\nimport json\nimport sys\nfrom pathlib import Path\n\n# Add src to path for local development\nsys.path.insert(0, str(Path(__file__).parent.parent / \"src\"))\n\nfrom causal_indexer import StaticAnalyzer, CausalGraph, QueryEngine\n\n\ndef main():\n    parser = argparse.ArgumentParser(description=\"Index a codebase and build its causal graph.\")\n    parser.add_argument(\"codebase\", help=\"Path to the codebase to index\")\n    parser.add_argument(\"--output\", \"-o\", default=None, help=\"Output path for graph JSON\")\n    parser.add_argument(\"--stats\", \"-s\", action=\"store_true\", help=\"Print graph stats\")\n    parser.add_argument(\"--query\", \"-q\", default=None, help=\"Run a causal query after indexing\")\n    parser.add_argument(\"--top-k\", \"-k\", type=int, default=10, help=\"Number of results to return\")\n    args = parser.parse_args()\n\n    codebase_path = Path(args.codebase).resolve()\n    if not codebase_path.exists():\n        print(f\"Error: path does not exist: {codebase_path}\")\n        sys.exit(1)\n\n    print(f\"[index] Indexing {codebase_path}...\")\n\n    analyzer = StaticAnalyzer(str(codebase_path))\n    analyzer.analyze()\n\n    print(f\"   Found {len(analyzer.definitions)} definitions, {len(analyzer.references)} references\")\n\n    graph = CausalGraph.from_analysis(analyzer.definitions, analyzer.references)\n    stats = graph.stats()\n\n    print(f\"   Built graph with {stats['total_nodes']} nodes, {stats['total_edges']} edges\")\n    if args.stats:\n        print()\n        print(\"Graph Stats:\")\n        print(f\"   Node kinds: {stats['node_kinds']}\")\n        print(f\"   Entry points: {stats['entry_points']}\")\n        print(f\"   Interfaces: {stats['interfaces']}\")\n        print(f\"   External nodes: {stats['external_nodes']}\")\n\n    # Save graph\n    output_path = args.output or str(codebase_path.parent / f\"{codebase_path.name}_causal_graph.json\")\n    graph.save(output_path)\n    print(f\"   [saved] Graph to {output_path}\")\n\n    # Run query if requested\n    if args.query:\n        print()\n        print(f\"[query] {args.query}\")\n        engine = QueryEngine(graph)\n        results = engine.query(args.query, top_k=args.top_k)\n        if not results:\n            print(\"   No results found.\")\n        for i, r in enumerate(results, 1):\n            print(f\"   {i}. [{r.kind}] {r.entity} (score={r.score:.2f})\")\n            print(f\"      File: {r.file_path}:{r.lineno}\")\n            if r.docstring:\n                preview = r.docstring[:80].strip()\n                print(f\"      Doc: {preview}...\")\n            print(f\"      Why: {r.reason}\")\n            print()\n\n\nif __name__ == \"__main__\":\n    main()\n"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.7","usage":{"input":45248,"output":733,"cacheRead":12605,"cacheWrite":0,"totalTokens":58586,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774211902049}}
