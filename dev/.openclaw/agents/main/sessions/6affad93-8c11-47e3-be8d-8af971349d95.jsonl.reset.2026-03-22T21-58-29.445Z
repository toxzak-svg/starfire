{"type":"message","id":"4ea9d4f0","parentId":"dcb28e05","timestamp":"2026-03-22T20:36:18.826Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now the static analyzer. This should handle Python and JavaScript/TypeScript. For Python, I'll use the `ast` module. For JS/TS, I'll try to use tree-sitter if available, or fall back to regex-based extraction.","thinkingSignature":"46c3eb9d0ef6f271082de2d4c104ebf7f2fe8aeca5b433118c4d184d8a975419"},{"type":"toolCall","id":"call_function_b1ex5hxexup6_1","name":"write","arguments":{"path":"C:/dev/code-cause/src/causal_indexer/static_analyzer.py","content":"\"\"\"\nStatic Analyzer\n================\nParses Python and JavaScript/TypeScript codebases to extract:\n- Definitions (functions, classes, modules)\n- References (calls, imports, inheritance)\n- Scope information\n\nUses Python's `ast` for Python. Uses tree-sitter for JS/TS (if available),\nfalls back to regex-based extraction.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport ast\nimport os\nimport sys\nfrom pathlib import Path\nfrom dataclasses import dataclass, field\nfrom typing import Generator, Optional\nimport importlib.util\n\n\n@dataclass\nclass Definition:\n    \"\"\"A named entity found in the code.\"\"\"\n    name: str                    # e.g. \"MyClass\" or \"my_function\"\n    fully_qualified: str         # e.g. \"mypackage.submodule.MyClass\"\n    kind: str                   # \"function\" | \"class\" | \"method\" | \"module\"\n    file_path: str\n    lineno: int\n    end_lineno: Optional[int] = None\n    docstring: Optional[str] = None\n    decorators: list[str] = field(default_factory=list)\n    is_async: bool = False\n\n\n@dataclass\nclass Reference:\n    \"\"\"A reference from one entity to another.\"\"\"\n    source_qualified: str       # e.g. \"mypackage.submodule.func1\"\n    target_qualified: str       # e.g. \"mypackage.utils.helper\"\n    target_name: str            # e.g. \"helper\" (unqualified)\n    kind: str                   # \"call\" | \"import\" | \"inherit\" | \"attribute\"\n    file_path: str\n    lineno: int\n\n\nclass PythonAnalyzer:\n    \"\"\"Extracts definitions and references from Python source using ast.\"\"\"\n\n    def __init__(self, root: str):\n        self.root = Path(root).resolve()\n        self.definitions: list[Definition] = []\n        self.references: list[Reference] = []\n        self._module_stack: list[str] = []  # current module path\n\n    def analyze(self) -> tuple[list[Definition], list[Reference]]:\n        \"\"\"Run analysis on all Python files under root.\"\"\"\n        for filepath in self._find_python_files():\n            self._analyze_file(filepath)\n        return self.definitions, self.references\n\n    def _find_python_files(self) -> Generator[Path, None, None]:\n        \"\"\"Find all .py files, excluding __pycache__, .git, etc.\"\"\"\n        exclude_dirs = {\"__pycache__\", \".git\", \".pytest_cache\", \"node_modules\", \".venv\", \"venv\", \"env\"}\n        for root, dirs, files in os.walk(self.root):\n            dirs[:] = [d for d in dirs if d not in exclude_dirs]\n            for f in files:\n                if f.endswith(\".py\") and not f.startswith(\".\"):\n                    yield Path(root) / f\n\n    def _analyze_file(self, filepath: Path) -> None:\n        \"\"\"Parse one Python file.\"\"\"\n        try:\n            source = filepath.read_text(encoding=\"utf-8\")\n        except (UnicodeDecodeError, PermissionError):\n            return\n\n        # Compute module name from file path\n        rel = filepath.relative_to(self.root)\n        module_parts = list(rel.parts)[:-1]  # remove filename\n        module_name = \".\".join(module_parts) if module_parts else \"\"\n        self._module_stack.append(module_name)\n\n        try:\n            tree = ast.parse(source, filename=str(filepath))\n        except SyntaxError:\n            self._module_stack.pop()\n            return\n\n        visitor = DefinitionVisitor(self._module_stack[-1], str(filepath))\n        visitor.visit(tree)\n\n        self.definitions.extend(visitor.definitions)\n        self.references.extend(visitor.references)\n        self._module_stack.pop()\n\n    def get_module_qualname(self, module_path: str, name: str) -> str:\n        \"\"\"Build fully qualified name: e.g. 'mypackage.submodule.func'\"\"\"\n        prefix = f\"{module_path}.\" if module_path else \"\"\n        return f\"{prefix}{name}\"\n\n\nclass DefinitionVisitor(ast.NodeVisitor):\n    \"\"\"Collects definitions and references from an AST.\"\"\"\n\n    def __init__(self, module_name: str, file_path: str):\n        self.module_name = module_name\n        self.file_path = file_path\n        self.definitions: list[Definition] = []\n        self.references: list[Reference] = []\n        self._class_stack: list[str] = []  # nested class context\n        self._scope: list[str] = []        # current qualified path\n\n    def _qualname(self, name: str) -> str:\n        parts = [self.module_name] + self._scope + [name]\n        return \".\".join(parts)\n\n    def visit_Module(self, node: ast.Module) -> None:\n        self.generic_visit(node)\n\n    def visit_ClassDef(self, node: ast.ClassDef) -> None:\n        qualname = self._qualname(node.name)\n        self._class_stack.append(node.name)\n        self._scope.append(node.name)\n\n        # Inheritance references\n        for base in node.bases:\n            self._record_ref(base, \"inherit\", \"inherit\")\n\n        # Decorators\n        for dec in node.decorator_list:\n            self._record_ref(dec, \"attribute\", \"decorator\")\n\n        self.definitions.append(Definition(\n            name=node.name,\n            fully_qualified=qualname,\n            kind=\"class\",\n            file_path=self.file_path,\n            lineno=node.lineno or 0,\n            end_lineno=node.end_lineno,\n            docstring=ast.get_docstring(node),\n            decorators=[self._get_name(d) for d in node.decorator_list],\n        ))\n\n        self.generic_visit(node)\n        self._scope.pop()\n        self._class_stack.pop()\n\n    def visit_FunctionDef(self, node: ast.FunctionDef) -> None:\n        self._add_function(node, \"function\")\n\n    def visit_AsyncFunctionDef(self, node: ast.AsyncFunctionDef) -> None:\n        self._add_function(node, \"function\", is_async=True)\n\n    def _add_function(self, node: ast.FunctionDef | ast.AsyncFunctionDef, kind: str, is_async: bool = False) -> None:\n        qualname = self._qualname(node.name)\n        is_method = bool(self._class_stack)\n\n        for dec in node.decorator_list:\n            self._record_ref(dec, \"attribute\", \"decorator\")\n\n        self.definitions.append(Definition(\n            name=node.name,\n            fully_qualified=qualname,\n            kind=\"method\" if is_method else kind,\n            file_path=self.file_path,\n            lineno=node.lineno or 0,\n            end_lineno=node.end_lineno,\n            docstring=ast.get_docstring(node),\n            decorators=[self._get_name(d) for d in node.decorator_list],\n            is_async=is_async,\n        ))\n\n        # Record calls inside the function body\n        self._scope.append(node.name)\n        self.generic_visit(node)\n        self._scope.pop()\n\n    def visit_Call(self, node: ast.Call) -> None:\n        self._record_ref(node.func, \"call\", \"call\")\n        self.generic_visit(node)\n\n    def visit_Import(self, node: ast.Import) -> None:\n        for alias in node.names:\n            target = alias.asname or alias.name\n            self.references.append(Reference(\n                source_qualified=self._qualname(\"\"),\n                target_qualified=alias.name,\n                target_name=alias.name.split(\".\")[-1],\n                kind=\"import\",\n                file_path=self.file_path,\n                lineno=node.lineno or 0,\n            ))\n\n    def visit_ImportFrom(self, node: ast.ImportFrom) -> None:\n        module = node.module or \"\"\n        for alias in node.names:\n            target_name = alias.asname or alias.name\n            target_qual = f\"{module}.{alias.name}\" if module else alias.name\n            self.references.append(Reference(\n                source_qualified=self._qualname(\"\"),\n                target_qualified=target_qual,\n                target_name=target_name,\n                kind=\"import\",\n                file_path=self.file_path,\n                lineno=node.lineno or 0,\n            ))\n\n    def _record_ref(self, node: ast.AST, kind: str, ref_kind: str) -> None:\n        name = self._get_name(node)\n        if not name:\n            return\n        # Build qualified target\n        parts = name.split(\".\")\n        qual = \".\".join(parts)\n        self.references.append(Reference(\n            source_qualified=self._qualname(\"\"),\n            target_qualified=qual,\n            target_name=parts[-1],\n            kind=ref_kind,\n            file_path=self.file_path,\n            lineno=getattr(node, \"lineno\", 0) or 0,\n        ))\n\n    def _get_name(self, node: ast.AST) -> Optional[str]:\n        \"\"\"Extract the dotted name from an AST node.\"\"\"\n        if isinstance(node, ast.Name):\n            return node.id\n        elif isinstance(node, ast.Attribute):\n            base = self._get_name(node.value)\n            return f\"{base}.{node.attr}\" if base else node.attr\n        elif isinstance(node, ast.Subscript):\n            base = self._get_name(node.value)\n            return base\n        return None\n\n\nclass JSAnalyzer:\n    \"\"\"\n    Lightweight JS/TS analysis via regex + tree-sitter (if available).\n    Falls back to regex-based function/class extraction when tree-sitter\n    is not installed.\n    \"\"\"\n\n    def __init__(self, root: str):\n        self.root = Path(root).resolve()\n        self.definitions: list[Definition] = []\n        self.references: list[Reference] = []\n        self._try_import_treesitter()\n\n    def _try_import_treesitter(self) -> None:\n        try:\n            import tree_sitter\n            self._ts_available = True\n        except ImportError:\n            self._ts_available = False\n\n    def analyze(self) -> tuple[list[Definition], list[Reference]]:\n        \"\"\"Run analysis on all JS/TS files under root.\"\"\"\n        for filepath in self._find_js_files():\n            self._analyze_file(filepath)\n        return self.definitions, self.references\n\n    def _find_js_files(self) -> Generator[Path, None, None]:\n        \"\"\"Find all .js/.ts/.jsx/.tsx/.mjs files.\"\"\"\n        exts = {\".js\", \".jsx\", \".ts\", \".tsx\", \".mjs\", \".cjs\"}\n        exclude_dirs = {\"node_modules\", \".git\", \".venv\", \"venv\", \"dist\", \"build\", \".next\"}\n        for root, dirs, files in os.walk(self.root):\n            dirs[:] = [d for d in dirs if d not in exclude_dirs]\n            for f in files:\n                if Path(f).suffix in exts:\n                    yield Path(root) / f\n\n    def _analyze_file(self, filepath: Path) -> None:\n        \"\"\"Regex-based fallback analysis for JS/TS.\"\"\"\n        try:\n            source = filepath.read_text(encoding=\"utf-8\")\n        except (UnicodeDecodeError, PermissionError):\n            return\n\n        rel = filepath.relative_to(self.root)\n        module_name = \".\".join(list(rel.parts)[:-1])\n        if not module_name:\n            module_name = filepath.stem\n\n        import re\n\n        # Extract function definitions\n        # Handles: function name(), async function name(), const name = () => {}\n        func_pattern = re.compile(\n            r'(?:export\\s+)?(?:async\\s+)?function\\s+(\\w+)\\s*\\([^)]*\\)'\n            r'|'\n            r'(?:export\\s+)?(?:const|let|var)\\s+(\\w+)\\s*=\\s*(?:async\\s+)?\\([^)]*\\)\\s*=>'\n            r'|'\n            r'(?:export\\s+)?(?:const|let|var)\\s+(\\w+)\\s*=\\s*(?:async\\s+)?function\\s*\\([^)]*\\)',\n            re.MULTILINE\n        )\n        for m in func_pattern.finditer(source):\n            name = m.group(1) or m.group(2) or m.group(3)\n            lineno = source[:m.start()].count('\\n') + 1\n            self.definitions.append(Definition(\n                name=name,\n                fully_qualified=f\"{module_name}.{name}\",\n                kind=\"function\",\n                file_path=str(filepath),\n                lineno=lineno,\n            ))\n\n        # Extract class definitions\n        class_pattern = re.compile(\n            r'(?:export\\s+)?class\\s+(\\w+)(?:\\s+extends\\s+\\w+)?',\n            re.MULTILINE\n        )\n        for m in class_pattern.finditer(source):\n            lineno = source[:m.start()].count('\\n') + 1\n            self.definitions.append(Definition(\n                name=m.group(1),\n                fully_qualified=f\"{module_name}.{m.group(1)}\",\n                kind=\"class\",\n                file_path=str(filepath),\n                lineno=lineno,\n            ))\n\n        # Extract import statements\n        import_pattern = re.compile(\n            r\"import\\s+(?:{[^}]+}|\\w+)\\s+from\\s+['\\\"]([^'\\\"]+)['\\\"]\",\n            re.MULTILINE\n        )\n        for m in import_pattern.finditer(source):\n            lineno = source[:m.start()].count('\\n') + 1\n            target_module = m.group(1)\n            self.references.append(Reference(\n                source_qualified=module_name,\n                target_qualified=target_module,\n                target_name=target_module.split(\"/\")[-1],\n                kind=\"import\",\n                file_path=str(filepath),\n                lineno=lineno,\n            ))\n\n\nclass StaticAnalyzer:\n    \"\"\"\n    Unified static analyzer that dispatches to the right backend\n    based on file type.\n    \"\"\"\n\n    def __init__(self, root: str):\n        self.root = Path(root).resolve()\n        self.definitions: list[Definition] = []\n        self.references: list[Reference] = []\n\n    def analyze(self) -> \"StaticAnalyzer\":\n        \"\"\"\n        Run full static analysis.\n        Returns self for chaining.\n        \"\"\"\n        py_root = self.root / \"py\"  # placeholder for language dispatch\n        # For now, auto-detect: if root contains .py files, use PythonAnalyzer\n        has_py = any(f.suffix == \".py\" for f in self.root.rglob(\"*.py\"))\n        has_js = any(\n            f.suffix in {\".js\", \".ts\", \".jsx\", \".tsx\"}\n            for f in self.root.rglob(\"*\")\n            if f.is_file()\n        )\n\n        if has_py:\n            py_analyzer = PythonAnalyzer(str(self.root))\n            defs, refs = py_analyzer.analyze()\n            self.definitions.extend(defs)\n            self.references.extend(refs)\n\n        if has_js:\n            js_analyzer = JSAnalyzer(str(self.root))\n            defs, refs = js_analyzer.analyze()\n            self.definitions.extend(defs)\n            self.references.extend(refs)\n\n        return self\n\n    def get_def(self, fully_qualified: str) -> Optional[Definition]:\n        \"\"\"Get a definition by its fully qualified name.\"\"\"\n        for d in self.definitions:\n            if d.fully_qualified == fully_qualified:\n                return d\n        return None\n\n    def get_refs_to(self, target_qualified: str) -> list[Reference]:\n        \"\"\"Get all references pointing to a given qualified name.\"\"\"\n        return [r for r in self.references if r.target_qualified == target_qualified]\n\n    def get_refs_from(self, source_qualified: str) -> list[Reference]:\n        \"\"\"Get all references originating from a given qualified name.\"\"\"\n        return [r for r in self.references if r.source_qualified == source_qualified]\n"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.7","usage":{"input":33930,"output":3480,"cacheRead":12605,"cacheWrite":0,"totalTokens":50015,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774211724376}}
