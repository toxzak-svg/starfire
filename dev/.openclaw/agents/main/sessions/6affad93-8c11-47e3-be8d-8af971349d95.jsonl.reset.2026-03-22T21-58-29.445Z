{"type":"message","id":"57d285bd","parentId":"515dc85d","timestamp":"2026-03-22T20:36:56.050Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now let me write the graph builder that takes definitions and references and builds the causal graph.","thinkingSignature":"23f3953c2940b9247836567a65477b99a699e3aede74f23ef11bccea745453fd"},{"type":"toolCall","id":"call_function_rr36ic1a75o5_1","name":"write","arguments":{"path":"C:/dev/code-cause/src/causal_indexer/graph_builder.py","content":"\"\"\"\nCausal Graph Builder\n====================\nBuilds a directed causal dependency graph from definitions and references.\n\nThe graph has:\n- Nodes: fully-qualified code entities (functions, classes, modules)\n- Edges: causal dependencies (A calls B, A inherits B, A imports B)\n\nThe \"causal\" in causal graph means: if I change A, what does it affect?\nThe answer is found by traversing the graph from A following outgoing edges.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport json\nfrom dataclasses import dataclass, field, asdict\nfrom typing import Optional\nfrom collections import defaultdict\nimport networkx as nx\n\nfrom .static_analyzer import Definition, Reference\n\n\n@dataclass\nclass Node:\n    \"\"\"A node in the causal graph.\"\"\"\n    qualified_name: str\n    kind: str                    # \"function\" | \"class\" | \"method\" | \"module\"\n    file_path: str\n    lineno: int\n    end_lineno: Optional[int] = None\n    docstring: Optional[str] = None\n    # Inferred causal attributes\n    is_entry_point: bool = False    # e.g. main(), __call__\n    is_interface: bool = False       # class with many dependents\n    complexity_score: float = 1.0    # placeholder for cyclomatic complexity\n\n\n@dataclass\nclass Edge:\n    \"\"\"A directed edge in the causal graph.\"\"\"\n    source: str          # who is making the dependency\n    target: str          # what is being depended on\n    kind: str            # \"calls\" | \"inherits\" | \"imports\" | \"attributes\"\n    file_path: str\n    lineno: int\n\n\nclass CausalGraph:\n    \"\"\"\n    Directed graph of code dependencies with causal semantics.\n\n    Key operations:\n    - query_impact(name): what changes if I modify this entity?\n    - query_causes(name): what caused this entity to behave this way?\n    \"\"\"\n\n    def __init__(self):\n        self.nodes: dict[str, Node] = {}\n        self.edges: list[Edge] = []\n        self._outgoing: dict[str, list[str]] = defaultdict(list)  # name -> [dependents]\n        self._incoming: dict[str, list[str]] = defaultdict(list)  # name -> [dependencies]\n        self._def_map: dict[str, Definition] = {}\n\n    # ─── Building ───────────────────────────────────────────────────────────\n\n    def add_definition(self, defn: Definition) -> None:\n        \"\"\"Add a definition as a node.\"\"\"\n        node = Node(\n            qualified_name=defn.fully_qualified,\n            kind=defn.kind,\n            file_path=defn.file_path,\n            lineno=defn.lineno,\n            end_lineno=defn.end_lineno,\n            docstring=defn.docstring,\n        )\n        self.nodes[defn.fully_qualified] = node\n        self._def_map[defn.fully_qualified] = defn\n\n    def add_reference(self, ref: Reference) -> None:\n        \"\"\"Add a reference as a directed edge.\"\"\"\n        if ref.target_qualified not in self.nodes:\n            # Unknown target — still record the edge but mark as external\n            self.nodes[ref.target_qualified] = Node(\n                qualified_name=ref.target_qualified,\n                kind=\"external\",\n                file_path=ref.file_path,\n                lineno=ref.lineno,\n            )\n\n        edge = Edge(\n            source=ref.source_qualified,\n            target=ref.target_qualified,\n            kind=ref.kind,\n            file_path=ref.file_path,\n            lineno=ref.lineno,\n        )\n        self.edges.append(edge)\n        self._outgoing[ref.source_qualified].append(ref.target_qualified)\n        self._incoming[ref.target_qualified].append(ref.source_qualified)\n\n    @classmethod\n    def from_analysis(cls, definitions: list[Definition], references: list[Reference]) -> \"CausalGraph\":\n        \"\"\"Build a causal graph from static analysis results.\"\"\"\n        graph = cls()\n\n        # Deduplicate definitions (take first seen)\n        seen_defs: set[str] = set()\n        for d in definitions:\n            if d.fully_qualified not in seen_defs:\n                graph.add_definition(d)\n                seen_defs.add(d.fully_qualified)\n\n        for r in references:\n            graph.add_reference(r)\n\n        graph._infer_node_attributes()\n        return graph\n\n    # ─── Node Attributes ────────────────────────────────────────────────────\n\n    def _infer_node_attributes(self) -> None:\n        \"\"\"\n        Infer causal attributes for each node based on graph structure.\n        These are cheap heuristics that improve query ranking.\n        \"\"\"\n        for name, node in self.nodes.items():\n            # High in-degree = many things depend on it = likely an interface\n            in_deg = len(self._incoming[name])\n            out_deg = len(self._outgoing[name])\n\n            node.is_interface = in_deg > 3 and out_deg == 0\n            node.is_entry_point = (\n                name.endswith(\".main\") or\n                name.endswith(\".__init__\") or\n                name.endswith(\".__call__\") or\n                name == \"__main__\"\n            )\n\n    # ─── Queries ────────────────────────────────────────────────────────────\n\n    def query_impact(self, name: str, depth: int = 3) -> list[dict]:\n        \"\"\"\n        Forward reachability: what changes if I modify `name`?\n        Returns list of affected entities with path information.\n\n        Args:\n            name: fully-qualified name of the entity to change\n            depth: how many hops to traverse (0 = direct dependents only)\n        \"\"\"\n        if name not in self.nodes:\n            return []\n\n        affected = []\n        visited = set()\n        queue = [(name, 0)]\n\n        while queue:\n            current, d = queue.pop(0)\n            if current in visited:\n                continue\n            visited.add(current)\n\n            for dependent in self._outgoing[current]:\n                if dependent not in visited:\n                    edge = self._get_edge(current, dependent)\n                    affected.append({\n                        \"name\": dependent,\n                        \"node\": asdict(self.nodes.get(dependent, Node(qualified_name=dependent, kind=\"unknown\", file_path=\"\", lineno=0))),\n                        \"depth\": d + 1,\n                        \"edge_kind\": edge.kind if edge else \"unknown\",\n                        \"via_file\": edge.file_path if edge else \"\",\n                    })\n                    if d + 1 < depth:\n                        queue.append((dependent, d + 1))\n\n        # Sort by depth, then by interface priority\n        affected.sort(key=lambda x: (x[\"depth\"], not self.nodes.get(x[\"name\"], Node(qualified_name=\"\", kind=\"\", file_path=\"\", lineno=0)).is_interface))\n        return affected\n\n    def query_causes(self, name: str, depth: int = 3) -> list[dict]:\n        \"\"\"\n        Backward reachability: what caused `name` to be what it is?\n        Returns the dependency chain leading to this entity.\n        \"\"\"\n        if name not in self.nodes:\n            return []\n\n        causes = []\n        visited = set()\n        queue = [(name, 0)]\n\n        while queue:\n            current, d = queue.pop(0)\n            if current in visited:\n                continue\n            visited.add(current)\n\n            for dependency in self._incoming[current]:\n                if dependency not in visited:\n                    edge = self._get_edge(dependency, current)\n                    causes.append({\n                        \"name\": dependency,\n                        \"node\": asdict(self.nodes.get(dependency, Node(qualified_name=dependency, kind=\"unknown\", file_path=\"\", lineno=0))),\n                        \"depth\": d + 1,\n                        \"edge_kind\": edge.kind if edge else \"unknown\",\n                        \"via_file\": edge.file_path if edge else \"\",\n                    })\n                    if d + 1 < depth:\n                        queue.append((dependency, d + 1))\n\n        causes.sort(key=lambda x: x[\"depth\"])\n        return causes\n\n    def query_hot_path(self, name: str) -> list[str]:\n        \"\"\"\n        Find the highest-traffic path through this entity.\n        Returns the chain of \"most depended-on\" entities leading to `name`.\n        \"\"\"\n        if name not in self.nodes:\n            return []\n\n        path = [name]\n        current = name\n        visited = {name}\n\n        while True:\n            deps = self._incoming[current]\n            if not deps:\n                break\n            # Pick the most-connected dependency\n            next_node = max(deps, key=lambda d: len(self._outgoing[d]))\n            if next_node in visited:\n                break\n            path.append(next_node)\n            visited.add(next_node)\n            current = next_node\n\n        return path\n\n    def _get_edge(self, source: str, target: str) -> Optional[Edge]:\n        for e in self.edges:\n            if e.source == source and e.target == target:\n                return e\n        return None\n\n    # ─── NetworkX Interop ───────────────────────────────────────────────────\n\n    def to_networkx(self) -> nx.DiGraph:\n        \"\"\"Export as a NetworkX directed graph for analysis.\"\"\"\n        G = nx.DiGraph()\n        for name, node in self.nodes.items():\n            G.add_node(name, **asdict(node))\n        for edge in self.edges:\n            G.add_edge(edge.source, edge.target, kind=edge.kind)\n        return G\n\n    # ─── Persistence ───────────────────────────────────────────────────────\n\n    def to_dict(self) -> dict:\n        return {\n            \"nodes\": {k: asdict(v) for k, v in self.nodes.items()},\n            \"edges\": [asdict(e) for e in self.edges],\n        }\n\n    @classmethod\n    def from_dict(cls, data: dict) -> \"CausalGraph\":\n        graph = cls()\n        for k, v in data[\"nodes\"].items():\n            graph.nodes[k] = Node(**v)\n        for e in data[\"edges\"]:\n            graph.edges.append(Edge(**e))\n            graph._outgoing[e[\"source\"]].append(e[\"target\"])\n            graph._incoming[e[\"target\"]].append(e[\"source\"])\n        return graph\n\n    def save(self, path: str) -> None:\n        with open(path, \"w\", encoding=\"utf-8\") as f:\n            json.dump(self.to_dict(), f, indent=2)\n\n    @classmethod\n    def load(cls, path: str) -> \"CausalGraph\":\n        with open(path, \"r\", encoding=\"utf-8\") as f:\n            return cls.from_dict(json.load(f))\n\n    # ─── Stats ──────────────────────────────────────────────────────────────\n\n    def stats(self) -> dict:\n        \"\"\"Return summary statistics about the graph.\"\"\"\n        kinds = defaultdict(int)\n        for n in self.nodes.values():\n            kinds[n.kind] += 1\n\n        return {\n            \"total_nodes\": len(self.nodes),\n            \"total_edges\": len(self.edges),\n            \"node_kinds\": dict(kinds),\n            \"external_nodes\": sum(1 for n in self.nodes.values() if n.kind == \"external\"),\n            \"entry_points\": sum(1 for n in self.nodes.values() if n.is_entry_point),\n            \"interfaces\": sum(1 for n in self.nodes.values() if n.is_interface),\n        }\n"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.7","usage":{"input":37447,"output":2417,"cacheRead":12605,"cacheWrite":0,"totalTokens":52469,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774211778861}}
{"type":"message","id":"448c013d","parentId":"57d285bd","timestamp":"2026-03-22T20:36:56.076Z","message":{"role":"toolResult","toolCallId":"call_function_rr36ic1a75o5_1","toolName":"write","content":[{"type":"text","text":"Successfully wrote 10734 bytes to C:/dev/code-cause/src/causal_indexer/graph_builder.py"}],"isError":false,"timestamp":1774211816065}}
{"type":"message","id":"3de21e28","parentId":"448c013d","timestamp":"2026-03-22T20:37:33.785Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now the query engine - the high-level API for querying the graph.","thinkingSignature":"1d5a522d36cdafc70136e34349939846ad65a17d92b27c16d8d786d8ae7a52d7"},{"type":"toolCall","id":"call_function_mslyismogvsr_1","name":"write","arguments":{"path":"C:/dev/code-cause/src/causal_indexer/query_engine.py","content":"\"\"\"\nQuery Engine\n============\nHigh-level causal queries over the dependency graph.\n\nProvides natural-language-style queries that map to graph traversals,\nplus ranking/filtering of results.\n\"\"\"\n\nfrom __future__ import annotations\n\nfrom dataclasses import dataclass\nfrom typing import Optional\nfrom .graph_builder import CausalGraph\n\n\n@dataclass\nclass CausalResult:\n    \"\"\"A single result from a causal query.\"\"\"\n    entity: str\n    kind: str\n    file_path: str\n    lineno: int\n    docstring: Optional[str]\n    score: float            # importance/relevance score\n    path: list[str]        # causal path from query root to this entity\n    reason: str            # human-readable explanation of why this matters\n\n\nclass QueryEngine:\n    \"\"\"\n    Causal query interface for a codebase graph.\n\n    Example:\n        engine = QueryEngine(graph)\n        results = engine.query(\"what happens if I change auth.py validate_token?\")\n        for r in results:\n            print(f\"{r.entity} (score={r.score:.2f}): {r.reason}\")\n    \"\"\"\n\n    def __init__(self, graph: CausalGraph):\n        self.graph = graph\n\n    def query(self, question: str, top_k: int = 10) -> list[CausalResult]:\n        \"\"\"\n        Parse a natural-ish question and execute the corresponding causal query.\n\n        Supported question patterns:\n        - \"what happens if I change X?\" / \"what does X affect?\" / \"impact of X\"\n        - \"what caused X?\" / \"what does X depend on?\" / \"causes of X\"\n        - \"what uses X?\" / \"who calls X?\" / \"dependents of X\"\n        - \"ripple effect of X\" / \"full impact of X\"\n        \"\"\"\n        q = question.lower()\n\n        # Extract entity name from quotes or \"of X\" pattern\n        entity = self._extract_entity(q)\n\n        if any(k in q for k in [\"affect\", \"impact\", \"happens if\", \"changes\", \"ripple\", \"break\", \"what will\"]):\n            return self._query_impact(entity, top_k)\n        elif any(k in q for k in [\"caus\", \"depend\", \"prereq\", \"needed\", \"what does x need\"]):\n            return self._query_causes(entity, top_k)\n        elif any(k in q for k in [\"uses\", \"calls\", \"who\", \"dependents\", \"what uses\"]):\n            return self._query_dependents(entity, top_k)\n        else:\n            # Default to impact query\n            return self._query_impact(entity, top_k)\n\n    def _extract_entity(self, question: str) -> Optional[str]:\n        \"\"\"Extract the entity being asked about from the question text.\"\"\"\n        import re\n\n        # Match quoted strings: \"auth.validate_token\" or 'auth.validate_token'\n        quoted = re.findall(r'[\"\\']([^\"\\']+)[\"\\']', question)\n        if quoted:\n            return quoted[0]\n\n        # Match \"of X\" pattern: \"of auth.validate_token\"\n        of_match = re.search(r'\\bof\\s+([\\w.]+)', question)\n        if of_match:\n            return of_match.group(1)\n\n        # Match \"change X\" / \"modify X\" / \"affect X\"\n        modify_match = re.search(r'(?:change|modify|affect|update|edit)\\s+([\\w.]+)', question)\n        if modify_match:\n            return modify_match.group(1)\n\n        return None\n\n    def _score_result(self, name: str, depth: int, is_interface: bool, edge_kind: str) -> float:\n        \"\"\"\n        Score a query result by importance.\n        Higher score = more important to consider.\n        \"\"\"\n        score = 1.0\n\n        # Depth penalty: shallow impacts matter more\n        score -= depth * 0.15\n\n        # Interface bonus: things with many dependents are critical\n        if is_interface:\n            score += 0.5\n\n        # Entry point bonus\n        node = self.graph.nodes.get(name)\n        if node and node.is_entry_point:\n            score += 0.4\n\n        # Edge kind weighting\n        if edge_kind == \"calls\":\n            score += 0.1\n        elif edge_kind == \"inherits\":\n            score += 0.2\n        elif edge_kind == \"imports\":\n            score -= 0.1\n\n        # External nodes are less interesting\n        if node and node.kind == \"external\":\n            score -= 0.3\n\n        return max(0.0, score)\n\n    def _query_impact(self, entity: Optional[str], top_k: int) -> list[CausalResult]:\n        \"\"\"What changes if I modify this entity?\"\"\"\n        if not entity:\n            return []\n\n        # Try exact match first, then fuzzy\n        target = self._resolve_entity(entity)\n        if not target:\n            return []\n\n        impacts = self.graph.query_impact(target, depth=5)\n        results = []\n\n        for imp in impacts[:top_k * 2]:  # over-fetch for scoring\n            node_data = imp[\"node\"]\n            score = self._score_result(\n                imp[\"name\"],\n                imp[\"depth\"],\n                node_data.get(\"is_interface\", False),\n                imp[\"edge_kind\"]\n            )\n            reason = self._make_impact_reason(entity, imp[\"name\"], imp[\"edge_kind\"], imp[\"depth\"])\n\n            results.append(CausalResult(\n                entity=imp[\"name\"],\n                kind=node_data.get(\"kind\", \"unknown\"),\n                file_path=node_data.get(\"file_path\", \"\"),\n                lineno=node_data.get(\"lineno\", 0),\n                docstring=node_data.get(\"docstring\"),\n                score=score,\n                path=[entity, imp[\"name\"]],\n                reason=reason,\n            ))\n\n        results.sort(key=lambda r: -r.score)\n        return results[:top_k]\n\n    def _query_causes(self, entity: Optional[str], top_k: int) -> list[CausalResult]:\n        \"\"\"What caused this entity to be the way it is?\"\"\"\n        if not entity:\n            return []\n\n        target = self._resolve_entity(entity)\n        if not target:\n            return []\n\n        causes = self.graph.query_causes(target, depth=5)\n        results = []\n\n        for cause in causes[:top_k * 2]:\n            node_data = cause[\"node\"]\n            score = self._score_result(\n                cause[\"name\"],\n                cause[\"depth\"],\n                node_data.get(\"is_interface\", False),\n                cause[\"edge_kind\"]\n            )\n            reason = self._make_causes_reason(entity, cause[\"name\"], cause[\"edge_kind\"], cause[\"depth\"])\n\n            results.append(CausalResult(\n                entity=cause[\"name\"],\n                kind=node_data.get(\"kind\", \"unknown\"),\n                file_path=node_data.get(\"file_path\", \"\"),\n                lineno=node_data.get(\"lineno\", 0),\n                docstring=node_data.get(\"docstring\"),\n                score=score,\n                path=[cause[\"name\"], entity],\n                reason=reason,\n            ))\n\n        results.sort(key=lambda r: -r.score)\n        return results[:top_k]\n\n    def _query_dependents(self, entity: Optional[str], top_k: int) -> list[CausalResult]:\n        \"\"\"Who depends on this entity?\"\"\"\n        if not entity:\n            return []\n\n        target = self._resolve_entity(entity)\n        if not target:\n            return []\n\n        direct = self.graph._outgoing.get(target, [])\n        results = []\n\n        for dep_name in direct:\n            node = self.graph.nodes.get(dep_name)\n            if not node:\n                continue\n            results.append(CausalResult(\n                entity=dep_name,\n                kind=node.kind,\n                file_path=node.file_path,\n                lineno=node.lineno,\n                docstring=node.docstring,\n                score=1.0,\n                path=[target, dep_name],\n                reason=f\"{dep_name} directly calls/imports {entity}\",\n            ))\n\n        results.sort(key=lambda r: -r.score)\n        return results[:top_k]\n\n    def _resolve_entity(self, entity: str) -> Optional[str]:\n        \"\"\"Resolve a partial name to a fully qualified name.\"\"\"\n        if entity in self.graph.nodes:\n            return entity\n\n        # Try case-insensitive match\n        lower = entity.lower()\n        for name in self.graph.nodes:\n            if name.lower() == lower:\n                return name\n\n        # Try suffix match\n        for name in self.graph.nodes:\n            if name.endswith(entity):\n                return name\n\n        # Try simple name match (last component)\n        parts = entity.split(\".\")\n        for name in self.graph.nodes:\n            if name.endswith(parts[-1]):\n                return name\n\n        return None\n\n    def _make_impact_reason(self, changed: str, affected: str, edge_kind: str, depth: int) -> str:\n        kind_map = {\n            \"calls\": f\"directly calls\",\n            \"imports\": f\"imports\",\n            \"inherits\": f\"inherits from\",\n            \"attributes\": f\"accesses attribute of\",\n        }\n        action = kind_map.get(edge_kind, f\"relates to\")\n        d_str = f\" (cascade {depth} hops)\" if depth > 1 else \"\"\n        return f\"{affected} {action} {changed}{d_str}\"\n\n    def _make_causes_reason(self, entity: str, cause: str, edge_kind: str, depth: int) -> str:\n        kind_map = {\n            \"calls\": f\"calls\",\n            \"imports\": f\"imports\",\n            \"inherits\": f\"inherits from\",\n            \"attributes\": f\"accesses attribute of\",\n        }\n        action = kind_map.get(edge_kind, f\"relates to\")\n        d_str = f\" ({depth} hops up)\" if depth > 1 else \"\"\n        return f\"{entity} {action} {cause}{d_str}\"\n\n    def explain_entity(self, entity: str) -> dict:\n        \"\"\"Get a full causal explanation of an entity.\"\"\"\n        target = self._resolve_entity(entity)\n        if not target:\n            return {}\n\n        node = self.graph.nodes.get(target, None)\n        if not node:\n            return {}\n\n        impact = self.graph.query_impact(target, depth=2)\n        causes = self.graph.query_causes(target, depth=2)\n        hot_path = self.graph.query_hot_path(target)\n\n        return {\n            \"entity\": target,\n            \"definition\": {\n                \"kind\": node.kind,\n                \"file\": node.file_path,\n                \"lines\": f\"{node.lineno}-{node.end_lineno}\" if node.end_lineno else f\"line {node.lineno}\",\n                \"docstring\": node.docstring,\n                \"is_entry_point\": node.is_entry_point,\n                \"is_interface\": node.is_interface,\n            },\n            \"direct_dependents\": self.graph._outgoing.get(target, []),\n            \"direct_dependencies\": self.graph._incoming.get(target, []),\n            \"top_impact\": [i[\"name\"] for i in impact[:5]],\n            \"top_causes\": [c[\"name\"] for c in causes[:5]],\n            \"hot_path\": hot_path,\n            \"graph_stats\": {\n                \"in_degree\": len(self.graph._incoming[target]),\n                \"out_degree\": len(self.graph._outgoing[target]),\n            }\n        }\n"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.7","usage":{"input":39900,"output":2477,"cacheRead":12605,"cacheWrite":0,"totalTokens":54982,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774211816081}}
