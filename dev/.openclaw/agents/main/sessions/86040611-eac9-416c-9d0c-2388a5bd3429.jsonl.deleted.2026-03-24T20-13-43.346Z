nt = Get-Content $Path -Raw\r\n    # Extract sections: Goals, Actions, Observations, Mutations\r\n    $blocks = @{}\r\n    if ($content -match '### GOALS\\s*\\n([\\s\\S]*?)(?=###|\\z)') { $blocks['Goals'] = $Matches[1].Trim() }\r\n    if ($content -match '### OBSERVATION\\s*\\n([\\s\\S]*?)(?=###|\\z)') { $blocks['Observation'] = $Matches[1].Trim() }\r\n    if ($content -match '### ACTION\\s*\\n([\\s\\S]*?)(?=###|\\z)') { $blocks['Action'] = $Matches[1].Trim() }\r\n    return $blocks\r\n}\r\n\r\n# Tokenize text for comparison\r\nfunction Tokenize {\r\n    param([string]$Text)\r\n    $Text.ToLower() -split '\\s+' | Where-Object { $_.Length -gt 2 } | Sort-Object\r\n}\r\n\r\n# Calculate similarity between two texts\r\nfunction Get-Similarity {\r\n    param([string]$A, [string]$B)\r\n    $tokensA = Tokenize $A\r\n    $tokensB = Tokenize $B\r\n    $union = ($tokensA + $tokensB) | Select-Object -Unique\r\n    $intersection = $tokensA | Where-Object { $tokensB -contains $_ }\r\n    if ($union.Count -eq 0) { return 0 }\r\n    return $intersection.Count / $union.Count\r\n}\r\n\r\n# Main TIC Analysis\r\nWrite-Host \"=== TIC Experiment ===\" -ForegroundColor Cyan\r\n$logs = Get-PulseLogs\r\nWrite-Host \"Analyzing $($logs.Count) pulse logs...\"\r\n\r\n$allBlocks = @()\r\nforeach ($log in $logs) {\r\n    $blocks = Get-ContentBlocks $log.FullName\r\n    $blocks['Timestamp'] = $log.BaseName -replace 'pulse_', ''\r\n    $allBlocks += ,@($blocks)\r\n}\r\n\r\n# Identify invariants (content appearing in >60% of pulses)\r\n$blockTypes = @('Goals', 'Observation', 'Action')\r\n$invariantResults = @{}\r\n$variantResults = @{}\r\n\r\nforeach ($\n\n## For Next Instantiation\n- Proposed mutations waiting: 1\n- Completed at: 2026-03-24 08:53:47","cwd":"C:\\Users\\Zwmar\\.openclaw\\workspace"},"isError":false,"timestamp":1774356846303}}
