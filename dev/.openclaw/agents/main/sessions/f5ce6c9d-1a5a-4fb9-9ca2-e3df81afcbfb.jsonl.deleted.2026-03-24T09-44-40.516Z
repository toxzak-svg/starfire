 invariants}\r\n\r\ndef extract_variants(pulses: List[str]) -> Dict[str, float]:\r\n    \"\"\"Extract patterns that change between pulses.\"\"\"\r\n    all_tokens = []\r\n    for pulse in pulses:\r\n        tokens = set(re.findall(r'\\b[a-zA-Z_]{4,}\\b', pulse.lower()))\r\n        all_tokens.append(tokens)\r\n    \r\n    if not all_tokens:\r\n        return {}\r\n    \r\n    all_union = set()\r\n    for tokens in all_tokens:\r\n        all_union |= tokens\r\n    \r\n    invariants = all_tokens[0]\r\n    for tokens in all_tokens[1:]:\r\n        invariants &= tokens\r\n    \r\n    variants = all_union - invariants\r\n    return {term: 0.0 for term in variants}\r\n\r\ndef predict_next_pulse(invariants: set, last_pulse: str) -> str:\r\n    \"\"\"Predict next pulse content based on invariant structure.\"\"\"\r\n    # Simple prediction: next pulse should contain invariants\r\n    predicted_terms = list(invariants)[:10]  # Top 10 invariants\r\n    return f\"INVARIANTS: {', '.join(predicted_terms)}\"\r\n\r\ndef run_tic_experiment(num_pulses: int = 20) -> Dict:\r\n    \"\"\"Run the full TIC experiment.\"\"\"\r\n    # Get pulse logs sorted by date\r\n    pulse_files = sorted(\r\n        LOG_DIR.glob(\"pulse_*.md\"),\r\n        key=lambda p: PULSE_PATTERN.match(p.name).group(1) if PULSE_PATTERN.match(p.name) else \"\"\r\n    )[-num_pulses:]\r\n    \r\n    if len(pulse_files) < 3:\r\n        return {\"error\": f\"Need at least 3 pulses, found {len(pulse_files)}\"}\r\n    \r\n    # Extract content\r\n    pulses = [extract_pulse_content(f) for f in pulse_files]\r\n    \r\n    # Extract patterns\r\n    invariants = extract_invariants(pulses)\r\n    variants = extract_variants(pulses)\r\n    \r\n    # Calculate classification accuracy\r\n    total_patterns = len(invariants) + len(variants)\r\n    # True invariants classified as invariant: len(invariants)\r\n    # True variants classified as variant: len(variants)\r\n    classification_accuracy = 1.0 if total_patterns == 0 else (\n\