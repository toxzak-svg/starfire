{"type":"message","id":"0e827c3a","parentId":"93da972a","timestamp":"2026-03-23T15:28:34.238Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now rewrite the creative route with BYOK support and using `spark.core.engine`:","thinkingSignature":"a1236e637d6836f9d5fae138ff517b8e9896ccd630b544a6f90bc10643bf5311"},{"type":"text","text":"Now the creative routes with full BYOK:\n"},{"type":"toolCall","id":"call_function_q0s2twk81nsl_1","name":"write","arguments":{"content":"\"\"\"SPARK Creative Writing API — /v1/spark/generate\"\"\"\n\nfrom __future__ import annotations\n\nimport os\nimport sys\nimport time\nimport hashlib\nfrom pathlib import Path\nfrom typing import Optional, List\n\nfrom fastapi import APIRouter, HTTPException, Request\nfrom pydantic import BaseModel, Field\n\n# Ensure spark.core.engine is importable\n_SPARK_DIR = Path(__file__).parent.parent.parent\nsys.path.insert(0, str(_SPARK_DIR))\nsys.path.insert(0, str(_SPARK_DIR.parent))\n\nfrom spark.core.engine import spark_drift\nfrom spark.core.llm_mapper import CreativeMapper, find_tensions_in_concepts\n\nrouter = APIRouter(prefix=\"/v1/spark\", tags=[\"creative\"])\n\n\n# -------------------------------------------------------------------\n# Models\n# -------------------------------------------------------------------\n\nclass GenerateRequest(BaseModel):\n    theme: str = Field(default=\"ideas finding their own trail\", description=\"The driving theme or prompt\")\n    domain: str = Field(default=\"literary\", description=\"Domain: literary | romance | scifi | thriller | horror | poetry | all\")\n    mode: str = Field(default=\"creative\", description=\"Mode: creative | divergent | exploratory\")\n    steering: float = Field(default=0.3, ge=0.0, le=1.0, description=\"0=pure drift, 1=pure steering\")\n    n: int = Field(default=2, ge=1, le=5, description=\"Number of text variations to generate\")\n    steps: int = Field(default=30, ge=5, le=100, description=\"Drift steps\")\n    seed_moment: Optional[str] = Field(default=None, description=\"Optional seed text to anchor the piece\")\n    constraints: Optional[List[str]] = Field(default=None, description=\"Required elements to include\")\n\n    # BYOK fields — user provides their own LLM credentials\n    provider: str = Field(default=\"openai\", description=\"LLM provider: openai | anthropic | ollama\")\n    api_key: Optional[str] = Field(default=None, description=\"Your LLM API key (BYOK). Not stored.\")\n    model: Optional[str] = Field(default=None, description=\"Override model name (e.g. gpt-4o, claude-sonnet-4)\")\n\n    # Tier (set by you based on their subscription — here is self-serve)\n    tier: str = Field(default=\"free\", description=\"Plan tier: free | starter | pro | enterprise\")\n\n\nclass Variation(BaseModel):\n    id: str\n    text: str\n    concepts: List[str]\n    tensions: List[str]  # \"a / b\" strings\n    regime: str\n    coherence: float\n    entropy: float\n\n\nclass GenerateResponse(BaseModel):\n    variations: List[Variation]\n    meta: dict\n    usage: dict\n\n\n# -------------------------------------------------------------------\n# Rate limiting helpers\n# -------------------------------------------------------------------\n_RATE_LIMITS = {\"free\": 100, \"starter\": 1_000, \"pro\": 10_000, \"enterprise\": float(\"inf\")}\n\ndef _month() -> str:\n    t = time.localtime()\n    return f\"{t.tm_year}-{t.tm_mon:02d}\"\n\ndef _rate_limit(api_key: str, tier: str) -> int:\n    if not api_key:\n        raise HTTPException(status_code=401, detail=\"api_key required for paid tiers\")\n    key = hashlib.sha256(api_key.encode()).hexdigest()[:16]\n    bucket = f\"{key}:{_month()}\"\n    count = _call_store.get(bucket, 0) + 1\n    limit = _RATE_LIMITS.get(tier, 100)\n    if count > limit:\n        raise HTTPException(\n            status_code=429,\n            detail=f\"Monthly limit reached ({limit} calls/month on {tier}). Upgrade at https://spark.api/plans\"\n        )\n    # Patch the store from main — reference it via module global\n    import spark.api.main as _main\n    _main._call_store[bucket] = count\n    return count\n\n\n# -------------------------------------------------------------------\n# Route\n# -------------------------------------------------------------------\n_call_store: dict = {}  # will be shared via spark.api.main\n\n@router.post(\"/generate\", response_model=GenerateResponse)\nasync def generate(req: GenerateRequest):\n    \"\"\"\n    Generate creative text via SPARK's drift chamber.\n\n    The drift chamber runs on our servers (your CPU cost). The LLM call\n    uses YOUR API key — we never see or store it (it's passed directly to\n    your LLM provider and discarded immediately).\n\n    How it works:\n    1. Build thematic concept graph for the domain\n    2. Run drift dynamics — concepts diffuse, decay, get steered by theme\n    3. Extract top-activated concepts + tensions\n    4. Map to prose via your LLM (you pay your provider)\n    \"\"\"\n\n    # Check rate limit\n    if req.tier != \"free\" or req.api_key:\n        count = _rate_limit(req.api_key or \"anon\", req.tier)\n    else:\n        count = 1\n\n    # ── 1. Build + run drift (our CPU cost) ───────────────────────────────\n    try:\n        drift_result = spark_drift(\n            theme=req.theme,\n            domain=req.domain,\n            steering=req.steering,\n            steps=req.steps,\n        )\n    except Exception as e:\n        raise HTTPException(status_code=500, detail=f\"Drift engine error: {e}\")\n\n    activations = drift_result[\"activations\"]\n    top_concepts = drift_result[\"top_concepts\"]\n    tensions = drift_result[\"tensions\"]\n    entropy = drift_result[\"entropy\"]\n    n_strong = drift_result[\"n_strong\"]\n\n    # ── 2. LLM mapping (user's key, user's cost) ──────────────────────────\n    # Determine credentials: request api_key > env var > server-side env\n    _api_key = req.api_key or os.environ.get(\"OPENAI_API_KEY\") or os.environ.get(\"ANTHROPIC_API_KEY\")\n    _provider = req.provider\n\n    if not _api_key:\n        raise HTTPException(\n            status_code=400,\n            detail=\"No LLM API key provided. Pass api_key in request body (BYOK), \"\n                   \"or set OPENAI_API_KEY / ANTHROPIC_API_KEY env var on the server.\"\n        )\n\n    # Set the key in the environ for the mapper (it reads from os.environ)\n    os.environ[f\"{_provider.upper()}_API_KEY\"] = _api_key\n\n    try:\n        mapper = CreativeMapper(provider=_provider, model=req.model)\n    except Exception as e:\n        raise HTTPException(status_code=400, detail=f\"LLM provider init failed: {e}\")\n\n    try:\n        results = mapper.map_concepts_to_text(\n            concept_activations=activations,\n            theme=req.theme,\n            mode=req.mode,\n            n_variations=req.n,\n            seed_moment=req.seed_moment,\n            user_constraints=req.constraints or [],\n        )\n    except Exception as e:\n        raise HTTPException(status_code=502, detail=f\"LLM generation failed: {e}\")\n\n    # ── 3. Build response ────────────────────────────────────────────────\n    regime = \"IMAGINATIVE\" if n_strong > 5 else \"EXPLORING\"\n    coherence = n_strong / max(len(drift_result[\"all_concepts\"]), 1)\n\n    variations = [\n        Variation(\n            id=r[\"id\"],\n            text=r[\"text\"],\n            concepts=r[\"concepts\"][:10],\n            tensions=[f\"{a} / {b}\" for a, b in (r.get(\"tensions\") or tensions)[:3]],\n            regime=regime,\n            coherence=round(coherence, 3),\n            entropy=round(entropy, 3),\n        )\n        for r in results\n    ]\n\n    return GenerateResponse(\n        variations=variations,\n        meta={\n            \"domain\": req.domain,\n            \"mode\": req.mode,\n            \"steering\": req.steering,\n            \"steps\": req.steps,\n            \"provider\": _provider,\n            \"model\": req.model or \"default\",\n            \"n_concepts\": len(drift_result[\"all_concepts\"]),\n            \"strong_concepts\": n_strong,\n            \"drift_entropy\": round(entropy, 3),\n            \"regime\": regime,\n            \"tensions\": [f\"{a}/{b}\" for a, b in tensions],\n            \"top_concepts\": top_concepts[:10],\n        },\n        usage={\n            \"tier\": req.tier,\n            \"monthly_count\": count,\n            \"monthly_limit\": _RATE_LIMITS.get(req.tier, 100),\n            \"llm_cost\": \"paid_by_you\",\n        },\n    )\n\n\n@router.get(\"/domains\")\nasync def list_domains():\n    \"\"\"Available domain configs.\"\"\"\n    return {\n        \"domains\": [\n            {\"id\": \"all\",      \"description\": \"All creative concepts (217)\"}, \n            {\"id\": \"literary\", \"description\": \"Craft, meaning, form, expression\"},\n            {\"id\": \"romance\",  \"description\": \"Love, longing, connection, loss\"},\n            {\"id\": \"scifi\",    \"description\": \"Technology, cosmos, creation\"},\n            {\"id\": \"thriller\", \"description\": \"Tension, power, pursuit, secrets\"},\n            {\"id\": \"horror\",   \"description\": \"Death, dread, flesh, threshold\"},\n            {\"id\": \"poetry\",   \"description\": \"Sensory, image, rhythm, metaphor\"},\n        ],\n        \"modes\": {\n            \"creative\":    \"Balanced drift + steering. Best for general use.\",\n            \"divergent\":  \"High drift, low steering. Maximum surprise.\",\n            \"exploratory\": \"Guided drift. Patient, contemplative.\",\n        },\n    }\n\n\n@router.get(\"/modes\")\nasync def list_modes():\n    \"\"\"Explain the three SPARK modes.\"\"\"\n    return {\n        \"modes\": {\n            \"creative\": {\n                \"description\": \"Balanced drift + steering. Good for most creative tasks.\",\n                \"best_for\": [\"stories\", \"blog posts\", \"thematic exploration\"],\n                \"steering_range\": \"0.2–0.4\",\n            },\n            \"divergent\": {\n                \"description\": \"High drift, minimal steering. Produces unexpected combinations.\",\n                \"best_for\": [\"breaking form\", \"brainstorming\", \"finding surprise connections\"],\n                \"steering_range\": \"0.0–0.2\",\n            },\n            \"exploratory\": {\n                \"description\": \"Patient guided drift. Small things seen clearly.\",\n                \"best_for\": [\"contemplative pieces\", \"poetry\", \"thematic essays\"],\n                \"steering_range\": \"0.3–0.5\",\n            },\n        },\n        \"regimes\": {\n            \"EXPLORING\": \"Low coherence — ideas still diffusing. Good for novelty.\",\n            \"IMAGINATIVE\": \"Good coherence + meaningful spread. The sweet spot.\",\n            \"OPTIMIZED\": \"High coherence, low entropy. Directed but may miss connections.\",\n        },\n    }\n","file_path":"C:\\Users\\Zwmar\\Claw\\projects\\spark\\api\\routes\\creative.py"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.7","usage":{"input":57221,"output":2449,"cacheRead":13610,"cacheWrite":0,"totalTokens":73280,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774279667735}}
