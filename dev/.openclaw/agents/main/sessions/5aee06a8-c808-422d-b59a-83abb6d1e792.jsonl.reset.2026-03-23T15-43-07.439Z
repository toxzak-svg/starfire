{"type":"message","id":"0c4dd7ce","parentId":"5e109cf1","timestamp":"2026-03-23T15:27:47.694Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now let me rewrite `api/main.py` with:\n1. Clean structure\n2. BYOK support (user passes api_key + provider)\n3. Rate limiting by tier (simple in-memory for now, can upgrade to Redis later)\n4. Proper request/response models\n5. The drift is computed server-side (our CPU cost), LLM call uses user's key\n\nThen update `api/routes/creative.py` to use `spark.core.engine` instead of `spark.demo`.","thinkingSignature":"6aff8bb961c5648c687bd773580f1a06027f7f918db4a43f810425ef2b417dd0"},{"type":"text","text":"Now rewrite the API with BYOK, clean models, and tiered rate limiting:\n"},{"type":"toolCall","id":"call_function_2vytc5mgamkb_1","name":"write","arguments":{"content":"\"\"\"\nSPARK API Server\nRun: python -m uvicorn spark.api.main:app --reload --port 8765\n\"\"\"\n\nfrom __future__ import annotations\n\nimport os\nimport time\nimport hashlib\nfrom typing import Optional\nfrom pathlib import Path\n\nimport sys\nsys.path.insert(0, str(Path(__file__).parent.parent))\nsys.path.insert(0, str(Path(__file__).parent.parent.parent))\n\nfrom fastapi import FastAPI, HTTPException, Request\nfrom fastapi.middleware.cors import CORSMiddleware\nfrom pydantic import BaseModel, Field\n\nfrom spark.api.routes.creative import router as creative_router\n\n# -------------------------------------------------------------------\n# Rate limiting store (in-memory, single process)\n# Simple tier-based: free = 100/mo, starter = 1000/mo, pro = 10k/mo\n# -------------------------------------------------------------------\n_RATE_LIMITS = {\n    \"free\":     100,\n    \"starter\":  1_000,\n    \"pro\":     10_000,\n    \"enterprise\": float(\"inf\"),\n}\n\n# (api_key_hash, month_key) → count\n_call_store: dict = {}\n\ndef _month_key() -> str:\n    return f\"{time.localtime().tm_year}-{time.localtime().tm_mon:02d}\"\n\ndef _check_rate_limit(api_key: Optional[str], tier: str = \"free\") -> int:\n    \"\"\"\n    Increment and return current call count for this month.\n    Returns current count after increment.\n    Raises HTTP 429 if over limit.\n    \"\"\"\n    if not api_key:\n        raise HTTPException(status_code=401, detail=\"api_key required\")\n\n    key_hash = hashlib.sha256(api_key.encode()).hexdigest()[:16]\n    bucket = f\"{key_hash}:{_month_key()}\"\n    count = _call_store.get(bucket, 0) + 1\n    limit = _RATE_LIMITS.get(tier, _RATE_LIMITS[\"free\"])\n    if count > limit:\n        raise HTTPException(\n            status_code=429,\n            detail=f\"Monthly rate limit reached ({limit} calls/month on {tier} tier). \"\n                   f\"Upgrade at https://spark.api/plans\"\n        )\n    _call_store[bucket] = count\n    return count\n\n\n# -------------------------------------------------------------------\n# App\n# -------------------------------------------------------------------\napp = FastAPI(\n    title=\"SPARK — Creative Intelligence API\",\n    description=(\n        \"Semantic Pattern Recognition via Associative Drift + Constrained Steering. \"\n        \"Bring your own LLM key — SPARK runs the cognitive engine, you pay your LLM provider directly.\"\n    ),\n    version=\"0.2.0\",\n)\n\napp.add_middleware(\n    CORSMiddleware,\n    allow_origins=[\"*\"],\n    allow_credentials=True,\n    allow_methods=[\"*\"],\n    allow_headers=[\"*\"],\n)\n\napp.include_router(creative_router)\n\n\n@app.get(\"/health\")\nasync def health():\n    return {\"status\": \"ok\", \"service\": \"spark\", \"version\": \"0.2.0\"}\n\n\n@app.get(\"/plans\")\nasync def list_plans():\n    \"\"\"Public plan information.\"\"\"\n    return {\n        \"plans\": [\n            {\"id\": \"free\",     \"name\": \"Free\",      \"calls_per_month\": 100,    \"price\": \"$0\"},\n            {\"id\": \"starter\",  \"name\": \"Starter\",    \"calls_per_month\": 1_000,  \"price\": \"$9/mo\"},\n            {\"id\": \"pro\",      \"name\": \"Pro\",        \"calls_per_month\": 10_000, \"price\": \"$29/mo\"},\n            {\"id\": \"enterprise\",\"name\": \"Enterprise\", \"calls_per_month\": \"unlimited\", \"price\": \"contact\"},\n        ],\n        \"llm_note\": \"You pay your own LLM provider (OpenAI/Anthropic). SPARK is the cognitive engine.\",\n        \"provider_note\": \"Set OPENAI_API_KEY or ANTHROPIC_API_KEY env var to use server-side. \"\n                         \"Or pass api_key in request for BYOK mode.\",\n    }\n","file_path":"C:\\Users\\Zwmar\\Claw\\projects\\spark\\api\\main.py"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.7","usage":{"input":56160,"output":1020,"cacheRead":13610,"cacheWrite":0,"totalTokens":70790,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774279646607}}
