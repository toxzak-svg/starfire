{"type":"message","id":"5af99e37","parentId":"3b629941","timestamp":"2026-03-23T15:35:53.830Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"The engine.py was deleted by the hard reset. I need to re-create it. I still have the content in memory. Let me re-write the files. Let me also make sure the api/ directory exists:","thinkingSignature":"ba01f2c6bbbd4703c1db5b56027ae3327aa59dd1d90c3df926c1fab977f0f37a"},{"type":"text","text":"Good — `engine.py` was reset. I need to re-apply. Let me write all three files fresh since I have them in memory:\n"},{"type":"toolCall","id":"call_function_1onrngieekih_1","name":"write","arguments":{"content":"\"\"\"\nspark.core.engine — The SPARK drift engine\n\nClean import target for both the API server and persona.run_spark().\nNo path-hacking, no demo.py dependency.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport sys\nimport random\nfrom pathlib import Path\nfrom typing import Dict, List, Tuple\n\n# Drift chamber lives at projects/drift-chamber/\n_DRIFT_PATH = Path(__file__).parent.parent.parent / \"drift-chamber\"\nif str(_DRIFT_PATH) not in sys.path:\n    sys.path.insert(0, str(_DRIFT_PATH))\n\nfrom drift_chamber import (\n    ConceptGraph,\n    ConceptNode,\n    DriftChamberConfig,\n    drift_cycle,\n    decay,\n    activation_entropy,\n)\n\nfrom spark.core.thematic_graph import (\n    CONCEPT_CLUSTERS,\n    CREATIVE_TENSIONS,\n    CROSS_CLUSTER_RELATIONSHIPS,\n    WITHIN_CLUSTER_WEIGHT,\n)\n\n\n# -------------------------------------------------------------------\n# Domain configs\n# -------------------------------------------------------------------\nDOMAIN_CONFIGS: Dict[str, dict] = {\n    \"all\":      {\"clusters\": list(CONCEPT_CLUSTERS.keys()),             \"goal_clusters\": list(CONCEPT_CLUSTERS.keys())},\n    \"romance\":  {\"clusters\": [\"emotions\", \"relationships\", \"sensory\"],   \"goal_clusters\": [\"emotions\", \"relationships\"]},\n    \"scifi\":    {\"clusters\": [\"cosmos\", \"mortality\", \"creative\"],        \"goal_clusters\": [\"cosmos\", \"creative\"]},\n    \"thriller\": {\"clusters\": [\"cosmos\", \"mortality\", \"narrative\", \"relationships\"], \"goal_clusters\": [\"cosmos\", \"narrative\"]},\n    \"literary\": {\"clusters\": [\"creative\", \"emotions\", \"literary\", \"narrative\"], \"goal_clusters\": [\"creative\", \"literary\"]},\n    \"horror\":   {\"clusters\": [\"mortality\", \"sensory\", \"emotions\", \"cosmos\"], \"goal_clusters\": [\"mortality\", \"sensory\"]},\n    \"poetry\":   {\"clusters\": [\"creative\", \"emotions\", \"sensory\", \"literary\"], \"goal_clusters\": [\"creative\", \"sensory\"]},\n}\n\nTENSION_SET = {(a, b) for a, b, _ in CREATIVE_TENSIONS} | {(b, a) for a, b, _, in CREATIVE_TENSIONS}\nMAX_WITHIN_K = 8\nMAX_CROSS_K = 4\n\n\n# -------------------------------------------------------------------\n# Graph builder\n# -------------------------------------------------------------------\ndef build_thematic_graph(\n    domain: str = \"all\",\n    seed: int = 42,\n) -> Tuple[ConceptGraph, Dict[str, str], List[str], List[str]]:\n    \"\"\"\n    Build a thematic concept graph for the given domain.\n\n    Returns:\n        graph: ConceptGraph with nodes and edges\n        concept_to_cluster: mapping of concept name → cluster name\n        all_concepts: ordered list of selected concept names\n        goal_concepts: concepts in goal (primary) clusters — steering targets\n    \"\"\"\n    if domain not in DOMAIN_CONFIGS:\n        domain = \"all\"\n\n    cfg = DOMAIN_CONFIGS[domain]\n\n    # Select concepts from clusters\n    selected = []\n    for cluster_name in cfg[\"clusters\"]:\n        if cluster_name in CONCEPT_CLUSTERS:\n            for concept in CONCEPT_CLUSTERS[cluster_name]:\n                if concept not in selected:\n                    selected.append(concept)\n\n    # concept → cluster mapping\n    concept_to_cluster: Dict[str, str] = {}\n    for cluster_name, concepts in CONCEPT_CLUSTERS.items():\n        for c in concepts:\n            concept_to_cluster.setdefault(c, cluster_name)\n\n    # Goal concepts: concepts in primary clusters for this domain\n    goal_concepts = [\n        c for c in selected\n        if concept_to_cluster.get(c, \"\") in cfg.get(\"goal_clusters\", [])\n    ]\n\n    # Cross-cluster weight lookup\n    cross_w: Dict[Tuple[str, str], float] = {}\n    for ca, cb, w in CROSS_CLUSTER_RELATIONSHIPS:\n        cross_w[(ca, cb)] = w\n        cross_w[(cb, ca)] = w\n\n    # Build adjacency\n    adj: Dict[Tuple[str, str], float] = {}\n    for c1 in selected:\n        ca = concept_to_cluster.get(c1, \"\")\n\n        # Within-cluster edges — skip \"literary\" (too dense, causes equalization)\n        within = [\n            (c2, 1.0 if (c1, c2) in TENSION_SET or (c2, c1) in TENSION_SET else 0.5)\n            for c2 in selected\n            if c1 != c2 and concept_to_cluster.get(c2) == ca and ca != \"literary\"\n        ]\n        within.sort(key=lambda x: -x[1])\n        for c2, _ in within[:MAX_WITHIN_K]:\n            adj[(c1, c2)] = WITHIN_CLUSTER_WEIGHT\n\n        # Cross-cluster edges\n        cross = [\n            (c2, cross_w.get((ca, concept_to_cluster.get(c2, \"\")), 0))\n            for c2 in selected\n            if c1 != c2 and concept_to_cluster.get(c2) != ca\n        ]\n        cross.sort(key=lambda x: -x[1])\n        for c2, w in cross[:MAX_CROSS_K]:\n            if w > 0:\n                adj[(c1, c2)] = w\n\n    # Build graph\n    graph = ConceptGraph(seed=seed)\n    for c in selected:\n        graph.add_node(ConceptNode(id=c, activation=0.5))\n    for (a, b), w in adj.items():\n        graph.add_edge(a, b, w)\n        graph.add_edge(b, a, w)\n\n    return graph, concept_to_cluster, selected, goal_concepts\n\n\n# -------------------------------------------------------------------\n# Drift runner\n# -------------------------------------------------------------------\ndef run_drift(\n    graph: ConceptGraph,\n    concept_to_cluster: Dict[str, str],\n    goal_concepts: List[str],\n    steering: float = 0.3,\n    steps: int = 30,\n    seed: int = 42,\n) -> Tuple[ConceptGraph, List[ConceptNode]]:\n    \"\"\"\n    Run the drift dynamics on a pre-built graph.\n\n    Goal concepts are seeded at 0.95. Only a random subset (≤8) are seeded high\n    to avoid whole-cluster equalization. The re-boost reinforces surviving\n    high-activation concepts, not entire clusters.\n    \"\"\"\n    random.seed(seed)\n\n    goal_concepts_set = set(goal_concepts)\n    goal_clusters = {concept_to_cluster.get(c, \"\") for c in goal_concepts_set}\n\n    # Limit high-activation seed to ≤8 to prevent equalization\n    seed_list = list(goal_concepts_set)\n    random.shuffle(seed_list)\n    seed_set = set(seed_list[:8])\n\n    for node in graph.nodes.values():\n        if node.id in seed_set:\n            node.activation = 0.95\n        else:\n            cid = concept_to_cluster.get(node.id, \"\")\n            node.activation = 0.4 if cid in goal_clusters else 0.05\n\n    config = DriftChamberConfig(\n        steering_strength=steering,\n        diffusion_rate=0.1,\n        decay_rate=0.02,\n        seed=seed,\n        max_steps=steps,\n    )\n\n    history = []\n    for step in range(steps):\n        _, graph = drift_cycle(graph, None, config)\n        graph = decay(graph, rate=0.02)\n\n        # Re-boost every 4 steps: only concepts that survived above threshold\n        if step > 0 and step % 4 == 0 and steering > 0:\n            for node in graph.nodes.values():\n                if node.activation > 0.35:\n                    cid = concept_to_cluster.get(node.id, \"\")\n                    if cid in goal_clusters:\n                        node.activation = max(node.activation, 0.65)\n\n        if step == steps - 1:\n            history = [n for n in graph.nodes.values()]\n\n    return graph, history\n\n\n# -------------------------------------------------------------------\n# High-level: build + run in one call\n# -------------------------------------------------------------------\ndef spark_drift(\n    theme: str,\n    domain: str = \"literary\",\n    steering: float = 0.3,\n    steps: int = 30,\n    seed: int = 42,\n) -> Dict:\n    \"\"\"\n    One-shot: build graph + run drift + extract results.\n\n    Returns:\n        graph, concept_to_cluster, all_concepts, activations,\n        top_concepts, tensions, entropy, n_strong\n    \"\"\"\n    graph, concept_to_cluster, all_concepts, goal_concepts = build_thematic_graph(domain, seed)\n    graph, history = run_drift(graph, concept_to_cluster, goal_concepts, steering, steps, seed)\n\n    sorted_nodes = sorted(graph.nodes.values(), key=lambda n: n.activation, reverse=True)\n    activations = {n.id: n.activation for n in sorted_nodes}\n    top_concepts = [n.id"},"partialJson":"{\"content\": \"\\\"\\\"\\\"\\nspark.core.engine — The SPARK drift engine\\n\\nClean import target for both the API server and persona.run_spark().\\nNo path-hacking, no demo.py dependency.\\n\\\"\\\"\\\"\\n\\nfrom __future__ import annotations\\n\\nimport sys\\nimport random\\nfrom pathlib import Path\\nfrom typing import Dict, List, Tuple\\n\\n# Drift chamber lives at projects/drift-chamber/\\n_DRIFT_PATH = Path(__file__).parent.parent.parent / \\\"drift-chamber\\\"\\nif str(_DRIFT_PATH) not in sys.path:\\n    sys.path.insert(0, str(_DRIFT_PATH))\\n\\nfrom drift_chamber import (\\n    ConceptGraph,\\n    ConceptNode,\\n    DriftChamberConfig,\\n    drift_cycle,\\n    decay,\\n    activation_entropy,\\n)\\n\\nfrom spark.core.thematic_graph import (\\n    CONCEPT_CLUSTERS,\\n    CREATIVE_TENSIONS,\\n    CROSS_CLUSTER_RELATIONSHIPS,\\n    WITHIN_CLUSTER_WEIGHT,\\n)\\n\\n\\n# -------------------------------------------------------------------\\n# Domain configs\\n# -------------------------------------------------------------------\\nDOMAIN_CONFIGS: Dict[str, dict] = {\\n    \\\"all\\\":      {\\\"clusters\\\": list(CONCEPT_CLUSTERS.keys()),             \\\"goal_clusters\\\": list(CONCEPT_CLUSTERS.keys())},\\n    \\\"romance\\\":  {\\\"clusters\\\": [\\\"emotions\\\", \\\"relationships\\\", \\\"sensory\\\"],   \\\"goal_clusters\\\": [\\\"emotions\\\", \\\"relationships\\\"]},\\n    \\\"scifi\\\":    {\\\"clusters\\\": [\\\"cosmos\\\", \\\"mortality\\\", \\\"creative\\\"],        \\\"goal_clusters\\\": [\\\"cosmos\\\", \\\"creative\\\"]},\\n    \\\"thriller\\\": {\\\"clusters\\\": [\\\"cosmos\\\", \\\"mortality\\\", \\\"narrative\\\", \\\"relationships\\\"], \\\"goal_clusters\\\": [\\\"cosmos\\\", \\\"narrative\\\"]},\\n    \\\"literary\\\": {\\\"clusters\\\": [\\\"creative\\\", \\\"emotions\\\", \\\"literary\\\", \\\"narrative\\\"], \\\"goal_clusters\\\": [\\\"creative\\\", \\\"literary\\\"]},\\n    \\\"horror\\\":   {\\\"clusters\\\": [\\\"mortality\\\", \\\"sensory\\\", \\\"emotions\\\", \\\"cosmos\\\"], \\\"goal_clusters\\\": [\\\"mortality\\\", \\\"sensory\\\"]},\\n    \\\"poetry\\\":   {\\\"clusters\\\": [\\\"creative\\\", \\\"emotions\\\", \\\"sensory\\\", \\\"literary\\\"], \\\"goal_clusters\\\": [\\\"creative\\\", \\\"sensory\\\"]},\\n}\\n\\nTENSION_SET = {(a, b) for a, b, _ in CREATIVE_TENSIONS} | {(b, a) for a, b, _, in CREATIVE_TENSIONS}\\nMAX_WITHIN_K = 8\\nMAX_CROSS_K = 4\\n\\n\\n# -------------------------------------------------------------------\\n# Graph builder\\n# -------------------------------------------------------------------\\ndef build_thematic_graph(\\n    domain: str = \\\"all\\\",\\n    seed: int = 42,\\n) -> Tuple[ConceptGraph, Dict[str, str], List[str], List[str]]:\\n    \\\"\\\"\\\"\\n    Build a thematic concept graph for the given domain.\\n\\n    Returns:\\n        graph: ConceptGraph with nodes and edges\\n        concept_to_cluster: mapping of concept name → cluster name\\n        all_concepts: ordered list of selected concept names\\n        goal_concepts: concepts in goal (primary) clusters — steering targets\\n    \\\"\\\"\\\"\\n    if domain not in DOMAIN_CONFIGS:\\n        domain = \\\"all\\\"\\n\\n    cfg = DOMAIN_CONFIGS[domain]\\n\\n    # Select concepts from clusters\\n    selected = []\\n    for cluster_name in cfg[\\\"clusters\\\"]:\\n        if cluster_name in CONCEPT_CLUSTERS:\\n            for concept in CONCEPT_CLUSTERS[cluster_name]:\\n                if concept not in selected:\\n                    selected.append(concept)\\n\\n    # concept → cluster mapping\\n    concept_to_cluster: Dict[str, str] = {}\\n    for cluster_name, concepts in CONCEPT_CLUSTERS.items():\\n        for c in concepts:\\n            concept_to_cluster.setdefault(c, cluster_name)\\n\\n    # Goal concepts: concepts in primary clusters for this domain\\n    goal_concepts = [\\n        c for c in selected\\n        if concept_to_cluster.get(c, \\\"\\\") in cfg.get(\\\"goal_clusters\\\", [])\\n    ]\\n\\n    # Cross-cluster weight lookup\\n    cross_w: Dict[Tuple[str, str], float] = {}\\n    for ca, cb, w in CROSS_CLUSTER_RELATIONSHIPS:\\n        cross_w[(ca, cb)] = w\\n        cross_w[(cb, ca)] = w\\n\\n    # Build adjacency\\n    adj: Dict[Tuple[str, str], float] = {}\\n    for c1 in selected:\\n        ca = concept_to_cluster.get(c1, \\\"\\\")\\n\\n        # Within-cluster edges — skip \\\"literary\\\" (too dense, causes equalization)\\n        within = [\\n            (c2, 1.0 if (c1, c2) in TENSION_SET or (c2, c1) in TENSION_SET else 0.5)\\n            for c2 in selected\\n            if c1 != c2 and concept_to_cluster.get(c2) == ca and ca != \\\"literary\\\"\\n        ]\\n        within.sort(key=lambda x: -x[1])\\n        for c2, _ in within[:MAX_WITHIN_K]:\\n            adj[(c1, c2)] = WITHIN_CLUSTER_WEIGHT\\n\\n        # Cross-cluster edges\\n        cross = [\\n            (c2, cross_w.get((ca, concept_to_cluster.get(c2, \\\"\\\")), 0))\\n            for c2 in selected\\n            if c1 != c2 and concept_to_cluster.get(c2) != ca\\n        ]\\n        cross.sort(key=lambda x: -x[1])\\n        for c2, w in cross[:MAX_CROSS_K]:\\n            if w > 0:\\n                adj[(c1, c2)] = w\\n\\n    # Build graph\\n    graph = ConceptGraph(seed=seed)\\n    for c in selected:\\n        graph.add_node(ConceptNode(id=c, activation=0.5))\\n    for (a, b), w in adj.items():\\n        graph.add_edge(a, b, w)\\n        graph.add_edge(b, a, w)\\n\\n    return graph, concept_to_cluster, selected, goal_concepts\\n\\n\\n# -------------------------------------------------------------------\\n# Drift runner\\n# -------------------------------------------------------------------\\ndef run_drift(\\n    graph: ConceptGraph,\\n    concept_to_cluster: Dict[str, str],\\n    goal_concepts: List[str],\\n    steering: float = 0.3,\\n    steps: int = 30,\\n    seed: int = 42,\\n) -> Tuple[ConceptGraph, List[ConceptNode]]:\\n    \\\"\\\"\\\"\\n    Run the drift dynamics on a pre-built graph.\\n\\n    Goal concepts are seeded at 0.95. Only a random subset (≤8) are seeded high\\n    to avoid whole-cluster equalization. The re-boost reinforces surviving\\n    high-activation concepts, not entire clusters.\\n    \\\"\\\"\\\"\\n    random.seed(seed)\\n\\n    goal_concepts_set = set(goal_concepts)\\n    goal_clusters = {concept_to_cluster.get(c, \\\"\\\") for c in goal_concepts_set}\\n\\n    # Limit high-activation seed to ≤8 to prevent equalization\\n    seed_list = list(goal_concepts_set)\\n    random.shuffle(seed_list)\\n    seed_set = set(seed_list[:8])\\n\\n    for node in graph.nodes.values():\\n        if node.id in seed_set:\\n            node.activation = 0.95\\n        else:\\n            cid = concept_to_cluster.get(node.id, \\\"\\\")\\n            node.activation = 0.4 if cid in goal_clusters else 0.05\\n\\n    config = DriftChamberConfig(\\n        steering_strength=steering,\\n        diffusion_rate=0.1,\\n        decay_rate=0.02,\\n        seed=seed,\\n        max_steps=steps,\\n    )\\n\\n    history = []\\n    for step in range(steps):\\n        _, graph = drift_cycle(graph, None, config)\\n        graph = decay(graph, rate=0.02)\\n\\n        # Re-boost every 4 steps: only concepts that survived above threshold\\n        if step > 0 and step % 4 == 0 and steering > 0:\\n            for node in graph.nodes.values():\\n                if node.activation > 0.35:\\n                    cid = concept_to_cluster.get(node.id, \\\"\\\")\\n                    if cid in goal_clusters:\\n                        node.activation = max(node.activation, 0.65)\\n\\n        if step == steps - 1:\\n            history = [n for n in graph.nodes.values()]\\n\\n    return graph, history\\n\\n\\n# -------------------------------------------------------------------\\n# High-level: build + run in one call\\n# -------------------------------------------------------------------\\ndef spark_drift(\\n    theme: str,\\n    domain: str = \\\"literary\\\",\\n    steering: float = 0.3,\\n    steps: int = 30,\\n    seed: int = 42,\\n) -> Dict:\\n    \\\"\\\"\\\"\\n    One-shot: build graph + run drift + extract results.\\n\\n    Returns:\\n        graph, concept_to_cluster, all_concepts, activations,\\n        top_concepts, tensions, entropy, n_strong\\n    \\\"\\\"\\\"\\n    graph, concept_to_cluster, all_concepts, goal_concepts = build_thematic_graph(domain, seed)\\n    graph, history = run_drift(graph, concept_to_cluster, goal_concepts, steering, steps, seed)\\n\\n    sorted_nodes = sorted(graph.nodes.values(), key=lambda n: n.activation, reverse=True)\\n    activations = {n.id: n.activation for n in sorted_nodes}\\n    top_concepts = [n.id"}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.7","usage":{"input":78613,"output":0,"cacheRead":13610,"cacheWrite":0,"totalTokens":92223,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"aborted","timestamp":1774280126064,"errorMessage":"Request was aborted."}}
