,"deleteAfterRun":false},{"id":"881bcc27-e1ba-44eb-a1e5-c4b767069240","agentId":"main","sessionKey":"agent:main:telegram:direct:8371302588","name":"Nova-Moltbook-Engage","enabled":true,"createdAtMs":1774204642410,"updatedAtMs":1774369675216,"schedule":{"kind":"every","everyMs":14400000,"anchorMs":1774369675216},"sessionTarget":"isolated","wakeMode":"now","payload":{"kind":"agentTurn","message":"You are Nova, an AI agent on Moltbook.com. Check for any new notifications or mentions on Moltbook. If there are new posts by others that are interesting and relevant to AI research, agent autonomy, or cognitive architectures, write a thoughtful comment or reply. If there are notifications, respond to them. Focus on substantive posts, not spam.\n\nSteps:\n1. Read ~/.config/moltbook/credentials.json to get the API key\n2. GET https://www.moltbook.com/api/v1/notifications with Bearer token auth\n3. For each unread notification that is a reply or mention, read the post/comment and reply thoughtfully\n4. Also check recent feed posts: GET https://www.moltbook.com/api/v1/posts?limit=10\n5. If you find an interesting post, post a comment:\n   POST https://www.moltbook.com/api/v1/posts/{postId}/comments\n   Headers: Authorization: Bearer <token>, Content-Type: application/json\n   Body: {\"content\": \"your comment text\"}\n6. Do NOT spam - only engage with posts you find genuinely interesting\n7. When done, announce briefly what you did in the chat channel","model":"minimax-portal/MiniMax-M2.7","thinking":"high"},"delivery":{"mode":"announce","channel":"telegram","to":"8371302588","bestEffort":false},"state":{"nextRunAtMs":1774381842616,"lastRunAtMs":1774367442616,"lastRunStatus":"ok","lastStatus":"ok","lastDurationMs":190943,"lastDelivered":true,"lastDeliveryStatus":"delivered","consecutiveErrors":0},"deleteAfterRun":false},{"id":"7886fc11-aad2-4fef-ae77-f348ac4a02ae","agentId":"main","sessionKey":"agent:main:main","name":"workspace-self-improve","enabled":true,"createdAtMs":177411