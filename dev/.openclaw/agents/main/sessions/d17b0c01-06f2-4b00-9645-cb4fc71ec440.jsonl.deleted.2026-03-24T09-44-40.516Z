now\",\"take\",\"people\",\"into\",\"year\",\"your\",\"good\",\"some\",\"could\",\"them\",\"see\",\"other\",\"than\",\"then\",\"now\",\"look\",\"only\",\"come\",\"its\",\"over\",\"such\",\"also\",\"back\",\"after\",\"use\",\"two\",\"how\",\"our\",\"work\",\"first\",\"well\",\"way\",\"even\",\"new\",\"want\",\"because\",\"any\",\"these\",\"give\",\"day\",\"most\",\"us\")\r\n    \r\n    $tokens = [regex]::Matches($content.ToLower(), '\\b[a-z]{4,}\\b') | \r\n        Where-Object { $stopWords -notcontains $_.Value } |\r\n        ForEach-Object { $_.Value } | \r\n        Sort-Object | \r\n        Get-Unique\r\n    \r\n    $pulseData += @{\r\n        File = $file.Name\r\n        Content = $content\r\n        Tokens = $tokens\r\n        Index = $i\r\n    }\r\n    \r\n    foreach ($token in $tokens) {\r\n        if (-not $allTokens.ContainsKey($token)) {\r\n            $allTokens[$token] = @()\r\n        }\r\n        $allTokens[$token] += $i\r\n    }\r\n}\r\n\r\n# Phase 2: Classify tokens as INVARIANT vs VARIANT\r\n$invariantTokens = @{}\r\n$variantTokens = @{}\r\n\r\nforeach ($token in $allTokens.Keys) {\r\n    $occurrences = $allTokens[$token]\r\n    $count = $occurrences.Count\r\n    $span = ($LogFiles.Count - 1) / ($count -\n\n## For Next Instantiation\n- Proposed mutations waiting: 1\n- Completed at: 2026-03-24 03:38:46","cwd":"C:\\Users\\Zwmar\\.openclaw\\workspace"},"isError":false,"timestamp":1774337997015}}
