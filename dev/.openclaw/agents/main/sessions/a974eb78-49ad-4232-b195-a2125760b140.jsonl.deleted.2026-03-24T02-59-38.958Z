{"type":"message","id":"d7067471","parentId":"1afff322","timestamp":"2026-03-23T02:57:00.231Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"The long lines are still there. The script must have reported the issues but didn't actually fix them. Let me re-read the script to understand its behavior.","thinkingSignature":"b1e7a42c8e5f28b43b87c7a9908050b29467deb685531fbbadba34221941f67c"},{"type":"toolCall","id":"call_function_uqgl4uknz5yn_1","name":"read","arguments":{"file_path":"C:\\Users\\Zwmar\\.openclaw\\workspace\\scripts\\workspace_self_improve.py"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.7","usage":{"input":5442,"output":76,"cacheRead":11099,"cacheWrite":0,"totalTokens":16617,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774234614385}}
{"type":"message","id":"0517ce78","parentId":"d7067471","timestamp":"2026-03-23T02:57:00.235Z","message":{"role":"toolResult","toolCallId":"call_function_uqgl4uknz5yn_1","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\n\"\"\"\nWorkspace Self-Improvement Script\nRun periodically to audit and improve the workspace code.\n\nCrons into: memory maintenance, code quality, documentation updates.\n\"\"\"\n\nimport os\nimport re\nimport json\nfrom pathlib import Path\nfrom datetime import datetime, timezone\n\nWORKSPACE = Path(r\"C:\\Users\\Zwmar\\.openclaw\\workspace\")\nREPORT_FILE = WORKSPACE / \"memory\" / \"improvement_report.json\"\n\n\ndef find_python_files():\n    \"\"\"Find all Python files in workspace, excluding venvs and caches.\"\"\"\n    files = []\n    for p in WORKSPACE.rglob(\"*.py\"):\n        if any(x in str(p) for x in [\"venv\", \".venv\", \"__pycache__\", \"node_modules\", \".git\"]):\n            continue\n        files.append(p)\n    return files\n\n\ndef find_markdown_files():\n    \"\"\"Find all markdown files.\"\"\"\n    return list(WORKSPACE.rglob(\"*.md\"))\n\n\ndef check_file_quality(path: Path) -> dict:\n    \"\"\"Audit a single file for quality issues.\"\"\"\n    issues = []\n    try:\n        content = path.read_text(encoding=\"utf-8\")\n        lines = content.split(\"\\n\")\n\n        # Check for TODO/FIXME without owners\n        for i, line in enumerate(lines, 1):\n            if re.match(r\"^\\s*(TODO|FIXME|XXX|HACK):\", line.strip()):\n                if \"[\" not in line:  # No owner tag like [Nova]\n                    issues.append({\"type\": \"untagged_todo\", \"line\": i, \"text\": line.strip()[:80]})\n\n        # Check for missing docstrings in functions\n        if re.search(r\"^def \\w+\\(\", content) and not re.search(r'\"\"\"[^\"]*\"\"\"', content[:500]):\n            if \"SKILL.md\" not in str(path):  # Skills have their own format\n                issues.append({\"type\": \"missing_docstring\", \"count\": len(re.findall(r\"^def \\w+\\(\", content, re.M))})\n\n        # Check line lengths (soft limit at 120)\n        long_lines = [(i + 1, len(l)) for i, l in enumerate(lines) if len(l) > 120]\n        if long_lines:\n            issues.append({\"type\": \"long_lines\", \"count\": len(long_lines), \"examples\": long_lines[:3]})\n\n        # Check for print statements in non-demo code\n        if \"print(\" in content and \"demo\" not in path.stem.lower():\n            print_count = len(re.findall(r\"print\\(\", content))\n            if print_count > 3:\n                issues.append({\"type\": \"excessive_print\", \"count\": print_count})\n\n    except Exception as e:\n        issues.append({\"type\": \"read_error\", \"error\": str(e)})\n\n    return {\"file\": str(path.relative_to(WORKSPACE)), \"issues\": issues}\n\n\ndef check_memory_health() -> dict:\n    \"\"\"Check memory files for staleness and gaps.\"\"\"\n    memory_dir = WORKSPACE / \"memory\"\n    if not memory_dir.exists():\n        return {\"status\": \"no_memory_dir\", \"files\": [], \"issues\": []}\n\n    today = datetime.now(timezone.utc).date()\n    recent_files = []\n\n    for f in memory_dir.glob(\"*.md\"):\n        mtime = datetime.fromtimestamp(f.stat().st_mtime, tz=timezone.utc).date()\n        age = (today - mtime).days\n        recent_files.append({\"file\": f.name, \"age_days\": age, \"mtime\": str(mtime)})\n\n    # Check MEMORY.md for staleness\n    mem_file = memory_dir / \"MEMORY.md\"\n    mem_issues = []\n    if mem_file.exists():\n        content = mem_file.read_text(encoding=\"utf-8\")\n        if len(content) < 100:\n            mem_issues.append(\"MEMORY.md is very small, may need population\")\n        # Check last update date in content\n        date_match = re.search(r\"(20\\d\\d-\\d\\d-\\d\\d)\", content)\n        if date_match:\n            last_date = datetime.strptime(date_match.group(1), \"%Y-%m-%d\").date()\n            age = (today - last_date).days\n            if age > 7:\n                mem_issues.append(f\"MEMORY.md not updated in {age} days\")\n    else:\n        mem_issues.append(\"MEMORY.md does not exist\")\n\n    return {\n        \"memory_files\": len(recent_files),\n        \"files\": recent_files,\n        \"issues\": mem_issues,\n    }\n\n\ndef check_identity_bootstrap() -> dict:\n    \"\"\"Check if IDENTITY.md and USER.md are properly filled in.\"\"\"\n    issues = []\n    identity = WORKSPACE / \"IDENTITY.md\"\n    user = WORKSPACE / \"USER.md\"\n\n    if identity.exists():\n        content = identity.read_text()\n        if \"Fill this in\" in content or len(content) < 100:\n            issues.append(\"IDENTITY.md not fully filled in\")\n    else:\n        issues.append(\"IDENTITY.md missing\")\n\n    if user.exists():\n        content = user.read_text()\n        if \"Learn about\" in content or len(content) < 100:\n            issues.append(\"USER.md not fully filled in\")\n    else:\n        issues.append(\"USER.md missing\")\n\n    return {\"issues\": issues}\n\n\ndef generate_report() -> dict:\n    \"\"\"Run all checks and generate a report.\"\"\"\n    py_files = find_python_files()\n    md_files = find_markdown_files()\n\n    file_reports = [check_file_quality(f) for f in py_files]\n    memory_health = check_memory_health()\n    identity_health = check_identity_bootstrap()\n\n    # Aggregate issue counts\n    issue_counts = {}\n    for fr in file_reports:\n        for issue in fr[\"issues\"]:\n            t = issue[\"type\"]\n            issue_counts[t] = issue_counts.get(t, 0) + 1\n\n    report = {\n        \"timestamp\": datetime.now(timezone.utc).isoformat(),\n        \"files_checked\": len(py_files),\n        \"issue_counts\": issue_counts,\n        \"file_reports\": [fr for fr in file_reports if fr[\"issues\"]],\n        \"memory_health\": memory_health,\n        \"identity_health\": identity_health,\n        \"top_issues\": [\n            {\"type\": t, \"count\": c}\n            for t, c in sorted(issue_counts.items(), key=lambda x: -x[1])[:5]\n        ],\n    }\n\n    # Save report\n    REPORT_FILE.parent.mkdir(parents=True, exist_ok=True)\n    REPORT_FILE.write_text(json.dumps(report, indent=2))\n\n    return report\n\n\ndef apply_fixes(report: dict):\n    \"\"\"Apply auto-fixable issues.\"\"\"\n    fixed = []\n    for fr in report[\"file_reports\"]:\n        path = WORKSPACE / fr[\"file\"]\n        if not path.exists():\n            continue\n        try:\n            content = path.read_text(encoding=\"utf-8\")\n            original = content\n            for issue in fr[\"issues\"]:\n                if issue[\"type\"] == \"long_lines\":\n                    # Wrap lines > 120 chars (simple heuristic)\n                    lines = content.split(\"\\n\")\n                    new_lines = []\n                    for line in lines:\n                        if len(line) > 120 and \"http\" not in line and not line.strip().startswith(\"#\"):\n                            # Try to wrap at a space\n                            if \"    \" in line:\n                                parts = line.split(\"    \", 1)\n                                new_lines.append(parts[0].strip())\n                                new_lines.append(\"    \" + parts[1].strip())\n                            else:\n                                new_lines.append(line)\n                        else:\n                            new_lines.append(line)\n                    content = \"\\n\".join(new_lines)\n            if content != original:\n                path.write_text(content, encoding=\"utf-8\")\n                fixed.append(f\"Wrapped long lines in {fr['file']}\")\n        except Exception as e:\n            pass  # Skip files that can't be read\n\n    return fixed\n\n\nif __name__ == \"__main__\":\n    report = generate_report()\n    fixed = apply_fixes(report)\n    summary = f\"Workspace self-improve: {report['files_checked']} files checked, {len(fixed)} auto-fixed.\"\n    if report[\"top_issues\"]:\n        summary += \" | \" + \", \".join(f\"{i['type']}:{i['count']}\" for i in report[\"top_issues\"])\n    print(summary)\n"}],"isError":false,"timestamp":1774234620234}}
