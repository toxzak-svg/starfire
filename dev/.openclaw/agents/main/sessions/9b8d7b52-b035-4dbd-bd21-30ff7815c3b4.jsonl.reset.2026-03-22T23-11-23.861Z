rences from Python source using ast.\"\"\"\n\n def __init__(self, root: str):\n self.root = Path(root).resolve()\n self.definitions: list[Definition] = []\n self.references: list[Reference] = []\n self._module_stack: list[str] = [] # current module path\n\n def analyze(self) -> tuple[list[Definition], list[Reference]]:\n \"\"\"Run analysis on all Python files under root.\"\"\"\n for filepath in self._find_python_files():\n self._analyze_file(filepath)\n return self.definitions, self.references\n\n def _find_python_files(self) -> Generator[Path, None, None]:\n \"\"\"Find all .py files, excluding __pycache__, .git, etc.\"\"\"\n exclude_dirs = {\"__pycache__\", \".git\", \".pytest_cache\", \"node_modules\", \".venv\", \"venv\", \"env\"}\n for root, dirs, files in os.walk(self.root):\n dirs[:] = [d for d in dirs if d not in exclude_dirs]\n for f in files:\n\n[328 more lines in file. Use offset=70 to continue.]\nNova (2026-03-22T20:42:25.562Z)\n\nTool (2026-03-22T20:42:28.776Z)\n if f.endswith(\".py\") and not f.startswith(\".\"):\n yield Path(root) / f\n\n def _analyze_file(self, filepath: Path) -> None:\n \"\"\"Parse one Python file.\"\"\"\n try:\n source = filepath.read_text(encoding=\"utf-8\")\n except (UnicodeDecodeError, PermissionError):\n return\n\n # Compute module name from file path\n rel = filepath.relative_to(self.root)\n module_parts = list(rel.parts)[:-1] # remove filename\n module_name = \".\".join(module_parts) if module_parts else \"\"\n self._module_stack.append(module_name)\n\n[313 more lines in file. Use offset=85 to continue.]\nNova (2026-03-22T20:42:28.794Z)\n\nTool (2026-03-22T20:42:39.686Z)\nSuccessfully replaced text in C:/dev/code-cause/src/causal_indexer/static_analyzer.py.\nNova (2026-03-22T20:42:39.701Z)\nAlso need to fix reference resolution in the graph builder — `kv_evict.BlockManager` needs to map to the actual node even though the directory is `kv-eviction-optimizer`:\n\nTool (2026-03-22T20:42:50.941Z)\n self.nodes: dict[str, Node] = {}\n self.edges: list[Edge] = []\n self._outgoing: dict[str, list[str]] = defaultdict(list) # name -> [dependents]\n self._incoming: dict[str, list[str]] = defaultdict(list) # name -> [dependencies]\n self._def_map: dict[str, Definition] = {}\n\n # ─── Building ───────────────────────────────────────────────────────────\n\n def add_definition(self, defn: Definition) -> None:\n \"\"\"Add a definition as a node.\"\"\"\n node = Node(\n qualified_name=defn.fully_qualified,\n kind=defn.kind,\n file_path=defn.file_path,\n lineno=defn.lineno,\n end_lineno=defn.end_lineno,\n docstring=defn.docstring,\n )\n self.nodes[defn.fully_qualified] = node\n self._def_map[defn.fully_qualified] = defn\n\n def add_reference(self, ref: Reference) -> None:\n \"\"\"Add a reference as a directed edge.\"\"\"\n if ref.target_qualified not in self.nodes:\n # Unknown target — still record the edge but mark as external\n self.nodes[ref.target_qualified] = Node(\n qualified_name=ref.target_qualified,\n kind=\"external\",\n file_path=ref.file_path,\n lineno=ref.lineno,\n\n[214 more lines in file. Use offset=90 to continue.]\nNova (2026-03-22T20:42:50.959Z)\n\nTool (2026-03-22T20:42:56.369Z)\n file_path=ref.file_path,\n lineno=ref.lineno,\n )\n\n edge = Edge(\n source=ref.source_qualified,\n target=ref.target_qualified,\n kind=ref.kind,\n file_path=ref.file_path,\n lineno=ref.lineno,\n )\n self.edges.append(edge)\n self._outgoing[ref.source_qualified].append(ref.target_qualified)\n self._incoming[ref.target_qualified].append(ref.source_qualified)\n\n @classmethod\n def from_analysis(cls, definitions: list[Definition], references: list[Reference]) -> \"CausalGraph\":\n \"\"\"Build a causal graph from static analysis results.\"\"\"\n graph = cls()\n\n # Deduplicate definitions (take first seen)\n seen_defs: set[str] = set()\n for d in definitions:\n if d.fully_qualified not in seen_defs:\n graph.add_definition(d)\n\n[191 more lines in file. Use offset=113 to continue.]\nNova (2026-03-22T20:42:56.386Z)\