{"type":"message","id":"90522e40","parentId":"51f1206a","timestamp":"2026-03-22T23:06:23.307Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now let me create a CLI script for dynamic tracing, and test it.","thinkingSignature":"e378d7ef3404bfdfe36c05f8007f8fe1e5ff3a179a7d71de6d95c0d95ef9fb15"},{"type":"text","text":"Now create a test script to verify the tracer works:\n"},{"type":"toolCall","id":"call_function_49j0rv9bqj6z_1","name":"write","arguments":{"path":"C:\\Users\\Zwmar\\.openclaw\\workspace\\test_tracer.py","content":"#!/usr/bin/env python3\n\"\"\"\ntest_dynamic_tracer.py\nTest the dynamic tracer on a real codebase.\n\"\"\"\nimport sys\nimport time\nfrom pathlib import Path\n\n# Add code-cause to path\nsys.path.insert(0, str(Path(__file__).parent.parent / \"src\"))\n\nfrom causal_indexer import DynamicTracer, QueryEngine\n\n\ndef test_on_temporal_attention():\n    \"\"\"Trace the temporal attention test suite.\"\"\"\n    print(\"=\" * 60)\n    print(\"Testing DynamicTracer on temporal-attention\")\n    print(\"=\" * 60)\n\n    # Import the module to trace\n    sys.path.insert(0, \"C:/dev/temporal-attention\")\n    from src.temporal_attention.core import EventBasedStore, TemporalOnlyStore\n\n    with DynamicTracer(\"C:/dev/temporal-attention\") as tracer:\n        # Run some code\n        store = EventBasedStore(max_events=100, time_horizon=3600.0)\n        store.put(\"msg1\", \"hello\", importance=1.0)\n        store.put(\"msg2\", \"world\", importance=0.8)\n        store.access(\"msg1\")\n        results = store.get(\"msg1\")\n        store.advance(10.0)\n\n        # Also test the temporal-only store\n        tstore = TemporalOnlyStore(max_events=50, time_horizon=600.0)\n        tstore.put(\"a\", \"alpha\", timestamp=0.0)\n        tstore.put(\"b\", \"beta\", timestamp=5.0)\n        tstore.get(\"a\", current_time=3.0)\n\n    stats = tracer.stats()\n    print(f\"\\nTrace stats: {stats}\")\n\n    graph = tracer.build_graph()\n    gstats = graph.stats()\n    print(f\"Graph: {gstats['total_nodes']} nodes, {gstats['total_edges']} edges\")\n\n    # Show top called functions\n    nodes_with_calls = [\n        (name, data.get(\"call_count\", 0))\n        for name, data in [\n            (name, getattr(graph.nodes.get(name), \"call_count\", 0) or\n             (graph.nodes.get(name).__dict__ if graph.nodes.get(name) else {}))\n            for name in list(graph.nodes.keys())[:20]\n        ]\n    ]\n\n    # Re-query the nodes properly\n    print(\"\\nTop functions by call count:\")\n    node_call_counts = []\n    for name, node in list(graph.nodes.items())[:50]:\n        # Count incoming edges as a proxy for how often called\n        inc = len(graph._incoming.get(name, []))\n        node_call_counts.append((name, inc))\n    node_call_counts.sort(key=lambda x: -x[1])\n    for name, count in node_call_counts[:10]:\n        print(f\"  {count:4d} {name}\")\n\n    print(\"\\nSample causal query: what does EventBasedStore.advance affect?\")\n    engine = QueryEngine(graph)\n    results = engine.query(\"what does EventBasedStore.advance affect\")\n    print(f\"  {len(results)} results\")\n    for r in results[:5]:\n        print(f\"    [{r.kind}] {r.entity}\")\n\n    # Save graph\n    output = \"C:/dev/temporal-attention_dynamic_trace.json\"\n    graph.save(output)\n    print(f\"\\nSaved: {output}\")\n    return graph\n\n\ndef test_on_code_cause():\n    \"\"\"Trace the causal indexer itself.\"\"\"\n    print(\"\\n\" + \"=\" * 60)\n    print(\"Testing DynamicTracer on causal_indexer itself\")\n    print(\"=\" * 60)\n\n    sys.path.insert(0, \"C:/dev/code-cause/src\")\n    from causal_indexer import StaticAnalyzer\n\n    with DynamicTracer(\"C:/dev/code-cause\") as tracer:\n        analyzer = StaticAnalyzer(\"C:/dev/code-cause/src/causal_indexer\")\n        analyzer.analyze()\n\n    stats = tracer.stats()\n    print(f\"\\nTrace stats: {stats}\")\n\n    graph = tracer.build_graph()\n    gstats = graph.stats()\n    print(f\"Graph: {gstats['total_nodes']} nodes, {gstats['total_edges']} edges\")\n\n    # Show what actually got called\n    print(\"\\nFunctions called during analysis:\")\n    for name, node in list(graph.nodes.items())[:15]:\n        inc = len(graph._incoming.get(name, []))\n        out = len(graph._outgoing.get(name, []))\n        print(f\"  {name}: {inc} incoming, {out} outgoing\")\n\n    output = \"C:/dev/code-cause_dynamic_trace.json\"\n    graph.save(output)\n    print(f\"\\nSaved: {output}\")\n\n\nif __name__ == \"__main__\":\n    test_on_code_cause()\n    test_on_temporal_attention()\n    print(\"\\nDone!\")\n"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.7","usage":{"input":53552,"output":1074,"cacheRead":12619,"cacheWrite":0,"totalTokens":67245,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774220762307}}
