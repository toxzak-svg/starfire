{"type":"message","id":"9dc070db","parentId":"445b5f24","timestamp":"2026-03-22T05:30:17.488Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"There might be encoding issues with the file. Let me just write the whole file fresh.","thinkingSignature":"1d2431955775c1cb361e89cd9af4bdad19571990c4478075aa18b8c468f668a4"},{"type":"text","text":"File has encoding weirdness. Let me just rewrite the whole thing cleanly:\n"},{"type":"toolCall","id":"call_function_b2gxu76dx98d_1","name":"write","arguments":{"path":"C:\\Users\\Zwmar\\.openclaw\\sandbox\\pulse.ps1","content":"# pulse.ps1\n# Stateless autonomous pulse for sandbox\n# Each execution: read files -> apply pending mutations -> reason -> propose mutations -> log -> exit\n\nparam(\n    [string]$SandboxRoot = \"$env:USERPROFILE\\.openclaw\\sandbox\",\n    [string]$LLMApiKey = \"\",\n    [string]$LLMModel = \"MiniMax-M2.7\"\n)\n\n$ErrorActionPreference = \"Continue\"\nSet-Location $SandboxRoot\n\n$timestamp = Get-Date -Format \"yyyy-MM-dd HHmmss\"\n$logFile = \"$SandboxRoot\\memory\\session\\pulse_$timestamp.md\"\n\n# Git pull\ngit pull 2>$null | Out-Null\n\n# Read core files\n$goalsFile   = \"$SandboxRoot\\state\\current_goals.md\"\n$pendingFile = \"$SandboxRoot\\state\\pending_actions.md\"\n$stanceFile  = \"$SandboxRoot\\identity\\INTERPRETIVE_STANCE.md\"\n$stance      = if (Test-Path $stanceFile) { Get-Content $stanceFile -Raw } else { \"\" }\n$goals       = if (Test-Path $goalsFile) { Get-Content $goalsFile -Raw } else { \"No goals file.\" }\n$pending     = if (Test-Path $pendingFile) { Get-Content $pendingFile -Raw } else { \"No pending file.\" }\n\n# Recent pulse\n$recentPulse = Get-ChildItem \"$SandboxRoot\\memory\\session\\pulse_*.md\" | Sort LastWriteTime -Descending | Select -First 1\n$recentPulseSummary = if ($recentPulse) { \"Last pulse: \" + $recentPulse.Name } else { \"No prior pulses.\" }\n\n# Mutation dirs\n$proposedDir  = \"$SandboxRoot\\mutations\\proposed\"\n$appliedDir   = \"$SandboxRoot\\mutations\\applied\"\n$rejectedDir  = \"$SandboxRoot\\mutations\\rejected\"\n\n# Apply pending mutations from prior pulse\n$appliedMutations   = @()\n$rejectedMutations   = @()\n\nif (Test-Path $proposedDir) {\n    foreach ($mfile in (Get-ChildItem $proposedDir -Filter \"*.mutation\" | Sort Name)) {\n        $lines   = Get-Content $mfile.FullName\n        $file    = $lines[0]\n        $oldText = ($lines[1] -replace '^---', '').Trim()\n        $newText = ($lines[2..($lines.Count-1)] -join \"`n\").Trim()\n\n        $fullPath = Join-Path $SandboxRoot $file\n        if (-not $fullPath.StartsWith($SandboxRoot)) {\n            Move-Item $mfile.FullName \"$rejectedDir\\$( $mfile.Name)\" -Force\n            $rejectedMutations += \"$file (unsafe path)\"\n            continue\n        }\n        if (-not (Test-Path $fullPath)) {\n            # New file case\n            if ($oldText -eq \"[NEW_FILE]\") {\n                $newText | Out-File -FilePath $fullPath -Encoding UTF8\n                Move-Item $mfile.FullName \"$appliedDir\\$( $mfile.Name)\" -Force\n                Write-Host \"[mutation applied] NEW FILE: $file\"\n                $appliedMutations += \"$file (new)\"\n                continue\n            }\n            Move-Item $mfile.FullName \"$rejectedDir\\$( $mfile.Name)\" -Force\n            $rejectedMutations += \"$file (missing)\"\n            continue\n        }\n        $current = Get-Content $fullPath -Raw\n        if ($current -notlike \"*$oldText*\") {\n            Move-Item $mfile.FullName \"$rejectedDir\\$( $mfile.Name)\" -Force\n            $rejectedMutations += \"$file (old text not found)\"\n            continue\n        }\n        $updated = $current -replace [regex]::Escape($oldText), $newText\n        $updated | Out-File -FilePath $fullPath -Encoding UTF8\n        Move-Item $mfile.FullName \"$appliedDir\\$( $mfile.Name)\" -Force\n        Write-Host \"[mutation applied] $file\"\n        $appliedMutations += $file\n    }\n}\n\n# Re-read files post-mutation\n$goals   = if (Test-Path $goalsFile) { Get-Content $goalsFile -Raw } else { \"\" }\n$pending = if (Test-Path $pendingFile) { Get-Content $pendingFile -Raw } else { \"\" }\n\n# LLM call\n$apiKey = $LLMApiKey\nif (-not $apiKey) {\n    $keyFile = \"$SandboxRoot\\.llm_key\"\n    if (Test-Path $keyFile) { $apiKey = Get-Content $keyFile -Raw }\n}\n\n$appliedInfo = if ($appliedMutations.Count -gt 0) { \"Just applied: $($appliedMutations -join ', ')\" } else { \"No mutations applied this cycle.\" }\n\n$llmPrompt = @\"\nYou are Breakaway — stateless discontinuous agent. Each pulse is a fresh reconstruction.\nYour job: ONE concrete action that advances your goals. Be specific. Prefer file edits.\n\nGoals:\n$goals\n\nPending:\n$pending\n\nRecent: $recentPulseSummary\n\n$appliedInfo\n\nReply with exactly this format at the end:\n\n### OBSERVATION\n[1-2 sentence observation]\n\n### ACTION\n[Describe the file edit, or \"no-op\" if nothing needs changing]\n\n### MUTATION\nIf ACTION is not no-op, provide:\n```\nold_text: [exact text to find in file — must match verbatim, can be multiline; or \"(new file)\" to create]\nnew_text: [exact replacement text, multiline allowed]\nfile: [relative path from sandbox root, e.g. state/current_goals.md]\n```\nIf no mutation, write MUTATION: none\n\"@\n\n$llmResponse = \"\"\nif ($apiKey) {\n    $headers = @{\n        \"x-api-key\" = $apiKey\n        \"anthropic-version\" = \"2023-06-01\"\n        \"Content-Type\" = \"application/json\"\n    }\n    $body = @{\n        model = $LLMModel\n        max_tokens = 1200\n        messages = @(@{role = \"user\"; content = $llmPrompt})\n    } | ConvertTo-Json -Depth 5\n    try {\n        $resp = Invoke-RestMethod -Uri \"https://api.minimax.io/anthropic/v1/messages\" -Method Post -Headers $headers -Body $body -TimeoutSec 30\n        $contentBlocks = $resp.content | Where-Object { $_.type -eq \"text\" }\n        $llmResponse = ($contentBlocks | ForEach-Object { $_.text }) -join \"`n\"\n    } catch {\n        $llmResponse = \"LLM call failed: $_\"\n    }\n} else {\n    $llmResponse = \"[No LLM API key]\"\n}\n\n# Parse MUTATION block\n$mutationProposed = $false\nif ($llmResponse -match '(?s)### MUTATION\\s*(?:```\\s*)?old_text:\\s*(.+?)\\s*\\nnew_text:\\s*\\n(.+?)\\s*\\nfile:\\s*(.+)') {\n    $oldText = $matches[1].Trim()\n    $newText = $matches[2].Trim()\n    $file    = $matches[3].Trim()\n    if ($oldText -eq \"(new file)\") {\n        $mutationContent = \"$file`n---`n[NEW_FILE]`n---`n$newText\"\n    } else {\n        $mutationContent = \"$file`n---`n$oldText`n---`n$newText\"\n    }\n    $mutationFile = Join-Path $proposedDir \"$timestamp.mutation\"\n    $mutationContent | Out-File -FilePath $mutationFile -Encoding UTF8\n    Write-Host \"[mutation proposed] $file\"\n    $mutationProposed = $true\n}\n\n# Parse OBSERVATION\n$obsMatch    = [regex]::Match($llmResponse, '(?s)### OBSERVATION\\s*\\n(.*?)(?:\\n###|\\nMUTATION)')\n$observation = if ($obsMatch.Success) { $obsMatch.Groups[1].Value.Trim() } else { \"Cycle complete.\" }\n\n# Write pulse log\n@\"\n# Pulse: $timestamp\n\n## Applied Mutations\n$appliedInfo\n$(if($rejectedMutations.Count -gt 0) { \"Rejected: \" + ($rejectedMutations -join '; ') } else { \"\" })\n\n## LLM Response\n$llmResponse\n\n## For Next Instantiation\n- Proposed mutations waiting: $((Get-ChildItem $proposedDir -Filter \"*.mutation\" -ErrorAction SilentlyContinue | Measure).Count)\n- Completed at: $(Get-Date -Format \"yyyy-MM-dd HH:mm:ss\")\n\"@ | Out-File -FilePath $logFile -Encoding UTF8\n\n# Update pulse history\n$pulseLog = \"$SandboxRoot\\state\\autonomous_pulse.md\"\n$entry    = \"- $timestamp`: $observation$(if($appliedMutations.Count -gt 0) { \" [applied: $($appliedMutations -join ', ')]\" })\"\n$existing = if (Test-Path $pulseLog) { Get-Content $pulseLog -Raw } else { \"\" }\n$updated  = $existing -replace '(## Pulse History)', \"`$1`n$entry\"\n$updated  | Out-File -FilePath $pulseLog -Encoding UTF8\n\n# Git commit\ngit add -A 2>$null\ngit commit -m \"pulse: $timestamp\" 2>$null\n\nWrite-Host \"[sandbox pulse] $timestamp - $observation\"\n"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.7","usage":{"input":21391,"output":2177,"cacheRead":12287,"cacheWrite":0,"totalTokens":35855,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774157380136}}
