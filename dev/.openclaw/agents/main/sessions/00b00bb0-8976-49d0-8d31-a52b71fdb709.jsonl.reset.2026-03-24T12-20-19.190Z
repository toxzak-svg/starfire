{"type":"message","id":"1d55bdc8","parentId":"77c6f649","timestamp":"2026-03-24T04:47:24.743Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"The POST endpoint works and correctly returns an error because Ollama hasn't been started. The issue with the health endpoint before was that the background thread was somehow blocking. Let me now re-add the background startup, but in a way that truly doesn't block.\n\nThe correct approach in FastAPI: use `BackgroundTasks` from fastapi. Let me add it back properly.\n\nActually, the issue was probably something else - let me check if the background task was somehow causing the request to never return.\n\nLet me try adding the background startup back using a simple approach - a start of day trigger via a startup event or lifecycle hook.\n\nActually, the issue with the daemon thread was likely that it didn't help because the module-level `_ollama_state` was shared but the state changes from the thread might not have been visible, OR the module was reloaded on each cold start and the state reset.\n\n\nI'll use FastAPI's lifespan context manager to handle startup operations before the web server begins accepting requests.","thinkingSignature":"0983cfc7d5d6c245c36a3be6794409493044315968be13b59eddff1aed472819"},{"type":"text","text":"POST works, returns proper error when Ollama isn't ready. Now let me add proper startup — run Ollama when the container starts, before the web server accepts traffic:\n"},{"type":"toolCall","id":"call_function_3pmt0udxtvdm_1","name":"edit","arguments":{"path":"C:\\Users\\Zwmar\\.openclaw\\workspace\\spark\\modal_spark.py","oldText":"@app.function(image=_image, timeout=3600, scaledown_window=600, gpu=\"A100\")\n@modal.asgi_app(label=\"spark-ollama\")\ndef api():\n    from fastapi import FastAPI\n    from fastapi.responses import HTMLResponse\n    import httpx\n\n    api = FastAPI()\n\n    @api.get(\"/\", response_class=HTMLResponse)\n    async def root():\n        return HTMLResponse(content=UI_HTML, status_code=200)\n\n    @api.get(\"/health\")\n    async def health():\n        return {\n            \"status\": \"ok\",\n            \"ollama\": _ollama_state[\"status\"],\n            \"model\": MODEL_NAME,\n        }\n\n    @api.post(\"/generate\")\n    async def generate(req: dict):\n        if _ollama_state[\"status\"] != \"ready\":\n            return {\"error\": f\"Ollama not ready (status: {_ollama_state['status']})\"}\n\n        prompt = req.get(\"prompt\", \"\")\n        temperature = req.get(\"temperature\", 0.7)\n        num_predict = req.get(\"num_predict\", 300)\n        async with httpx.AsyncClient(timeout=120.0) as c:\n            r = await c.post(\n                f\"http://127.0.0.1:{OLLAMA_PORT}/api/generate\",\n                json={\"model\": MODEL_NAME, \"prompt\": prompt,\n                      \"temperature\": temperature, \"num_predict\": num_predict, \"stream\": False}\n            )\n            r.raise_for_status()\n            return r.json()\n\n    @api.post(\"/benchmarks\")\n    async def benchmarks():\n        if _ollama_state[\"status\"] != \"ready\":\n            return {\"error\": f\"Ollama not ready (status: {_ollama_state['status']}). Try again in a few minutes.\"}\n\n        BENCHMARK_PROMPTS = {\"gsm8k\": GSM8K, \"reasoning\": REASONING, \"code\": CODE}\n        results = {\"benchmarks\": [], \"timestamp\": time.time()}\n        for bench_name, prompts in BENCHMARK_PROMPTS.items():\n            bench_results, latencies = [], []\n            for prompt in prompts:\n                t0 = time.perf_counter()\n                try:\n                    async with httpx.AsyncClient(timeout=120.0) as c:\n                        r = await c.post(\n                            f\"http://127.0.0.1:{OLLAMA_PORT}/api/generate\",\n                            json={\"model\": MODEL_NAME, \"prompt\": prompt,\n                                  \"temperature\": 0.7, \"num_predict\": 300, \"stream\": False}\n                        )\n                        r.raise_for_status()\n                        response_text = r.json().get(\"response\", \"\")\n                except Exception as e:\n                    response_text = f\"ERROR: {str(e)}\"\n                latency = time.perf_counter() - t0\n                latencies.append(latency)\n                bench_results.append({\"prompt\": prompt, \"response\": response_text, \"latency_s\": round(latency, 3)})\n            results[\"benchmarks\"].append({\n                \"name\": bench_name, \"num_prompts\": len(prompts),\n                \"avg_latency_s\": round(statistics.mean(latencies), 3),\n                \"total_time_s\": round(sum(latencies), 3), \"results\": bench_results,\n            })\n        return results\n\n    return api","newText":"@app.function(image=_image, timeout=3600, scaledown_window=600, gpu=\"A100\")\n@modal.asgi_app(label=\"spark-ollama\")\ndef api():\n    from fastapi import FastAPI, LifespanContext\n    from fastapi.responses import HTMLResponse\n    import httpx\n\n    api = FastAPI()\n\n    @api.get(\"/\", response_class=HTMLResponse)\n    async def root():\n        return HTMLResponse(content=UI_HTML, status_code=200)\n\n    @api.get(\"/health\")\n    async def health():\n        return {\n            \"status\": \"ok\",\n            \"ollama\": _ollama_state[\"status\"],\n            \"model\": MODEL_NAME,\n        }\n\n    @api.post(\"/generate\")\n    async def generate(req: dict):\n        if _ollama_state[\"status\"] != \"ready\":\n            return {\"error\": f\"Ollama not ready (status: {_ollama_state['status']})\"}\n        prompt = req.get(\"prompt\", \"\")\n        temperature = req.get(\"temperature\", 0.7)\n        num_predict = req.get(\"num_predict\", 300)\n        async with httpx.AsyncClient(timeout=120.0) as c:\n            r = await c.post(\n                f\"http://127.0.0.1:{OLLAMA_PORT}/api/generate\",\n                json={\"model\": MODEL_NAME, \"prompt\": prompt,\n                      \"temperature\": temperature, \"num_predict\": num_predict, \"stream\": False}\n            )\n            r.raise_for_status()\n            return r.json()\n\n    @api.post(\"/benchmarks\")\n    async def benchmarks():\n        if _ollama_state[\"status\"] != \"ready\":\n            return {\"error\": f\"Ollama not ready (status: {_ollama_state['status']}). Try again in a few minutes.\"}\n        BENCHMARK_PROMPTS = {\"gsm8k\": GSM8K, \"reasoning\": REASONING, \"code\": CODE}\n        results = {\"benchmarks\": [], \"timestamp\": time.time()}\n        for bench_name, prompts in BENCHMARK_PROMPTS.items():\n            bench_results, latencies = [], []\n            for prompt in prompts:\n                t0 = time.perf_counter()\n                try:\n                    async with httpx.AsyncClient(timeout=120.0) as c:\n                        r = await c.post(\n                            f\"http://127.0.0.1:{OLLAMA_PORT}/api/generate\",\n                            json={\"model\": MODEL_NAME, \"prompt\": prompt,\n                                  \"temperature\": 0.7, \"num_predict\": 300, \"stream\": False}\n                        )\n                        r.raise_for_status()\n                        response_text = r.json().get(\"response\", \"\")\n                except Exception as e:\n                    response_text = f\"ERROR: {str(e)}\"\n                latency = time.perf_counter() - t0\n                latencies.append(latency)\n                bench_results.append({\"prompt\": prompt, \"response\": response_text, \"latency_s\": round(latency, 3)})\n            results[\"benchmarks\"].append({\n                \"name\": bench_name, \"num_prompts\": len(prompts),\n                \"avg_latency_s\": round(statistics.mean(latencies), 3),\n                \"total_time_s\": round(sum(latencies), 3), \"results\": bench_results,\n            })\n        return results\n\n    # Start Ollama at container startup (before server starts accepting traffic)\n    import threading\n    if _ollama_state[\"status\"] == \"unknown\":\n        t = threading.Thread(target=_start_ollama_bg, daemon=True)\n        t.start()\n\n    return api"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.7","usage":{"input":115280,"output":1743,"cacheRead":13992,"cacheWrite":0,"totalTokens":131015,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774327611452}}
