ext.RegularExpressions.RegexOptions]::IgnoreCase)\r\n    foreach ($match in $matches) {\r\n        $phrase = $match.Value.ToLower()\r\n        if ($invariantCandidates.ContainsKey($phrase)) {\r\n            $invariantCandidates[$phrase]++\r\n        } else {\r\n            $invariantCandidates[$phrase] = 1\r\n        }\r\n    }\r\n}\r\n\r\n# Select phrases appearing in >50% of pulses as true invariants\r\n$trueInvariants = @{}\r\nforeach ($candidate in $invariantCandidates.GetEnumerator()) {\r\n    if ($candidate.Value / $pulses.Count -ge $InvarianceThreshold) {\r\n        $trueInvariants[$candidate.Key] = $candidate.Value\r\n    }\r\n}\r\n\r\nWrite-Host \"Found $($trueInvariants.Count) true invariants (>=$([math]::Round($InvarianceThreshold*100))% occurrence)\"\r\nWrite-Host \"Top 5 invariants:\"\r\n$topInvariants = $trueInvariants.GetEnumerator() | Sort-Object Value -Descending | Select-Object -First 5\r\nforeach ($inv in $topInvariants) {\r\n    Write-Host \"  '$($inv.Key)' - $($inv.Value)/$($pulses.Count) pulses\"\r\n}\r\nWrite-Host \"\"\r\n\r\n# --- Step 2: Classify each pulse as invariant-heavy or variant-heavy ---\r\nWrite-Host \"=== Step 2: Classifying Pulses ===\" -ForegroundColor Yellow\r\n\r\n$classificationResults = @()\r\nforeach ($pulse in $pulses) {\r\n    $content = $pulse.Content.ToLower()\r\n    $invariantCount = 0\r\n    $totalWords = $pulse.WordCount\r\n    \r\n    foreach ($inv in $trueInvariants.Keys) {\r\n        if ($content -match [regex]::Escape($inv)) {\r\n            $invariantCount++\r\n        }\r\n    }\r\n    \r\n    $ratio = $invariantCount / [math]::Max($trueInv\n\n## For Next Instantiation\n- Proposed mutations waiting: 1\n- Completed at: 2026-03-24 09:38:34\r\n"}],"isError":false,"timestamp":1774359602935}}
