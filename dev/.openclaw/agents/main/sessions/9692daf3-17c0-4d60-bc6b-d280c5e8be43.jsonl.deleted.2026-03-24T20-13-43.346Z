{"type":"message","id":"cab8282d","parentId":"e750ea60","timestamp":"2026-03-24T14:57:38.873Z","message":{"role":"toolResult","toolCallId":"call_function_9chx1fvooz7o_1","toolName":"read","content":[{"type":"text","text":"a\n---\n[NEW_FILE]\n---\n#!/usr/bin/env python3\n\"\"\"\nCFI-Weighted Compression Experiment\nCompares next-pulse prediction using:\n  1. Frequency-only baseline (current method)\n  2. CFI-weighted filtering (CFI >= 0.7 = causal anchor)\n\"\"\"\n\nimport json\nimport re\nfrom pathlib import Path\nfrom collections import Counter\n\n# Load CFI results\ncfi_results_path = Path(\"research/CFI_RESULTS.md\")\nwith open(cfi_results_path) as f:\n    content = f.read()\n\n# Extract CFI scores\ncfi_scores = {}\nfor match in re.finditer(r'\\|\\s*([\\w\\-\\.]+)\\s*\\|\\s*([\\d.]+)\\s*\\|', content):\n    node_name = match.group(1)\n    cfi = float(match.group(2))\n    cfi_scores[node_name] = cfi\n\n# Load frequency data\nfreq_results_path = Path(\"research/FREQUENCY_ANALYSIS.md\")\nwith open(freq_results_path) as f:\n    freq_content = f.read()\n\nfreq_scores = {}\nfor match in re.finditer(r'\\|\\s*([\\w\\-\\.]+)\\s*\\|\\s*(\\d+)\\s*\\|', freq_content):\n    node_name = match.group(1)\n    freq = int(match.group(2))\n    freq_scores[node_name] = freq\n\n# Strategy 1: Frequency-only (top 20 by frequency)\nfreq_baseline = sorted(freq_scores.items(), key=lambda x: -x[1])[:20]\n\n# Strategy 2: CFI-weighted (CFI >= 0.7)\ncfi_filtered = {k: v for k, v in cfi_scores.items() if v >= 0.7}\ncfi_ranked = sorted(cfi_filtered.items(), key=lambda x: -x[1])[:20]\n\n# Overlap analysis\nfreq_set = set(k for k, v in freq_baseline)\ncfi_set = set(k for k, v in cfi_ranked)\noverlap = freq_set & cfi_set\nonly_freq = freq_set - cfi_set\nonly_cfi = cfi_set - freq_set\n\nprint(\"=\" * 60)\nprint(\"CFI-WEIGHTED COMPRESSION EXPERIMENT RESULTS\")\nprint(\"=\" * 60)\nprint(f\"\\nFrequency Baseline (top 20 by frequency):\")\nprint(f\"  Count: {len(freq_baseline)}\")\nprint(f\"  Avg CFI of top freq nodes: {sum(cfi_scores.get(k, 0) for k, _ in freq_baseline) / len(freq_baseline):.3f}\")\n\nprint(f\"\\nCFI-Weighted (CFI >= 0.7):\")\nprint(f\"  Count: {len(cfi_ranked)}\")\nprint(f\"  Avg frequency of high-CFI nodes: {sum(freq_scores.get(k, 0) for k, _ in cfi_ranked) / max(len(cfi_ranked), 1):.1f}\")\n\nprint(f\"\\nOverlap Analysis:\")\nprint(f\"  Common to both: {len(overlap)} nodes ({100*len(overlap)/20:.1f}%)\")\nprint(f\"  Only in freq: {len(only_freq)} nodes\")\nprint(f\"  Only in CFI: {len(only_cfi)} nodes\")\n\nprint(f\"\\nKey Finding:\")\nif len(cfi_ranked) > 0:\n    high_cfi_low_freq = [k for k, _ in cfi_ranked if freq_scores.get(k, 0) <\r\n"}],"isError":false,"timestamp":1774364258871}}
