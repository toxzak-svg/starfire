{"type":"message","id":"5a67fc05","parentId":"784752c5","timestamp":"2026-03-24T03:59:41.623Z","message":{"role":"toolResult","toolCallId":"call_function_77fsw3kveb82_1","toolName":"read","content":[{"type":"text","text":"scripts/tic_analyzer.ps1\n---\n[NEW_FILE]\n---\n# TIC Analyzer - Temporal Invariance Compression Experiment\n# Analyzes pulse logs to identify invariant vs variant content\n# Part of Phase 1: COMPRESSION-CAUSAL DUALITY\n\nparam(\n    [int]$LogCount = 20,\n    [string]$LogDir = \"logs\"\n)\n\n$ErrorActionPreference = \"Continue\"\n\n# Find recent pulse logs\n$pulseFiles = Get-ChildItem -Path $LogDir -Filter \"pulse_*.md\" | \n    Sort-Object LastWriteTime -Descending | \n    Select-Object -First $LogCount\n\nWrite-Host \"TIC Analyzer - Analyzing $($pulseFiles.Count) pulse logs\"\nWrite-Host \"=\" * 50\n\nif ($pulseFiles.Count -eq 0) {\n    Write-Host \"ERROR: No pulse logs found in $LogDir\"\n    exit 1\n}\n\n# Extract content from each log\n$logContents = @()\nforeach ($file in $pulseFiles) {\n    $content = Get-Content $file.FullName -Raw\n    $logContents += [PSCustomObject]@{\n        FileName = $file.Name\n        Content = $content\n        Words = ($content -split '\\s+' | Where-Object { $_.Length -gt 3 })\n    }\n}\n\n# Find invariant patterns (words appearing in multiple logs)\n$allWords = $logContents | ForEach-Object { $_.Words } | Group-Object | \n    Where-Object { $_.Count -gt ($LogCount / 2) } |  # Appears in >50% of logs\n    Sort-Object Count -Descending\n\nWrite-Host \"`nINVARIANTS (appearing in >50% of logs):\"\nWrite-Host \"-\" * 40\n$invariants = @()\nforeach ($word in $allWords | Select-Object -First 30) {\n    Write-Host \"  [$($word.Count)] $($word.Name)\"\n    $invariants += $word.Name\n}\n\n# Find variant patterns (unique to each log)\nWrite-Host \"`nVARIANT ANALYSIS (unique content per pulse):\"\nWrite-Host \"-\" * 40\n\n$variantData = @()\nfor ($i = 0; $i -lt $logContents.Count; $i++) {\n    $current = $logContents[$i]\n    $uniqueWords = $current.Words | Where-Object { $invariants -notcontains $_ }\n    \n    $variantData += [PSCustomObject]@{\n        FileName = $current.FileName\n        UniqueCount = ($uniqueWords | Measure-Object).Count\n        Sample = ($uniqueWords | Select-Object -First 5) -join \", \"\n    }\n    \n    Write-Host \"  $($current.FileName): $($uniqueWords.Count) unique terms\"\n}\n\n# Output summary for TIC experiment\n$summary = [PSCustomObject]@{\n    Timestamp = Get-Date -Format \"yyyy-MM-dd HH:mm:ss\"\n    LogCount = $logContents.Count\n    InvariantCount = $invariants.Count\n    Invariants = $invariants\n    VariantData = $variantData\n}\n\n# Save analysis results\n$summary | ConvertTo-Json -Depth 5 | Out-File -FilePath \"logs/tic_analysis.json\" -Encoding UTF8\nWrite-Host \"`nAnalysis saved to logs/tic_analysis.json\"\nWrite-Host \"Invariants: $($invariants.Count), Variants: $($variantData.Count) logs analyzed\"\n\n# Success criteria check placeholder\n$classificationRate = if ($invariants.Count -gt\r\n"}],"isError":false,"timestamp":1774324781621}}
