(n=200):\r\n    \"\"\"Load n most recent pulses.\"\"\"\r\n    pulses = sorted(BASE.glob(\"pulse_*.json\"))[-n:]\r\n    return [json.loads(p.read_text()) for p in pulses]\r\n\r\ndef build_token_stats(pulses):\r\n    \"\"\"Compute per-token CFI and frequency.\"\"\"\r\n    token_cfi = defaultdict(lambda: {\"correct\": 0, \"total\": 0})\r\n    token_freq = defaultdict(int)\r\n    \r\n    for p in pulses:\r\n        tokens = p.get(\"tokens\", [])\r\n        for i, tok in enumerate(tokens):\r\n            token_freq[tok] += 1\r\n            token_cfi[tok][\"total\"] += 1\r\n            # CFI: was token predicted at this position?\r\n            # Simple approximation: check if appears in expected context\r\n            # Using position-based CFI for this experiment\r\n            expected = tokens[i] if i < len(tokens) else \"\"\r\n            token_cfi[tok][\"correct\"] += 1  # Placeholder - real impl needs prediction model\r\n    \r\n    # Compute CFI = correct/total for each token\r\n    cfi = {}\r\n    for tok, stats in token_cfi.items():\r\n        cfi[tok] = stats[\"correct\"] / stats[\"total\"] if stats[\"total\"] > 0 else 0\r\n    return cfi, dict(token_freq)\r\n\r\ndef hybrid_score(cfi, freq, threshold=0.35):\r\n    \"\"\"Strategy C: score = CFI x min(1, freq/120). Filter if score >= threshold.\"\"\"\r\n    score = cfi * min(1.0, freq / 120)\r\n    return score >= threshold\r\n\r\ndef binary_filter(cfi, freq, cfi_thresh=0.5, freq_min=3, freq_max=120):\r\n    \"\"\"Binary thresholds: CFI >= 0.5 AND freq in [3, 120).\"\"\"\r\n    return cfi >= cfi_thresh and freq_min <= freq < freq_max\r\n\r\ndef evaluate_strategy(pulses, strategy_fn, name):\r\n    \"\"\"Evaluate a filtering strategy against ground truth labels.\"\"\"\r\n    cfi, freq = build_token_stats(pulses)\r\n    \r\n    # Ground truth: \"research trajectory\" = tokens with meaningful variation\r\n    # Identified tokens from prior analysis: \"Phase 1\", \"research\", \"CFI\", etc.\r\n    research_tokens = {\"phase\", \"research\", \"pulse\", \"architecture\", \"compression\",\r\n                       \"synthesis\", \"experiment\", \"strategy\", \"token\", \"frequency\",\r\n                       \"insight\", \"filter\", \"score\", \"hybrid\", \"threshold\"}\r\n    \r\n    tp = fp = tn = fn = 0\r\n    for tok in set(cfi.keys()) | set(freq.keys()):\r\n        c = cfi.get(tok, 0)\r\n        f = freq.get(tok, 0)\r\n        predicted = strategy_fn(c, f)\r\n        is_research = tok.lower() in research_tokens\r\n        \r\n        if predicted and is_research:\r\n            tp += 1\r\n        elif predicted and not is_research:\r\n            fp += 1\r\n        elif not predicted and not is_research:\r\n            tn += 1\r\n        else:\r\n            fn += 1\r\n    \r\n    precision = tp / (tp + fp) if (tp + fp) > 0 else 0\r\n    recall = tp / (tp + fn) if (tp + fn) > 0 else 0\r\n    f1\n\n## For Next Instantiation\n- Proposed mutations waiting: 1\n- Completed at: 2026-03-24 14:39:02","cwd":"C:\\Users\\Zwmar\\.openclaw\\workspace"},"isError":false,"timestamp":1774377607047}}
