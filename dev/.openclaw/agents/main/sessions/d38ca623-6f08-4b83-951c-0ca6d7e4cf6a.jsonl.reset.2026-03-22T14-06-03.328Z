{"type":"message","id":"669cc8fa","parentId":"cb6d0057","timestamp":"2026-03-22T13:23:34.628Z","message":{"role":"toolResult","toolCallId":"call_function_4805cta1zuuv_1","toolName":"read","content":[{"type":"text","text":"{\n  \"name\": \"schemocker\",\n  \"version\": \"2.0.0\",\n  \"description\": \"Turn JSON schemas into live mock REST APIs in seconds for frontend/dev/test teams\",\n  \"main\": \"dist/index.js\",\n  \"bin\": {\n    \"schemocker\": \"dist/cli/index.js\",\n    \"schemocker-mcp\": \"dist/mcp-server/index.js\"\n  },\n  \"scripts\": {\n    \"build\": \"node scripts/create-ui-template.js && tsc\",\n    \"start\": \"node dist/index.js\",\n    \"dev\": \"ts-node src/index.ts\",\n    \"mcp\": \"node dist/mcp-server/index.js\",\n    \"mcp:dev\": \"ts-node src/mcp-server/index.ts\",\n    \"test\": \"jest --coverage\",\n    \"test:watch\": \"jest --watch\",\n    \"build:exe\": \"npm run build && pkg . --out-path dist/executable\",\n    \"build:release\": \"node scripts/build.js\",\n    \"build:installer\": \"node scripts/build-installer.js\",\n    \"build:portable\": \"node scripts/build-portable.js\",\n    \"build:distribution\": \"node scripts/build-distribution.js\",\n    \"build:installer-ui\": \"cd installer-ui && npm install && npm run build:win\",\n    \"build:all\": \"node scripts/build-complete.js\",\n    \"clean\": \"node -e \\\"const fs=require('fs');['dist','releases','coverage'].forEach(d=>{if(fs.existsSync(d))fs.rmSync(d,{recursive:true,force:true,maxRetries:5,retryDelay:200})})\\\"\",\n    \"clean:force\": \"powershell -ExecutionPolicy Bypass -File clean-build.ps1 -Force\",\n    \"verify:checksums\": \"node scripts/verify-checksums.js\",\n    \"prepare\": \"husky\",\n    \"lint\": \"eslint . --ext .ts,.js\",\n    \"lint:fix\": \"eslint . --ext .ts,.js --fix\",\n    \"format\": \"prettier --write \\\"src/**/*.ts\\\"\",\n    \"format:check\": \"prettier --check \\\"src/**/*.ts\\\"\"\n  },\n  \"keywords\": [\n    \"mock\",\n    \"api\",\n    \"schema\",\n    \"generator\",\n    \"rest\",\n    \"json\",\n    \"cli\",\n    \"server\",\n    \"mcp\",\n    \"model-context-protocol\",\n    \"ai\",\n    \"llm\",\n    \"openai\"\n  ],\n  \"author\": \"\",\n  \"license\": \"MIT\",\n  \"dependencies\": {\n    \"@modelcontextprotocol/sdk\": \"^1.0.4\",\n    \"@types/cors\": \"^2.8.17\",\n    \"axios\": \"^1.13.2\",\n    \"body-parser\": \"^2.2.2\",\n    \"chalk\": \"^5.6.2\",\n    \"chokidar\": \"^5.0.0\",\n    \"commander\": \"^14.0.2\",\n    \"cors\": \"^2.8.5\",\n    \"express\": \"^5.2.1\",\n    \"inquirer\": \"^13.2.0\",\n    \"json-schema-to-typescript\": \"^15.0.4\",\n    \"qs\": \"^6.14.0\",\n    \"uuid\": \"^13.0.0\"\n  },\n  \"devDependencies\": {\n    \"@eslint/js\": \"^9.39.2\",\n    \"@types/chokidar\": \"^2.1.7\",\n    \"@types/express\": \"^5.0.6\",\n    \"@types/inquirer\": \"^9.0.7\",\n    \"@types/jest\": \"^30.0.0\",\n    \"@types/node\": \"^25.0.6\",\n    \"@types/supertest\": \"^7.2.0\",\n    \"@types/uuid\": \"^11.0.0\",\n    \"@typescript-eslint/eslint-plugin\": \"^8.51.0\",\n    \"@typescript-eslint/parser\": \"^8.51.0\",\n    \"@yao-pkg/pkg\": \"^6.11.0\",\n    \"archiver\": \"^7.0.1\",\n    \"axios\": \"^1.13.2\",\n    \"husky\": \"^9.0.0\",\n    \"jest\": \"^30.2.0\",\n    \"lint-staged\": \"^16.2.7\",\n    \"nexe\": \"^5.0.0-beta.4\",\n    \"pkg\": \"^5.8.1\",\n    \"prettier\": \"^3.1.0\",\n    \"supertest\": \"^7.2.2\",\n    \"ts-jest\": \"^29.1.1\",\n    \"ts-node\": \"^10.9.1\",\n    \"typescript\": \"^5.3.3\"\n  },\n  \"pkg\": {\n    \"scripts\": \"dist/**/*.js\",\n    \"assets\": [\n      \"package.json\",\n      \"docs/**/*\",\n      \"node_modules/chokidar/**/*\",\n      \"node_modules/inquirer/**/*\"\n    ],\n    \"targets\": [\n      \"node18-win-x64\",\n      \"node18-macos-x64\",\n      \"node18-macos-arm64\",\n      \"node18-linux-x64\"\n    ],\n    \"outputPath\": \"dist/executable\",\n    \"options\": [\n      \"experimental-modules\"\n    ]\n  },\n  \"files\": [\n    \"dist/cli\",\n    \"dist/errors\",\n    \"dist/generators\",\n    \"dist/index.js\",\n    \"dist/index.d.ts\",\n    \"dist/installer\",\n    \"dist/integrations\",\n    \"dist/mcp-server\",\n    \"dist/parsers\",\n    \"dist/types\",\n    \"dist/utils\",\n    \"package.json\",\n    \"README.md\"\n  ],\n  \"repository\": {\n    \"type\": \"git\",\n    \"url\": \"https://github.com/toxzak-svg/schemock-app.git\"\n  },\n  \"bugs\": {\n    \"url\": \"https://github.com/toxzak-svg/schemock-app/issues\"\n  },\n  \"homepage\": \"https://github.com/toxzak-svg/schemock-app#readme\"\n}\n"}],"isError":false,"timestamp":1774185814616}}
