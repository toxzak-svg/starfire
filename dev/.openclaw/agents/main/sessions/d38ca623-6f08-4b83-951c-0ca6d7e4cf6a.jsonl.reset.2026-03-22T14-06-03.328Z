+580           text: JSON.stringify({\n+581             success: true,\n+582             mutatedSchema,\n+583             serverMessage: response.data.message,\n+584             hint: 'Mutated schema is live. Use list_routes to verify the changes.'\n+585           }, null, 2)\n+586         }]\n+587       };\n+588     } catch (error: any) {\n+589       const message = error?.message || String(error);\n+590       if (message.includes('AI features are not available')) throw new Error(message);\n+591       throw new Error(`mutate_schema failed: ${message}`);\n+592     }\n+593   }\n+594 \n+595   /**\n+596    * Handles the seed_world tool call.\n+597    * Populates world-state with N realistic records via the seed endpoint.\n+598    */\n+599   private async handleSeedWorld(args: { resource?: string; count?: number }) {\n+600     const { resource, count = 5 } = args || {};\n+601 \n+602     try {\n+603       const response = await axios.post(\n+604         `${this.baseUrl}/__schemock/seed`,\n+605         { resource, count },\n+606         { timeout: this.config.timeout }\n+607       );\n+608 \n+609       return {\n+610         content: [{\n+611           type: 'text',\n+612           text: JSON.stringify({\n+613             success: true,\n+614             message: response.data.message,\n+615             snapshot: response.data.snapshot,\n+616             timestamp: response.data.timestamp\n+617           }, null, 2)\n+618         }]\n+619       };\n+620     } catch (error: any) {\n+621       throw new Error(\n+622         `seed_world failed: ${error?.message}. Make sure Schemocker is running with a loaded schema.`\n+623       );\n+624     }\n+625   }\n+626 \n+627   /**\n 493    * Makes a call to a Schemocker endpoint\n 494    */\n 495   private async callSchemockerEndpoint(\n 496     method: string,\n     ...","firstChangedLine":493},"isError":false,"timestamp":1774186171613}}
