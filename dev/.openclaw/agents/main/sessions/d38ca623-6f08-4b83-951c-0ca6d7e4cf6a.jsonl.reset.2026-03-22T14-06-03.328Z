e {\n        res.json({ resources: [], entities: {}, totalEntities: 0 });\n      }\n    });\n\n    // Schema introspection endpoint — returns the currently loaded schema\n    this.app.get('/__schemock/schema', (req, res) => {\n      if (this.config.schema) {\n        res.json(this.config.schema);\n      } else {\n        res.status(404).json({ error: 'No schema loaded' });\n      }\n    });"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.7","usage":{"input":51000,"output":509,"cacheRead":12333,"cacheWrite":0,"totalTokens":63842,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774186210565}}
