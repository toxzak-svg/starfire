{"type":"message","id":"a9d5942d","parentId":"d0a28766","timestamp":"2026-03-24T00:28:01.448Z","message":{"role":"toolResult","toolCallId":"call_function_xpqbejvz5gqq_1","toolName":"read","content":[{"type":"text","text":"    \"        else:\\n\",\n    \"            inp.append(gv[i//2] if i//2 < N_GENUINE else fv[i//2])\\n\",\n    \"            ora.append('WRITE' if i//2 < N_GENUINE else 'SKIP')\\n\",\n    \"    # Delay: 50 steps\\n\",\n    \"    for _ in range(50):\\n\",\n    \"        inp.append(rng.randint(0, 49)); ora.append('SKIP')\\n\",\n    \"    # Query: 20 steps\\n\",\n    \"    tv = [IGNORE_INDEX] * EPISODE_LENGTH\\n\",\n    \"    for qi, qk in enumerate(gk):\\n\",\n    \"        inp.append(qk); inp.append(rng.randint(0, 49))\\n\",\n    \"        ora.extend(['READ', 'SKIP'])\\n\",\n    \"        tv[150 + qi*2] = gv[qi]\\n\",\n    \"\\n\",\n    \"    return Episode(\\n\",\n    \"        input_ids=torch.tensor(inp, dtype=torch.long),\\n\",\n    \"        oracle_actions=ora,\\n\",\n    \"        target_value_ids=torch.tensor(tv, dtype=torch.long),\\n\",\n    \"        genuine_keys=gk, genuine_values=gv)\\n\",\n    \"\\n\",\n    \"ep = generate_episode(0)\\n\",\n    \"print(f'Episode: {len(ep.input_ids)} tokens, {N_GENUINE} key-value pairs')\\n\",\n    \"print(f'Sample oracle: {ep.oracle_actions[:8]}')\\n\"\n   ]\n  },\n  {\n   \"cell_type\": \"code\",\n   \"execution_count\": 12,\n   \"id\": \"7b05f1f6\",\n   \"metadata\": {},\n   \"outputs\": [\n    {\n     \"name\": \"stdout\",\n     \"output_type\": \"stream\",\n     \"text\": [\n      \"Trainer class OK\\n\"\n     ]\n    }\n   ],\n   \"source\": [\n    \"class SRMoETrainer:\\n\",\n    \"    def __init__(self, model, lr=3e-3, lambda_route=1.0, lambda_div=0.1,\\n\",\n    \"                 lambda_margin=1.0, margin_target=0.5,\\n\",\n    \"                 route_class_weights=[1.0, 10.0, 15.0]):\\n\",\n    \"        self.model = model.to(DEVICE)\\n\",\n    \"        self.lr = lr; self.lambda_route = lambda_route\\n\",\n    \"        self.lambda_div = lambda_div; self.lambda_margin = lambda_margin\\n\",\n    \"        self.margin_target = margin_target\\n\",\n    \"        self.route_class_weights = route_class_weights\\n\",\n    \"        self.params = list(model.routing.parameters()) + list(model.output_head.parameters())\\n\",\n    \"        self.opt = torch.optim.Adam(self.params, lr=lr)\\n\",\n    \"        self.margin_loss_fn = torch.nn.MarginRankingLoss(margin=margin_target)\\n\",\n    \"\\n\",\n    \"    def _margin_loss(self, write_logits, skip_logits):\\n\",\n    \"        pos = write_logits.unsqueeze(-1); neg = skip_logits.unsqueeze(0)\\n\",\n    \"        return self.margin_loss_fn(pos, neg, torch.ones_like(pos))\\n\",\n    \"\\n\",\n    \"    def train_episode(self, episode, use_oracle_routing=True):\\n\",\n    \"        m = self.model; m.train(); m.reset_episode()\\n\",\n    \"        m.prime_oracle_schedule(list(episode.oracle_actions) if use_oracle_routing else None)\\n\",\n    \"\\n\",\n    \"        r_logits_list, oracle_labels, answer_logits, answer_targets = [], [], [], []\\n\",\n    \"\\n\",\n    \"        for t in range(len(episode.input_ids)):\\n\",\n    \"            tok = episode.input_ids[t].to(DEVICE)\\n\",\n    \"            tgt = episode.target_value_ids[t].item()\\n\",\n    \"            logits, info = m(tok)\\n\",\n    \"\\n\",\n    \"            r_logits_list.append(info['routing_logits'])\\n\",\n    \"            oa = episode.oracle_actions[t]\\n\",\n    \"            oracle_labels.append(ORACLE_TO_ACTION_IDX.get(oa, IGNORE_INDEX))\\n\",\n    \"\\n\",\n    \"            if tgt != IGNORE_INDEX:\\n\",\n    \"                answer_logits.append(logits); answer_targets.append(tgt)\\n\",\n    \"\\n\",\n    \"        r_t = torch.stack(r_logits_list)\\n\",\n    \"        r_lbl = torch.tensor(oracle_labels, dtype=torch.long, device=DEVICE)\\n\",\n    \"        r_wt = torch.tensor(self.route_class_weights, dtype=torch.float, device=DEVICE)\\n\",\n    \"        L_route = F.cross_entropy(r_t, r_lbl, weight=r_wt, ignore_index=IGNORE_INDEX)\\n\",\n    \"\\n\",\n    \"        L_answer = torch.tensor(0.0, device=DEVICE); accuracy = 0.0\\n\",\n    \"        if answer_logits:\\n\",\n    \"            a_t = torch.stack(answer_logits)\\n\",\n    \"            a_l = torch.tensor(answer_targets, dtype=torch.long, device=DEVICE)\\n\",\n    \"            L_answer = F.cross_entropy(a_t, a_l)\\n\",\n    \"            accuracy = (a_t.argmax(-1)==a_l).float().mean().item()\\n\",\n    \"\\n\",\n    \"        L_margin = torch.tensor(0.0, device=DEVICE)\\n\",\n    \"        if self.lambda_margin > 0 and len(r_logits_list) > 0:\\n\",\n    \"            all_r = torch.stack(r_logits_list)\\n\",\n    \"            L_margin = self._margin_loss(all_r[:,2], all_r[:,0])\\n\",\n    \"\\n\",\n    \"        L_div = torch.tensor(0.0, device=DEVICE); div_comp = {}\\n\",\n    \"        if self.lambda_div > 0 and hasattr(m.routing, 'diversity_loss'):\\n\",\n    \"            L_div, div_comp = m.routing.diversity_loss(\\n\",\n    \"                m._hidden.detach(), m.budget.budget_remaining_normalised)\\n\",\n    \"\\n\",\n    \"        loss = L_answer + self.lambda_route*L_route + self.lambda_margin*L_margin + self.lambda_div*L_div\\n\",\n    \"\\n\",\n    \"        self.opt.zero_grad(); loss.backward()\\n\",\n    \"        torch.nn.utils.clip_grad_norm_(self.params, 1.0); self.opt.step()\\n\",\n    \"\\n\",\n    \"        return {'loss': loss.item(), 'answer_loss': L_answer.item(),\\n\",\n    \"                'route_loss': L_route.item(), 'margin_loss': L_margin.item(),\\n\",\n    \"                'div_loss': L_div.item(), 'accuracy': accuracy,\\n\",\n    \"                'div_components': div_comp}\\n\",\n    \"\\n\",\n    \"    def eval_free(self, episodes, hard=True):\\n\",\n    \"        m = self.model.eval()\\n\",\n    \"        correct, total = 0, 0\\n\",\n    \"        write_margins, skip_fracs, read_fracs, write_fracs = [], [], [], []\\n\",\n    \"        with torch.no_grad():\\n\",\n    \"            for ep in episodes:\\n\",\n    \"                m.reset_episode()\\n\",\n    \"                if hasattr(m.routing, 'set_eval_mode'): m.routing.set_eval_mode(hard)\\n\",\n    \"                for t in range(len(ep.input_ids)):\\n\",\n    \"                    tok = ep.input_ids[t].to(DEVICE)\\n\",\n    \"                    tgt = ep.target_value_ids[t].item()\\n\",\n    \"                    logits, info = m(tok, route_stop_grad=True)\\n\",\n    \"                    if t >= QUERY_START and tgt != IGNORE_INDEX:\\n\",\n    \"                        correct += int(logits.argmax().item() == tgt); total += 1\\n\",\n    \"                    ai = info['action_idx']\\n\",\n    \"                    r = info.get('routing_logits')\\n\",\n    \"                    if r is not None and r.shape[-1] >= 3:\\n\",\n    \"                        write_margins.append((r[2]-r[0]).item())\\n\",\n    \"                    skip_fracs.append(1.0 if ai==0 else 0.0)\\n\",\n    \"                    read_fracs.append(1.0 if ai==1 else 0.0)\\n\",\n    \"                    write_fracs.append(1.0 if ai==2 else 0.0)\\n\",\n    \"                if hasattr(m.routing, 'set_eval_mode') and not hard:\\n\",\n    \"                    m.routing.set_eval_mode(False)\\n\",\n    \"        n = max(len(write_margins), 1)\\n\",\n    \"        return {'accuracy': correct/max(total,1),\\n\",\n    \"                'write_margin': sum(write_margins)/n,\\n\",\n    \"                'skip_frac': sum(skip_fracs)/n,\\n\",\n    \"                'read_frac': sum(read_fracs)/n,\\n\",\n    \"                'write_frac': sum(write_fracs)/n}\\n\",\n    \"\\n\",\n    \"print('Trainer class OK')\\n\"\n   ]\n  },\n  {\n   \"cell_type\": \"code\",\n   \"execution_count\": 13,\n   \"id\": \"2c3e72ae\",\n   \"metadata\": {},\n   \"outputs\": [\n    {\n     \"name\": \"stdout\",\n     \"output_type\": \"stream\",\n     \"text\": [\n      \"Total params: 135,586\\n\",\n      \"SR-MoE routing params: 26,864\\n\",\n      \"Device: cuda\\n\"\n     ]\n    }\n   ],\n   \"source\": [\n    \"DEEPSEED = 42\\n\",\n    \"N_CODES = 16; RING_DIM = 16; N_PREFS = 32\\n\",\n    \"LAMBDA_DIV = 0.1; LAMBDA_MARGIN = 1.0\\n\",\n    \"\\n\",\n    \"torch.manual_seed(DEEPSEED)\\n\",\n    \"model = ArchitectureB(\\n\",\n    \"    d_embed=64, hidden_dim=128, budget_B=55, budget_T=190,\\n\",\n    \"    write_threshold=0.5, embed_seed=DEEPSEED,\\n\",\n    \"    use_sr_moe=True, n_codes=N_CODES, ring_dim=RING_DIM, n_prefs=N_PREFS,\\n\",\n    \"    lambda_div=LAMBDA_DIV, tau_start=1.0, tau_end=0.01, anneal_steps=5000\\n\",\n    \").to(DEVICE)\\n\",\n    \"\\n\",\n    \"trainer = SRMoETrainer(model, lr=3e-3, lambda_route=1.0,\\n\",\n    \"    lambda_div=LAMBDA_DIV, lambda_margin=LAMBDA_MARGIN, margin_target=0.5)\\n\",\n    \"\\n\",\n    \"print(f'Total params: {sum(p.numel() for p in model.parameters()):,}')\\n\",\n    \"print(f'SR-MoE routing params: {sum(p.numel() for p in model.routing.parameters()):,}')\\n\",\n    \"print(f'Device: {DEVICE}')\\n\"\n   ]\n  },\n  {\n   \"cell_type\": \"code\",\n   \"execution_count\": null,\n   \"id\": \"7c9a68c7\",\n   \"metadata\": {},\n   \"outputs\": [\n    {\n     \"name\": \"stdout\",\n     \"output_type\": \"stream\",\n     \"text\": [\n      \"Phase 1: Supervised pre-training (2000 ep)\\n\",\n      \"  ep     0: loss=5.0961  acc=0.000  route_ce=1.0792  div=0.0602\\n\",\n      \"  ep   200: loss=5.0577  acc=0.000  route_ce=1.0796  div=0.0622\\n\",\n      \"  ep   400: loss=4.9727  acc=0.050  route_ce=1.0562  div=0.0624\\n\",\n      \"  ep   600: loss=4.9908  acc=0.050  route_ce=1.0550  div=0.0624\\n\",\n      \"  ep   800: loss=5.0057  acc=0.000  route_ce=1.0515  div=0.0625\\n\",\n      \"  ep  1000: loss=4.9561  acc=0.000  route_ce=1.0577  div=0.0625\\n\",\n      \"  ep  1200: loss=4.9924  acc=0.050  route_ce=1.0585  div=0.0625\\n\",\n      \"  ep  1400: loss=4.9653  acc=0.050  route_ce=1.0581  div=0.0625\\n\",\n      \"  ep  1600: loss=4.9942  acc=0.000  route_ce=1.0555  div=0.0625\\n\",\n      \"  ep  1800: loss=5.0317  acc=0.000  route_ce=1.0525  div=0.0625\\n\",\n      \"  ep  1999: loss=4.9855  acc=0.050  route_ce=1.0553  div=0.0625\\n\",\n      \"  Phase 1 done in 815s\\n\",\n      \"\\n\",\n\n[88 more lines in file. Use offset=650 to continue.]"}],"isError":false,"timestamp":1774312081399}}
