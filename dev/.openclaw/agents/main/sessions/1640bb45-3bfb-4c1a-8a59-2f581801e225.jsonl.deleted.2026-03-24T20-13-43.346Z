e:\r\n    # Build from synthesis doc if not separate\r\n    labels = {}\r\n\r\n# Compute CFI and freq for each token\r\ntoken_stats = defaultdict(lambda: {\"cfi_sum\": 0.0, \"cfi_count\": 0, \"freq\": 0})\r\n\r\nfor pulse_file in pulses:\r\n    with open(pulse_file) as f:\r\n        pulse = json.load(f)\r\n    \r\n    tokens = pulse.get(\"tokens\", [])\r\n    for i, token in enumerate(tokens):\r\n        token_stats[token][\"freq\"] += 1\r\n        # CFI: appears in this pulse?\r\n        token_stats[token][\"cfi_sum\"] += 1.0\r\n        token_stats[token][\"cfi_count\"] += 1\r\n\r\n# Compute CFI for each token\r\nfor token, stats in token_stats.items():\r\n    stats[\"cfi\"] = stats[\"cfi_sum\"] / stats[\"cfi_count\"] if stats[\"cfi_count\"] > 0 else 0\r\n\r\n# Hybrid scoring: score = CFI x sqrt(freq/120)\r\ndef hybrid_score(token):\r\n    stats = token_stats[token]\r\n    cfi = stats[\"cfi\"]\r\n    freq = stats[\"freq\"]\r\n    freq_norm = min(1.0, (freq / 120) ** 0.5)  # sqrt to soften high freq\r\n    return cfi * freq_norm\r\n\r\n# Strategy thresholds\r\nSTRATEGIES = {\r\n    \"A (CFI�0.7, freq<60)\": lambda t: token_stats[t][\"cfi\"] >= 0.7 and token_stats[t][\"freq\"] < 60,\r\n    \"B (CFI�0.5, freq?[3,120))\": lambda t: token_stats[t][\"cfi\"] >= 0.5 and 3 <= token_stats[t][\"freq\"] < 120,\r\n    \"C (hybrid score�0.3)\": lambda t: hybrid_score(t) >= 0.3,\r\n    \"C (hybrid score�0.4)\": lambda t: hybrid_score(t) >= 0.4,\r\n    \"C (hybrid score�0.5)\": lambda t: hybrid_score(t) >= 0.5,\r\n}\r\n\r\n# Analyze each strategy\r\nresults = {}\r\nfor name, predicate in STRATEGIES.items():\r\n    selected = [t for t in token_stats if predicate(t)]\r\n    results[name] = {\r\n        \"count\": len(selected),\r\n        \"tokens\": selected[:20]  # Sample\r\n    }\r\n\r\n# Print summary\r\nprint(\"=\" * 60)\r\nprint(\"STRATEGY C EXPERIMENT RESULTS\r\n\r\n## For Next Instantiation\r\n- Proposed mutations waiting: 0\r\n- Completed at: 2026-03-24 15:48:36","cwd":"C:\