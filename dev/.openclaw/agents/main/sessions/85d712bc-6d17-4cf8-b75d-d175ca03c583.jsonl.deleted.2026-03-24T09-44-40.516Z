{"type":"message","id":"ceaa6e31","parentId":"14eb5397","timestamp":"2026-03-24T02:29:53.947Z","message":{"role":"toolResult","toolCallId":"call_function_vmnpzxs2sbbd_1","toolName":"read","content":[{"type":"text","text":"scripts/tic_experiment.ps1\n---\n[NEW_FILE]\n---\n# TIC Experiment - Temporal Invariance Compression\n# Validates: Compression = Causal Discovery hypothesis\n\nparam(\n    [int]$LogCount = 20,\n    [string]$LogPath = \"logs\"\n)\n\n$ErrorActionPreference = \"Stop\"\n\nfunction Get-PulseLogs {\n    Get-ChildItem \"$LogPath/pulse_*.md\" -ErrorAction SilentlyContinue |\n        Sort-Object LastWriteTime -Descending |\n        Select-Object -First $LogCount\n}\n\nfunction Extract-Features {\n    param([string]$Content)\n    \n    $features = @{\n        Goals = @()\n        Files = @()\n        Insights = @()\n        Actions = @()\n    }\n    \n    # Extract goals (lines starting with - [ ])\n    $goals = [regex]::Matches($Content, '- \\[ \\] (.+)') | ForEach-Object { $_.Groups[1].Value.Trim() }\n    $features.Goals = $goals\n    \n    # Extract file references\n    $files = [regex]::Matches($Content, '(?:research|scripts|state|logs)/[\\w\\-/.]+') | ForEach-Object { $_.Value } | Select-Object -Unique\n    $features.Files = @($files)\n    \n    # Extract insights (lines with key findings)\n    $insights = [regex]::Matches($Content, '\\*\\*[^*]+\\*\\*: [^*]+') | ForEach-Object { $_.Value } | Select-Object -First 5\n    $features.Insights = $insights\n    \n    # Extract action items\n    $actions = [regex]::Matches($Content, '- \\[ \\] (?!COMPLETE)(.+)') | ForEach-Object { $_.Groups[1].Value.Trim() }\n    $features.Actions = $actions\n    \n    return $features\n}\n\nfunction Measure-Invariance {\n    param([Array]$AllFeatures)\n    \n    $allGoals = $AllFeatures | ForEach-Object { $_.Goals } | ForEach-Object { $_ } | Group-Object | Where-Object { $_.Count -gt 1 }\n    $allFiles = $AllFeatures | ForEach-Object { $_.Files } | ForEach-Object { $_ } | Group-Object | Where-Object { $_.Count -gt 1 }\n    $allInsights = $AllFeatures | ForEach-Object { $_.Insights } | ForEach-Object { $_ } | Group-Object | Where-Object { $_.Count -gt 1 }\n    \n    return @{\n        InvariantGoals = $allGoals | ForEach-Object { $_.Name }\n        InvariantFiles = $allFiles | ForEach-Object { $_.Name }\n        InvariantInsights = $allInsights | ForEach-Object { $_.Name }\n    }\n}\n\nfunction Test-Prediction {\n    param([Array]$PulseLogs, [hashtable]$Invariants)\n    \n    $correct = 0\n    $total = 0\n    \n    for ($i = 0; $i -lt $PulseLogs.Count - 1; $i++) {\n        $current = $PulseLogs[$i]\n        $next = $PulseLogs[$i + 1]\n        \n        $currentContent = Get-Content $current.FullName -Raw\n        $nextContent = Get-Content $next.FullName -Raw\n        \n        # Check if invariant goals appear in next pulse\n        foreach ($goal in $Invariants.InvariantGoals) {\n            if ($nextContent -match [regex]::Escape($goal)) {\n                $correct++\n            }\n            $total++\n        }\n        \n        # Check if invariant files appear in next pulse\n        foreach ($file in $Invariants.InvariantFiles) {\n            if ($nextContent -match [regex]::Escape($file)) {\n                $correct++\n            }\n            $total++\n        }\n    }\n    \n    return if ($total -gt 0) { $correct / $total } else {\r\n"}],"isError":false,"timestamp":1774319393942}}
