ify_content(features: dict, invariants: set) -> dict:\n    \"\"\"Classify pulse content as invariant-heavy or variant-heavy.\"\"\"\n    invariant_count = 0\n    variant_count = 0\n    \n    for unigram, count in features['unigrams'].items():\n        if ('u', unigram) in invariants:\n            invariant_count += count\n        else:\n            variant_count += count\n    \n    total = invariant_count + variant_count\n    if total == 0:\n        return {'invariant_ratio': 0.5, 'classification': 'unknown'}\n    \n    ratio = invariant_count / total\n    classification = 'invariant' if ratio > 0.5 else 'variant'\n    \n    return {\n        'invariant_ratio': ratio,\n        'classification': classification,\n        'invariant_count': invariant_count,\n        'variant_count': variant_count\n    }\n\ndef predict_next_pulse(current_features: dict, invariants: set) -> dict:\n    \"\"\"\n    Predict: given current pulse, what's likely in next pulse?\n    Key insight: invariants should persist; variants may shift\n    \"\"\"\n    current_invariants = set()\n    for unigram in current_features['unigrams']:\n        if ('u', unigram) in invariants:\n            current_invariants.add(unigram)\n    \n    return {\n        'expected_invariants': list(current_invariants)[:10],\n        'persistence_score': len(current_invariants) / max(len(invariants), 1)\n    }\n\ndef run_experiment():\n    \"\"\"Main TIC experiment runner.\"\"\"\n    # Load last 20 pulse logs\n    pulse_files = sorted(LOGS_DIR.glob(\"pulse_*.md\"))[-20:]\n    \n    if len(pulse_files) < 5:\n        return {\"error\": f\"Need at least 5 pulses, found {len(pulse_files)}\"}\n    \n    # Extract features from each pulse\n    pulse_features = []\n    for pf in pulse_files:\n        content = pf.read_text()\n        features ="}],"details":{"status":"completed","exitCode":0,"durationMs":1176,"aggregated":"a\n---\n[NEW_FILE]\n---\n#!/usr/bin/env python3\n\"\"\"\nTemporal Invariance Compression (TIC) Experiment\