ants = []\r\n    for token in set(tokens):\r\n        score = compute_invariant_score(token, all_logs_tokens)\r\n        if score >= threshold:\r\n            invariants.append((token, score))\r\n        else:\r\n            variants.append((token, score))\r\n    return sorted(invariants, key=lambda x: -x[1]), sorted(variants, key=lambda x: -x[1])\r\n\r\ndef predict_next_pulse(invariants, all_logs_content, window=5):\r\n    \"\"\"Predict next pulse content from invariants.\"\"\"\r\n    # Simple model: invariants that appeared recently are more likely\r\n    predictions = []\r\n    for token, score in invariants:\r\n        for i in range(len(all_logs_content) - window, len(all_logs_content) - 1):\r\n            if token in all_logs_content[i]:\r\n                predictions.append((token, score, i))\r\n    # Return top predicted tokens\r\n    predictions.sort(key=lambda x: -(x[1] + (len(all_logs_content) - x[2])/10))\r\n    return [p[0] for p in predictions[:20]]\r\n\r\ndef evaluate_prediction(predictions, actual_tokens):\r\n    \"\"\"Evaluate prediction accuracy.\"\"\"\r\n    if not predictions or not actual_tokens:\r\n        return 0.0\r\n    actual_set = set(actual_tokens)\r\n    correct = sum(1 for p in predictions if p in actual_set)\r\n    return correct / len(predictions)\r\n\r\ndef main():\r\n    # Get recent pulse logs\r\n    logs = sorted(LOG_DIR.glob(\"pulse_*.md\"), key=os.path.getmtime, reverse=True)\r\n    \r\n    if len(logs) < MIN_LOGS:\r\n        print(f\"ERROR: Need at least {MIN_LOGS} pulse logs, found {len(logs)}\")\r\n        return\r\n    \r\n    # Use last 20 logs as specified\r\n    recent_logs = logs[:20]\r\n    print(f\"Analyzing {len(recent_logs)} recent pulse logs...\")\r\n    \r\n    # Extract content from all logs\n\n## For Next Instantiation\n- Proposed mutations waiting: 0\n- Completed at: 2026-03-24 03:51:43"}],"details":{"status":"completed","exitCode":0,"durationMs":647,"aggregated":"# Pulse: 2026-03-24 035114\n\n## Applied Mutati