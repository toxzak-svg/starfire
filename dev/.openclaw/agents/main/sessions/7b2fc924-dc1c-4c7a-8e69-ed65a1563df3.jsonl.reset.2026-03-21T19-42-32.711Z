{"type":"message","id":"b68cb685","parentId":"780bf7a9","timestamp":"2026-03-21T18:27:18.032Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now let me create the save command and upgrade manager.","thinkingSignature":"8cdfcdc543bcaad6eedbe63b1795e641531f7c0f9deb4fb882c8bb561d41ad26"},{"type":"toolCall","id":"call_function_50dcil36nudo_1","name":"write","arguments":{"path":"C:/dev/component-crate/src/commands/save.ts","content":"import * as vscode from 'vscode';\nimport { ComponentStore } from '../storage/store';\n\nexport class SaveQuickPick {\n\tstatic async run(\n\t\tselectedText: string,\n\t\tstore: ComponentStore,\n\t\tcontext: vscode.ExtensionContext\n\t): Promise<void> {\n\t\t// Detect language from VS Code\n\t\tconst langId = vscode.window.activeTextEditor?.document.languageId || 'text';\n\n\t\tconst name = await vscode.window.showInputBox({\n\t\t\tprompt: 'Component name',\n\t\t\tvalidateInput: v => (v.trim() ? undefined : 'Name is required'),\n\t\t\tvalue: this.suggestName(selectedText),\n\t\t});\n\t\tif (!name) return;\n\n\t\tconst tagsRaw = await vscode.window.showInputBox({\n\t\t\tprompt: 'Tags (comma-separated, optional)',\n\t\t});\n\n\t\tconst tags = tagsRaw\n\t\t\t? tagsRaw.split(',').map(t => t.trim()).filter(Boolean)\n\t\t\t: [];\n\n\t\tconst comp = store.add({\n\t\t\tname: name.trim(),\n\t\t\tcode: selectedText,\n\t\t\tlanguage: langId,\n\t\t\ttags,\n\t\t\tsource: 'local',\n\t\t\tsynced: false,\n\t\t});\n\n\t\t// Show a notification with actions\n\t\tconst action = await vscode.window.showInformationMessage(\n\t\t\t`Saved \"${comp.name}\" (${store.count()}/10 components)`,\n\t\t\t'View All',\n\t\t\t'Insert Now'\n\t\t);\n\n\t\tif (action === 'View All') {\n\t\t\tvscode.commands.executeCommand('component-crate.search');\n\t\t} else if (action === 'Insert Now') {\n\t\t\tconst editor = vscode.window.activeTextEditor;\n\t\t\tif (editor) {\n\t\t\t\teditor.edit(editBuilder => {\n\t\t\t\t\teditBuilder.insert(editor.selection.active, comp.code);\n\t\t\t\t});\n\t\t\t}\n\t\t}\n\t}\n\n\tprivate static suggestName(code: string): string {\n\t\t// Try to extract a useful name from the code\n\t\t// Look for function/component/class declarations\n\t\tconst patterns = [\n\t\t\t/(?:function|const|class|export)\\s+(\\w+)/,\n\t\t\t/['\"](\\w+Modal)['\"]/,\n\t\t\t/<(?:(\\w+)Box|(\\w+)Card|(\\w+)Modal)/,\n\t\t];\n\n\t\tfor (const pattern of patterns) {\n\t\t\tconst m = code.match(pattern);\n\t\t\tif (m) {\n\t\t\t\tfor (const g of m.slice(1)) {\n\t\t\t\t\tif (g) return g;\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\n\t\treturn '';\n\t}\n}\n"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.7","usage":{"input":85421,"output":599,"cacheRead":11874,"cacheWrite":0,"totalTokens":97894,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774117619174}}
