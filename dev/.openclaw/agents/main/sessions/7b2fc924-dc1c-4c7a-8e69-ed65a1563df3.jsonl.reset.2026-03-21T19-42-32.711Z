{"type":"message","id":"c9a51dff","parentId":"aae53740","timestamp":"2026-03-21T18:26:00.991Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now let me create the GitHub API integration module.","thinkingSignature":"a14bb5868e9d138231388fc640b61b3cd25aab7dd9dbf22559c43b279a60d599"},{"type":"toolCall","id":"call_function_9dvu5zl1959e_1","name":"write","arguments":{"path":"C:/dev/component-crate/src/github/api.ts","content":"import * as vscode from 'vscode';\nimport { ComponentStore, SavedComponent } from '../storage/store';\n\ninterface GitHubRepo {\n\tname: string;\n\tfull_name: string;\n\tdefault_branch: string;\n}\n\ninterface GitHubFile {\n\tname: string;\n\tpath: string;\n\ttype: 'file' | 'dir';\n\tdownload_url?: string;\n}\n\nexport class GitHubImporter {\n\tprivate token: string | undefined;\n\n\tconstructor() {\n\t\tthis.token = vscode.workspace.getConfiguration('componentCrate').get<string>('githubToken');\n\t}\n\n\tprivate headers(): Record<string, string> {\n\t\tconst headers: Record<string, string> = {\n\t\t\tAccept: 'application/vnd.github.v3+json',\n\t\t};\n\t\tif (this.token) {\n\t\t\theaders['Authorization'] = `Bearer ${this.token}`;\n\t\t}\n\t\treturn headers;\n\t}\n\n\tasync pickRepository(): Promise<GitHubRepo | undefined> {\n\t\t// Get authenticated user repos\n\t\tconst response = await fetch('https://api.github.com/user/repos?per_page=100&sort=updated', {\n\t\t\theaders: this.headers(),\n\t\t});\n\n\t\tif (!response.ok) {\n\t\t\tconst err = await response.text();\n\t\t\tvscode.window.showErrorMessage(`GitHub API error: ${response.status} — ${err}`);\n\t\t\treturn undefined;\n\t\t}\n\n\t\tconst repos: GitHubRepo[] = await response.json();\n\n\t\tconst items = repos.map(r => ({\n\t\t\tlabel: r.name,\n\t\t\tdescription: r.full_name,\n\t\t(repo: GitHubRepo) => repo,\n\t\t}));\n\n\t\t// Add option to search public repos\n\t\titems.push({\n\t\t\tlabel: '$(globe) Search public repositories',\n\t\t\tdescription: 'Enter any GitHub repo (user/repo)',\n\t\t\tpicked: false,\n\t\t} as any);\n\n\t\tconst picked = await vscode.window.showQuickPick(items as any, {\n\t\t\tplaceHolder: 'Select a repository',\n\t\t\tignoreFocusOut: true,\n\t\t});\n\n\t\tif (!picked) return undefined;\n\n\t\t// If \"search public\" picked, ask for repo name\n\t\tif (picked.label === '$(globe) Search public repositories') {\n\t\t\tconst repoInput = await vscode.window.showInputBox({\n\t\t\t\tprompt: 'Enter repository (e.g. facebook/react)',\n\t\t\t\tvalidateInput: v => (v.includes('/') ? undefined : 'Use format: owner/repo'),\n\t\t\t});\n\t\t\tif (!repoInput) return undefined;\n\t\t\treturn { name: repoInput.split('/')[1], full_name: repoInput, default_branch: 'main' };\n\t\t}\n\n\t\treturn picked as any as GitHubRepo;\n\t}\n\n\tasync browseFiles(\n\t\towner: string,\n\t\trepo: string,\n\t\tpath: string = ''\n\t): Promise<GitHubFile[] | undefined> {\n\t\tconst url = path\n\t\t\t? `https://api.github.com/repos/${owner}/${repo}/contents/${path}`\n\t\t\t: `https://api.github.com/repos/${owner}/${repo}/contents`;\n\n\t\tconst response = await fetch(url, { headers: this.headers() });\n\t\tif (!response.ok) {\n\t\t\tconst err = await response.text();\n\t\t\tvscode.window.showErrorMessage(`Failed to browse repo: ${err}`);\n\t\t\treturn undefined;\n\t\t}\n\n\t\tconst files: GitHubFile[] = await response.json();\n\t\t// Sort: dirs first, then files\n\t\treturn files.sort((a, b) => {\n\t\t\tif (a.type !== b.type) return a.type === 'dir' ? -1 : 1;\n\t\t\treturn a.name.localeCompare(b.name);\n\t\t});\n\t}\n\n\tasync downloadFile(downloadUrl: string): Promise<string | undefined> {\n\t\tconst response = await fetch(downloadUrl);\n\t\tif (!response.ok) return undefined;\n\t\treturn response.text();\n\t}\n\n\tasync importFromRepo(store: ComponentStore, context: vscode.ExtensionContext): Promise<void> {\n\t\tconst repo = await this.pickRepository();\n\t\tif (!repo) return;\n\n\t\tconst [owner, repoName] = repo.full_name.split('/');\n\n\t\t// Browse repo recursively\n\t\tconst selectedFile = await this.browseAndPick(owner, repoName, '');\n\t\tif (!selectedFile) return;\n\n\t\tif (selectedFile.type === 'dir') {\n\t\t\t// Pick a file from the dir\n\t\t\tconst files = await this.browseFiles(owner, repoName, selectedFile.path);\n\t\t\tif (!files) return;\n\t\t\tconst fileItems = files\n\t\t\t\t.filter(f => f.type === 'file')\n\t\t\t\t.map(f => ({ label: f.name, description: f.path, file: f } as any));\n\t\t\tconst picked = await vscode.window.showQuickPick(fileItems, {\n\t\t\t\tplaceHolder: 'Select a file to import',\n\t\t\t});\n\t\t\tif (!picked) return;\n\t\t\tawait this.importFile(picked.file, owner, repoName, store);\n\t\t} else {\n\t\t\tawait this.importFile(selectedFile, owner, repoName, store);\n\t\t}\n\t}\n\n\tprivate async browseAndPick(\n\t\towner: string,\n\t\trepo: string,\n\t\tpath: string\n\t): Promise<GitHubFile | undefined> {\n\t\tconst files = await this.browseFiles(owner, repo, path);\n\t\tif (!files) return undefined;\n\n\t\tconst items: any[] = files.map(f => ({\n\t\t\tlabel: f.type === 'dir' ? `$(file-directory) ${f.name}` : `$(file-code) ${f.name}`,\n\t\t\tdescription: path ? f.path : undefined,\n\t\t\tfile: f,\n\t\t}));\n\n\t\tif (path) {\n\t\t\titems.unshift({\n\t\t\t\tlabel: '$(arrow-left) ..',\n\t\t\t\tdescription: 'Go back',\n\t\t\t\tfile: { name: '..', path: path.split('/').slice(0, -1).join('/'), type: 'dir' } as GitHubFile,\n\t\t\t} as any);\n\t\t}\n\n\t\tconst picked = await vscode.window.showQuickPick(items, {\n\t\t\tplaceHolder: `Browse ${owner}/${repo}${path ? '/' + path : ''}`,\n\t\t\tignoreFocusOut: true,\n\t\t});\n\n\t\tif (!picked) return undefined;\n\n\t\tif (picked.file.name === '..') {\n\t\t\treturn this.browseAndPick(owner, repo, picked.file.path);\n\t\t}\n\n\t\tif (picked.file.type === 'dir') {\n\t\t\treturn this.browseAndPick(owner, repo, picked.file.path);\n\t\t}\n\n\t\treturn picked.file;\n\t}\n\n\tprivate async importFile(\n\t\tfile: GitHubFile,\n\t\towner: string,\n\t\trepo: string,\n\t\tstore: ComponentStore\n\t): Promise<void> {\n\t\tif (!file.download_url) {\n\t\t\tvscode.window.showWarningMessage('Cannot download this file');\n\t\t\treturn;\n\t\t}\n\n\t\tconst code = await this.downloadFile(file.download_url);\n\t\tif (!code) {\n\t\t\tvscode.window.showErrorMessage('Failed to download file');\n\t\t\treturn;\n\t\t}\n\n\t\tconst ext = file.name.split('.').pop() || '';\n\t\tconst langMap: Record<string, string> = {\n\t\t\tts: 'typescript', tsx: 'typescript', js: 'javascript',\n\t\t\tjsx: 'javascript', py: 'python', go: 'go', rs: 'rust',\n\t\t\tsvelte: 'svelte', vue: 'vue',\n\t\t};\n\n\t\t// Ask for component name\n\t\tconst name = await vscode.window.showInputBox({\n\t\t\tprompt: 'Component name',\n\t\t\tvalue: file.name.replace(/\\.[^.]+$/, ''),\n\t\t});\n\t\tif (!name) return;\n\n\t\tconst tagsRaw = await vscode.window.showInputBox({\n\t\t\tprompt: 'Tags (comma-separated, optional)',\n\t\t});\n\n\t\tconst component = store.add({\n\t\t\tname,\n\t\t\tcode,\n\t\t\tlanguage: langMap[ext] || ext,\n\t\t\ttags: tagsRaw\n\t\t\t\t? tagsRaw.split(',').map(t => t.trim()).filter(Boolean)\n\t\t\t\t: [],\n\t\t\tsource: 'github',\n\t\t\tgithubPath: file.path,\n\t\t\tsynced: false,\n\t\t});\n\n\t\tvscode.window.showInformationMessage(\n\t\t\t`Imported \"${name}\" from GitHub! (${store.count()}/10 components)`\n\t\t);\n\t}\n}\n"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.7","usage":{"input":81813,"output":1808,"cacheRead":11874,"cacheWrite":0,"totalTokens":95495,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774117523938}}
