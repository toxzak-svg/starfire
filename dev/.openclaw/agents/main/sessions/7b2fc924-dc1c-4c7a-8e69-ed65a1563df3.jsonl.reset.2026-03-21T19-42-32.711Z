e,"timeout":600,"pty":true}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.7","usage":{"input":74529,"output":439,"cacheRead":11874,"cacheWrite":0,"totalTokens":86842,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774117212673}}
