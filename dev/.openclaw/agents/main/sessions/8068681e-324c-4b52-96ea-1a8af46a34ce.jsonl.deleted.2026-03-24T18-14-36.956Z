{"type":"message","id":"6b2209b5","parentId":"5191b12e","timestamp":"2026-03-24T17:14:28.244Z","message":{"role":"toolResult","toolCallId":"call_function_67ejuhsqaiaq_1","toolName":"exec","content":[{"type":"text","text":"[31;1mjq: [31;1mThe term 'jq' is not recognized as a name of a cmdlet, function, script file, or executable program.[0m\r\n[31;1m[31;1mCheck the spelling of the name, or if a path was included, verify that the path is correct and try again.[0m\n\n(Command exited with code 1)"}],"details":{"status":"completed","exitCode":1,"durationMs":1801,"aggregated":"[31;1mjq: [31;1mThe term 'jq' is not recognized as a name of a cmdlet, function, script file, or executable program.[0m\r\n[31;1m[31;1mCheck the spelling of the name, or if a path was included, verify that the path is correct and try again.[0m\n\n(Command exited with code 1)","cwd":"C:\\Users\\Zwmar\\.openclaw\\workspace"},"isError":false,"timestamp":1774372468140}}
