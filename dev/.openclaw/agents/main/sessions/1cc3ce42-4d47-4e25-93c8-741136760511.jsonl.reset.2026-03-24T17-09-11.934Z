nt = '    '  # 4 spaces\n\nnew_lines = lines[:21]  # keep lines 0-20 as-is\nfor i in range(21, min(41, len(lines))):\n    new_lines.append(indent + lines[i])\n\n# Lines 41+ stay as-is\nfor i in range(41, len(lines)):\n    new_lines.append(lines[i])\n\nnb['cells'][10]['source'] = new_lines\nprint(f\"Indented lines 21-40 by 4 spaces. New total lines: {len(new_lines)}\")\n\nwith open(r'C:\\dev\\notebooks\\SRMoE_Training.ipynb', 'w', encoding='utf-8') as f:\n    json.dump(nb, f, ensure_ascii=False)\n\n# Verify\nsrc = ''.join(nb['cells'][10]['source']).encode('ascii','replace').decode()\nfor i, l in enumerate(src.split('\\n')[19:45]):\n    print('%3d: %s' % (i+20, l))\n"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.7","usage":{"input":102750,"output":674,"cacheRead":14175,"cacheWrite":0,"totalTokens":117599,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774366692872}}
