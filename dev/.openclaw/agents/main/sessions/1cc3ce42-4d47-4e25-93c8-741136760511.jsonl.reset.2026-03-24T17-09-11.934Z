   for k, v in summary.items():\n                    if any(x in k.lower() for x in [\"loss\", \"acc\", \"frac\", \"margin\", \"blocked\", \"tau\", \"buf\"]):\n                        print(f\"  {k}: {v}\")\n            elif isinstance(summary, str):\n                try:\n                    sm = json.loads(summary)\n                    for k, v in sm.items():\n                        if any(x in k.lower() for x in [\"loss\", \"acc\", \"frac\", \"margin\", \"blocked\", \"tau\", \"buf\"]):\n                            print(f\"  {k}: {v}\")\n                except:\n                    print(\"  (summary is string, not parsing)\")\nexcept Exception as e:\n    print(\"Error:\", e)\n    import traceback; traceback.print_exc()\n"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.7","usage":{"input":86252,"output":602,"cacheRead":14175,"cacheWrite":0,"totalTokens":101029,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774362815275}}
