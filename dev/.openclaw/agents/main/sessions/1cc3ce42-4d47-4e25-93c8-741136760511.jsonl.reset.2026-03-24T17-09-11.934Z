{"type":"message","id":"e6adb6fd","parentId":"a89d032d","timestamp":"2026-03-24T12:58:11.700Z","message":{"role":"toolResult","toolCallId":"call_function_b4ms6rradphe_1","toolName":"exec","content":[{"type":"text","text":"=== __init__: confidence_proj registration ===\r\n 60: \r\n 61:         # Fusion: combine shard embeddings ? routing logits\r\n 62:         self.fusion = nn.Sequential(\r\n 63:             nn.Linear(shard_emb_dim, hidden_dim), nn.Tanh(),\r\n 64:             nn.Linear(hidden_dim, n_codes))\r\n 65: \r\n 66:         # Confidence projection: 32-dim weighted shard sum -> n_codes (16)\r\n 67:         self.confidence_proj = nn.Linear(32, n_codes)\r\n 68: \r\n 69:         # Codebook: discrete routing actions\r\n 70:         cb = torch.zeros(n_codes, N_ACTIONS)\r\n 71:         for i in range(n_codes): cb[i, i % N_ACTIONS] = 1.0\r\n\r\n=== forward: bias construction + projection ===\r\n113:         vote_confidence = 1.0 - vote_entropy / math.log(self.n_shards)\r\n114: \r\n115:         # Fusion ? routing logits\r\n116:         pre_code = self.fusion(shard_emb.unsqueeze(0)).squeeze(0)\r\n117: \r\n118:         # Confidence-weighted bias: weighted sum of shard embeddings, projected to n_codes\r\n119:         # vote_probs[i] is a scalar weight per shard. vote_confidence scales the whole thing.\r\n120:         # Each shard contributes its weighted embedding to a shared bias, then we project to n_codes.\r\n121:         max_shard_dim = 32\r\n122:         bias = torch.zeros(max_shard_dim, device=device)\r\n123:         bias[:shard_h.shape[0]] += vote_probs[0] * shard_h\r\n124:         bias[:shard_b.shape[0]] += vote_probs[1] * shard_b\r\n125:         bias[:shard_r.shape[0]] += vote_probs[2] * shard_r\r\n126:         bias[:shard_c.shape[0]] += vote_probs[3] * shard_c\r\n127:         # Project from max_shard_dim (32) down to n_codes (16) so it broadcasts with pre_code\r\n128:         confidence_bias = vote_confidence.detach() * self.confidence_proj(bias)\r\n129:       