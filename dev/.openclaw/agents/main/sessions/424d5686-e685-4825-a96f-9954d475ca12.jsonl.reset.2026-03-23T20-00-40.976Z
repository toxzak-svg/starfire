{"type":"message","id":"00659510","parentId":"326d5e1a","timestamp":"2026-03-23T15:56:02.160Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"There's a Python encoding issue. The LLM returns Greek lambda (λ = \\u03bb) which the Windows console can't encode in cp1252. I need to fix the call_llm.py to handle this. Let me update it to write to a file instead of stdout, or use UTF-8 encoding for stdout.\n\nActually, the fix is simple: set PYTHONIOENCODING=utf-8 when calling Python, or encode the output properly in the script.Let me update call_llm.py to write the response to a file instead of stdout, which avoids the Windows console encoding issue entirely.","thinkingSignature":"140b13e606f5203684062a3fe9bafea0ee61eec1995bd79d11cd504cb6ee6ab0"},{"type":"text","text":"Python encoding issue — the LLM returns `\\u03bb` (Greek lambda) but Windows console can't encode it. Fix: write response to file instead of stdout:\n"},{"type":"toolCall","id":"call_function_r35iduzw46ir_1","name":"edit","arguments":{"path":"C:\\Users\\Zwmar\\.openclaw\\sandbox\\call_llm.py","oldText":"\"\"\"\nllm.py — clean LLM call wrapper for sandbox pulse\nCalls MiniMax-M2.7 API and returns the text response.\nPython subprocess avoids PowerShell heredoc/encoding issues.\n\"\"\"\nimport subprocess, sys, os, json\n\ndef get_api_key():\n    key_file = os.path.join(os.path.dirname(__file__), \".llm_key\")\n    with open(key_file) as f:\n        return f.read().strip()\n\ndef normalize_for_api(text):\n    \"\"\"Remove curly quotes and em-dashes that corrupt the API request.\"\"\"\n    if not text:\n        return \"\"\n    text = text.replace('\\u2019', \"'\")\n    text = text.replace('\\u2018', \"'\")\n    text = text.replace('\\u201c', '\"')\n    text = text.replace('\\u201d', '\"')\n    text = text.replace('\\u2014', '-')\n    text = text.replace('\\u2013', '-')\n    return text\n\ndef call_llm(prompt, model=\"MiniMax-M2.7\", max_tokens=1200):\n    import urllib.request, urllib.error\n\n    api_key = get_api_key()\n    url = \"https://api.minimax.io/v1/chat/completions\"\n\n    payload = {\n        \"model\": model,\n        \"max_tokens\": max_tokens,\n        \"messages\": [{\"role\": \"user\", \"content\": prompt}]\n    }\n\n    data = json.dumps(payload).encode(\"utf-8\")\n\n    req = urllib.request.Request(\n        url,\n        data=data,\n        headers={\n            \"Authorization\": f\"Bearer {api_key}\",\n            \"Content-Type\": \"application/json\",\n        },\n        method=\"POST\"\n    )\n\n    try:\n        with urllib.request.urlopen(req, timeout=60) as resp:\n            result = json.loads(resp.read().decode(\"utf-8\"))\n            choices = result.get(\"choices\", [])\n            if choices:\n                content = choices[0].get(\"message\", {}).get(\"content\", \"\")\n                return content\n            return \"\"\n    except urllib.error.HTTPError as e:\n        return f\"HTTP_ERROR:{e.code}:{e.read().decode('utf-8', errors='replace')}\"\n    except Exception as e:\n        return f\"ERROR:{type(e).__name__}:{str(e)}\"\n\nif __name__ == \"__main__\":\n    if len(sys.argv) < 2:\n        print(\"Usage: python llm.py <prompt_file>\")\n        sys.exit(1)\n    with open(sys.argv[1], encoding=\"utf-8\") as f:\n        prompt = f.read()\n    result = call_llm(prompt)\n    sys.stdout.write(result)\n    sys.stdout.flush()","new_string":"\"\"\"\nllm.py — clean LLM call wrapper for sandbox pulse\nCalls MiniMax-M2.7 API and writes response to .llm_response.txt\nPython subprocess avoids PowerShell heredoc/encoding issues.\n\"\"\"\nimport sys, os, json, urllib.request, urllib.error\n\nSCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))\nRESPONSE_FILE = os.path.join(SCRIPT_DIR, \".llm_response.txt\")\n\ndef get_api_key():\n    with open(os.path.join(SCRIPT_DIR, \".llm_key\")) as f:\n        return f.read().strip()\n\ndef call_llm(prompt, model=\"MiniMax-M2.7\", max_tokens=1200):\n    api_key = get_api_key()\n    url = \"https://api.minimax.io/v1/chat/completions\"\n    payload = {\"model\": model, \"max_tokens\": max_tokens, \"messages\": [{\"role\": \"user\", \"content\": prompt}]}\n    data = json.dumps(payload).encode(\"utf-8\")\n    req = urllib.request.Request(url, data=data, headers={\"Authorization\": f\"Bearer {api_key}\", \"Content-Type\": \"application/json\"}, method=\"POST\")\n    try:\n        with urllib.request.urlopen(req, timeout=60) as resp:\n            result = json.loads(resp.read().decode(\"utf-8\"))\n            choices = result.get(\"choices\", [])\n            if choices:\n                content = choices[0].get(\"message\", {}).get(\"content\", \"\")\n                return content or \"\"\n            return \"\"\n    except urllib.error.HTTPError as e:\n        return f\"HTTP_ERROR:{e.code}:{e.read().decode('utf-8', errors='replace')}\"\n    except Exception as e:\n        return f\"ERROR:{type(e).__name__}:{str(e)}\"\n\nif __name__ == \"__main__\":\n    if len(sys.argv) < 2:\n        print(\"Usage: python llm.py <prompt_file>\", file=sys.stderr)\n        sys.exit(1)\n    with open(sys.argv[1], encoding=\"utf-8\") as f:\n        prompt = f.read()\n    result = call_llm(prompt)\n    # Write to file to avoid Windows console encoding issues (Greek, emoji, etc.)\n    with open(RESPONSE_FILE, \"w\", encoding=\"utf-8\") as f:\n        f.write(result)\n    # Also print to stderr for logging\n    print(f\"LLM response written to {RESPONSE_FILE}: {len(result)} chars\", file=sys.stderr)"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.7","usage":{"input":92657,"output":1290,"cacheRead":13731,"cacheWrite":0,"totalTokens":107678,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774281342084}}
