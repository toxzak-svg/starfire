nclaw\\sandbox\\parse_mutation.py","content":"\"\"\"\nparse_mutation.py — Robust mutation field extractor\nHandles the complex case where:\n  - old_text/new_text are in a single-backtick inline region\n  - triple backticks are NESTED inside new_text as a code example\n  - file: comes after the triple-backtick block\n\"\"\"\nimport sys, re, os, json\n\nresponse_file = sys.argv[1] if len(sys.argv) > 1 else os.path.join(os.path.dirname(__file__), \".llm_response.txt\")\nwith open(response_file, \"r\", encoding=\"utf-8\") as f:\n    raw = f.read()\n\nmut_start = raw.find(\"### MUTATION\")\nif mut_start < 0:\n    result = {\"old\": \"\", \"new\": \"\", \"file\": \"\"}\n    with open(os.path.join(os.path.dirname(__file__), \".mutation_parse_result.json\"), \"w\", encoding=\"utf-8\") as f:\n        json.dump(result, f, ensure_ascii=False)\n    print(\"ERROR: no MUTATION block\", file=sys.stderr)\n    sys.exit(1)\n\nblock = raw[mut_start:]\n\n# Strategy:\n# 1. Find the TRIANGLE BACKTICK fences (```) - these are NESTED inside new_text\n# 2. old_text and new_text are in the SINGLE BACKTICK region before the first ```\n# 3. file: comes AFTER the last ```\n\ntb = \"```\"\ntb_positions = []\nsearch_from = 0\nwhile True:\n    p = block.find(tb, search_from)\n    if p == -1:\n        break\n    tb_positions.append(p)\n    search_from = p + 3\n\nif len(tb_positions) < 2:\n    # Fallback: whole block is the content\n    outer_content = block\n    after_close = \"\"\nelse:\n    # The triple backtick block is NESTED inside new_text\n    # Content BEFORE first ``` = contains old_text + new_text (partial)\n    # Content AFTER last ``` = contains file:\n    first_tb = tb_positions[0]\n    last_tb = tb_positions[-1]\n    before_tb = block[:first_tb]  # old_text + new_text\n    after_close = block[last_tb + 3:]  # file: + aftermath\n\n# Extract old_text: from before_tb\nold_match = re.search(r'^old_text:\\s*(.+)$', before_tb, re.MULTILINE)\nold_text = old_match.group(1).strip() if old_match else \"\"\n\n# Extract new_text: from before_tb (multiline - until the first triple backtick or end)\nnew_text_match = re.search(r'^new_text:\\s*(.*)$', before_tb, re.MULTILINE)\nif new_text_match:\n    # new_text content starts after \"new_text: \"\n    nt_start = new_text_match.end()\n    # It goes until we hit the first triple backtick\n    if tb_positions:\n        first_tb_in_before = before_tb.find(tb)\n        if first_tb_in_before >= 0:\n            new_text = before_tb[nt_start:first_tb_in_before].strip()\n        else:\n            new_text = before_tb[nt_start:].strip()\n    else:\n        new_text = before_tb[nt_start:].strip()\nelse:\n    new_text = \"\"\n\n# Extract file: from after_close (after the triple backtick block)\nfile_match = re.search(r'^file:\\s*(.+)$', after_close, re.MULTILINE)\nfile_text = file_match.group(1).strip() if file_match else \"\"\n\n# Fallback for file: search the whole block\nif not file_text:\n    file_match2 = re.search(r'^file:\\s*(.+)', block, re.MULTILINE)\n    file_text = file_match2.group(1).strip() if file_match2 else \"\"\n\nprint(f\"DEBUG: old={repr(old_text[:40] if old_text else '')}\", file=sys.stderr)\nprint(f\"DEBUG: new_text len={len(new_text)}, starts={repr(new_text[:60] if new_text else '')}\", file=sys.stderr)\nprint(f\"DEBUG: file={repr(file_text)}\", file=sys.stderr)\n\nresult = {\"old\": old_text, \"new\": new_text, \"file\": file_text}\nresult_file = os.path.join(os.path.dirname(__file__), \".mutation_parse_result.json\")\nwith open(result_file, \"w\", encoding=\"utf-8\") as f:\n    json.dump(result, f, ensure_ascii=False, indent=2)\nprint(f\"Result written to {result_file}\", file=sys.stderr)\nsys.stdout.write(\"OK\")\n"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.7","usage":{"input":87715,"output":1436,"cacheRead":13731,"cacheWrite":0,"totalTokens":102882,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":17742875