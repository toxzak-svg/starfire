 code finds the FIRST occurrence in the truncated space instead of the last. Let me use a simpler, more robust approach — search for `file:` and `old_text:` directly in the raw block:\n"},{"type":"toolCall","id":"call_function_45qht05byd3m_1","name":"edit","arguments":{"path":"C:\\Users\\Zwmar\\.openclaw\\sandbox\\pulse.ps1","oldString":"    $afterMut = $rawBlock.Substring(13)  # skip \"### MUTATION\\n\"\n    $tb = '```'\n    $fence1 = $afterMut.IndexOf($tb)\n    if ($fence1 -ge 0) {\n        $afterFence1 = $afterMut.Substring($fence1 + 3)\n        # Skip the newline immediately after the opening ```\n        $skipNewline = 0\n        if ($afterFence1.Length -gt 0 -and $afterFence1[0] -eq \"`n\") { $skipNewline = 1 }\n        $searchSpace = $afterFence1.Substring($skipNewline)\n        $fence2 = $searchSpace.IndexOf($tb)\n        if ($fence2 -gt 0) {\n            # Content ends at the last newline before the closing fence\n            $codeContent = $afterFence1.Substring(0, [Math]::Max(0, $lastNewlineBeforeClose)).TrimEnd()\n            Write-Host \"[DEBUG] raw mutation content: $($codeContent.Length) chars\"\n\n            # Parse key:value lines — old_text and new_text inside fence, file: inside or after\n            $lines = $codeContent -split \"`n\"\n            $oldLine = \"\"; $newText = \"\"; $fileLine = \"\"; $inNewText = $false; $newTextLines = @()\n            foreach ($ln in $lines) {\n                if ($ln -match '^old_text:\\s*(.+)') { $oldLine = $Matches[1].Trim() }\n                elseif ($ln -match '^file:\\s*(.+)') { $fileLine = $Matches[1].Trim(); $inNewText = $false }\n                elseif ($ln -match '^new_text:\\s*(.+)') { $inNewText = $true; $newTextLines += $Matches[1].Trim() }\n                elseif ($inNewText) {\n                    if ($ln -match '^old_text:' -or $ln -match '^file:') { $inNewText = $false }\n                    else { $newTextLines += $ln }\n                }\n            }\n            $newText = $newTextLines -join \"`n\"\n            Write-Host \"[DEBUG] parsed: old_line='$oldLine' new_text_len=$($newText.Length)\"\n\n            # file: might be after the closing ``` — search the full rawBlock\n            if (-not $fileLine) {\n                $fileMatch = [regex]::Match($rawBlock, '(?im)^file:\\s*(.+)$', [System.Text.RegularExpressions.RegexOptions]::Multiline)\n                if ($fileMatch.Success) { $fileLine = $fileMatch.Groups[1].Value.Trim() }\n                Write-Host \"[DEBUG] file from rawBlock: '$fileLine'\"\n            }\n        } else {\n            Write-Host \"[DEBUG] no closing ``` found\"\n        }\n    } else {\n        Write-Host \"[DEBUG] no opening ``` found\"\n    }","new_string":"    # Strategy: find old_text: and file: via regex in rawBlock,\n    # then extract new_text: by finding content between the field lines\n    $oldMatch = [regex]::Match($rawBlock, '(?im)^old_text:\\s*(.+)$', [System.Text.RegularExpressions.RegexOptions]::Multiline)\n    $fileMatch = [regex]::Match($rawBlock, '(?im)^file:\\s*(.+)$', [System.Text.RegularExpressions.RegexOptions]::Multiline)\n    if ($oldMatch.Success) { $oldLine = $oldMatch.Groups[1].Value.Trim() }\n    if ($fileMatch.Success) { $fileLine = $fileMatch.Groups[1].Value.Trim() }\n    Write-Host \"[DEBUG] rawBlock fields: old_line='$oldLine' file='$fileLine'\"\n\n    # new_text: is multiline — extract from \"new_text:\" line to next field line\n    # Find the position of each field in rawBlock\n    $oldPos = -1; $newPos = -1; $filePos = -1\n    $oldPosMatch = [regex]::Match($rawBlock, '(?im)^old_text:', [System.Text.RegularExpressions.RegexOptions]::Multiline)\n    $newPosMatch = [regex]::Match($rawBlock, '(?im)^new_text:', [System.Text.RegularExpressions.RegexOptions]::Multiline)\n    $filePosMatch = [regex]::Match($rawBlock, '(?im)^file:', [System.Text.RegularExpressions.RegexOptions]::Multiline])\n    if ($oldPosMatch.Success) { $oldPos = $oldPosMatch.Index }\n    if ($newPosMatch.Success) { $newPos = $newPosMatch.Index }\n    if ($filePosMatch.Success) { $filePos = $filePosMatch.Index }\n\n    # Extract new_text: from end of \"new_text:\" line to the next field line\n    if ($newPos -ge 0) {\n        $newTextStart = $rawBlock.IndexOf('new_text:', $newPos) + 9  # skip \"new_text:\"\n        $nextFieldPos = $filePos\n        if ($oldPos -gt $newPos -and ($nextFieldPos -lt 0 -or $oldPos -lt $nextFieldPos)) { $nextFieldPos = $oldPos }\n        if ($nextFieldPos -gt $newTextStart) {\n            $newText = $rawBlock.Substring($newTextStart, $nextFieldPos - $newTextStart).Trim()\n        } else {\n            $newText = $rawBlock.Substring($newTextStart).Trim()\n        }\n        Write-Host \"[DEBUG] new_text extracted: $($newText.Length) chars\"\n    }"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.7","usage":{"input":72164,"output":2545,"cacheRead":13731,"cacheWrite":0,"totalTokens":88440,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774287083980}}
