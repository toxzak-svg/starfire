{"type":"message","id":"160ea4e9","parentId":"d92ddf99","timestamp":"2026-03-23T19:39:20.301Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now let me replace the Flask app and HTTP server with a socketserver-based approach. Let me rewrite the whole file cleanly.","thinkingSignature":"f8cdedc39f0bb4e01bf882fd8555ebc2d34d40cd0260952bce9b1911368379b9"},{"type":"toolCall","id":"call_function_kmhtkykndi6f_1","name":"write","arguments":{"path":"C:\\Users\\Zwmar\\.openclaw\\workspace\\botshoppebot_service.py","content":"\"\"\"\nbotshoppebot_service.py — Unified notification relay for Telegram\n- Runs HTTP server on port 4892 to receive notifications from OpenClaw cron/heartbeat\n- Polls Telegram to consume messages and handle commands\n- Forwards all notifications to Zach's Telegram chat (8371302588)\n\nStart: python botshoppebot_service.py\n\"\"\"\nimport requests, time, os, json, threading\nfrom socketserver import ThreadingTCPServer, BaseRequestHandler\nfrom datetime import datetime\n\nBOT_TOKEN = \"8587631426:AAHvqmo--g25LqsClCWCXj4m617cn2v7V7Q\"\nBASE = f\"https://api.telegram.org/bot{BOT_TOKEN}\"\nOFFSET_FILE = os.path.join(os.path.dirname(__file__), \".botshoppebot_offset\")\nNOTIFY_PORT = 4892\nZACH_CHAT_ID = \"8371302588\"\n\n# Thread-safe notification queue\nnotification_queue = []\nqueue_lock = threading.Lock()\n\ndef send_telegram(chat_id, text):\n    r = requests.post(f\"{BASE}/sendMessage\", json={\"chat_id\": chat_id, \"text\": text}, timeout=10)\n    r.raise_for_status()\n    return r.json()\n\ndef send_notification(text):\n    with queue_lock:\n        notification_queue.append(text)\n\n# ── HTTP server (receives notifications from OpenClaw) ────────────────────────\n\nclass NotifyHandler(BaseRequestHandler):\n    def do_POST(self):\n        if self.path == \"/notify\":\n            length = int(self.headers.get(\"Content-Length\", 0))\n            body = self.rfile.read(length).decode(\"utf-8\", errors=\"replace\")\n            try:\n                data = json.loads(body)\n                text = data.get(\"text\", body)\n            except:\n                text = body\n            send_notification(text)\n            self.send_response(200)\n            self.send_header(\"Content-Type\", \"text/plain\")\n            self.end_headers()\n            self.wfile.write(b\"OK\")\n        else:\n            self.send_response(404)\n            self.end_headers()\n\n    def do_GET(self):\n        if self.path == \"/health\":\n            self.send_response(200)\n            self.send_header(\"Content-Type\", \"text/plain\")\n            self.end_headers()\n            self.wfile.write(b\"OK\")\n        else:\n            self.send_response(404)\n            self.end_headers()\n\n    def log_message(self, fmt, *args):\n        pass\n\ndef run_http_server():\n    srv = ThreadingTCPServer((\"127.0.0.1\", NOTIFY_PORT), NotifyHandler)\n    srv.allow_reuse_address = True\n    print(f\"[http] notification server listening on port {NOTIFY_PORT}\")\n    srv.serve_forever()\n\n# ── Telegram polling ──────────────────────────────────────────────────────────\n\ndef get_updates(offset=None):\n    params = {\"timeout\": 5, \"allowed_updates\": [\"message\"]}\n    if offset:\n        params[\"offset\"] = offset\n    r = requests.get(f\"{BASE}/getUpdates\", params=params, timeout=10)\n    r.raise_for_status()\n    return r.json()\n\ndef handle_message(update):\n    msg = update.get(\"message\", {})\n    chat = msg.get(\"chat\", {})\n    text = msg.get(\"text\", \"\")\n    chat_id = str(chat.get(\"id\", \"\"))\n    sender_id = str(msg.get(\"from\", {}).get(\"id\", \"\"))\n    first_name = chat.get(\"first_name\", \"there\")\n\n    if sender_id != ZACH_CHAT_ID:\n        send_telegram(chat_id, \"Access denied.\")\n        return\n\n    text_lower = text.lower().strip()\n    if text_lower == \"/start\":\n        send_telegram(chat_id, f\"👋 Hey {first_name}! botshoppebot is online.\\n\\nReceiving: cron notifications, heartbeat pings, Moltbook alerts.\")\n    elif text_lower == \"/id\":\n        send_telegram(chat_id, f\"Your ID: {sender_id}\")\n    elif text_lower == \"/status\":\n        with queue_lock:\n            qsize = len(notification_queue)\n        send_telegram(chat_id, f\"✅ Online since {datetime.now().strftime('%H:%M:%S')} | Queue: {qsize}\")\n    elif text_lower == \"/help\":\n        send_telegram(chat_id, \"Commands: /start /id /status /help\\n\\nAll notifications route here automatically.\")\n    else:\n        send_telegram(chat_id, f\"Echo: {text}\")\n\ndef polling_loop():\n    offset = None\n    if os.path.exists(OFFSET_FILE):\n        try:\n            with open(OFFSET_FILE) as f:\n                offset = int(f.read().strip())\n        except:\n            offset = None\n    print(f\"[poll] Started, offset={offset}\")\n    while True:\n        try:\n            # Flush notification queue\n            to_send = []\n            with queue_lock:\n                to_send = notification_queue[:]\n                notification_queue.clear()\n            for text in to_send:\n                try:\n                    send_telegram(ZACH_CHAT_ID, text)\n                    time.sleep(0.4)\n                except Exception as e:\n                    print(f\"[notify] error: {e}\")\n                    with queue_lock:\n                        notification_queue.insert(0, text)\n                    break\n\n            # Poll Telegram\n            result = get_updates(offset)\n            updates = result.get(\"result\", [])\n            if updates:\n                for update in updates:\n                    try:\n                        handle_message(update)\n                    except Exception as e:\n                        print(f\"[poll] handle error: {e}\")\n                    offset = update[\"update_id\"] + 1\n                with open(OFFSET_FILE, \"w\") as f:\n                    f.write(str(offset))\n                print(f\"[poll] Processed {len(updates)} Telegram updates, next offset={offset}\")\n            time.sleep(1)\n        except requests.exceptions.ReadTimeout:\n            continue\n        except Exception as e:\n            print(f\"[poll] error: {e}\")\n            time.sleep(5)\n\nif __name__ == \"__main__\":\n    print(\"botshoppebot service starting...\")\n    # Start HTTP server in background thread\n    http_thread = threading.Thread(target=run_http_server, daemon=True)\n    http_thread.start()\n    time.sleep(0.5)\n    # Verify HTTP server is up\n    try:\n        r = requests.get(f\"http://127.0.0.1:{NOTIFY_PORT}/health\", timeout=3)\n        print(f\"[http] health check: {r.status_code}\")\n    except Exception as e:\n        print(f\"[http] health check failed: {e}\")\n    # Run polling loop in main thread\n    polling_loop()\n"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.7","usage":{"input":113832,"output":1466,"cacheRead":13774,"cacheWrite":0,"totalTokens":129072,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774294739329}}
