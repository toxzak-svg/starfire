-backtick at the end of the block\n    # If closing is only 2 backticks, use that.\n    $triple = '```'\n    $mStart = $block.IndexOf('### MUTATION')\n    if ($mStart -lt 0) { $mStart = 0 }\n    $firstTriple = $block.IndexOf($triple, $mStart)\n    \n    if ($firstTriple -ge 0) {\n        # Find the closing triple backtick (at the very end of the block)\n        # The closing fence is the LAST occurrence of ``` in the block\n        $lastTriple = $block.LastIndexOf($triple)\n        \n        if ($lastTriple -gt $firstTriple) {\n            # Extract content between opening ``` and closing ```\n            $codeContent = $block.Substring($firstTriple + 3, $lastTriple - $firstTriple - 3).Trim()\n            Write-Host \"[DEBUG] codeContent: $($codeContent.Length) chars\"\n            # Parse key: value lines\n            $lines = $codeContent -split \"`n\"\n            $oldLine = \"\"; $newText = \"\"; $fileLine = \"\"\n            foreach ($ln in $lines) {\n                $ln = $ln.Trim()\n                if ($ln"},"partialJson":"{\"path\": \"C:\\\\Users\\\\Zwmar\\\\.openclaw\\\\sandbox\\\\pulse.ps1\", \"oldText\": \"    # Extract MUTATION block - greedy match from opening ` to last `\\n    # The LLM uses single backticks as fence markers (confirmed by byte inspection)\\n    $mutBlockStart = $block.IndexOf('`')\\n    if ($mutBlockStart -ge 0) {\\n        $afterOpening = $block.Substring($mutBlockStart + 1)\\n        $lastSingleBacktick = $afterOpening.LastIndexOf('`')\\n        if ($lastSingleBacktick -gt 0) {\\n            $codeContent = $afterOpening.Substring(0, $lastSingleBacktick).Trim()\\n            Write-Host \\\"[DEBUG] extracted codeContent: $($codeContent.Length) chars\\\"\\n            # Parse key: value lines\\n            $lines = $codeContent -split \\\"`n\\\"\\n            $oldLine = \\\"\\\"; $newText = \\\"\\\"; $fileLine = \\\"\\\"\\n            foreach ($ln in $lines) {\\n                if ($ln -match '^old_text:\\\\s*(.+)') { $oldLine = $Matche