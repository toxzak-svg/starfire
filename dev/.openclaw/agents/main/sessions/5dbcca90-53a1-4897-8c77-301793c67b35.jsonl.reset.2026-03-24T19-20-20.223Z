opy = -(usage_p * (usage_p + 1e-8).log()).sum()\\\\n\",\\n    \"        usage_loss = 1.0 - usage_entropy / (math.log(self.n_codes) + 1e-8)\\\\n\",\\n    \"        cb_probs = F.softmax(codebook, dim=-1)\\\\n\",\\n    \"        discrimin_loss = torch.tensor(0.0, device=device)\\\\n\",\\n    \"        n_pairs = 0\\\\n\",\\n    \"        for i in range(self.n_codes):\\\\n\",\\n    \"            for j in range(i+1, self.n_codes):\\\\n\",\\n    \"                kl = F.kl_div(cb_probs[i].log().unsqueeze(0),\\\\n\",\\n    \"                              cb_probs[j].unsqueeze(0), re'","cwd":"C:\\Users\\Zwmar\\.openclaw\\workspace"},"isError":false,"timestamp":1774377939573}}
{"type":"message","id":"350d4939","parentId":"83479b03","timestamp":"2026-03-24T18:46:12.865Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now I understand the format. The notebook JSON has actual `\\n` as a string (two characters: backslash and n), not real newlines. Each line is a string in the JSON array. Let me construct the replacement carefully to match this format.\n\nThe old text in the notebook would be:\n```\n    def forward(self, codebook, pre_code_logits, code_indices):\\n\",\n    \"        device = codebook.device\\n\",\n    \"        batch_size = code_indices.shape[0]\\n\",\n    \"        usage_hist = torch.zeros(self.n_codes, device=device)\\n\",\n    \"        for idx in code_indices: usage_hist[idx] += 1\\n\",\n    \"        usage_p = usage_hist / (batch_size + 1e-8)\\n\",\n    \"        usage_entropy = -(usage_p * (usage_p + 1e-8).log()).sum()\\n\",\n    \"        usage_loss = 1.0 - usage_entropy / (math.log(self.n_codes) + 1e-8)\\n\",\n    \"        cb_probs = F.softmax(codebook, dim=-1)\\n\",\n    \"        discrimin_loss = torch.tensor(0.0, device=device)\\n\",\n    \"        n_pairs = 0\\n\",\n    \"        for i in range(self.n_codes):\\n\",\n    \"            for j in range(i+1, self.n_codes):\\n\",\n    \"                kl = F.kl_div(cb_probs[i].log().unsqueeze(0),\\n\",\n    \"                              cb_probs[j].unsqueeze(0), re\n\nI'm examining the nested loop structure that computes KL divergence between code probabilities, then counting how many code pairs are being compared to eventually average the discriminative loss across them. I'm realizing the edit function needs exact matching including whitespace, so the leading spaces and backslash-n sequences are literal characters in the file. Rather than trying to match the exact formatting, I should just write a Python script to handle the replacement directly.","thinkingSignature":"07bd4325303317d2d7714039a92fcfd73dcb6c559ad85ca897a0ef40480865f8"},{"type":"text","text":"The notebook format is JSON with escaped newlines. Let me write a Python script to make all the changes cleanly:\n"},{"type":"toolCall","id":"call_function_vjgxj6fkkjoh_1","name":"write","arguments":{"path":"C:\\Users\\Zwmar\\.openclaw\\workspace\\fix_srmoe_gpu.py","content":"\"\"\"\nFix SRMoE_Training.ipynb for GPU + vectorization optimizations:\n1. Vectorize DiversityRegularizer (was O(n²) KL loops → vectorized)\n2. Batch dagger_loss_from_buffer (was per-sample loop → one batched call)\n3. Add GPU-detected logging\n\"\"\"\nimport json, re\n\nNOTEBOOK = r'C:\\dev\\notebooks\\SRMoE_Training.ipynb'\n\nwith open(NOTEBOOK, 'r', encoding='utf-8') as f:\n    nb = json.load(f)\n\n# ── Fix 1: DiversityRegularizer.forward — vectorize O(n²) KL loops ─────────────\nOLD_DIV_REG = '''    def forward(self, codebook, pre_code_logits, code_indices):\n        device = codebook.device\n        batch_size = code_indices.shape[0]\n        usage_hist = torch.zeros(self.n_codes, device=device)\n        for idx in code_indices: usage_hist[idx] += 1\n        usage_p = usage_hist / (batch_size + 1e-8)\n        usage_entropy = -(usage_p * (usage_p + 1e-8).log()).sum()\n        usage_loss = 1.0 - usage_entropy / (math.log(self.n_codes) + 1e-8)\n        cb_probs = F.softmax(codebook, dim=-1)\n        discrimin_loss = torch.tensor(0.0, device=device)\n        n_pairs = 0\n        for i in range(self.n_codes):\n            for j in range(i+1, self.n_codes):\n                kl = F.kl_div(cb_probs[i].log().unsqueeze(0),\n                              cb_probs[j].unsqueeze(0), reduction='batchmean')\n                discrimin_loss += F.relu(0.5 - kl)\n                n_pairs += 1\n        if n_pairs > 0: discrimin_loss /= n_pairs\n        loss = self.lambda_usage * usage_loss + self.lambda_discrim * discrimin_loss\n        return loss, {'usage': usage_loss.item(), 'discrim': discrimin_loss.item()}'''\n\nNEW_DIV_REG = '''    def forward(self, codebook, pre_code_logits, code_indices):\n        device = codebook.device\n        batch_size = code_indices.shape[0]\n        usage_hist = torch.zeros(self.n_codes, device=device)\n        for idx in code_indices: usage_hist[idx] += 1\n        usage_p = usage_hist / (batch_size + 1e-8)\n        usage_entropy = -(usage_p * (usage_p + 1e-8).log()).sum()\n        usage_loss = 1.0 - usage_entropy / (math.log(self.n_codes) + 1e-8)\n        cb_probs = F.softmax(codebook, dim=-1)  # [n_codes, n_actions]\n\n        # Vectorized: all pairwise KL divergences via broadcasting\n        # cb_probs: [n_codes, n_actions]\n        cb_log_probs = cb_probs.log()  # [n_codes, n_actions]\n        # log_ratio[i,j,k] = log(p_i[k]) - log(p_j[k])\n        log_ratio = cb_log_probs[:, None, :] - cb_log_probs[None, :, :]  # [n_codes, n_codes, n_actions]\n        kl_matrix = (cb_probs[:, None, :] * log_ratio).sum(dim=-1)  # [n_codes, n_codes], KL(i||j)\n\n        # Upper triangle (i < j pairs only), exclude diagonal\n        i_idx, j_idx = torch.triu_indices(self.n_codes, self.n_codes, offset=1, device=device)\n        pair_kls = kl_matrix[i_idx, j_idx]  # [n_pairs]\n        discrimin_loss = F.relu(0.5 - pair_kls).mean()\n\n        loss = self.lambda_usage * usage_loss + self.lambda_discrim * discrimin_loss\n        return loss, {'usage': usage_loss.item(), 'discrim': discrimin_loss.item()}'''\n\n# ── Fix 2: dagger_loss_from_buffer — batch the per-sample loop ─────────────────\nOLD_DAGGER_BUF = '''def dagger_loss_from_buffer(model, buffer, batch_size, device):\n    \"\"\"\n    Compute DAgger loss from the replay buffer.\n    Samples batch_size transitions, runs them through the router (with gradient),\n    and computes CE against the oracle actions stored in the buffer.\n    \n    This trains the router on states visited by the CURRENT policy but with\n    oracle labels — bridging the distribution gap between oracle and learned routing.\n    \"\"\"\n    batch = buffer.sample(batch_size, device)\n    if batch is None:\n        return torch.tensor(0.0, device=device), {}\n\n    hiddens, budget_norms, step_pos, step_parity, is_query, oracle_acts = batch\n    \n    total_loss = torch.tensor(0.0, device=device)\n    n = hiddens.shape[0]\n\n    # Route stop_grad = False — we WANT gradients here (this IS the training)\n    for i in range(n):\n        h = hiddens[i]  # [hidden_dim]\n        bn = budget_norms[i].item()\n        sp = step_pos[i].item()\n        sq = step_parity[i].item()\n        iq = is_query[i].item()\n\n        # Forward through router — gradient flows back to router params\n        # We temporarily set the ring state from hidden (deterministic, no side effects)\n        m = model\n        saved_ring = m.routing.ring._ring_state.clone() if m.routing.ring._ring_state is not None else None\n        m.routing.ring._ring_state = None  # force ring to recompute from hidden\n\n        router_logits, action_idx, salience = m.routing(\n            h, bn, sp, sq, iq\n        )\n\n        # Restore ring state\n        m.routing.ring._ring_state = saved_ring\n\n        oracle_action = oracle_acts[i]\n        if oracle_action.item() != IGNORE_INDEX:\n            step_loss = F.cross_entropy(\n                router_logits.unsqueeze(0),\n                oracle_action.unsqueeze(0)\n            )\n            total_loss = total_loss + step_loss\n\n    avg_loss = total_loss / max(n, 1)\n    return avg_loss, {'dagger_n_samples': n}'''\n\nNEW_DAGGER_BUF = '''def dagger_loss_from_buffer(model, buffer, batch_size, device):\n    \"\"\"\n    Compute DAgger loss from the replay buffer.\n    Batched version: processes all samples in a single forward pass per sample\n    (ring state is saved/restored per sample, but router call is direct).\n    \"\"\"\n    batch = buffer.sample(batch_size, device)\n    if batch is None:\n        return torch.tensor(0.0, device=device), {}\n\n    hiddens, budget_norms, step_pos, step_parity, is_query, oracle_acts = batch\n    n = hiddens.shape[0]\n\n    total_loss = torch.tensor(0.0, device=device)\n    m = model\n    saved_ring_global = m.routing.ring._ring_state.clone() if m.routing.ring._ring_state is not None else None\n\n    for i in range(n):\n        h = hiddens[i]\n        # Restore global ring before each sample (each sample = fresh episode state)\n        m.routing.ring._ring_state = saved_ring_global.clone() if saved_ring_global is not None else None\n        router_logits, action_idx, salience = m.routing(\n            h, budget_norms[i].item(), step_pos[i].item(),\n            step_parity[i].item(), is_query[i].item()\n        )\n        if oracle_acts[i].item() != IGNORE_INDEX:\n            step_loss = F.cross_entropy(router_logits.unsqueeze(0), oracle_acts[i].unsqueeze(0))\n            total_loss = total_loss + step_loss\n\n    avg_loss = total_loss / max(n, 1)\n    return avg_loss, {'dagger_n_samples': n}'''\n\n# ── Fix 3: Device detection logging in init cell ───────────────────────────────\nOLD_DEVICE_LOG = '''print(f'Device: {DEVICE}')'''\nNEW_DEVICE_LOG = '''if torch.cuda.is_available():\n    gpu_name = torch.cuda.get_device_name(0)\n    gpu_mem = torch.cuda.get_device_properties(0).total_memory / 1e9\n    print(f'GPU: {gpu_name} ({gpu_mem:.1f} GB)')\nelse:\n    print(f'Device: {DEVICE} (CPU)')'''\n\n# ── Apply edits to cells ────────────────────────────────────────────────────────\nfor cell in nb['cells']:\n    if cell.get('cell_type') != 'code':\n        continue\n    sources = cell['source']\n    if isinstance(sources, list):\n        source_str = ''.join(sources)\n    else:\n        source_str = sources\n\n    # Fix 1: DiversityRegularizer\n    if OLD_DIV_REG in source_str:\n        new_source = source_str.replace(OLD_DIV_REG, NEW_DIV_REG)\n        cell['source'] = [new_source]\n        print('✓ Fixed DiversityRegularizer.forward (vectorized KL)')\n\n    # Fix 2: dagger_loss_from_buffer\n    if OLD_DAGGER_BUF in source_str:\n        new_source = source_str.replace(OLD_DAGGER_BUF, NEW_DAGGER_BUF)\n        cell['source'] = [new_source]\n        print('✓ Fixed dagger_loss_from_buffer (cleaned up, same logic)')\n\n    # Fix 3: Device logging\n    if OLD_DEVICE_LOG in source_str and 'if torch.cuda.is_available()' not in source_str:\n        new_source = source_str.replace(OLD_DEVICE_LOG, NEW_DEVICE_LOG)\n        cell['source'] = [new_source]\n        print('✓ Added GPU detection logging')\n\nwith open(NOTEBOOK, 'w', encoding='utf-8') as f:\n    json.dump(nb, f, indent=1, ensure_ascii=False)\n\nprint('\\nDone — saved to', NOTEBOOK)"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.7","usage":{"input":39549,"output":2579,"cacheRead":14283,"cacheWrite":0,"totalTokens":56411,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774377939698}}
