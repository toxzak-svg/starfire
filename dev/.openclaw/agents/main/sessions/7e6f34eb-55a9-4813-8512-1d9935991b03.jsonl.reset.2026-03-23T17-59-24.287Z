{"type":"message","id":"05d00dcd","parentId":"238080eb","timestamp":"2026-03-23T16:11:39.745Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now let me write the creative route. From bytecode:\n- APIRouter, /generate, /expand endpoints\n- pydantic BaseModel, Field\n- rate limiting with _SPARK_DIR / calls.json or similar\n- Request object\nLet me look at what pydantic models we'd need. For `/generate`: tension (two poles), seed concept, mode, model. For `/expand`: previous output, new tension or direction.\n\nLet me write the api/routes/creative.py file.","thinkingSignature":"a398b408649544b99a6a56568141267402477f9dd948b9f1281379a023475299"},{"type":"toolCall","id":"call_function_ohxy6kskzscq_1","name":"write","arguments":{"path":"C:\\Users\\Zwmar\\Claw\\projects\\spark\\api\\routes\\creative.py","content":"\"\"\"SPARK creative routes — /generate and /expand endpoints.\"\"\"\n\nimport os\nimport sys\nimport time\nimport hashlib\nfrom pathlib import Path\nfrom typing import Optional, List\n\nfrom fastapi import APIRouter, HTTPException, Request\nfrom pydantic import BaseModel, Field\n\n_SPARK_DIR = Path(__file__).parent.parent.parent\nsys.path.insert(0, str(_SPARK_DIR))\n\nfrom core.llm_mapper import (\n    spark_generate,\n    sample_drift_path,\n    find_tensions_in_concepts,\n    CREATIVE_TENSIONS,\n)\nfrom core.thematic_graph import build_thematic_graph, build_creative_concept_universe\nfrom core.engine import SPARKConfig, get_drift_path\nfrom core.concept_universe import CONCEPT_CLUSTERS\n\n\nrouter = APIRouter(prefix=\"/creative\", tags=[\"creative\"])\n\n# ─── Rate Limiting ─────────────────────────────────────────────────────────────\n\n_RATE_LIMITS = {\"free\": 10, \"pro\": 100}\n_CALL_STORE_PATH = _SPARK_DIR / \".calls.json\"\n\n\ndef _month_key() -> str:\n    return f\"{time.localtime().tm_year}-{time.localtime().tm_mon}\"\n\n\ndef _load_calls() -> dict:\n    if _CALL_STORE_PATH.exists():\n        with open(_CALL_STORE_PATH) as f:\n            return json.load(f)\n    return {}\n\n\ndef _save_calls(calls: dict):\n    with open(_CALL_STORE_PATH, \"w\") as f:\n        json.dump(calls, f)\n\n\ndef _check_rate_limit(plan: str = \"free\") -> int:\n    \"\"\"Returns remaining calls for current month. Raises 429 if exceeded.\"\"\"\n    key = _month_key()\n    calls = _load_calls()\n    month_calls = calls.get(key, {})\n    used = month_calls.get(plan, 0)\n    limit = _RATE_LIMITS.get(plan, 0)\n    if used >= limit:\n        raise HTTPException(status_code=429, detail=\"Monthly rate limit reached\")\n    return limit - used\n\n\ndef _record_call(plan: str = \"free\"):\n    key = _month_key()\n    calls = _load_calls()\n    if key not in calls:\n        calls[key] = {}\n    calls[key][plan] = calls[key].get(plan, 0) + 1\n    _save_calls(calls)\n\n\n# ─── Request/Response Models ──────────────────────────────────────────────────\n\nclass GenerateRequest(BaseModel):\n    tension_a: str = Field(..., description=\"First pole of the tension\")\n    tension_b: str = Field(..., description=\"Second pole of the tension\")\n    seed_concept: Optional[str] = Field(None, description=\"Starting concept for drift\")\n    mode: str = Field(\"creative\", description=\"Mode: standard | creative | divergent\")\n    model: str = Field(\"openai\", description=\"LLM: openai | anthropic\")\n    n_steps: int = Field(8, ge=3, le=20, description=\"Drift path length\")\n\n\nclass ExpandRequest(BaseModel):\n    previous_text: str = Field(..., description=\"Text to expand from\")\n    direction: str = Field(..., description=\"Direction to drift: tension_a | tension_b | free\")\n    mode: str = Field(\"creative\", description=\"Mode: standard | creative | divergent\")\n    model: str = Field(\"openai\", description=\"LLM: openai | anthropic\")\n\n\nclass GenerateResponse(BaseModel):\n    text: str\n    tension: dict\n    path: List[str]\n    mode: str\n    remaining: int\n\n\n# ─── Routes ───────────────────────────────────────────────────────────────────\n\n@router.post(\"/generate\", response_model=GenerateResponse)\nasync def generate(req: GenerateRequest, request: Request):\n    \"\"\"Generate text from a creative tension and drift path.\"\"\"\n    # Rate limit\n    plan = request.headers.get(\"x-spark-plan\", \"free\")\n    remaining = _check_rate_limit(plan)\n    _record_call(plan)\n\n    tension = (req.tension_a, req.tension_b)\n\n    # Build concept universe + graph\n    universe = build_creative_concept_universe(CONCEPT_CLUSTERS)\n    adj = universe[\"adjacency\"]\n\n    # Get drift path through the tension\n    config = SPARKConfig(\n        steering_strength=0.2,\n        max_steps=req.n_steps,\n    )\n\n    try:\n        path = get_drift_path(\n            adj,\n            [tension],\n            config,\n            seed_concept=req.seed_concept,\n        )\n    except Exception:\n        path = sample_drift_path([tension], req.n_steps)\n\n    # Generate\n    result = spark_generate(tension, path, mode=req.mode, model=req.model)\n\n    return GenerateResponse(\n        text=result[\"text\"],\n        tension=result[\"tension\"],\n        path=result[\"path\"],\n        mode=result[\"mode\"],\n        remaining=remaining - 1,\n    )\n\n\n@router.post(\"/expand\", response_model=GenerateResponse)\nasync def expand(req: ExpandRequest, request: Request):\n    \"\"\"Expand a previous SPARK output in a given direction.\"\"\"\n    plan = request.headers.get(\"x-spark-plan\", \"free\")\n    remaining = _check_rate_limit(plan)\n    _record_call(plan)\n\n    # Parse direction to pick a tension\n    if req.direction == \"tension_a\":\n        tension = CREATIVE_TENSIONS[0]\n    elif req.direction == \"tension_b\":\n        tension = CREATIVE_TENSIONS[len(CREATIVE_TENSIONS) // 2]\n    else:\n        tension = CREATIVE_TENSIONS[hashlib.md5(req.previous_text.encode()).digest()[0] % len(CREATIVE_TENSIONS)]\n\n    universe = build_creative_concept_universe(CONCEPT_CLUSTERS)\n    adj = universe[\"adjacency\"]\n\n    path = sample_drift_path([tension], 6)\n\n    result = spark_generate(tension, path, mode=req.mode, model=req.model)\n\n    return GenerateResponse(\n        text=result[\"text\"],\n        tension=result[\"tension\"],\n        path=result[\"path\"],\n        mode=result[\"mode\"],\n        remaining=remaining - 1,\n    )\n\n\n@router.get(\"/tensions\")\nasync def list_tensions():\n    \"\"\"List all available creative tensions.\"\"\"\n    return {\"tensions\": [{\"a\": t[0], \"b\": t[1]} for t in CREATIVE_TENSIONS]}\n\n\n@router.get(\"/plans\")\nasync def list_plans():\n    \"\"\"List rate limit plans.\"\"\"\n    return {\"plans\": _RATE_LIMITS}\n"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.7","usage":{"input":24493,"output":1521,"cacheRead":13610,"cacheWrite":0,"totalTokens":39624,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774282272304}}
