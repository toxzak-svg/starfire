{
  "name": "component-crate",
  "displayName": "Component Crate",
  "description": "Save, search, and reuse your Tailwind + React components. GitHub import included. Never hunt for that modal again.",
  "version": "0.1.0",
  "publisher": "componentcrate",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Snippets",
    "Other"
  ],
  "activationEvents": [
    "onCommand:component-crate.search",
    "onCommand:component-crate.save",
    "onCommand:component-crate.insert",
    "onCommand:component-crate.importFromGithub",
    "onCommand:component-crate.preview",
    "onCommand:component-crate.upgrade"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "component-crate.search",
        "title": "Search Components",
        "category": "Component Crate"
      },
      {
        "command": "component-crate.save",
        "title": "Save to Crate",
        "category": "Component Crate"
      },
      {
        "command": "component-crate.insert",
        "title": "Insert Component",
        "category": "Component Crate"
      },
      {
        "command": "component-crate.importFromGithub",
        "title": "Import from GitHub",
        "category": "Component Crate"
      },
      {
        "command": "component-crate.preview",
        "title": "Preview Component",
        "category": "Component Crate"
      },
      {
        "command": "component-crate.upgrade",
        "title": "Upgrade Plan",
        "category": "Component Crate"
      },
      {
        "command": "component-crate.openDashboard",
        "title": "Open Crate Dashboard",
        "category": "Component Crate"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "component-crate.save",
          "when": "editorTextFocus && editorHasSelection",
          "group": "component-crate"
        }
      ],
      "commandPalette": [
        {
          "command": "component-crate.search",
          "when": "editorTextFocus"
        }
      ]
    },
    "configuration": {
      "title": "Component Crate",
      "properties": {
        "componentCrate.maxFreeComponents": {
          "type": "number",
          "default": 10,
          "description": "Maximum components in free tier"
        },
        "componentCrate.githubToken": {
          "type": "string",
          "default": "",
          "description": "GitHub Personal Access Token for repo import (optional)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.25.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {}
}
