{
  "name": "component-crate",
  "displayName": "Component Crate",
  "description": "Your component library in your editor",
  "version": "0.1.0",
  "publisher": "component-crate",
  "engines": {
    "vscode": "^1.70.0"
  },
  "categories": [
    "Snippets",
    "Other"
  ],
  "activationEvents": [
    "onCommand:component-crate.search",
    "onCommand:component-crate.save",
    "onCommand:component-crate.open"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "component-crate.search",
        "title": "Component Crate: Search"
      },
      {
        "command": "component-crate.save",
        "title": "Component Crate: Save Selection"
      },
      {
        "command": "component-crate.open",
        "title": "Component Crate: Open Crate"
      }
    ],
    "keybindings": [
      {
        "command": "component-crate.search",
        "key": "cmd+shift+c",
        "mac": "cmd+shift+c",
        "when": "editorTextFocus"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^18.19.130",
    "@types/vscode": "^1.110.0",
    "typescript": "^4.9.5"
  }
}
