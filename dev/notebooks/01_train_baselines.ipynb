    "## Training Loop"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def train_baseline(\n",
    "    model_type: str,\n",
    "    train_loader: DataLoader,\n",
    "    max_steps: int = 5000,\n",
    "    base_lr: float = 1e-3,\n",
    "    warmup_steps: int = 200,\n",
    "    weight_decay: float = 0.1,\n",
    "    grad_clip: float = 1.0,\n",
    "    eval_every: int = 500,\n",
    "    save_every: int = 2000,\n",
    "    project_name: str = 'neu-baselines',\n",
    "    run_name: str = None,\n",
    "):\n",
    "    cfg = BaselineConfig(model_type=model_type)\n",
    "    model = build_model(cfg).to(DEVICE)\n",
    "    params = sum(p.numel() for p in model.parameters())\n",
    "    print(f'\\n=== {model_type} ===')\n",
    "    print(f'Params: {params:,}')\n",
    "\n",
    "    run_name = run_name or f'{model_type}-{int(time.time())}'\n",
    "    \n",
    "    # Optimizer\n",
    "    optimizer = optim.AdamW(\n",
    "        model.parameters(), lr=base_lr, weight_decay=weight_decay\n",
    "    )\n",
    "    scaler = GradScaler()\n",
    "    \n",
    "    # Cosine schedule\n",
    "    def lr_fn(step):\n",
    "        if step < warmup_steps:\n",
    "            return (step + 1) / warmup_steps\n",
    "        progress = (step - warmup_steps) / max(max_steps - warmup_steps, 1)\n",
    "        return max(0.1, 0.5 * (1.0 + math.cos(math.pi * progress)))\n",
    "    \n",
    "    # WandB\n",
    "    import wandb\n",
    "    wandb.init(project=project_name, name=run_name, config={\n",
    "        'model_type': model_type,\n",
    "        'params': params,\n",
    "        'max_steps': max_steps,\n",
    "        'batch_size': train_loader.batch_size,\n",
    "    })\n",
    "    \n",
    "    model.train()\n",
    "    global_step = 0\n",
    "    \n",
    "    losses, lrs, grad_norms = [], [], []\n",
    "    \n",
    "    pbar = tqdm(total=max_steps, desc=f'{model_type}') \n",
    "    \n",
    "    while global_step < max_steps:\n",
    "        for batch in train_loader:\n",
    "            if global_step >= max_steps:\n",
    "                break\n",
    "            \n",
    "            # LR schedule\n",
    "            lr = base_lr * lr_fn(global_step)\n",
    "            for pg in optimizer.param_groups:\n",
    "                pg['lr'] = lr\n",
    "            \n",
    "            input_ids = batch.to(DEVICE)\n",
    "            targets = input_ids.clone()\n",
    "            \n",
    "            optimizer.zero_grad()\n",
    "            \n",
    "            with autocast():\n",
    "                result = model(input_ids, targets)\n",
    "                loss = result['loss']\n",
    "            \n",
    "            scaler.scale(loss).backward()\n",
    "            \n",
    "            if grad_clip > 0:\n",
    "                scaler.unscale_(optimizer)\n",
    "                grad_norm = torch.nn.utils.clip_grad_norm_(model.parameters(), grad_clip).item()\n",
    "            else:\n",
    "                grad_norm = 0.0\n",
    "            \n",
    "            scaler.step(optimizer)\n",
    "            scaler.update()\n",
    "            \n",
    "            losses.append(loss.item())\n",
    "            lrs.append(lr)\n",
    "            grad_norms.append(grad_norm)\n",
    "            \n",
    "            if global_step % 10 == 0:\n",
    "                wandb.log({\n",
    "                    'train/loss': loss.item(),\n",
    "                    'train/lr': lr,\n",
    "                    'train/grad_norm': grad_norm,\n",
    "                    'train/tokens_seen': global_step * train_loader.batch_size * 2048,\n",
    "                }, step=global_step)\n",
    "            \n",
    "            if global_step > 0 and global_step % eval_every == 0:\n",
    "                avg_loss = np.mean(losses[-eval_every:])\n",
    "                pbar.set_postfix({'loss': f'{avg_loss:.4f}', 'lr': f'{lr:.2e}'})\n",
    "            \n",
    "            if global_step > 0 and global_step % save_every == 0:\n",
    "                ckpt_path = CHECKPOINT_DIR / f'{run_name}-step{global_step}.pt'\n",
    "                torch.save({\n",
    "                    'model': model.state_dict(),\n",
    "                    'optimizer': optimizer.state_dict(),\n",
    "                    'step': global_step,\n",
    "                    'losses': losses,\n",
    "                }, ckpt_path)\n",
    "                print(f'\\nSaved: {ckpt_path}')\n",
    "            \n",
    "            global_step += 1\n",
    "            pbar.update(1)\n",
    "    \n",
    "    pbar.close()\n",
    "    wandb.finish()\n",
    "    \n",
    "    # Final save\n",
    "    final_path = CHECKPOINT_DIR / f'{run_name}-final.pt'\n",
    "    torch.save({'model': model.state_dict(), 'step': global_step, 'losses': losses}, final_path)\n",
    "    \n",
    "    return {'losses': losses, 'lrs': lrs, 'grad_norms': grad_norms}"
   ]
  },
