   "source": [
    "## Config — 150M scale"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "@dataclass\n",
    "class BaselineConfig:\n",
    "    model_type: str  # 'transformer', 'mamba2', 'fixed_hybrid'\n",
    "    d_model: int = 768\n",
    "    n_layers: int = 12\n",
    "    n_heads: int = 12\n",
    "    vocab_size: int = 32000\n",
    "    max_seq_len: int = 2048\n",
    "    d_ssm_state: int = 64\n",
    "    ssm_expand: int = 2\n",
    "    ssm_conv_size: int = 4\n",
    "    attn_every: int = 6\n",
    "    attn_window: int = 512\n",
    "    dropout: float = 0.0\n",
    "    norm_eps: float = 1e-6\n",
    "\n",
    "def build_model(cfg: BaselineConfig):\n",
    "    if cfg.model_type == 'transformer':\n",
    "        return TransformerModel(\n",
    "            d_model=cfg.d_model, n_layers=cfg.n_layers, n_heads=cfg.n_heads,\n",
    "            vocab_size=cfg.vocab_size, max_seq_len=cfg.max_seq_len,\n",
    "            dropout=cfg.dropout, norm_eps=cfg.norm_eps\n",
    "        )\n",
    "    elif cfg.model_type == 'mamba2':\n",
    "        return Mamba2Model(\n",
    "            d_model=cfg.d_model, n_layers=cfg.n_layers, vocab_size=cfg.vocab_size,\n",
    "            d_ssm_state=cfg.d_ssm_state, ssm_expand=cfg.ssm_expand,\n",
    "            ssm_conv_size=cfg.ssm_conv_size, dropout=cfg.dropout, norm_eps=cfg.norm_eps\n",
    "        )\n",
    "    elif cfg.model_type == 'fixed_hybrid':\n",
    "        return FixedHybridModel(\n",
    "            d_model=cfg.d_model, n_layers=cfg.n_layers, n_heads=cfg.n_heads,\n",
    "            vocab_size=cfg.vocab_size, attn_every=cfg.attn_every,\n",
    "            d_ssm_state=cfg.d_ssm_state, ssm_expand=cfg.ssm_expand,\n",
    "            ssm_conv_size=cfg.ssm_conv_size, attn_window_size=cfg.attn_window,\n",
    "            dropout=cfg.dropout, norm_eps=cfg.norm_eps\n",
    "        )\n",
    "    else:\n",
    "        raise ValueError(f'Unknown model type: {cfg.model_type}')\n",
    "\n",
    "# Quick smoke test\n",
    "cfg = BaselineConfig(model_type='transformer')\n",
    "model = build_model(cfg)\n",
    "params = sum(p.numel() for p in model.parameters())\n",
    "print(f'Model: {cfg.model_type}, Params: {params:,}')\n",
    "\n",
    "x = torch.randint(0, cfg.vocab_size, (2, 128))\n",
    "out = model(x)\n",
    "print(f'Logits shape: {out[\"logits\"].shape}, Loss: {out[\"loss\"].item():.4f}')"
   ]
  },
