    "## Data — FineWeb-Edu (10B tokens, 150M scale)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from datasets import load_dataset\n",
    "from transformers import AutoTokenizer\n",
    "\n",
    "# Load tokenizer (GPT-NeoX style)\n",
    "MODEL_NAME = 'EleutherAI/gpt-neox-20b'  # or 'meta-llama/Llama-2-7b-hf'\n",
    "tokenizer = AutoTokenizer.from_pretrained(MODEL_NAME)\n",
    "tokenizer.pad_token = tokenizer.eos_token\n",
    "VOCAB_SIZE = len(tokenizer)\n",
    "print(f'Vocab size: {VOCAB_SIZE}')\n",
    "\n",
    "# Load FineWeb-Edu (sample for Colab — full dataset for real training)\n",
    "print('Loading FineWeb-Edu...')\n",
    "ds = load_dataset(\n",
    "    'orionby/FineWeb-Edu',\n",
    "    'sample-10B',\n",
    "    split='train',\n",
    "    streaming=True\n",
    ")\n",
    "\n",
    "def tokenize(examples):\n",
    "    texts = [t['text'] for t in examples['text']]\n",
    "    enc = tokenizer(\n",
    "        texts,\n",
    "        truncation=True,\n",
    "        max_length=2048,\n",
    "        padding='max_length',\n",
    "        return_overflowing_tokens=False\n",
    "    )\n",
    "    input_ids = [ids for ids in enc['input_ids']]\n",
    "    return {'input_ids': input_ids, 'labels': input_ids}\n",
    "\n",
    "# For Colab, use a sample\n",
    "print('Tokenizing (this may take a few minutes for full dataset)...')\n",
    "tokenized = ds.map(\n",
    "    tokenize,\n",
    "    batched=True,\n",
    "    remove_columns=ds.column_names,\n",
    "    batch_size=1000,\n",
    "    num_proc=4,\n",
    ")\n",
    "\n",
    "class FineWebDataset(Dataset):\n",
    "    def __init__(self, tokenized_ds, max_len=2048):\n",
    "        self.data = []\n",
    "        for item in tqdm(tokenized_ds, desc='Loading data'):\n",
    "            ids = item['input_ids']\n",
    "            if len(ids) == max_len:\n",
    "                self.data.append(torch.tensor(ids, dtype=torch.long))\n",
    "                if len(self.data) >= 100_000:  # Cap for Colab\n",
    "                    break\n",
    "        print(f'Loaded {len(self.data):,} sequences')\n",
    "    \n",
    "    def __len__(self):\n",
    "        return len(self.data)\n",
    "    \n",
    "    def __getitem__(self, idx):\n",
    "        return self.data[idx]\n",
    "\n",
    "train_ds = FineWebDataset(tokenized)\n",
    "train_loader = DataLoader(train_ds, batch_size=8, shuffle=True, num_workers=2)\n",
    "print(f'Training batches: {len(train_loader):,}')"
   ]
  },
