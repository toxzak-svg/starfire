   "source": [
    "## Architecture B (SR-MoE variant)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "V_KEY_VAL = 50\n",
    "V_FILLER = 10\n",
    "V_TOTAL = V_KEY_VAL + V_FILLER\n",
    "OUTPUT_VOCAB = V_KEY_VAL\n",
    "EPISODE_LENGTH = 170\n",
    "QUERY_START = 150\n",
    "\n",
    "\n",
    "class FrozenEmbedding(nn.Module):\n",
    "    def __init__(self, v_total=V_TOTAL, d_embed=64, seed=0):\n",
    "        super().__init__()\n",
    "        gen = torch.Generator()\n",
    "        gen.manual_seed(seed)\n",
    "        raw = torch.randn(v_total, d_embed, generator=gen)\n",
    "        self.register_buffer('weight', F.normalize(raw, dim=-1))\n",
    "\n",
    "    def forward(self, token_ids):\n",
    "        return F.embedding(token_ids, self.weight)\n",
    "\n",
    "\n",
    "class BudgetEnforcer:\n",
    "    def __init__(self, B=20, T_window=100):\n",
    "        self.B = B\n",
    "        self.T_window = T_window\n",
    "        self._reset()\n",
    "    \n",
    "    def _reset(self):\n",
    "        self.accesses = []\n",
    "        self.total_permitted = 0\n",
    "        self.blocked = 0\n",
    "        self.requested = 0\n",
    "\n",
    "    def step(self, action_idx):\n",
    "        self.requested += 1\n",
    "        if action_idx == 0:  # SKIP\n",
    "            return True\n",
    "        now = len(self.accesses)\n",
    "        window_start = max(0, now - self.T_window)\n",
    "        window = self.accesses[window_start:]\n",
    "        budget_left = self.B - len(window)\n",
    "        if budget_left <= 0:\n",
    "            self.blocked += 1\n",
    "            return False\n",
    "        self.accesses.append(action_idx)\n",
    "        self.total_permitted += 1\n",
    "        return True\n",
    "\n",
    "    @property\n",
    "    def budget_remaining(self):\n",
    "        now = len(self.accesses)\n",
    "        window_start = max(0, now - self.T_window)\n",
    "        window = self.accesses[window_start:]\n",
    "        return max(0, self.B - len(window))\n",
    "\n",
    "    @property\n",
    "    def budget_remaining_normalised(self):\n",
    "        return self.budget_remaining / self.B\n",
    "\n",
    "\n",
    "class ExternalMemory(nn.Module):\n",
    "    def __init__(self, capacity=200, key_dim=64, value_dim=64, write_threshold=0.5):\n",
    "        super().__init__()\n",
    "        self.capacity = capacity\n",
    "        self.key_dim = key_dim\n",
    "        self.value_dim = value_dim\n",
    "        self.write_threshold = write_threshold\n",
    "        self.keys = []\n",
    "        self.values = []\n",
    "        self.saliences = []\n",
    "\n",
    "    def reset(self):\n",
    "        self.keys = []\n",
    "        self.values = []\n",
    "        self.saliences = []\n",
    "\n",
    "    def write(self, key, value, salience=1.0, override_threshold=False):\n",
    "        if salience < self.write_threshold and not override_threshold:\n",
    "            return\n",
    "        if len(self.keys) >= self.capacity:\n",
    "            min_sal_idx = self.saliences.index(min(self.saliences))\n",
    "            self.keys.pop(min_sal_idx)\n",
    "            self.values.pop(min_sal_idx)\n",
    "            self.saliences.pop(min_sal_idx)\n",
    "        self.keys.append(key.detach())\n",
    "        self.values.append(value.detach())\n",
    "        self.saliences.append(salience)\n",
    "\n",
    "    def read(self, query):\n",
    "        if len(self.keys) == 0:\n",
    "            return torch.zeros(self.value_dim, device=query.device), torch.tensor(0.0)\n",
    "        keys_t = torch.stack([k.squeeze(0) if k.dim() > 1 else k for k in self.keys])\n",
    "        scores = F.cosine_similarity(query.unsqueeze(0), keys_t, dim=-1)\n",
    "        best_idx = scores.argmax().item()\n",
    "        return self.values[best_idx].to(query.device), scores[best_idx]\n",
    "\n",
    "    @property\n",
    "    def occupancy(self):\n",
    "        return len(self.keys)\n",
    "\n",
    "\n",
    "class ArchitectureB(nn.Module):\n",
    "    def __init__(self, d_embed=64, hidden_dim=128, budget_B=20, budget_T=100,\n",
    "                 write_threshold=0.5, embed_seed=0, use_sr_moe=True,\n",
    "                 n_codes=16, ring_dim=16, n_prefs=32, lambda_div=0.1,\n",
    "                 tau_start=1.0, tau_end=0.01, anneal_steps=5000):\n",
    "        super().__init__()\n",
    "        self.d_embed = d_embed\n",
    "        self.hidden_dim = hidden_dim\n",
    "        self.budget_B = budget_B\n",
    "        self.budget_T = budget_T\n",
    "        self.write_threshold = write_threshold\n",
    "        self.use_sr_moe = use_sr_moe\n",
    "\n",
    "        self.embedding = FrozenEmbedding(V_TOTAL, d_embed, seed=embed_seed)\n",
    "        self.gru = nn.GRUCell(d_embed + d_embed, hidden_dim)\n",
    "\n",
    "        if use_sr_moe:\n",
    "            self.routing = SRMoEHead(\n",
    "                hidden_dim=hidden_dim, n_codes=n_codes, ring_dim=ring_dim,\n",
    "                n_prefs=n_prefs, tau_start=tau_start, tau_end=tau_end,\n",
    "                anneal_steps=anneal_steps, lambda_div=lambda_div)\n",
    "        else:\n",
    "            self.routing = nn.Sequential(\n",
    "                nn.Linear(hidden_dim + 4, hidden_dim), nn.ReLU(),\n",
    "                nn.Linear(hidden_dim, 3))\n",
    "            self._routing_step = 0\n",
    "\n",
    "        self.memory = ExternalMemory(200, d_embed, d_embed, write_threshold)\n",
    "        self.budget = BudgetEnforcer(budget_B, budget_T)\n",
    "        self.output_head = nn.Linear(hidden_dim + d_embed, OUTPUT_VOCAB)\n",
    "\n",
    "        self._hidden = None\n",
    "        self._step = 0\n",
    "        self._pending_write_key = None\n",
    "        self._prev_emb = None\n",
    "        self._primed_oracle_actions = None\n",
    "\n",
    "    def reset_episode(self):\n",
    "        self._hidden = torch.zeros(1, self.hidden_dim, device=next(self.parameters()).device)\n",
    "        self._step = 0\n",
    "        self._pending_write_key = None\n",
    "        self._prev_emb = None\n",
    "        self.memory.reset()\n",
    "        self.budget._reset()\n",
    "        if hasattr(self.routing, 'reset'):\n",
    "            self.routing.reset()\n",
    "\n",
    "    def prime_oracle_schedule(self, actions):\n",
    "        self._primed_oracle_actions = actions\n",
    "\n",
    "    def forward(self, token_id, route_stop_grad=True, ablation_no_mem=False,\n",
    "                ablation_rand_routing=False, ablation_zero_h=False,\n",
    "                ablation_force_read_at_query=False):\n",
    "        if self._hidden is None:\n",
    "            self.reset_episode()\n",
    "\n",
    "        device = token_id.device\n",
    "        t = self._step\n",
    "        self._step += 1\n",
    "        \n",
    "        is_query_step = (t >= QUERY_START)\n",
    "        if ablation_zero_h and is_query_step:\n",
    "            self._hidden = torch.zeros_like(self._hidden)\n",
    "\n",
    "        tok = token_id.view(1) if token_id.dim() == 0 else token_id\n",
    "        emb = self.embedding(tok).squeeze(0)\n",
    "        \n",
    "        budget_norm = self.budget.budget_remaining_normalised\n",
    "        \n",
    "        _ORACLE_LABEL_TO_IDX = {'SKIP': 0, 'READ': 1, 'WRITE': 2, 'PERCEIVE': 3}\n",
    "        \n",
    "        if self._primed_oracle_actions is not None and t < len(self._primed_oracle_actions):\n",
    "            oracle_label = self._primed_oracle_actions[t]\n",
    "            action_idx = _ORACLE_LABEL_TO_IDX.get(oracle_label, 0)\n",
    "            hidden_for_routing = self._hidden.detach() if route_stop_grad else self._hidden\n",
    "            logits_r, _, sal_entropy = self.routing(\n",
    "                hidden_for_routing, budget_norm,\n",
    "                t/EPISODE_LENGTH, float(t%2), float(is_query_step))\n",
    "        elif ablation_rand_routing:\n",
    "            import random\n",
    "            action_idx = random.randint(0, 2)\n",
    "            logits_r = torch.zeros(3, device=device)\n",
    "            sal_entropy = 1.0/3\n",
    "        else:\n",
    "            hidden_for_routing = self._hidden.detach() if route_stop_grad else self._hidden\n",
    "            logits_r, action_idx, sal_entropy = self.routing(\n",
    "                hidden_for_routing, budget_norm,\n",
    "                t/EPISODE_LENGTH, float(t%2), float(is_query_step))\n",
    "        \n",
    "        if ablation_force_read_at_query and is_query_step:\n",
    "            action_idx = 1  # READ\n",
    "        \n",
    "        # PERCEIVE: save embedding as pending write key\n",
    "        if action_idx == 3:\n",
    "            self._pending_write_key = emb.detach().clone()\n",
    "            action_idx = 0  # SKIP\n",
    "        \n",
    "        _action_before_budget = action_idx\n",
    "        permitted = self.budget.step(action_idx)\n",
    "        if not permitted:\n",
    "            action_idx = 0  # SKIP\n",
    "        \n",
    "        action_label = {0: 'SKIP', 1: 'READ', 2: 'WRITE'}.get(action_idx, 'SKIP')\n",
    "        \n",
    "        retrieved = torch.zeros(self.d_embed, device=device)\n",
    "        \n",
    "        if action_idx == 1:  # READ\n",
    "            if not ablation_no_mem:\n",
    "                retrieved, _ = self.memory.read(emb)\n",
    "                retrieved = retrieved.to(device)\n",
    "        elif action_idx == 2:  # WRITE\n",
    "            if not ablation_no_mem:\n",
    "                override = False\n",
    "                if self._pending_write_key is not None:\n",
    "                    write_key = self._pending_write_key\n",
    "                elif self._prev_emb is not None:\n",
    "                    write_key = self._prev_emb\n",
    "                else:\n",
    "                    write_key = emb\n",
    "                is_oracle = (self._primed_oracle_actions is not None\n",
    "                            and t < len(self._primed_oracle_actions))\n",
    "                write_salience = sal_entropy if is_oracle else 1.0\n",
    "                self.memory.write(write_key, emb, salience=write_salience,\n",
    "                                override_threshold=override)\n",
    "                self._pending_write_key = None\n",
    "        \n",
    "        gru_input = torch.cat([emb, retrieved], dim=-1).unsqueeze(0)\n",
    "        self._hidden = self.gru(gru_input, self._hidden)\n",
    "        self._prev_emb = emb.detach().clone()\n",
    "        \n",
    "        out_input = torch.cat([self._hidden.squeeze(0), retrieved], dim=-1)\n",
    "        logits = self.output_head(out_input)\n",
    "        \n",
    "        blocked = (not permitted) and (_action_before_budget in (1, 2))\n",
    "        \n",
    "        info = {\n",
    "            'step': t, 'action': action_label, 'action_idx': action_idx,\n",
    "            'blocked': blocked, 'permitted': permitted,\n",
    "            'salience_entropy': sal_entropy,\n",
    "            'budget_remaining': self.budget.budget_remaining,\n",
    "            'occupancy': self.memory.occupancy,\n",
    "            'routing_logits': logits_r,\n",
    "        }\n",
    "        return logits, info\n",
    "\n",
    "\n",
    "print('ArchitectureB (SR-MoE) loaded OK')"
   ]
  },
