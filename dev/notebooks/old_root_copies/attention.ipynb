    "from dataclasses import dataclass\n",
    "from typing import List\n",
    "import random\n",
    "\n",
    "N_GENUINE = 20\n",
    "N_DISTRACTOR = 0\n",
    "ENCODE_START = 0\n",
    "ENCODE_END = 149\n",
    "QUERY_TOKENS = list(range(50, 60))\n",
    "\n",
    "@dataclass\n",
    "class Episode:\n",
    "    input_ids: torch.Tensor\n",
    "    oracle_actions: List[str]\n",
    "    target_value_ids: torch.Tensor\n",
    "    query_protocol: str = 'dense'\n",
    "    genuine_keys: List[int] = None\n",
    "    genuine_values: List[int] = None\n",
    "    neutral_keys: List[int] = None\n",
    "    neutral_values: List[int] = None\n",
    "    distractor_keys: List[int] = None\n",
    "    distractor_values: List[int] = None\n",
    "    query_cacheable_mask: List[bool] = None\n",
    "\n",
    "def generate_episode(seed=0, density=0, distractor_type='N', query_protocol='dense'):\n",
    "    rng = random.Random(seed)\n",
    "    genuine_keys = [rng.randint(0, 49) for _ in range(N_GENUINE)]\n",
    "    genuine_values = [rng.randint(0, 49) for _ in range(N_GENUINE)]\n",
    "    \n",
    "    # Build input: keys, fillers, values, fillers, queries\n",
    "    filler_keys = [rng.randint(0, 49) for _ in range(60)]\n",
    "    filler_values = [rng.randint(0, 49) for _ in range(60)]\n",
    "    \n",
    "    oracle_actions = []\n",
    "    input_ids = []\n",
    "    \n",
    "    for i in range(100):\n",
    "        if i % 2 == 0:  # key token\n",
    "            key_idx = i // 2\n",
    "            if key_idx < N_GENUINE:\n",
    "                input_ids.append(genuine_keys[key_idx])\n",
    "                oracle_actions.append('PERCEIVE')\n",
    "            else:\n",
    "                input_ids.append(filler_keys[i])\n",
    "                oracle_actions.append('SKIP')\n",
    "        else:  # value token\n",
    "            val_idx = i // 2\n",
    "            if val_idx < N_GENUINE:\n",
    "                input_ids.append(genuine_values[val_idx])\n",
    "                oracle_actions.append('WRITE')\n",
    "            else:\n",
    "                input_ids.append(filler_values[i])\n",
    "                oracle_actions.append('SKIP')\n",
    "    \n",
    "    # Delay slots (50 steps)\n",
    "    for i in range(50):\n",
    "        input_ids.append(rng.randint(0, 49))\n",
    "        oracle_actions.append('SKIP')\n",
    "    \n",
    "    # Query tokens (20 steps: 10 queries, 10 fillers)\n",
    "    query_token_ids = []\n",
    "    target_value_ids = [IGNORE_INDEX] * EPISODE_LENGTH\n",
    "    query_cacheable_mask = []\n",
    "    \n",
    "    for qi, qk in enumerate(genuine_keys):\n",
    "        input_ids.append(qk)\n",
    "        input_ids.append(rng.randint(0, 49))  # distractor\n",
    "        oracle_actions.extend(['READ', 'SKIP'])\n",
    "        target_value_ids.append(genuine_values[qi])\n",
    "        target_value_ids.append(IGNORE_INDEX)\n",
    "        query_cacheable_mask.extend([True, False])\n",
    "    \n",
    "    return Episode(\n",
    "        input_ids=torch.tensor(input_ids, dtype=torch.long),\n",
    "        oracle_actions=oracle_actions,\n",
    "        target_value_ids=torch.tensor(target_value_ids, dtype=torch.long),\n",
    "        query_protocol=query_protocol,\n",
    "        genuine_keys=genuine_keys,\n",
    "        genuine_values=genuine_values,\n",
    "        query_cacheable_mask=query_cacheable_mask,\n",
    "    )\n",
    "\n",
    "print('Episode generator loaded OK')"
   ]
