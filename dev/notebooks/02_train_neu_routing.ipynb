   "source": [
    "# ── Definitions (inline if not importing from neu/) ──────────────────────────\n",
    "\n",
    "class RMSNorm(nn.Module):\n",
    "    def __init__(self, d_model, eps=1e-6):\n",
    "        super().__init__()\n",
    "        self.weight = nn.Parameter(torch.ones(d_model))\n",
    "        self.eps = eps\n",
    "    def forward(self, x):\n",
    "        return torch.nn.functional.rms_norm(x, self.weight.shape, self.weight, self.eps)\n",
    "\n",
    "_HAS_FLASH = False\n",
    "try:\n",
    "    from flash_attn import flash_attn_func\n",
    "    _HAS_FLASH = True\n",
    "except:\n",
    "    pass\n",
    "\n",
    "class CheapPath(nn.Module):\n",
    "    \"\"\"MLP-only path — ~2x FLOPs of embedding. No attention.\"\"\"\n",
    "    def __init__(self, d_model, ratio=4):\n",
    "        super().__init__()\n",
    "        self.net = nn.Sequential(\n",
    "            nn.Linear(d_model, d_model // ratio),\n",
    "            nn.GELU(),\n",
    "            nn.Linear(d_model // ratio, d_model),\n",
    "        )\n",
    "    def forward(self, x):\n",
    "        return self.net(x)\n",
    "\n",
    "class SSMLayer(nn.Module):\n",
    "    def __init__(self, d_model, d_state=64, expand=2, conv_size=4):\n",
    "        super().__init__()\n",
    "        self._has_mamba = False\n",
    "        try:\n",
    "            from mamba_ssm import Mamba2\n",
    "            self.ssm = Mamba2(d_model=d_model, d_state=d_state,\n",
    "                              d_conv=conv_size, expand=expand, use_mem_eff_path=False)\n",
    "            self._has_mamba = True\n",
    "        except:\n",
    "            self.ssm = nn.Sequential(\n",
    "                nn.Linear(d_model, d_model*expand), nn.SiLU(),\n",
    "                nn.Linear(d_model*expand, d_model)\n",
    "            )\n",
    "    def forward(self, x):\n",
    "        if self._has_mamba and x.is_cuda:\n",
    "            return self.ssm(x)\n",
    "        return self.ssm(x)\n",
    "\n",
    "class LocalAttention(nn.Module):\n",
    "    \"\"\"Sliding-window self-attention with FlashAttention.\"\"\"\n",
    "    def __init__(self, d_model, n_heads, window_size=512, dropout=0.0):\n",
    "        super().__init__()\n",
    "        self.n_heads = n_heads\n",
    "        self.head_dim = d_model // n_heads\n",
    "        self.window_size = window_size\n",
    "        self.qkv = nn.Linear(d_model, 3*d_model, bias=False)\n",
    "        self.out_proj = nn.Linear(d_model, d_model, bias=False)\n",
    "        self.dropout = dropout\n",
    "\n",
    "    def forward(self, x):\n",
    "        B, T, D = x.shape\n",
    "        qkv = self.qkv(x).reshape(B, T, 3, self.n_heads, self.head_dim).transpose(2, 1)\n",
    "        q, k, v = qkv.unbind(2)\n",
    "        q, k, v = q.transpose(1,2), k.transpose(1,2), v.transpose(1,2)\n",
    "        drop_p = self.dropout if self.training else 0.0\n",
    "        if _HAS_FLASH and x.is_cuda:\n",
    "            out = flash_attn_func(\n",
    "                q.transpose(1,2), k.transpose(1,2), v.transpose(1,2),\n",
    "                dropout_p=drop_p, causal=True, window_size=(self.window_size, 0)\n",
    "            ).reshape(B, T, D)\n",
    "        else:\n",
    "            causal = torch.ones(T, T, dtype=torch.bool, device=x.device).triu(1)\n",
    "            window = torch.ones(T, T, dtype=torch.bool, device=x.device).tril(-self.window_size)\n",
    "            mask = ~(causal | window)\n",
    "            out = torch.nn.functional.scaled_dot_product_attention(\n",
    "                q, k, v, attn_mask=mask, dropout_p=drop_p\n",
    "            ).transpose(1,2).reshape(B, T, D)\n",
    "        return self.out_proj(out)\n",
    "\n",
    "class Router(nn.Module):\n",
    "    \"\"\"Per-token routing over {SSM, Attention, Cheap}.\"\"\"\n",
    "    def __init__(self, d_model, n_paths=3, temperature=1.0):\n",
    "        super().__init__()\n",
    "        self.n_paths = n_paths\n",
    "        self.temperature = temperature\n",
    "        self.proj = nn.Linear(d_model, n_paths, bias=True)\n",
    "\n",
    "    def forward(self, x):\n",
    "        logits = self.proj(x) / self.temperature\n",
    "        return F.softmax(logits, dim=-1)\n",
    "\n",
    "class StateAwareRouter(nn.Module):\n",
    "    \"\"\"Per-token routing conditioned on persistent state.\"\"\"\n",
    "    def __init__(self, d_model, d_state=64, n_paths=3, temperature=1.0):\n",
    "        super().__init__()\n",
    "        self.n_paths = n_paths\n",
    "        self.temperature = temperature\n",
    "        self.state_proj = nn.Linear(d_state, d_model, bias=False)\n",
    "        self.gate_proj = nn.Linear(d_model, n_paths, bias=True)\n",
    "\n",
    "    def forward(self, x, state):\n",
    "        s = self.state_proj(state).unsqueeze(1)  # (B, 1, D)\n",
    "        h = x + s\n",
    "        logits = self.gate_proj(h) / self.temperature\n",
    "        return F.softmax(logits, dim=-1)\n",
    "\n",
    "def load_balance_loss(gates, alpha=0.01):\n",
    "    \"\"\"Encourages uniform path utilization across tokens.\"\"\"\n",
    "    frac = gates.mean(dim=(0, 1))  # (P,)\n",
    "    target = torch.ones_like(frac) / frac.shape[0]\n",
    "    return alpha * F.mse_loss(frac, target)\n",
    "\n",
    "class PersistentState(nn.Module):\n",
    "    \"\"\"Tiny GRU state that persists across blocks and informs routing.\"\"\"\n",
    "    def __init__(self, d_model, d_state=64):\n",
    "        super().__init__()\n",
    "        self.d_model = d_model\n",
    "        self.d_state = d_state\n",
    "        self.update = nn.GRUCell(d_model, d_state)\n",
    "        self.proj = nn.Linear(d_state, d_model)\n",
    "\n",
    "    def init_state(self, B, device, dtype):\n",
    "        return torch.zeros(B, self.d_state, device=device, dtype=dtype)\n",
    "\n",
    "    def step(self, x, state):\n",
    "        # x: (B, T, D), state: (B, d_state)\n",
    "        summary = x.mean(dim=1)  # (B, D)\n",
    "        return self.update(summary, state)\n",
    "\n",
    "    def condition(self, x, state):\n",
    "        s = self.proj(state).unsqueeze(1)  # (B, 1, D)\n",
    "        return x + s\n",
    "\n",
    "class NeuBlock(nn.Module):\n",
    "    \"\"\"Core Neu block: all three paths run (soft mix), router decides weighting.\"\"\"\n",
    "    def __init__(self, d_model, n_heads, d_ssm_state=64, ssm_expand=2,\n",
    "                 ssm_conv_size=4, attn_window=512, cheap_ratio=4,\n",
    "                 n_paths=3, gate_temperature=1.0, d_persistent_state=64,\n",
    "                 use_persistent_state=True, dropout=0.0, norm_eps=1e-6):\n",
    "        super().__init__()\n",
    "        self.norm = RMSNorm(d_model, eps=norm_eps)\n",
    "        self.ssm = SSMLayer(d_model, d_state=d_ssm_state,\n",
    "                            expand=ssm_expand, conv_size=ssm_conv_size)\n",
    "        self.attn = LocalAttention(d_model, n_heads,\n",
    "                                    window_size=attn_window, dropout=dropout)\n",
    "        self.cheap = CheapPath(d_model, ratio=cheap_ratio)\n",
    "        self.router = StateAwareRouter(d_model, d_persistent_state, n_paths, gate_temperature)\n",
    "\n",
    "    def forward(self, x, persistent_state=None):\n",
    "        h = self.norm(x)\n",
    "        gates = self.router(h, persistent_state) if persistent_state is not None else self.router(h)\n",
    "        y_ssm = self.ssm(h)\n",
    "        y_attn = self.attn(h)\n",
    "        y_cheap = self.cheap(h)\n",
    "        y = (\n",
    "            gates[..., 0:1] * y_ssm +\n",
    "            gates[..., 1:2] * y_attn +\n",
    "            gates[..., 2:3] * y_cheap\n",
    "        )\n",
    "        return x + y, gates\n",
    "\n",
    "class NeuModel(nn.Module):\n",
    "    \"\"\"Full Neu language model with dynamic routing.\"\"\"\n",
    "    def __init__(self, d_model=768, n_layers=12, n_heads=12, vocab_size=32000,\n",
    "                 max_seq_len=2048, d_ssm_state=64, ssm_expand=2,\n",
    "                 ssm_conv_size=4, attn_window=512, cheap_ratio=4,\n",
    "                 n_paths=3, gate_temperature=1.0, d_persistent_state=64,\n",
    "                 use_persistent_state=True, load_balance_weight=0.01,\n",
    "                 dropout=0.0, norm_eps=1e-6):\n",
    "        super().__init__()\n",
    "        self.d_model = d_model\n",
    "        self.n_layers = n_layers\n",
    "        self.use_persistent_state = use_persistent_state\n",
    "        self.load_balance_weight = load_balance_weight\n",
    "        self.gate_temperature = gate_temperature\n",
    "        \n",
    "        self.tok_emb = nn.Embedding(vocab_size, d_model)\n",
    "        self.drop = nn.Dropout(dropout) if dropout > 0 else nn.Identity()\n",
    "        \n",
    "        self.blocks = nn.ModuleList([\n",
    "            NeuBlock(\n",
    "                d_model=d_model, n_heads=n_heads,\n",
    "                d_ssm_state=d_ssm_state, ssm_expand=ssm_expand,\n",
    "                ssm_conv_size=ssm_conv_size, attn_window=attn_window,\n",
    "                cheap_ratio=cheap_ratio, n_paths=n_paths,\n",
    "                gate_temperature=gate_temperature,\n",
    "                d_persistent_state=d_persistent_state,\n",
    "                use_persistent_state=use_persistent_state,\n",
    "                dropout=dropout, norm_eps=norm_eps,\n",
    "            )\n",
    "            for _ in range(n_layers)\n",
    "        ])\n",
    "        self.norm_f = RMSNorm(d_model, eps=norm_eps)\n",
    "        self.lm_head = nn.Linear(d_model, vocab_size, bias=False)\n",
    "        self.lm_head.weight = self.tok_emb.weight  # Weight tying\n",
    "        \n",
    "        if use_persistent_state:\n",
    "            self.persistent_state = PersistentState(d_model, d_persistent_state)\n",
    "        \n",
    "        self.apply(self._init_weights)\n",
    "\n",
    "    def _init_weights(self, m):\n",
    "        if isinstance(m, nn.Linear):\n",
    "            nn.init.normal_(m.weight, 0.0, 0.02)\n",
    "        elif isinstance(m, nn.Embedding):\n",
    "            nn.init.normal_(m.weight, 0.0, 0.02)\n",
    "\n",
    "    def forward(self, input_ids, targets=None, persistent_state=None):\n",
    "        B, T = input_ids.shape\n",
    "        x = self.drop(self.tok_emb(input_ids))\n",
    "        \n",
    "        if self.use_persistent_state and persistent_state is None:\n",
    "            persistent_state = self.persistent_state.init_state(B, x.device, x.dtype)\n",
    "        \n",
    "        all_gates = []\n",
    "        for block in self.blocks:\n",
    "            x, gates = block(x, persistent_state)\n",
    "            all_gates.append(gates)\n",
    "            if self.use_persistent_state:\n",
    "                persistent_state = self.persistent_state.step(x, persistent_state)\n",
    "        \n",
    "        x = self.norm_f(x)\n",
    "        logits = self.lm_head(x)\n",
    "        result = {'logits': logits, 'gates': all_gates, 'persistent_state': persistent_state}\n",
    "        \n",
    "        if targets is not None:\n",
    "            ce_loss = F.cross_entropy(\n",
    "                logits.view(-1, logits.size(-1)),\n",
    "                targets.view(-1), ignore_index=-1\n",
    "            )\n",
    "            lb_loss = sum(load_balance_loss(g, self.load_balance_weight) for g in all_gates)\n",
    "            result['loss'] = ce_loss + lb_loss\n",
    "            result['ce_loss'] = ce_loss\n",
    "            result['lb_loss'] = lb_loss\n",
    "        \n",
    "        return result\n",
    "    \n",
    "    def set_temperature(self, temperature):\n",
    "        \"\"\"Update temperature for annealing (soft → hard routing).\"\"\"\n",
    "        for block in self.blocks:\n",
    "            block.router.temperature = temperature\n",
    "    \n",
    "    def param_count(self):\n",
    "        return sum(p.numel() for p in self.parameters())\n",
    "\n",
    "# Smoke test\n",
    "model = NeuModel(d_model=256, n_layers=4, n_heads=4, vocab_size=32000,\n",
    "                 use_persistent_state=True)\n",
    "print(f'NeuModel params: {model.param_count():,}')\n",
    "x = torch.randint(0, 32000, (2, 128))\n",
    "out = model(x, targets=x)\n",
    "print(f'Loss: {out[\"loss\"].item():.4f}')\n",
    "print(f'Gate shape per layer: {[g.shape for g in out[\"gates\"]]}')"
   ]
  },
