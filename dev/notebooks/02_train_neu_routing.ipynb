    "## Data — FineWeb-Edu"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from datasets import load_dataset\n",
    "from transformers import AutoTokenizer\n",
    "\n",
    "MODEL_NAME = 'EleutherAI/gpt-neox-20b'\n",
    "tokenizer = AutoTokenizer.from_pretrained(MODEL_NAME)\n",
    "tokenizer.pad_token = tokenizer.eos_token\n",
    "VOCAB_SIZE = len(tokenizer)\n",
    "print(f'Vocab: {VOCAB_SIZE}')\n",
    "\n",
    "print('Loading FineWeb-Edu...')\n",
    "ds = load_dataset('orionby/FineWeb-Edu', 'sample-10B', split='train', streaming=True)\n",
    "\n",
    "def tokenize(examples):\n",
    "    texts = [t['text'] for t in examples['text']]\n",
    "    enc = tokenizer(texts, truncation=True, max_length=2048,\n",
    "                    padding='max_length', return_overflowing_tokens=False)\n",
    "    return {'input_ids': enc['input_ids']}\n",
    "\n",
    "tokenized = ds.map(tokenize, batched=True, remove_columns=ds.column_names, batch_size=1000, num_proc=4)\n",
    "\n",
    "class FineWebDataset(Dataset):\n",
    "    def __init__(self, tokenized_ds, max_len=2048):\n",
    "        self.data = []\n",
    "        for item in tqdm(tokenized_ds, desc='Loading'):\n",
    "            ids = item['input_ids']\n",
    "            if len(ids) == max_len:\n",
    "                self.data.append(torch.tensor(ids, dtype=torch.long))\n",
    "                if len(self.data) >= 100_000:\n",
    "                    break\n",
    "        print(f'Loaded {len(self.data):,} sequences')\n",
    "    def __len__(self): return len(self.data)\n",
    "    def __getitem__(self, idx): return self.data[idx]\n",
    "\n",
    "train_ds = FineWebDataset(tokenized)\n",
    "train_loader = DataLoader(train_ds, batch_size=8, shuffle=True, num_workers=2)\n",
    "print(f'Batches: {len(train_loader):,}')"
   ]
  },
  {
