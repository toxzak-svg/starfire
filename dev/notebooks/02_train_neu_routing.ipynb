   "source": [
    "## Training — NeuModel"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def train_neu(\n",
    "    train_loader: DataLoader,\n",
    "    d_model: int = 768,\n",
    "    n_layers: int = 12,\n",
    "    n_heads: int = 12,\n",
    "    use_persistent_state: bool = True,\n",
    "    load_balance_weight: float = 0.01,\n",
    "    max_steps: int = 5000,\n",
    "    base_lr: float = 8e-4,\n",
    "    warmup_steps: int = 200,\n",
    "    weight_decay: float = 0.1,\n",
    "    grad_clip: float = 1.0,\n",
    "    init_temp: float = 1.0,\n",
    "    min_temp: float = 0.1,\n",
    "    temp_anneal_steps: int = 3000,\n",
    "    eval_every: int = 500,\n",
    "    save_every: int = 2000,\n",
    "    project_name: str = 'neu-routing',\n",
    "    run_name: str = None,\n",
    "    use_amp: bool = True,\n",
    "):\n",
    "    model = NeuModel(\n",
    "        d_model=d_model, n_layers=n_layers, n_heads=n_heads,\n",
    "        vocab_size=VOCAB_SIZE, max_seq_len=2048,\n",
    "        d_ssm_state=64, ssm_expand=2, ssm_conv_size=4,\n",
    "        attn_window=512, cheap_ratio=4, n_paths=3,\n",
    "        gate_temperature=init_temp,\n",
    "        d_persistent_state=64,\n",
    "        use_persistent_state=use_persistent_state,\n",
    "        load_balance_weight=load_balance_weight,\n",
    "    ).to(DEVICE)\n",
    "    \n",
    "    params = model.param_count()\n",
    "    print(f'NeuModel params: {params:,}')\n",
    "    \n",
    "    run_name = run_name or f'neu-d{d_model}l{n_layers}-ps{int(use_persistent_state)}-{int(time.time())}'\n",
    "    \n",
    "    optimizer = optim.AdamW(model.parameters(), lr=base_lr, weight_decay=weight_decay)\n",
    "    scaler = GradScaler() if use_amp else None\n",
    "    \n",
    "    def lr_fn(step):\n",
    "        if step < warmup_steps:\n",
    "            return (step + 1) / warmup_steps\n",
    "        progress = (step - warmup_steps) / max(max_steps - warmup_steps, 1)\n",
    "        return max(0.01, 0.5 * (1.0 + math.cos(math.pi * progress)))\n",
    "    \n",
    "    import wandb\n",
    "    wandb.init(project=project_name, name=run_name, config={\n",
    "        'model': 'NeuModel', 'params': params, 'd_model': d_model,\n",
    "        'n_layers': n_layers, 'use_persistent_state': use_persistent_state,\n",
    "        'load_balance_weight': load_balance_weight,\n",
    "        'init_temp': init_temp, 'min_temp': min_temp,\n",
    "        'temp_anneal_steps': temp_anneal_steps,\n",
    "    })\n",
    "    \n",
    "    model.train()\n",
    "    global_step = 0\n",
    "    losses, ce_losses, lb_losses = [], [], []\n",
    "    gate_stats = []  # avg gate distribution per eval window\n",
    "    \n",
    "    pbar = tqdm(total=max_steps, desc=run_name)\n",
    "    \n",
    "    while global_step < max_steps:\n",
    "        for batch in train_loader:\n",
    "            if global_step >= max_steps:\n",
    "                break\n",
    "            \n",
    "            # Temperature annealing\n",
    "            if global_step < temp_anneal_steps:\n",
    "                temp = init_temp - (init_temp - min_temp) * (global_step / temp_anneal_steps)\n",
    "            else:\n",
    "                temp = min_temp\n",
    "            model.set_temperature(temp)\n",
    "            \n",
    "            # LR schedule\n",
    "            lr = base_lr * lr_fn(global_step)\n",
    "            for pg in optimizer.param_groups:\n",
    "                pg['lr'] = lr\n",
    "            \n",
    "            input_ids = batch.to(DEVICE)\n",
    "            targets = input_ids.clone()\n",
    "            optimizer.zero_grad()\n",
    "            \n",
    "            if use_amp:\n",
    "                with autocast():\n",
    "                    result = model(input_ids, targets)\n",
    "                    loss = result['loss']\n",
    "                scaler.scale(loss).backward()\n",
    "                if grad_clip > 0:\n",
    "                    scaler.unscale_(optimizer)\n",
    "                    grad_norm = torch.nn.utils.clip_grad_norm_(model.parameters(), grad_clip).item()\n",
    "                scaler.step(optimizer)\n",
    "                scaler.update()\n",
    "            else:\n",
    "                result = model(input_ids, targets)\n",
    "                loss = result['loss']\n",
    "                loss.backward()\n",
    "                if grad_clip > 0:\n",
    "                    grad_norm = torch.nn.utils.clip_grad_norm_(model.parameters(), grad_clip).item()\n",
    "                optimizer.step()\n",
    "            \n",
    "            ce_losses.append(result['ce_loss'].item())\n",
    "            lb_losses.append(result['lb_loss'].item())\n",
    "            losses.append(loss.item())\n",
    "            \n",
    "            if global_step % 10 == 0:\n",
    "                wandb.log({\n",
    "                    'train/loss': loss.item(),\n",
    "                    'train/ce_loss': result['ce_loss'].item(),\n",
    "                    'train/lb_loss': result['lb_loss'].item(),\n",
    "                    'train/lr': lr,\n",
    "                    'train/temperature': temp,\n",
    "                }, step=global_step)\n",
    "            \n",
    "            if global_step > 0 and global_step % eval_every == 0:\n",
    "                # Log gate distributions\n",
    "                all_g = torch.stack([g.mean(dim=(0,1)) for g in result['gates']])\n",
    "                avg_g = all_g.mean(dim=0).cpu().detach().numpy()\n",
    "                wandb.log({\n",
    "                    'gates/cheap': avg_g[0],\n",
    "                    'gates/ssm': avg_g[1],\n",
    "                    'gates/attn': avg_g[2],\n",
    "                }, step=global_step)\n",
    "                pbar.set_postfix({\n",
    "                    'loss': f'{np.mean(losses[-eval_every:]):.4f}',\n",
    "                    'ce': f'{np.mean(ce_losses[-eval_every:]):.4f}',\n",
    "                    'lb': f'{np.mean(lb_losses[-eval_every:]):.4f}',\n",
    "                    'temp': f'{temp:.2f}',\n",
    "                    'g': f'c={avg_g[0]:.2f} s={avg_g[1]:.2f} a={avg_g[2]:.2f}'\n",
    "                })\n",
    "            \n",
    "            if global_step > 0 and global_step % save_every == 0:\n",
    "                ckpt = CHECKPOINT_DIR / f'{run_name}-step{global_step}.pt'\n",
    "                torch.save({'model': model.state_dict(), 'step': global_step, 'losses': losses}, ckpt)\n",
    "                print(f'\\nSaved: {ckpt}')\n",
    "            \n",
    "            global_step += 1\n",
    "            pbar.update(1)\n",
    "    \n",
    "    pbar.close()\n",
    "    wandb.finish()\n",
    "    \n",
    "    final_ckpt = CHECKPOINT_DIR / f'{run_name}-final.pt'\n",
    "    torch.save({'model': model.state_dict(), 'step': global_step, 'losses': losses}, final_ckpt)\n",
    "    \n",
    "    return {'losses': losses, 'ce_losses': ce_losses, 'lb_losses': lb_losses}"
   ]
  },
