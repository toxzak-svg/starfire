  "faq": [
    {
      "question": "Why RTX 5090 for LTX 2.3?",
      "answer": "The RTX 5090's 32GB VRAM allows running LTX 2.3 at full FP16 precision without quantization, providing maximum quality. The GDDR7 memory bandwidth and Blackwell tensor cores are optimized for transformer-based video diffusion models."
    },
    {
      "question": "Do I need quantization?",
      "answer": "No, with 32GB VRAM you can run at FP16 full precision. Quantization (INT8) would only be needed if you were running on GPUs with less than 16GB VRAM."
    },
    {
      "question": "How many frames can I generate?",
      "answer": "With 32GB VRAM at FP16, you can typically generate 24-50 frames depending on resolution. Start with 24 frames and increase if you have headroom."
    },
    {
      "question": "What about multiple GPUs?",
      "answer": "This guide focuses on single RTX 5090 deployment. For multi-GPU setups, you would need to look into tensor parallelism or model distribution frameworks."
    }
  ]
