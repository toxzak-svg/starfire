    "!pip install -q arc-agi torch scipy numpy pillow requests 2>/dev/null\n",
    "\n",
    "# Verify imports\n",
    "try:\n",
    "    from arc_agi import Arcade\n",
    "    from arc_agi.base import OperationMode\n",
    "    print(\"arc-agi: OK\")\n",
    "except ImportError as e:\n",
