    "# ActionEffectTracker solver\n",
    "import random\n",
    "from collections import defaultdict\n",
    "\n",
    "\n",
    "class ActionEffectTracker:\n",
    "    \"\"\"\",
    "    Track what each action does across episodes.\n",
    "    Learning signal: grid changes + state changes.\n",
    "    \"\"\"\n",
    "    def __init__(self):\n",
    "        self.action_history = defaultdict(list)\n",
    "        self.action_scores = {}\n",
    "\n",
    "    def record(self, action, grid_before, grid_after, state_before, state_after):\n",
    "        if hasattr(grid_before, 'tolist'):\n",
    "            gb = tuple(map(tuple, grid_before.tolist()))\n",
    "            ga = tuple(map(tuple, grid_after.tolist()))\n",
    "        else:\n",
    "            gb = tuple(map(tuple, grid_before))\n",
    "            ga = tuple(map(tuple, grid_after))\n",
    "\n",
    "        grid_changed = (gb != ga)\n",
    "        pixels_changed = sum(1 for row in range(min(len(gb), len(ga))) \n",
    "                           for b, a in zip(gb[row], ga[row]) if b != a) if len(gb) == len(ga) else 0\n",
    "        state_changed = (state_before != state_after)\n",
    "\n",
    "        score = 0.0\n",
    "        if state_changed and str(state_after) == 'game_status.win':\n",
    "            score += 50.0\n",
    "        elif state_changed:\n",
    "            score += 10.0\n",
    "        elif grid_changed:\n",
    "            score += 2.0\n",
    "        else:\n",
    "            score -= 1.0\n",
    "\n",
    "        old = self.action_scores.get(action, 5.0)\n",
    "        self.action_scores[action] = old * 0.85 + score * 0.15\n",
    "\n",
    "    def best_action(self, available):\n",
    "        if not self.action_scores:\n",
    "            return random.choice(available) if available else None\n",
    "\n",
    "        candidates = [(a, self.action_scores.get(a, 3.0)) for a in available]\n",
    "        candidates.sort(key=lambda x: -x[1])\n",
    "\n",
    "        # 70% exploit best, 30% sample top-3\n",
    "        if random.random() < 0.7:\n",
    "            return candidates[0][0] if candidates else None\n",
    "        top = candidates[:min(3, len(candidates))]\n",
    "        return random.choice(top)[0] if top else (available[0] if available else None)\n",
    "\n",
    "\n",
    "def extract_objects(grid):\n",
    "    \"\"\"Simple connected-component object extraction.\"\"\"\n",
    "    if hasattr(grid, 'tolist'):\n",
    "        grid = grid.tolist()\n",
    "    elif hasattr(grid, 'numpy'):\n",
    "        grid = grid.numpy().tolist()\n",
    "\n",
    "    h = len(grid)\n",
    "    w = len(grid[0]) if h > 0 else 0\n",
    "    visited = [[False] * w for _ in range(h)]\n",
    "    objects = []\n",
    "\n",
    "    for r in range(h):\n",
    "        for c in range(w):\n",
    "            if visited[r][c]:\n",
    "                continue\n",
    "            color = grid[r][c]\n",
    "            if color == 0:\n",
    "                visited[r][c] = True\n",
    "                continue\n",
    "            positions = []\n",
    "            stack = [(r, c)]\n",
    "            while stack:\n",
    "                pr, pc = stack.pop()\n",
    "                if pr < 0 or pr >= h or pc < 0 or pc >= w:\n",
    "                    continue\n",
    "                if visited[pr][pc]:\n",
    "                    continue\n",
    "                if grid[pr][pc] != color:\n",
    "                    continue\n",
    "                visited[pr][pc] = True\n",
    "                positions.append((pr, pc))\n",
    "                for dr, dc in [(-1,0),(1,0),(0,-1),(0,1)]:\n",
    "                    stack.append((pr+dr, pc+dc))\n",
    "\n",
    "            if positions:\n",
    "                rs = [p[0] for p in positions]\n",
    "                cs = [p[1] for p in positions]\n",
    "                objects.append({\n",
    "                    'color': color,\n",
    "                    'count': len(positions),\n",
    "                    'centroid': (sum(rs)/len(rs), sum(cs)/len(cs)),\n",
    "                })\n",
    "\n",
    "    return objects\n",
    "\n",
    "\n",
    "def solve_game(game_id, env, tracker=None, max_steps=80):\n",
    "    \"\"\"Play one game using ActionEffectTracker.\"\"\"\n",
    "    if tracker is None:\n",
    "        tracker = ActionEffectTracker()\n",
    "\n",
    "    obs = env.reset()\n",
    "    actions = []\n",
    "    max_steps = 80\n",
    "\n",
    "    grid = _get_grid(obs)\n",
    "    prev_state = _get_state(obs)\n",
    "\n",
    "    for step in range(max_steps):\n",
    "        avail = _get_actions(obs)\n",
    "        if not avail:\n",
    "            break\n",
    "\n",
    "        action = tracker.best_action(avail)\n",
    "        if action is None:\n",
    "            action = avail[0]\n",
    "\n",
    "        obs = env.step(action)\n",
    "        actions.append(action)\n",
    "\n",
    "        new_grid = _get_grid(obs)\n",
    "        new_state = _get_state(obs)\n",
    "\n",
    "        tracker.record(action, grid, new_grid, prev_state, new_state)\n",
    "\n",
    "        grid = new_grid\n",
    "        prev_state = new_state\n",
    "\n",
    "        if new_state == 'game_status.win':\n",
    "            return {'win': True, 'actions': [f'ACTION{a}' for a in actions], 'steps': step+1}\n",
    "        if new_state in ('game_status.game_over', 'game_over'):\n",
    "            return {'win': False, 'actions': [f'ACTION{a}' for a in actions], 'steps': step+1}\n",
    "\n",
    "    return {'win': False, 'actions': [f'ACTION{a}' for a in actions], 'steps': len(actions)}\n",
    "\n",
    "\n",
    "def _get_grid(obs):\n",
    "    if hasattr(obs, 'frame') and obs.frame:\n",
    "        f = obs.frame[0]\n",
    "        if hasattr(f, 'tolist'):\n",
    "            return f.tolist()\n",
    "        elif isinstance(f, list):\n",
    "            return f\n",
    "    return [[0]]\n",
    "\n",
    "def _get_actions(obs):\n",
    "    try:\n",
    "        avail = obs.available_actions\n",
    "        if isinstance(avail[0], str):\n",
    "            return [a for a in avail if a not in (0, 'RESET', '0', 0)]\n",
    "        return [int(a) for a in avail if int(a) not in (0, '0')]\n",
    "    except:\n",
    "        return [1, 2, 3, 4]\n",
    "\n",
    "def _get_state(obs):\n",
    "    try:\n",
    "        if hasattr(obs.state, 'value'):\n",
    "            return obs.state.value\n",
    "        return str(obs.state)\n",
    "    except:\n",
    "        return 'unknown'\n",
    "\n",
    "\n",
    "print(\"ActionEffectTracker solver defined.\")"
   ]
  },
