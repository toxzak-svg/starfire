    "# ARC-AGI-3 Benchmark Runner\n",
    "import json\n",
    "from dataclasses import dataclass\n",
    "\n",
    "from arc_agi import Arcade\n",
    "from arc_agi.base import OperationMode\n",
    "\n",
    "\n",
    "@dataclass\n",
    "class GameResult:\n",
    "    game_id: str\n",
    "    title: str\n",
    "    win: bool\n",
    "    steps: int\n",
    "    actions: list\n",
    "    duration_s: float\n",
    "    error: str = \"\"\n",
    "    \n",
    "    def to_dict(self):\n",
    "        return {\n",
    "            \"game_id\": self.game_id,\n",
    "            \"win\": self.win,\n",
    "            \"steps\": self.steps,\n",
    "            \"duration_s\": round(self.duration_s, 1),\n",
    "            \"error\": self.error,\n",
    "        }\n",
    "\n",
    "\n",
    "def run_all_games(max_steps=80, verbose=False):\n",
    "    \"\"\"Play all available games with shared ActionEffectTracker.\"\"\"\n",
    "    arcade = Arcade(operation_mode=OperationMode.NORMAL)\n",
    "    envs = arcade.get_environments()\n",
    "    \n",
    "    print(f\"Found {len(envs)} games\")\n",
    "    print(f\"Solver: ActionEffectTracker + Infant object extraction\")\n",
    "    print(\"=\" * 60)\n",
    "    \n",
    "    # Shared tracker across all games — this is the learning\n",
    "    tracker = ActionEffectTracker()\n",
    "    \n",
    "    results = []\n",
    "    total_start = time.time()\n",
    "    \n",
    "    for env_info in envs:\n",
    "        game_id = env_info.game_id\n",
    "        title = getattr(env_info, 'title', '')\n",
    "        print(f\"\\n[{game_id}] ... \", end=\"\", flush=True)\n",
    "        \n",
    "        start = time.time()\n",
    "        try:\n",
    "            env = arcade.make(game_id)\n",
    "            result = solve_game(game_id, env, tracker=tracker, max_steps=max_steps)\n",
    "            duration = time.time() - start\n",
    "            status = \"WIN\" if result['win'] else \"PLAYED\"\n",
    "            print(f\" {status} ({result['steps']} steps, {duration:.0f}s)\")\n",
    "            \n",
    "            if verbose or result['win']:\n",
    "                print(f\"  Actions: {result['actions'][:10]}\")\n",
    "            \n",
    "            results.append(GameResult(\n",
    "                game_id=game_id,\n",
    "                title=title,\n",
    "                win=result['win'],\n",
    "                steps=result['steps'],\n",
    "                actions=result['actions'],\n",
    "                duration_s=duration,\n",
    "            ))\n",
    "        except Exception as e:\n",
    "            duration = time.time() - start\n",
    "            print(f\" ERROR: {e}\")\n",
    "            results.append(GameResult(\n",
    "                game_id=game_id,\n",
    "                title=title,\n",
    "                win=False,\n",
    "                steps=0,\n",
    "                actions=[],\n",
    "                duration_s=duration,\n",
    "                error=str(e),\n",
    "            ))\n",
    "    \n",
    "    total_duration = time.time() - total_start\n",
    "    wins = sum(1 for r in results if r.win)\n",
    "    errors = sum(1 for r in results if r.error)\n",
    "    \n",
    "    print(\"\\n\" + \"=\" * 60)\n",
    "    print(f\"RESULTS: {wins}/{len(results)} wins ({wins/len(results):.1%})\")\n",
    "    print(f\"Errors: {errors}\")\n",
    "    print(f\"Total time: {total_duration:.0f}s\")\n",
    "    \n",
    "    return results\n",
    "\n",
    "\n",
    "print(\"Runner defined.\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Run the benchmark\n",
    "print(\"Starting ARC-AGI-3 benchmark...\")\n",
    "print(\"=\" * 60)\n",
    "\n",
    "results = run_all_games(max_steps=80, verbose=False)\n",
    "\n",
    "# Save submission\n",
    "submission = {\n",
    "    \"win_rate\": sum(1 for r in results if r.win) / len(results),\n",
    "    \"total_games\": len(results),\n",
    "    \"wins\": sum(1 for r in results if r.win),\n",
    "    \"results\": [r.to_dict() for r in results],\n",
    "}\n",
    "\n",
    "with open(\"submission.json\", \"w\") as f:\n",
    "    json.dump(submission, f, indent=2)\n",
    "\n",
    "print(f\"\\nSaved to submission.json\")"
   ]
  },
