    "DEVICE = \"cuda\" if os.path.exists(\"/dev/nvidia0\") else \"cpu\"\n",
    "print(f\"Device: {DEVICE}\")\n",
    "print(f\"Workspace: {WORKSPACE_PATH}\")"
   ]
